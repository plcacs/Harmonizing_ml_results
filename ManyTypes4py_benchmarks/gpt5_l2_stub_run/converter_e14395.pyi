from typing import Any, Callable, List, Optional, Text, Type, Union
from pypinyin.contrib.uv import V2UMixin
from pypinyin.contrib.neutral_tone import NeutralToneWith5Mixin
from pypinyin.contrib.tone_sandhi import ToneSandhiMixin

class Converter(object):
    def convert(self, words: Text, style: Any, heteronym: bool, errors: Union[str, Callable[[Text], Any]], strict: bool, **kwargs: Any) -> List[List[Text]]: ...

class DefaultConverter(Converter):
    def __init__(self, **kwargs: Any) -> None: ...
    def convert(self, words: Text, style: Any, heteronym: bool, errors: Union[str, Callable[[Text], Any]], strict: bool, **kwargs: Any) -> List[List[Text]]: ...
    def pre_convert_style(self, han: Text, orig_pinyin: Text, style: Any, strict: bool, **kwargs: Any) -> Optional[Text]: ...
    def convert_style(self, han: Text, orig_pinyin: Text, style: Any, strict: bool, **kwargs: Any) -> Text: ...
    def post_convert_style(self, han: Text, orig_pinyin: Text, converted_pinyin: Text, style: Any, strict: bool, **kwargs: Any) -> Optional[Text]: ...
    def pre_handle_nopinyin(self, chars: Text, style: Any, heteronym: bool, errors: Union[str, Callable[[Text], Any]], strict: bool, **kwargs: Any) -> Optional[Union[Text, List[Text], List[List[Text]]]]: ...
    def handle_nopinyin(self, chars: Text, style: Any, heteronym: bool, errors: Union[str, Callable[[Text], Any]], strict: bool, **kwargs: Any) -> List[List[Text]]: ...
    def post_handle_nopinyin(self, chars: Text, style: Any, heteronym: bool, errors: Union[str, Callable[[Text], Any]], strict: bool, pinyin: Union[Text, List[Text], List[List[Text]]], **kwargs: Any) -> Optional[Union[Text, List[Text], List[List[Text]]]]: ...
    def post_pinyin(self, han: Text, heteronym: bool, pinyin: List[List[Text]], **kwargs: Any) -> Optional[List[List[Text]]]: ...
    def _phrase_pinyin(self, phrase: Text, style: Any, heteronym: bool, errors: Union[str, Callable[[Text], Any]], strict: bool) -> List[List[Text]]: ...
    def convert_styles(self, pinyin_list: List[List[Text]], phrase: Text, style: Any, heteronym: bool, errors: Union[str, Callable[[Text], Any]], strict: bool, **kwargs: Any) -> List[List[Text]]: ...
    def _single_pinyin(self, han: Text, style: Any, heteronym: bool, errors: Union[str, Callable[[Text], Any]], strict: bool) -> List[List[Text]]: ...
    def _convert_style(self, han: Text, pinyin: Text, style: Any, strict: bool, default: Text, **kwargs: Any) -> Text: ...
    def _convert_nopinyin_chars(self, chars: Text, style: Any, heteronym: bool, errors: Union[str, Callable[[Text], Any]], strict: bool) -> Optional[Union[Text, List[Text], List[List[Text]]]]: ...

class _v2UConverter(V2UMixin, DefaultConverter): ...
class _neutralToneWith5Converter(NeutralToneWith5Mixin, DefaultConverter): ...
class _toneSandhiConverter(ToneSandhiMixin, DefaultConverter): ...

class UltimateConverter(DefaultConverter):
    _v_to_u: bool
    _neutral_tone_with_five: bool
    _tone_sandhi: bool
    def __init__(self, v_to_u: bool = False, neutral_tone_with_five: bool = False, tone_sandhi: bool = False, **kwargs: Any) -> None: ...
    def post_convert_style(self, han: Text, orig_pinyin: Text, converted_pinyin: Text, style: Any, strict: bool, **kwargs: Any) -> Text: ...
    def post_pinyin(self, han: Text, heteronym: bool, pinyin: List[List[Text]], **kwargs: Any) -> List[List[Text]]: ...

_mixConverter: Type[UltimateConverter] ...