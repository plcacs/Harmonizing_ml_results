from typing import Any, Callable, Dict, List, Mapping, Optional, Tuple, Type, TypeVar, Union, ParamSpec
from alerta.database.base import Database

db: Database = ...

T_Gauge = TypeVar("T_Gauge", bound="Gauge")
T_Counter = TypeVar("T_Counter", bound="Counter")
T_Timer = TypeVar("T_Timer", bound="Timer")
P = ParamSpec("P")
R = TypeVar("R")

class Gauge:
    group: str
    name: str
    title: Optional[str]
    description: Optional[str]
    type: str
    value: int

    def __init__(self, group: str, name: str, title: Optional[str] = ..., description: Optional[str] = ..., value: int = 0) -> None: ...
    def serialize(self, format: str = "json") -> Union[str, Dict[str, Union[str, int, None]]]: ...
    def __repr__(self) -> str: ...
    @classmethod
    def from_document(cls: Type[T_Gauge], doc: Mapping[str, Any]) -> T_Gauge: ...
    @classmethod
    def from_record(cls: Type[T_Gauge], rec: Any) -> T_Gauge: ...
    @classmethod
    def from_db(cls: Type[T_Gauge], r: Union[Mapping[str, Any], Tuple[Any, ...]]) -> T_Gauge: ...
    def set(self, value: int) -> Gauge: ...
    @classmethod
    def find_all(cls: Type[T_Gauge]) -> List[T_Gauge]: ...

class Counter:
    group: str
    name: str
    title: Optional[str]
    description: Optional[str]
    type: str
    count: int

    def __init__(self, group: str, name: str, title: Optional[str] = ..., description: Optional[str] = ..., count: int = 0) -> None: ...
    def serialize(self, format: str = "json") -> Union[str, Dict[str, Union[str, int, None]]]: ...
    def __repr__(self) -> str: ...
    @classmethod
    def from_document(cls: Type[T_Counter], doc: Mapping[str, Any]) -> T_Counter: ...
    @classmethod
    def from_record(cls: Type[T_Counter], rec: Any) -> T_Counter: ...
    @classmethod
    def from_db(cls: Type[T_Counter], r: Union[Mapping[str, Any], Tuple[Any, ...]]) -> T_Counter: ...
    def inc(self, count: int = 1) -> None: ...
    @classmethod
    def find_all(cls: Type[T_Counter]) -> List[T_Counter]: ...

class Timer:
    group: str
    name: str
    title: Optional[str]
    description: Optional[str]
    type: str
    start: Optional[int]
    count: int
    total_time: int

    def __init__(self, group: str, name: str, title: Optional[str] = ..., description: Optional[str] = ..., count: int = 0, total_time: int = 0) -> None: ...
    def serialize(self, format: str = "json") -> Union[str, Dict[str, Union[str, int, None]]]: ...
    def __repr__(self) -> str: ...
    @classmethod
    def from_document(cls: Type[T_Timer], doc: Mapping[str, Any]) -> T_Timer: ...
    @classmethod
    def from_record(cls: Type[T_Timer], rec: Any) -> T_Timer: ...
    @classmethod
    def from_db(cls: Type[T_Timer], r: Union[Mapping[str, Any], Tuple[Any, ...]]) -> T_Timer: ...
    def _time_in_millis(self) -> int: ...
    def start_timer(self) -> int: ...
    def stop_timer(self, start: int, count: int = 1) -> None: ...
    @classmethod
    def find_all(cls: Type[T_Timer]) -> List[T_Timer]: ...

def timer(metric: Timer) -> Callable[[Callable[P, R]], Callable[P, R]]: ...