from typing import Any, Callable, Dict, Generator, List, Optional, Sequence, Set, Tuple, Union
from pydantic.v1.utils import Representation

ColorTuple = Union[Tuple[int, int, int], Tuple[int, int, int, float]]
ColorType = Union[ColorTuple, str]
HslColorTuple = Union[Tuple[float, float, float], Tuple[float, float, float, float]]

class RGBA:
    r: float
    g: float
    b: float
    alpha: Optional[float]
    _tuple: Tuple[float, float, float, Optional[float]]
    def __init__(self, r: float, g: float, b: float, alpha: Optional[float]) -> None: ...
    def __getitem__(self, item: Union[int, slice]) -> Union[float, Tuple[float, ...]]: ...

r_hex_short: str
r_hex_long: str
r_rgb: str
r_rgba: str
r_hsl: str
r_hsla: str
repeat_colors: Set[int]
rads: float

class Color(Representation):
    def __init__(self, value: Union[ColorType, Sequence[Union[int, float, str]], "Color"]) -> None: ...
    @classmethod
    def __modify_schema__(cls, field_schema: Dict[str, Any]) -> None: ...
    def original(self) -> Any: ...
    def as_named(self, *, fallback: bool = ...) -> str: ...
    def as_hex(self) -> str: ...
    def as_rgb(self) -> str: ...
    def as_rgb_tuple(self, *, alpha: Optional[bool] = ...) -> ColorTuple: ...
    def as_hsl(self) -> str: ...
    def as_hsl_tuple(self, *, alpha: Optional[bool] = ...) -> HslColorTuple: ...
    def _alpha_float(self) -> float: ...
    @classmethod
    def __get_validators__(cls) -> Generator[Callable[..., Any], None, None]: ...
    def __str__(self) -> str: ...
    def __repr_args__(self) -> List[Tuple[Optional[str], Any]]: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

def parse_tuple(value: Union[Tuple[Union[int, float, str], ...], List[Union[int, float, str]]]) -> RGBA: ...
def parse_str(value: str) -> RGBA: ...
def ints_to_rgba(
    r: Union[int, float, str],
    g: Union[int, float, str],
    b: Union[int, float, str],
    alpha: Optional[Union[int, float, str]],
) -> RGBA: ...
def parse_color_value(value: Union[int, float, str], max_val: int = ...) -> float: ...
def parse_float_alpha(value: Optional[Union[int, float, str]]) -> Optional[float]: ...
def parse_hsl(
    h: Union[int, float, str],
    h_units: Optional[str],
    sat: Union[int, float, str],
    light: Union[int, float, str],
    alpha: Optional[float] = ...,
) -> RGBA: ...
def float_to_255(c: float) -> int: ...

COLORS_BY_NAME: Dict[str, Tuple[int, int, int]]
COLORS_BY_VALUE: Dict[Tuple[int, int, int], str]