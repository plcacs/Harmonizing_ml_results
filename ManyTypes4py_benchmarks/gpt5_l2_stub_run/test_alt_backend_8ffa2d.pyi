from typing import ContextManager, Iterator, Optional, Sequence, Type

from hypothesis import Verbosity
from hypothesis.internal.conjecture.data import ConjectureData, PrimitiveProvider
from hypothesis.internal.intervalsets import IntervalSet


class PrngProvider(PrimitiveProvider):
    def __init__(self, conjecturedata: ConjectureData, /) -> None: ...
    def draw_boolean(self, p: float = ...) -> bool: ...
    def draw_integer(
        self,
        min_value: Optional[int] = ...,
        max_value: Optional[int] = ...,
        *,
        weights: Optional[Sequence[float]] = ...,
        shrink_towards: int = ...,
    ) -> int: ...
    def draw_float(
        self,
        *,
        min_value: float = ...,
        max_value: float = ...,
        allow_nan: bool = ...,
        smallest_nonzero_magnitude: float,
    ) -> float: ...
    def draw_string(
        self,
        intervals: IntervalSet,
        *,
        min_size: int = 0,
        max_size: Optional[int] = ...,
    ) -> str: ...
    def draw_bytes(self, min_size: int = 0, max_size: Optional[int] = ...) -> bytes: ...


