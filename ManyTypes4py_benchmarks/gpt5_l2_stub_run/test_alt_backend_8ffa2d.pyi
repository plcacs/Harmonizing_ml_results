    def draw_boolean(self, *args: object, **kwargs: object) -> bool: ...
    def draw_float(self, *args: object, **kwargs: object) -> float: ...
    def draw_bytes(self, *args: object, **kwargs: object) -> bytes: ...
    def draw_string(self, *args: object, **kwargs: object) -> str: ...


