from collections.abc import MutableMapping
from os import PathLike
from typing import Any, Dict, Iterator, List, Optional, Type, TypeVar, Union, OrderedDict as TypingOrderedDict
import logging

T = TypeVar("T", Dict[str, Any], List[Any])
P = TypeVar("P", bound="Params")

logger: logging.Logger = ...

def infer_and_cast(value: Any) -> Any: ...
def with_overrides(original: T, overrides_dict: Dict[str, Any], prefix: str = ...) -> T: ...
def parse_overrides(serialized_overrides: Optional[str], ext_vars: Optional[Dict[str, str]] = ...) -> Dict[str, Any]: ...

class Params(MutableMapping[str, Any]):
    DEFAULT: object = ...
    params: Dict[str, Any]
    history: str

    def __init__(self, params: Dict[str, Any], history: str = ...) -> None: ...
    def pop(self, key: str, default: object = DEFAULT, keep_as_dict: bool = ...) -> Any: ...
    def pop_int(self, key: str, default: object = DEFAULT) -> Optional[int]: ...
    def pop_float(self, key: str, default: object = DEFAULT) -> Optional[float]: ...
    def pop_bool(self, key: str, default: object = DEFAULT) -> Optional[bool]: ...
    def get(self, key: str, default: object = DEFAULT) -> Any: ...
    def pop_choice(self, key: str, choices: List[str], default_to_first_choice: bool = ..., allow_class_names: bool = ...) -> str: ...
    def as_dict(self, quiet: bool = ..., infer_type_and_cast: bool = ...) -> Dict[str, Any]: ...
    def as_flat_dict(self) -> Dict[str, Any]: ...
    def duplicate(self) -> "Params": ...
    def assert_empty(self, class_name: str) -> None: ...
    def __getitem__(self, key: str) -> Any: ...
    def __setitem__(self, key: str, value: Any) -> None: ...
    def __delitem__(self, key: str) -> None: ...
    def __iter__(self) -> Iterator[str]: ...
    def __len__(self) -> int: ...
    def _check_is_dict(self, new_history: str, value: Any) -> Any: ...
    @classmethod
    def from_file(
        cls: Type[P],
        params_file: Union[str, PathLike],
        params_overrides: Union[str, Dict[str, Any]] = ...,
        ext_vars: Optional[Dict[str, str]] = ...,
    ) -> P: ...
    def to_file(self, params_file: Union[str, PathLike], preference_orders: Optional[List[List[str]]] = ...) -> None: ...
    def as_ordered_dict(self, preference_orders: Optional[List[List[str]]] = ...) -> TypingOrderedDict[str, Any]: ...
    def get_hash(self) -> str: ...
    def __str__(self) -> str: ...

def pop_choice(
    params: Dict[str, Any],
    key: str,
    choices: List[str],
    default_to_first_choice: bool = ...,
    history: str = "?.",
    allow_class_names: bool = ...,
) -> str: ...
def remove_keys_from_params(params: Params, keys: List[str] = ...) -> None: ...