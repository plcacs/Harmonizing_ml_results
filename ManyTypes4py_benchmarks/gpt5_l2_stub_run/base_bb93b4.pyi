import abc
from typing import Any, Literal, Mapping, Optional, Pattern
from pandas._libs import lib

class BaseStringArrayMethods(abc.ABC):
    def _str_getitem(self, key: int | slice) -> object: ...
    @abc.abstractmethod
    def _str_count(self, pat: str | Pattern[str], flags: int = 0) -> object: ...
    @abc.abstractmethod
    def _str_pad(self, width: int, side: Literal["left", "right", "both"] = "left", fillchar: str = " ") -> object: ...
    @abc.abstractmethod
    def _str_contains(self, pat: str | Pattern[str], case: bool = True, flags: int = 0, na: object | None = None, regex: bool = True) -> object: ...
    @abc.abstractmethod
    def _str_startswith(self, pat: object, na: object | None = None) -> object: ...
    @abc.abstractmethod
    def _str_endswith(self, pat: object, na: object | None = None) -> object: ...
    @abc.abstractmethod
    def _str_replace(self, pat: str | Pattern[str], repl: object, n: int = -1, case: bool = True, flags: int = 0, regex: bool = True) -> object: ...
    @abc.abstractmethod
    def _str_repeat(self, repeats: int) -> object: ...
    @abc.abstractmethod
    def _str_match(self, pat: str | Pattern[str], case: bool = True, flags: int = 0, na: object = lib.no_default) -> object: ...
    @abc.abstractmethod
    def _str_fullmatch(self, pat: str | Pattern[str], case: bool = True, flags: int = 0, na: object = lib.no_default) -> object: ...
    @abc.abstractmethod
    def _str_encode(self, encoding: str, errors: str = "strict") -> object: ...
    @abc.abstractmethod
    def _str_find(self, sub: str, start: int = 0, end: Optional[int] = None) -> object: ...
    @abc.abstractmethod
    def _str_rfind(self, sub: str, start: int = 0, end: Optional[int] = None) -> object: ...
    @abc.abstractmethod
    def _str_findall(self, pat: str | Pattern[str], flags: int = 0) -> object: ...
    @abc.abstractmethod
    def _str_get(self, i: int) -> object: ...
    @abc.abstractmethod
    def _str_index(self, sub: str, start: int = 0, end: Optional[int] = None) -> object: ...
    @abc.abstractmethod
    def _str_rindex(self, sub: str, start: int = 0, end: Optional[int] = None) -> object: ...
    @abc.abstractmethod
    def _str_join(self, sep: str) -> object: ...
    @abc.abstractmethod
    def _str_partition(self, sep: Optional[str], expand: bool) -> object: ...
    @abc.abstractmethod
    def _str_rpartition(self, sep: Optional[str], expand: bool) -> object: ...
    @abc.abstractmethod
    def _str_len(self) -> object: ...
    @abc.abstractmethod
    def _str_slice(self, start: Optional[int] = None, stop: Optional[int] = None, step: Optional[int] = None) -> object: ...
    @abc.abstractmethod
    def _str_slice_replace(self, start: Optional[int] = None, stop: Optional[int] = None, repl: Optional[str] = None) -> object: ...
    @abc.abstractmethod
    def _str_translate(self, table: Mapping[int, object]) -> object: ...
    @abc.abstractmethod
    def _str_wrap(self, width: int, **kwargs: Any) -> object: ...
    @abc.abstractmethod
    def _str_get_dummies(self, sep: str = "|", dtype: object | None = None) -> object: ...
    @abc.abstractmethod
    def _str_isalnum(self) -> object: ...
    @abc.abstractmethod
    def _str_isalpha(self) -> object: ...
    @abc.abstractmethod
    def _str_isascii(self) -> object: ...
    @abc.abstractmethod
    def _str_isdecimal(self) -> object: ...
    @abc.abstractmethod
    def _str_isdigit(self) -> object: ...
    @abc.abstractmethod
    def _str_islower(self) -> object: ...
    @abc.abstractmethod
    def _str_isnumeric(self) -> object: ...
    @abc.abstractmethod
    def _str_isspace(self) -> object: ...
    @abc.abstractmethod
    def _str_istitle(self) -> object: ...
    @abc.abstractmethod
    def _str_isupper(self) -> object: ...
    @abc.abstractmethod
    def _str_capitalize(self) -> object: ...
    @abc.abstractmethod
    def _str_casefold(self) -> object: ...
    @abc.abstractmethod
    def _str_title(self) -> object: ...
    @abc.abstractmethod
    def _str_swapcase(self) -> object: ...
    @abc.abstractmethod
    def _str_lower(self) -> object: ...
    @abc.abstractmethod
    def _str_upper(self) -> object: ...
    @abc.abstractmethod
    def _str_normalize(self, form: str) -> object: ...
    @abc.abstractmethod
    def _str_strip(self, to_strip: Optional[str] = None) -> object: ...
    @abc.abstractmethod
    def _str_lstrip(self, to_strip: Optional[str] = None) -> object: ...
    @abc.abstractmethod
    def _str_rstrip(self, to_strip: Optional[str] = None) -> object: ...
    @abc.abstractmethod
    def _str_removeprefix(self, prefix: str) -> object: ...
    @abc.abstractmethod
    def _str_removesuffix(self, suffix: str) -> object: ...
    @abc.abstractmethod
    def _str_split(self, pat: str | Pattern[str] | None = None, n: int = -1, expand: bool = False, regex: Optional[bool] = None) -> object: ...
    @abc.abstractmethod
    def _str_rsplit(self, pat: str | Pattern[str] | None = None, n: int = -1) -> object: ...
    @abc.abstractmethod
    def _str_extract(self, pat: str | Pattern[str], flags: int = 0, expand: bool = True) -> object: ...