from typing import Any, Callable, Dict, IO, List, Optional, Tuple, Union
from queue import Queue
from subprocess import Popen
from threading import Thread

from jedi.inference import InferenceState
from jedi.inference.compiled.access import DirectObjectAccess

_MAIN_PATH: str = ...
PICKLE_PROTOCOL: int = ...

def _GeneralizedPopen(*args: Any, **kwargs: Any) -> Popen[Any]: ...
def _enqueue_output(out: IO[bytes], queue_: Queue[bytes]) -> None: ...
def _add_stderr_to_debug(stderr_queue: Queue[bytes]) -> None: ...
def _get_function(name: str) -> Callable[..., Any]: ...
def _cleanup_process(process: Popen[Any], thread: Thread) -> None: ...

class _InferenceStateProcess:
    def __init__(self, inference_state: InferenceState) -> None: ...
    def get_or_create_access_handle(self, obj: object) -> AccessHandle: ...
    def get_access_handle(self, id_: int) -> AccessHandle: ...
    def set_access_handle(self, handle: AccessHandle) -> None: ...

class InferenceStateSameProcess(_InferenceStateProcess):
    def __getattr__(self, name: str) -> Callable[..., Any]: ...

class InferenceStateSubprocess(_InferenceStateProcess):
    def __init__(self, inference_state: InferenceState, compiled_subprocess: CompiledSubprocess) -> None: ...
    def __getattr__(self, name: str) -> Callable[..., Any]: ...
    def _convert_access_handles(self, obj: Any) -> Any: ...
    def __del__(self) -> None: ...

class CompiledSubprocess:
    is_crashed: bool = ...
    def __init__(self, executable: str, env_vars: Optional[Dict[str, str]] = ...) -> None: ...
    def __repr__(self) -> str: ...
    def _get_process(self) -> Popen[Any]: ...
    def run(
        self,
        inference_state: InferenceState,
        function: Callable[..., Any],
        args: Tuple[Any, ...] = ...,
        kwargs: Dict[str, Any] = ...,
    ) -> Any: ...
    def get_sys_path(self) -> List[str]: ...
    def _kill(self) -> None: ...
    def _send(
        self,
        inference_state_id: Optional[int],
        function: Optional[Callable[..., Any]],
        args: Tuple[Any, ...] = ...,
        kwargs: Dict[str, Any] = ...,
    ) -> Any: ...
    def delete_inference_state(self, inference_state_id: int) -> None: ...

class Listener:
    def __init__(self) -> None: ...
    def _get_inference_state(self, function: Callable[..., Any], inference_state_id: int) -> InferenceState: ...
    def _run(
        self,
        inference_state_id: Optional[int],
        function: Optional[Callable[..., Any]],
        args: Tuple[Any, ...],
        kwargs: Dict[str, Any],
    ) -> Any: ...
    def listen(self) -> None: ...

class AccessHandle:
    def __init__(
        self,
        subprocess: Union[InferenceStateSameProcess, InferenceStateSubprocess],
        access: DirectObjectAccess,
        id_: int,
    ) -> None: ...
    def add_subprocess(self, subprocess: Union[InferenceStateSameProcess, InferenceStateSubprocess]) -> None: ...
    def __repr__(self) -> str: ...
    def __getstate__(self) -> int: ...
    def __setstate__(self, state: int) -> None: ...
    def __getattr__(self, name: str) -> Callable[..., Any]: ...
    def _workaround(self, name: str, *args: Any, **kwargs: Any) -> Any: ...
    def _cached_results(self, name: str, *args: Any, **kwargs: Any) -> Any: ...