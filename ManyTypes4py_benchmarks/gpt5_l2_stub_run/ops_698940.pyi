from typing import Callable, ClassVar, Optional, Tuple, Type, Union, final
from pandas import DataFrame, Index, Series

class BaseOpsUtil:
    series_scalar_exc: ClassVar[Optional[Type[BaseException]]] = ...
    frame_scalar_exc: ClassVar[Optional[Type[BaseException]]] = ...
    series_array_exc: ClassVar[Optional[Type[BaseException]]] = ...
    divmod_exc: ClassVar[Optional[Type[BaseException]]] = ...
    def _get_expected_exception(self, op_name: str, obj: object, other: object) -> Optional[Type[BaseException]]: ...
    def _cast_pointwise_result(self, op_name: str, obj: object, other: object, pointwise_result: object) -> object: ...
    def get_op_from_name(self, op_name: str) -> Callable[[object, object], object]: ...
    @final
    def check_opname(self, ser: Union[Series, DataFrame], op_name: str, other: object) -> None: ...
    @final
    def _combine(self, obj: Union[Series, DataFrame], other: object, op: Callable[[object, object], object]) -> Union[Series, DataFrame]: ...
    @final
    def _check_op(self, ser: Union[Series, DataFrame], op: Callable[[object, object], object], other: object, op_name: str, exc: Optional[Type[BaseException]] = ...) -> None: ...
    @final
    def _check_divmod_op(self, ser: object, op: Callable[[object, object], Tuple[object, object]], other: object) -> None: ...

class BaseArithmeticOpsTests(BaseOpsUtil):
    series_scalar_exc: ClassVar[Optional[Type[BaseException]]] = ...
    frame_scalar_exc: ClassVar[Optional[Type[BaseException]]] = ...
    series_array_exc: ClassVar[Optional[Type[BaseException]]] = ...
    divmod_exc: ClassVar[Optional[Type[BaseException]]] = ...
    def test_arith_series_with_scalar(self, data: object, all_arithmetic_operators: str) -> None: ...
    def test_arith_frame_with_scalar(self, data: object, all_arithmetic_operators: str) -> None: ...
    def test_arith_series_with_array(self, data: object, all_arithmetic_operators: str) -> None: ...
    def test_divmod(self, data: object) -> None: ...
    def test_divmod_series_array(self, data: object, data_for_twos: object) -> None: ...
    def test_add_series_with_extension_array(self, data: object) -> None: ...
    def test_direct_arith_with_ndframe_returns_not_implemented(self, data: object, box: Union[Type[Series], Type[DataFrame], Type[Index]], op_name: str) -> None: ...

class BaseComparisonOpsTests(BaseOpsUtil):
    def _compare_other(self, ser: Series, data: object, op: Callable[[object, object], object], other: object) -> None: ...
    def test_compare_scalar(self, data: object, comparison_op: Callable[[object, object], object]) -> None: ...
    def test_compare_array(self, data: object, comparison_op: Callable[[object, object], object]) -> None: ...

class BaseUnaryOpsTests(BaseOpsUtil):
    def test_invert(self, data: object) -> None: ...
    def test_unary_ufunc_dunder_equivalence(self, data: object, ufunc: Callable[[object], object]) -> None: ...