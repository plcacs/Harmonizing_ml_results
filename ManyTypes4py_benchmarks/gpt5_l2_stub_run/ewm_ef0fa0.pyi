    def var(self, bias: bool = ..., numeric_only: bool = ...) -> DataFrame | Series: ...
    def cov(self, other: Series | DataFrame | None = ..., pairwise: bool | None = ..., bias: bool = ..., numeric_only: bool = ...) -> DataFrame | Series: ...
    def corr(self, other: Series | DataFrame | None = ..., pairwise: bool | None = ..., numeric_only: bool = ...) -> DataFrame | Series: ...

