from typing import Any, Iterable, Iterator, List, Optional, Tuple

from abc import abstractproperty
from jedi.inference.arguments import TreeArgumentsWrapper, ValuesArguments
from jedi.inference.base_value import Value, ValueSet, ValueWrapper, iterator_to_value_set
from jedi.inference.filters import AbstractFilter, AnonymousFunctionExecutionFilter
from jedi.inference.lazy_value import LazyKnownValue, LazyKnownValues
from jedi.inference.names import NameWrapper, ParamName, TreeNameDefinition, ValueName
from jedi.inference.value.function import (
    BaseFunctionExecutionContext,
    FunctionExecutionContext,
    FunctionMixin,
    FunctionNameInClass,
    FunctionValue,
    OverloadedFunctionValue,
)
from jedi.inference.value.klass import ClassFilter


class InstanceExecutedParamName(ParamName):
    def __init__(self, instance: Value, function_value: FunctionValue, tree_name: Any) -> None: ...
    def infer(self) -> ValueSet: ...
    def matches_signature(self) -> bool: ...


class AnonymousMethodExecutionFilter(AnonymousFunctionExecutionFilter):
    def __init__(self, instance: Value, *args: Any, **kwargs: Any) -> None: ...
    def _convert_param(self, param: Any, name: Any) -> ParamName: ...


class AnonymousMethodExecutionContext(BaseFunctionExecutionContext):
    def __init__(self, instance: Value, value: "BoundMethod") -> None: ...
    def get_filters(self, until_position: Optional[Any] = ..., origin_scope: Optional[Any] = ...) -> Iterator[AbstractFilter]: ...
    def get_param_names(self) -> List[ParamName]: ...


class MethodExecutionContext(FunctionExecutionContext):
    def __init__(self, instance: Value, *args: Any, **kwargs: Any) -> None: ...


class AbstractInstanceValue(Value):
    api_type: str
    class_value: Value
    def __init__(self, inference_state: Any, parent_context: Any, class_value: Value) -> None: ...
    def is_instance(self) -> bool: ...
    def get_qualified_names(self) -> Any: ...
    def get_annotated_class_object(self) -> Value: ...
    def py__class__(self) -> Value: ...
    def py__bool__(self) -> Optional[bool]: ...
    @abstractproperty
    def name(self) -> Any: ...
    def get_signatures(self) -> List[Any]: ...
    def get_function_slot_names(self, name: str) -> List[Any]: ...
    def execute_function_slots(self, names: Iterable[Any], *inferred_args: Any) -> ValueSet: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...
    def py__getitem__(self, index_value_set: ValueSet, contextualized_node: Any) -> ValueSet: ...
    def py__iter__(self, contextualized_node: Optional[Any] = ...) -> Iterator[LazyKnownValues]: ...
    def __repr__(self) -> str: ...


class CompiledInstance(AbstractInstanceValue):
    def __init__(self, inference_state: Any, parent_context: Any, class_value: Value, arguments: Any) -> None: ...
    def get_filters(self, origin_scope: Optional[Any] = ..., include_self_names: bool = ...) -> Iterator[AbstractFilter]: ...
    @property
    def name(self) -> Any: ...
    def is_stub(self) -> bool: ...


class _BaseTreeInstance(AbstractInstanceValue):
    @property
    def array_type(self) -> Optional[str]: ...
    @property
    def name(self) -> ValueName: ...
    def get_filters(self, origin_scope: Optional[Any] = ..., include_self_names: bool = ...) -> Iterator[AbstractFilter]: ...
    def create_instance_context(self, class_context: Any, node: Any) -> Any: ...
    def py__getattribute__alternatives(self, string_name: str) -> ValueSet: ...
    def py__next__(self, contextualized_node: Optional[Any] = ...) -> Iterator[LazyKnownValues]: ...
    def py__call__(self, arguments: ValuesArguments) -> ValueSet: ...
    def py__get__(self, instance: Optional[Value], class_value: Value) -> ValueSet: ...


class TreeInstance(_BaseTreeInstance):
    tree_node: Any
    def __init__(self, inference_state: Any, parent_context: Any, class_value: Value, arguments: Any) -> None: ...
    def _get_annotated_class_object(self) -> Optional[Value]: ...
    def get_annotated_class_object(self) -> Value: ...
    def get_key_values(self) -> ValueSet: ...
    def py__simple_getitem__(self, index: Any) -> ValueSet: ...
    def __repr__(self) -> str: ...


class AnonymousInstance(_BaseTreeInstance):
    _arguments: Any = ...


class CompiledInstanceName(NameWrapper):
    @iterator_to_value_set
    def infer(self) -> ValueSet: ...


class CompiledInstanceClassFilter(AbstractFilter):
    def __init__(self, instance: AbstractInstanceValue, f: AbstractFilter) -> None: ...
    def get(self, name: str) -> List[NameWrapper]: ...
    def values(self) -> List[NameWrapper]: ...
    def _convert(self, names: Any) -> List[NameWrapper]: ...


class BoundMethod(FunctionMixin, ValueWrapper):
    instance: Value
    _class_context: Any
    def __init__(self, instance: Value, class_context: Any, function: FunctionValue) -> None: ...
    def is_bound_method(self) -> bool: ...
    @property
    def name(self) -> FunctionNameInClass: ...
    def py__class__(self) -> Value: ...
    def _get_arguments(self, arguments: ValuesArguments) -> "InstanceArguments": ...
    def _as_context(self, arguments: Optional[ValuesArguments] = ...) -> BaseFunctionExecutionContext: ...
    def py__call__(self, arguments: ValuesArguments) -> ValueSet: ...
    def get_signature_functions(self) -> List["BoundMethod"]: ...
    def get_signatures(self) -> List[Any]: ...
    def __repr__(self) -> str: ...


class CompiledBoundMethod(ValueWrapper):
    def is_bound_method(self) -> bool: ...
    def get_signatures(self) -> List[Any]: ...


class SelfName(TreeNameDefinition):
    _instance: AbstractInstanceValue
    class_context: Any
    tree_name: Any
    def __init__(self, instance: AbstractInstanceValue, class_context: Any, tree_name: Any) -> None: ...
    @property
    def parent_context(self) -> Any: ...
    def get_defining_qualified_value(self) -> AbstractInstanceValue: ...
    def infer(self) -> ValueSet: ...


class LazyInstanceClassName(NameWrapper):
    def __init__(self, instance: AbstractInstanceValue, class_member_name: Any) -> None: ...
    @iterator_to_value_set
    def infer(self) -> ValueSet: ...
    def get_signatures(self) -> List[Any]: ...
    def get_defining_qualified_value(self) -> AbstractInstanceValue: ...


class InstanceClassFilter(AbstractFilter):
    def __init__(self, instance: AbstractInstanceValue, class_filter: ClassFilter) -> None: ...
    def get(self, name: str) -> List[NameWrapper]: ...
    def values(self) -> List[NameWrapper]: ...
    def _convert(self, names: Any) -> List[NameWrapper]: ...
    def __repr__(self) -> str: ...


class SelfAttributeFilter(ClassFilter):
    def __init__(self, instance: AbstractInstanceValue, instance_class: Value, node_context: Any, origin_scope: Any) -> None: ...
    def _filter(self, names: List[Any]) -> List[Any]: ...
    def _filter_self_names(self, names: List[Any]) -> Iterable[Any]: ...
    def _is_in_right_scope(self, self_name: Any, name: Any) -> bool: ...
    def _convert_names(self, names: List[Any]) -> List[SelfName]: ...
    def _check_flows(self, names: List[Any]) -> List[Any]: ...


class InstanceArguments(TreeArgumentsWrapper):
    instance: AbstractInstanceValue
    def __init__(self, instance: AbstractInstanceValue, arguments: ValuesArguments) -> None: ...
    def unpack(self, func: Optional[Any] = ...) -> Iterator[Tuple[Optional[str], Any]]: ...