from pandas.core.arraylike import OpsMixin
from pandas.core.arrays._mixins import NDArrayBackedExtensionArray
from pandas.core.arrays import TimedeltaArray
from pandas.core.dtypes.dtypes import NumpyEADtype
from pandas.core.strings.object_array import ObjectStringArrayMixin

class NumpyExtensionArray(OpsMixin, NDArrayBackedExtensionArray, ObjectStringArrayMixin):
    _typ: str
    __array_priority__: int
    _internal_fill_value: float
    def __init__(self, values: np.ndarray | NumpyExtensionArray, copy: bool = ...) -> None: ...
    @classmethod
    def _from_sequence(cls, scalars: object, *, dtype: NumpyEADtype | DTypeLike | None = ..., copy: bool = ...) -> Self: ...
    @property
    def dtype(self) -> NumpyEADtype: ...
    def __array__(self, dtype: DTypeLike | None = ..., copy: bool | None = ...) -> np.ndarray: ...
    def __array_ufunc__(self, ufunc: np.ufunc, method: str, /, *inputs: object, **kwargs: object) -> object: ...
    def astype(self, dtype: object, copy: bool = ...) -> object: ...
    def isna(self) -> NDArray[bool_]: ...
    def _validate_scalar(self, fill_value: object | None) -> object: ...
    def _values_for_factorize(self) -> tuple[np.ndarray, object | None]: ...
    def _pad_or_backfill(self, *, method: Literal["ffill", "pad", "bfill", "backfill"], limit: int | None = ..., limit_area: Literal["inside", "outside"] | None = ..., copy: bool = ...) -> Self: ...
    def interpolate(self, *, method: str, axis: AxisInt, index: Index, limit: int | None, limit_direction: str, limit_area: str | None, copy: bool, **kwargs: object) -> Self: ...
    def any(self, *, axis: AxisInt | None = ..., out: object | None = ..., keepdims: bool = ..., skipna: bool = ...) -> object: ...
    def all(self, *, axis: AxisInt | None = ..., out: object | None = ..., keepdims: bool = ..., skipna: bool = ...) -> object: ...
    def min(self, *, axis: AxisInt | None = ..., skipna: bool = ..., **kwargs: object) -> object: ...
    def max(self, *, axis: AxisInt | None = ..., skipna: bool = ..., **kwargs: object) -> object: ...
    def sum(self, *, axis: AxisInt | None = ..., skipna: bool = ..., min_count: int = ..., **kwargs: object) -> object: ...
    def prod(self, *, axis: AxisInt | None = ..., skipna: bool = ..., min_count: int = ..., **kwargs: object) -> object: ...
    def mean(self, *, axis: AxisInt | None = ..., dtype: DTypeLike | None = ..., out: object | None = ..., keepdims: bool = ..., skipna: bool = ...) -> object: ...
    def median(self, *, axis: AxisInt | None = ..., out: object | None = ..., overwrite_input: bool = ..., keepdims: bool = ..., skipna: bool = ...) -> object: ...
    def std(self, *, axis: AxisInt | None = ..., dtype: DTypeLike | None = ..., out: object | None = ..., ddof: int = ..., keepdims: bool = ..., skipna: bool = ...) -> object: ...
    def var(self, *, axis: AxisInt | None = ..., dtype: DTypeLike | None = ..., out: object | None = ..., ddof: int = ..., keepdims: bool = ..., skipna: bool = ...) -> object: ...
    def sem(self, *, axis: AxisInt | None = ..., dtype: DTypeLike | None = ..., out: object | None = ..., ddof: int = ..., keepdims: bool = ..., skipna: bool = ...) -> object: ...
    def kurt(self, *, axis: AxisInt | None = ..., dtype: DTypeLike | None = ..., out: object | None = ..., keepdims: bool = ..., skipna: bool = ...) -> object: ...
    def skew(self, *, axis: AxisInt | None = ..., dtype: DTypeLike | None = ..., out: object | None = ..., keepdims: bool = ..., skipna: bool = ...) -> object: ...
    def to_numpy(self, dtype: DTypeLike | None = ..., copy: bool = ..., na_value: object = lib.no_default) -> np.ndarray: ...
    def __invert__(self) -> Self: ...
    def __neg__(self) -> Self: ...
    def __pos__(self) -> Self: ...
    def __abs__(self) -> Self: ...
    def _cmp_method(self, other: object, op: object) -> object: ...
    def _arith_method(self, other: object, op: object) -> object: ...
    def _wrap_ndarray_result(self, result: np.ndarray) -> NumpyExtensionArray | TimedeltaArray: ...