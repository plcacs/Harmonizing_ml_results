from __future__ import annotations

from typing import Any, Callable, Iterable, Literal, Optional, Self

import numpy as np
from pandas import Series
from pandas.core.arrays.base import ExtensionArray
from pandas.core.arrays.floating import FloatingArray, FloatingDtype
from pandas.core.arrays.integer import IntegerArray, IntegerDtype
from pandas.core.arrays.numpy_ import NumpyExtensionArray
from pandas.core.dtypes.base import ExtensionDtype, StorageExtensionDtype
from pandas.core.arrays.string_arrow import ArrowStringArray, ArrowStringArrayNumpySemantics
import pyarrow


class StringDtype(StorageExtensionDtype):
    @property
    def name(self) -> str: ...
    @property
    def na_value(self) -> object: ...
    _metadata: tuple[str, str]
    storage: str
    _na_value: object

    def __init__(self, storage: Optional[Literal["python", "pyarrow", "pyarrow_numpy"]] = ..., na_value: object = ...) -> None: ...
    def __repr__(self) -> str: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def __reduce__(self) -> tuple[type[StringDtype], tuple[str, object]]: ...
    @property
    def type(self) -> type[str]: ...
    @classmethod
    def construct_from_string(cls, string: str) -> StringDtype: ...
    def construct_array_type(self) -> type[BaseStringArray]: ...
    def _get_common_dtype(self, dtypes: Iterable[object]) -> StringDtype | None: ...
    def __from_arrow__(self, array: Any) -> BaseStringArray: ...


class BaseStringArray(ExtensionArray):
    def tolist(self) -> list[object]: ...
    @classmethod
    def _from_scalars(cls, scalars: Iterable[object], dtype: StringDtype) -> Self: ...
    def _formatter(self, boxed: bool = ...) -> Callable[[Any], str]: ...
    def _str_map(
        self,
        f: Callable[[Any], Any],
        na_value: Any = ...,
        dtype: object | None = ...,
        convert: bool = ...,
    ) -> object: ...
    def _str_map_str_or_object(
        self,
        dtype: object,
        na_value: object,
        arr: np.ndarray,
        f: Callable[[Any], Any],
        mask: np.ndarray,
    ) -> object: ...
    def _str_map_nan_semantics(
        self,
        f: Callable[[Any], Any],
        na_value: Any = ...,
        dtype: object | None = ...,
    ) -> object: ...
    def view(self, dtype: None = ...) -> BaseStringArray: ...


class StringArray(BaseStringArray, NumpyExtensionArray):
    _typ: str
    _storage: str
    _na_value: object

    def __init__(self, values: object, copy: bool = ...) -> None: ...
    def _validate(self) -> None: ...
    def _validate_scalar(self, value: object) -> object: ...
    @classmethod
    def _from_sequence(cls, scalars: Any, *, dtype: object | None = ..., copy: bool = ...) -> Self: ...
    @classmethod
    def _from_sequence_of_strings(cls, strings: Any, *, dtype: object, copy: bool = ...) -> Self: ...
    @classmethod
    def _empty(cls, shape: int | tuple[int, ...], dtype: object) -> Self: ...
    def __arrow_array__(self, type: Any | None = ...) -> pyarrow.Array: ...
    def _values_for_factorize(self) -> tuple[np.ndarray, object]: ...
    def _maybe_convert_setitem_value(self, value: object) -> object: ...
    def __setitem__(self, key: Any, value: object) -> None: ...
    def _putmask(self, mask: np.ndarray, value: object) -> None: ...
    def _where(self, mask: np.ndarray, value: object) -> BaseStringArray: ...
    def isin(self, values: Any) -> np.ndarray: ...
    def astype(self, dtype: object, copy: bool = ...) -> IntegerArray | FloatingArray | ExtensionArray | np.ndarray: ...
    def _reduce(self, name: str, *, skipna: bool = ..., keepdims: bool = ..., axis: int = ..., **kwargs: Any) -> Any: ...
    def _wrap_reduction_result(self, axis: object, result: object) -> object: ...
    def min(self, axis: int | None = ..., skipna: bool = ..., **kwargs: Any) -> Any: ...
    def max(self, axis: int | None = ..., skipna: bool = ..., **kwargs: Any) -> Any: ...
    def sum(self, *, axis: int | None = ..., skipna: bool = ..., min_count: int = ..., **kwargs: Any) -> Any: ...
    def value_counts(self, dropna: bool = ...) -> Series: ...
    def memory_usage(self, deep: bool = ...) -> int: ...
    def searchsorted(self, value: object, side: Literal["left", "right"] = ..., sorter: np.ndarray | None = ...) -> np.ndarray: ...
    def _cmp_method(self, other: object, op: Callable[..., Any]) -> Any: ...
    _arith_method: Any


class StringArrayNumpySemantics(StringArray):
    _storage: str
    _na_value: object

    def _validate(self) -> None: ...
    @classmethod
    def _from_sequence(cls, scalars: Any, *, dtype: object | None = ..., copy: bool = ...) -> Self: ...