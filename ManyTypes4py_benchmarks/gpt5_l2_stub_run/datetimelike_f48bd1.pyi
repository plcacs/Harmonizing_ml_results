from __future__ import annotations

from abc import ABC
from datetime import datetime
from typing import Any, Callable, Sequence

import numpy as np
from pandas._libs import Timedelta
from pandas._libs.tslibs import BaseOffset, Resolution, Tick
from pandas.core.arrays import ExtensionArray
from pandas.core.indexes.base import Index
from pandas.core.indexes.extension import NDArrayBackedExtensionIndex
from pandas.core.indexes.range import RangeIndex


class DatetimeIndexOpsMixin(NDArrayBackedExtensionIndex, ABC):
    _can_hold_strings: bool = ...
    _default_na_rep: str = ...

    def mean(self, *, skipna: bool = ..., axis: int = ...) -> Any: ...
    @property
    def freq(self) -> BaseOffset | None: ...
    @freq.setter
    def freq(self, value: BaseOffset | None) -> None: ...
    @property
    def asi8(self) -> np.ndarray: ...
    @property
    def freqstr(self) -> str | None: ...
    @property
    def _resolution_obj(self) -> Resolution: ...
    @property
    def resolution(self) -> str: ...
    @property
    def hasnans(self) -> bool: ...
    def equals(self, other: object) -> bool: ...
    def __contains__(self, key: object) -> bool: ...
    def _convert_tolerance(self, tolerance: Any, target: Any) -> Any: ...
    def _format_with_header(self, *, header: list[str], na_rep: str, date_format: str | None = ...) -> list[str]: ...
    @property
    def _formatter_func(self) -> Callable[[Any], str]: ...
    def _format_attrs(self) -> list[tuple[str, Any]]: ...
    def _summary(self, name: str | None = ...) -> str: ...
    def _can_partial_date_slice(self, reso: Resolution) -> bool: ...
    def _parsed_string_to_bounds(self, reso: Resolution, parsed: datetime) -> tuple[Any, Any]: ...
    def _parse_with_reso(self, label: object) -> tuple[datetime, Resolution]: ...
    def _get_string_slice(self, key: str) -> slice | np.ndarray: ...
    def _partial_date_slice(self, reso: Resolution, parsed: datetime) -> slice | np.ndarray: ...
    def _maybe_cast_slice_bound(self, label: object, side: str) -> object: ...
    def shift(self, periods: int = ..., freq: BaseOffset | Timedelta | str | None = ...) -> DatetimeIndexOpsMixin: ...
    def _maybe_cast_listlike_indexer(self, keyarr: Any) -> Index: ...


class DatetimeTimedeltaMixin(DatetimeIndexOpsMixin, ABC):
    @property
    def unit(self) -> str: ...
    def as_unit(self, unit: str) -> DatetimeTimedeltaMixin: ...
    def _with_freq(self, freq: BaseOffset | str | None) -> DatetimeTimedeltaMixin: ...
    @property
    def values(self) -> np.ndarray: ...
    def shift(self, periods: int = ..., freq: BaseOffset | Timedelta | str | None = ...) -> DatetimeTimedeltaMixin: ...
    @property
    def inferred_freq(self) -> str | None: ...
    @property
    def _as_range_index(self) -> RangeIndex: ...
    def _can_range_setop(self, other: DatetimeTimedeltaMixin) -> bool: ...
    def _wrap_range_setop(self, other: DatetimeTimedeltaMixin, res_i8: Index) -> DatetimeTimedeltaMixin: ...
    def _range_intersect(self, other: DatetimeTimedeltaMixin, sort: bool | None) -> DatetimeTimedeltaMixin: ...
    def _range_union(self, other: DatetimeTimedeltaMixin, sort: bool | None) -> DatetimeTimedeltaMixin: ...
    def _intersection(self, other: DatetimeTimedeltaMixin, sort: bool | None = ...) -> DatetimeTimedeltaMixin: ...
    def _fast_intersect(self, other: DatetimeTimedeltaMixin, sort: bool | None) -> DatetimeTimedeltaMixin: ...
    def _can_fast_intersect(self, other: DatetimeTimedeltaMixin) -> bool: ...
    def _can_fast_union(self, other: DatetimeTimedeltaMixin) -> bool: ...
    def _fast_union(self, other: DatetimeTimedeltaMixin, sort: bool | None = ...) -> DatetimeTimedeltaMixin: ...
    def _union(self, other: DatetimeTimedeltaMixin, sort: bool | None) -> DatetimeTimedeltaMixin: ...
    def _get_join_freq(self, other: DatetimeTimedeltaMixin) -> BaseOffset | None: ...
    def _wrap_join_result(self, joined: Index, other: DatetimeTimedeltaMixin, lidx: np.ndarray | None, ridx: np.ndarray | None, how: Any) -> tuple[Index, np.ndarray | None, np.ndarray | None]: ...
    def _get_engine_target(self) -> np.ndarray: ...
    def _from_join_target(self, result: np.ndarray) -> ExtensionArray: ...
    def _get_delete_freq(self, loc: int | slice | Sequence[int] | np.ndarray) -> BaseOffset | None: ...
    def _get_insert_freq(self, loc: int | slice, item: Any) -> BaseOffset | None: ...
    def delete(self, loc: int | slice | Sequence[int] | np.ndarray) -> DatetimeTimedeltaMixin: ...
    def insert(self, loc: int, item: Any) -> Index: ...
    def take(self, indices: Sequence[int] | np.ndarray, axis: int = ..., allow_fill: bool = ..., fill_value: Any = ..., **kwargs: Any) -> DatetimeTimedeltaMixin: ...