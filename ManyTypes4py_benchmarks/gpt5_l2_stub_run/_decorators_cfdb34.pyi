from typing import Any, Callable, Mapping, Optional, Union, Type, List
from pandas._libs.properties import cache_readonly
from pandas._typing import F, T

def deprecate(
    name: str,
    alternative: Callable[..., T],
    version: str,
    alt_name: Optional[str] = ...,
    klass: Optional[Type[Warning]] = ...,
    stacklevel: int = ...,
    msg: Optional[str] = ...,
) -> Callable[..., T]: ...
def deprecate_kwarg(
    old_arg_name: str,
    new_arg_name: Optional[str],
    mapping: Optional[Union[Mapping[Any, Any], Callable[[Any], Any]]] = ...,
    stacklevel: int = ...,
) -> Callable[[F], F]: ...
def _format_argument_list(allow_args: List[str]) -> str: ...
def future_version_msg(version: Optional[str]) -> str: ...
def deprecate_nonkeyword_arguments(
    version: Optional[str],
    allowed_args: Optional[List[str]] = ...,
    name: Optional[str] = ...,
) -> Callable[[F], F]: ...
def doc(*docstrings: Union[str, None, Callable[..., Any]], **params: Any) -> Callable[[F], F]: ...

class Substitution:
    def __init__(self, *args: Any, **kwargs: Any) -> None: ...
    def __call__(self, func: F) -> F: ...
    def update(self, *args: Any, **kwargs: Any) -> None: ...

class Appender:
    def __init__(self, addendum: Optional[str], join: str = ..., indents: int = ...) -> None: ...
    def __call__(self, func: F) -> F: ...

def indent(text: Optional[str], indents: int = ...) -> str: ...

__all__: List[str] = ...

def set_module(module: Optional[str]) -> Callable[[T], T]: ...