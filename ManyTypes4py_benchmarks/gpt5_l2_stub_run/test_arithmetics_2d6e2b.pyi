from typing import Any, Callable, Iterable, Optional, Union
from numpy import ndarray
from pandas.core.arrays.sparse import SparseArray
from pytest import FixtureRequest

def kind(request: FixtureRequest) -> str: ...
def mix(request: FixtureRequest) -> bool: ...

class TestSparseArrayArithmetics:
    def _assert(self, a: ndarray, b: ndarray) -> None: ...
    def _check_numeric_ops(
        self,
        a: SparseArray,
        b: Union[SparseArray, int, float, ndarray],
        a_dense: ndarray,
        b_dense: Union[ndarray, int, float],
        mix: bool,
        op: Callable[[Any, Any], Any],
    ) -> None: ...
    def _check_bool_result(self, res: SparseArray) -> None: ...
    def _check_comparison_ops(
        self,
        a: SparseArray,
        b: Union[SparseArray, int, float, bool],
        a_dense: ndarray,
        b_dense: Union[ndarray, int, float, bool],
    ) -> None: ...
    def _check_logical_ops(self, a: SparseArray, b: SparseArray, a_dense: ndarray, b_dense: ndarray) -> None: ...
    def test_float_scalar(
        self,
        kind: str,
        mix: bool,
        all_arithmetic_functions: Callable[[Any, Any], Any],
        fill_value: Optional[int],
        scalar: int,
        request: FixtureRequest,
    ) -> None: ...
    def test_float_scalar_comparison(self, kind: str) -> None: ...
    def test_float_same_index_without_nans(
        self, kind: str, mix: bool, all_arithmetic_functions: Callable[[Any, Any], Any]
    ) -> None: ...
    def test_float_same_index_with_nans(
        self, kind: str, mix: bool, all_arithmetic_functions: Callable[[Any, Any], Any], request: FixtureRequest
    ) -> None: ...
    def test_float_same_index_comparison(self, kind: str) -> None: ...
    def test_float_array(self, kind: str, mix: bool, all_arithmetic_functions: Callable[[Any, Any], Any]) -> None: ...
    def test_float_array_different_kind(self, mix: bool, all_arithmetic_functions: Callable[[Any, Any], Any]) -> None: ...
    def test_float_array_comparison(self, kind: str) -> None: ...
    def test_int_array(self, kind: str, mix: bool, all_arithmetic_functions: Callable[[Any, Any], Any]) -> None: ...
    def test_int_array_comparison(self, kind: str) -> None: ...
    def test_bool_same_index(self, kind: str, fill_value: Union[bool, float]) -> None: ...
    def test_bool_array_logical(self, kind: str, fill_value: Union[bool, float]) -> None: ...
    def test_mixed_array_float_int(
        self, kind: str, mix: bool, all_arithmetic_functions: Callable[[Any, Any], Any], request: FixtureRequest
    ) -> None: ...
    def test_mixed_array_comparison(self, kind: str) -> None: ...
    def test_xor(self) -> None: ...

def test_with_list(op: Callable[[Any, Any], Any]) -> None: ...
def test_with_dataframe() -> None: ...
def test_with_zerodim_ndarray() -> None: ...
def test_ufuncs(ufunc: Callable[[Any], Any], arr: SparseArray) -> None: ...
def test_binary_ufuncs(ufunc: Callable[[Any, Any], Any], a: SparseArray, b: ndarray) -> None: ...
def test_ndarray_inplace() -> None: ...
def test_sparray_inplace() -> None: ...
def test_mismatched_length_cmp_op(cons: Callable[[Iterable[bool]], Any]) -> None: ...
def test_mismatched_length_arith_op(
    a: list[int], b: list[int], all_arithmetic_functions: Callable[[Any, Any], Any]
