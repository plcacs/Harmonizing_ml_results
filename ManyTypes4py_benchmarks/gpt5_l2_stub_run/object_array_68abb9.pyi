from typing import Any, Callable, Literal, Sequence, overload
import re
import numpy as np
from numpy.typing import ArrayLike
from pandas._libs import lib
from pandas._typing import NpDtype, Scalar
from pandas.core.strings.base import BaseStringArrayMethods
from pandas.core.arrays.string_ import BaseStringArray

class ObjectStringArrayMixin(BaseStringArrayMethods):
    def __len__(self) -> int: ...
    def _str_map(
        self,
        f: Callable[[Any], Any],
        na_value: object = lib.no_default,
        dtype: NpDtype | None = None,
        convert: bool = True,
    ) -> ArrayLike: ...
    def _str_count(self, pat: str | re.Pattern, flags: int = 0) -> np.ndarray: ...
    def _str_pad(
        self,
        width: int,
        side: Literal["left", "right", "both"] = "left",
        fillchar: str = " ",
    ) -> np.ndarray: ...
    def _str_contains(
        self,
        pat: str | re.Pattern,
        case: bool = True,
        flags: int = 0,
        na: object = lib.no_default,
        regex: bool = True,
    ) -> np.ndarray: ...
    def _str_startswith(self, pat: str | tuple[str, ...], na: object = lib.no_default) -> np.ndarray: ...
    def _str_endswith(self, pat: str | tuple[str, ...], na: object = lib.no_default) -> np.ndarray: ...
    def _str_replace(
        self,
        pat: str | re.Pattern,
        repl: str | Callable[..., str],
        n: int = -1,
        case: bool = True,
        flags: int = 0,
        regex: bool = True,
    ) -> np.ndarray: ...
    def _str_repeat(self, repeats: int | Sequence[int]) -> np.ndarray | BaseStringArray: ...
    def _str_match(self, pat: str, case: bool = True, flags: int = 0, na: Scalar = lib.no_default) -> np.ndarray: ...
    def _str_fullmatch(
        self,
        pat: str | re.Pattern,
        case: bool = True,
        flags: int = 0,
        na: Scalar = lib.no_default,
    ) -> np.ndarray: ...
    def _str_encode(self, encoding: str, errors: str = "strict") -> np.ndarray: ...
    def _str_find(self, sub: str, start: int = 0, end: int | None = None) -> np.ndarray: ...
    def _str_rfind(self, sub: str, start: int = 0, end: int | None = None) -> np.ndarray: ...
    def _str_find_(self, sub: str, start: int, end: int | None, side: Literal["left", "right"]) -> np.ndarray: ...
    def _str_findall(self, pat: str | re.Pattern, flags: int = 0) -> np.ndarray: ...
    def _str_get(self, i: object) -> np.ndarray: ...
    def _str_index(self, sub: str, start: int = 0, end: int | None = None) -> np.ndarray: ...
    def _str_rindex(self, sub: str, start: int = 0, end: int | None = None) -> np.ndarray: ...
    def _str_join(self, sep: str) -> np.ndarray: ...
    def _str_partition(self, sep: str, expand: bool) -> np.ndarray: ...
    def _str_rpartition(self, sep: str, expand: bool) -> np.ndarray: ...
    def _str_len(self) -> np.ndarray: ...
    def _str_slice(self, start: int | None = None, stop: int | None = None, step: int | None = None) -> np.ndarray: ...
    def _str_slice_replace(self, start: int | None = None, stop: int | None = None, repl: str | None = None) -> np.ndarray: ...
    def _str_split(
        self,
        pat: str | re.Pattern | None = None,
        n: int = -1,
        expand: bool = False,
        regex: bool | None = None,
    ) -> np.ndarray: ...
    def _str_rsplit(self, pat: str | None = None, n: int = -1) -> np.ndarray: ...
    def _str_translate(self, table: object) -> np.ndarray: ...
    def _str_wrap(self, width: int, **kwargs: Any) -> np.ndarray: ...
    def _str_get_dummies(self, sep: str = "|", dtype: NpDtype | None = None) -> tuple[np.ndarray, list[str]]: ...
    def _str_upper(self) -> np.ndarray: ...
    def _str_isalnum(self) -> np.ndarray: ...
    def _str_isalpha(self) -> np.ndarray: ...
    def _str_isascii(self) -> np.ndarray: ...
    def _str_isdecimal(self) -> np.ndarray: ...
    def _str_isdigit(self) -> np.ndarray: ...
    def _str_islower(self) -> np.ndarray: ...
    def _str_isnumeric(self) -> np.ndarray: ...
    def _str_isspace(self) -> np.ndarray: ...
    def _str_istitle(self) -> np.ndarray: ...
    def _str_isupper(self) -> np.ndarray: ...
    def _str_capitalize(self) -> np.ndarray: ...
    def _str_casefold(self) -> np.ndarray: ...
    def _str_title(self) -> np.ndarray: ...
    def _str_swapcase(self) -> np.ndarray: ...
    def _str_lower(self) -> np.ndarray: ...
    def _str_normalize(self, form: str) -> np.ndarray: ...
    def _str_strip(self, to_strip: str | None = None) -> np.ndarray: ...
    def _str_lstrip(self, to_strip: str | None = None) -> np.ndarray: ...
    def _str_rstrip(self, to_strip: str | None = None) -> np.ndarray: ...
    def _str_removeprefix(self, prefix: str) -> np.ndarray: ...
    def _str_removesuffix(self, suffix: str) -> np.ndarray: ...
    @overload
    def _str_extract(self, pat: str | re.Pattern, flags: int = 0, expand: Literal[True] = True) -> list[list[object]]: ...
    @overload
    def _str_extract(self, pat: str | re.Pattern, flags: int = 0, expand: Literal[False] = ...) -> np.ndarray: ...
    def _str_extract(self, pat: str | re.Pattern, flags: int = 0, expand: bool = True) -> list[list[object]] | np.ndarray: ...