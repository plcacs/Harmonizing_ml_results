from typing import Any, Awaitable, Callable, Coroutine, Dict, List, Optional, TypeVar, Union
import asyncio
from enum import Enum
from aiortc import RTCDataChannel, RTCPeerConnection, RTCSessionDescription
from gevent.lock import Semaphore
from gevent.event import Event as GEvent
from raiden.network.transport.matrix.client import ReceivedRaidenMessage
from raiden.utils.runnable import Runnable
from raiden.utils.typing import Address

log: Any
_SDP_MID_DEFAULT: str
_SDP_MLINE_INDEX_DEFAULT: int

class _RTCMessageType(Enum):
    OFFER: _RTCMessageType
    ANSWER: _RTCMessageType
    CANDIDATES: _RTCMessageType
    HANGUP: _RTCMessageType

class _SDPTypes(Enum):
    OFFER: _SDPTypes
    ANSWER: _SDPTypes

class _RTCChannelState(Enum):
    CONNECTING: _RTCChannelState
    OPEN: _RTCChannelState
    CLOSING: _RTCChannelState
    CLOSED: _RTCChannelState

class _RTCSignallingState(Enum):
    STABLE: _RTCSignallingState
    HAVE_LOCAL_OFFER: _RTCSignallingState
    HAVE_REMOTE_OFFER: _RTCSignallingState
    CLOSED: _RTCSignallingState

class _ConnectionState(Enum):
    NEW: _ConnectionState
    CONNECTING: _ConnectionState
    CONNECTED: _ConnectionState
    FAILED: _ConnectionState
    CLOSED: _ConnectionState

_T = TypeVar("_T")

class _TaskHandler:
    def __init__(self) -> None: ...
    def schedule_task(
        self,
        coroutine: Coroutine[Any, Any, _T],
        callback: Optional[Callable[..., Any]] = ...,
        *args: Any,
        **kwargs: Any
    ) -> None: ...
    def schedule_greenlet(self, func: Optional[Callable[..., Any]] = ..., *args: Any, **kwargs: Any) -> None: ...
    def wait_for_tasks(self) -> Awaitable[None]: ...

class _RTCConnection(_TaskHandler):
    def __init__(
        self,
        partner_address: Address,
        node_address: Address,
        signaling_send: Callable[[Address, str], None],
        ice_connection_closed: Callable[["_RTCConnection"], Any],
        handle_message_callback: Callable[..., Any],
    ) -> None: ...
    @staticmethod
    def from_offer(
        partner_address: Address,
        node_address: Address,
        signaling_send: Callable[[Address, str], None],
        ice_connection_closed: Callable[["_RTCConnection"], Any],
        handle_message_callback: Callable[..., Any],
        offer: Dict[str, Any],
    ) -> "_RTCConnection": ...
    @property
    def initiator_address(self) -> Address: ...
    def channel_open(self) -> bool: ...
    @property
    def call_id(self) -> str: ...
    def _try_signaling(self, coroutine: Awaitable[Any]) -> Awaitable[Optional[Any]]: ...
    def _set_local_description(self, description: RTCSessionDescription) -> Awaitable[None]: ...
    def initialize_signaling(self) -> None: ...
    def _initialize_signaling(self) -> Awaitable[Optional[RTCSessionDescription]]: ...
    def process_signaling(self, description: Dict[str, Any]) -> None: ...
    def _process_signaling(self, description: Dict[str, Any]) -> Awaitable[Optional[RTCSessionDescription]]: ...
    def set_candidates(self, content: Dict[str, Any]) -> None: ...
    def _set_candidates(self, content: Dict[str, Any]) -> Awaitable[None]: ...
    def send_message(self, message: Union[str, bytes, bytearray]) -> None: ...
    def _send_message(self, message: Union[str, bytes, bytearray]) -> Awaitable[None]: ...
    def close(self) -> asyncio.Task[None]: ...
    def _close(self) -> Awaitable[None]: ...
    def _handle_candidates_callback(self, candidates: List[Dict[str, Any]]) -> None: ...
    def send_hangup_message(self) -> None: ...
    def _handle_sdp_callback(self, rtc_session_description: Optional[RTCSessionDescription]) -> None: ...
    def __repr__(self) -> str: ...
    def _on_datachannel(self, channel: RTCDataChannel) -> None: ...
    def _on_channel_open(self) -> None: ...
    def _on_channel_message(self, message: Union[str, bytes, bytearray]) -> None: ...
    def _on_ice_gathering_state_change(self) -> None: ...
    def _on_connection_state_change(self) -> None: ...
    def _on_signalling_state_change(self) -> None: ...

class WebRTCManager(Runnable):
    def __init__(
        self,
        node_address: Address,
        process_messages: Callable[[List[ReceivedRaidenMessage]], Any],
        signaling_send: Callable[[Address, str], None],
        stop_event: GEvent,
    ) -> None: ...
    def get_lock(self, address: Address) -> Semaphore: ...
    def is_locked(self, address: Address) -> bool: ...
    def _handle_message(self, message_data: Union[str, bytes, bytearray], partner_address: Address) -> None: ...
    def _handle_ice_connection_closed(self, conn: _RTCConnection) -> None: ...
    def _wrapped_initialize_web_rtc(self, address: Address) -> None: ...
    def _initialize_web_rtc(self, partner_address: Address) -> None: ...
    def get_channel_init_timeout(self) -> float: ...
    def _add_connection(self, partner_address: Address, conn: _RTCConnection) -> None: ...
    def has_ready_channel(self, partner_address: Address) -> bool: ...
    def _reset_state(self) -> None: ...
    def _set_candidates_for_address(self, partner_address: Address, content: Dict[str, Any]) -> None: ...
    def _process_signaling_for_address(self, partner_address: Address, rtc_message_type: str, description: Dict[str, Any]) -> None: ...
    def send_message(self, partner_address: Address, message: Union[str, bytes, bytearray]) -> None: ...
    def health_check(self, partner_address: Address) -> None: ...
    def close_connection(self, partner_address: Address) -> None: ...
    def _process_signaling_message(self, partner_address: Address, rtc_message_type: str, content: Dict[str, Any]) -> None: ...
    def process_signaling_message(self, partner_address: Address, rtc_message_type: str, content: Dict[str, Any]) -> None: ...
    def stop(self) -> None: ...