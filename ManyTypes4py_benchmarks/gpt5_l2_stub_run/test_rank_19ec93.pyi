from typing import Any, Mapping, Optional, Protocol, Sequence, Union, Literal
import numpy as np
from pandas import DataFrame, Series

RankMethod = Literal["average", "min", "max", "first", "dense"]
NaOption = Literal["top", "bottom"]


class FrameOrSeriesFactory(Protocol):
    def __call__(self, data: Any, dtype: Any = ...) -> Union[Series, DataFrame]: ...


class TestRank:
    s: Series = ...
    df: DataFrame = ...
    results: dict[str, np.ndarray] = ...

    def test_rank(self, float_frame: DataFrame) -> None: ...
    def test_rank2(self) -> None: ...
    def test_rank_does_not_mutate(self) -> None: ...
    def test_rank_mixed_frame(self, float_string_frame: DataFrame) -> None: ...
    def test_rank_na_option(self, float_frame: DataFrame) -> None: ...
    def test_rank_axis(self) -> None: ...
    def test_rank_methods_frame(self, ax: int, rank_method: RankMethod) -> None: ...
    def test_rank_descending(self, rank_method: RankMethod, dtype: str) -> None: ...
    def test_rank_2d_tie_methods(self, rank_method: RankMethod, axis: int, dtype: Optional[type]) -> None: ...
    def test_rank_pct_true(self, rank_method: RankMethod, exp: list[list[float]]) -> None: ...
    def test_pct_max_many_rows(self) -> None: ...
    def test_rank_inf_and_nan(self, contents: list[object], dtype: str, frame_or_series: FrameOrSeriesFactory) -> None: ...
    def test_df_series_inf_nan_consistency(self) -> None: ...
    def test_rank_both_inf(self) -> None: ...
    def test_rank_inf_nans_na_option(self, frame_or_series: FrameOrSeriesFactory, rank_method: RankMethod, na_option: NaOption, ascending: bool, expected: list[float]) -> None: ...
    def test_rank_object_first(self, frame_or_series: FrameOrSeriesFactory, na_option: NaOption, ascending: bool, expected: list[float]) -> None: ...
    def test_rank_mixed_axis_zero(self, data: Mapping[str, list[object]], expected: DataFrame) -> None: ...
    def test_rank_string_dtype(self, string_dtype_no_object: object) -> None: ...