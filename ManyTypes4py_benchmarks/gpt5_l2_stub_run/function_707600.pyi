from typing import Any, Iterator, List, Optional, Tuple, Union

from jedi.inference.base_value import ContextualizedNode, NO_VALUES, TreeValue, ValueSet, ValueWrapper
from jedi.inference.context import TreeContextMixin, ValueContext
from jedi.inference.filters import AnonymousFunctionExecutionFilter, FunctionExecutionFilter, ParserTreeFilter
from jedi.inference.lazy_value import LazyKnownValue, LazyKnownValues, LazyTreeValue
from jedi.inference.names import AbstractNameDefinition, AnonymousParamName, NameWrapper, ParamName, ValueName
from jedi.inference.signature import TreeSignature
from jedi.inference.cache import CachedMetaClass


class LambdaName(AbstractNameDefinition):
    string_name: str = ...
    api_type: str = ...
    def __init__(self, lambda_value: "FunctionValue") -> None: ...
    @property
    def start_pos(self) -> Any: ...
    def infer(self) -> ValueSet: ...


class FunctionAndClassBase(TreeValue):
    def get_qualified_names(self) -> Optional[Tuple[str, ...]]: ...


class FunctionMixin:
    api_type: str = ...
    def get_filters(self, origin_scope: Any = ...) -> Iterator[Any]: ...
    def py__get__(self, instance: Optional[Any], class_value: Any) -> ValueSet: ...
    def get_param_names(self) -> List[AnonymousParamName]: ...
    @property
    def name(self) -> Union[AbstractNameDefinition, NameWrapper]: ...
    def is_function(self) -> bool: ...
    def py__name__(self) -> str: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...
    def py__call__(self, arguments: Any) -> ValueSet: ...
    def _as_context(self, arguments: Any = ...) -> Union["AnonymousFunctionExecution", "FunctionExecutionContext"]: ...
    def get_signatures(self) -> List[TreeSignature]: ...


class FunctionValue(FunctionMixin, FunctionAndClassBase, metaclass=CachedMetaClass):
    @classmethod
    def from_context(cls, context: ValueContext, tree_node: Any) -> Union["FunctionValue", "OverloadedFunctionValue"]: ...
    def py__class__(self) -> Any: ...
    def get_default_param_context(self) -> ValueContext: ...
    def get_signature_functions(self) -> List["FunctionValue"]: ...


class FunctionNameInClass(NameWrapper):
    def __init__(self, class_context: ValueContext, name: AbstractNameDefinition) -> None: ...
    def get_defining_qualified_value(self) -> Any: ...


class MethodValue(FunctionValue):
    class_context: ValueContext
    def __init__(self, inference_state: Any, class_context: ValueContext, *args: Any, **kwargs: Any) -> None: ...
    def get_default_param_context(self) -> ValueContext: ...
    def get_qualified_names(self) -> Optional[Tuple[str, ...]]: ...
    @property
    def name(self) -> FunctionNameInClass: ...


class BaseFunctionExecutionContext(ValueContext, TreeContextMixin):
    def infer_annotations(self) -> ValueSet: ...
    def get_return_values(self, check_yields: bool = ...) -> ValueSet: ...
    def _get_yield_lazy_value(self, yield_expr: Any) -> Iterator[Union[LazyKnownValue, LazyTreeValue, LazyKnownValues]]: ...
    def get_yield_lazy_values(self, is_async: bool = ...) -> Iterator[Union[LazyKnownValues, LazyKnownValue, LazyTreeValue]]: ...
    def merge_yield_values(self, is_async: bool = ...) -> ValueSet: ...
    def is_generator(self) -> bool: ...
    def infer(self) -> ValueSet: ...


class FunctionExecutionContext(BaseFunctionExecutionContext):
    def __init__(self, function_value: FunctionValue, arguments: Any) -> None: ...
    def get_filters(self, until_position: Any = ..., origin_scope: Any = ...) -> Iterator[FunctionExecutionFilter]: ...
    def infer_annotations(self) -> ValueSet: ...
    def get_param_names(self) -> List[ParamName]: ...


class AnonymousFunctionExecution(BaseFunctionExecutionContext):
    def infer_annotations(self) -> ValueSet: ...
    def get_filters(self, until_position: Any = ..., origin_scope: Any = ...) -> Iterator[AnonymousFunctionExecutionFilter]: ...
    def get_param_names(self) -> List[AnonymousParamName]: ...


class OverloadedFunctionValue(FunctionMixin, ValueWrapper):
    def __init__(self, function: FunctionValue, overloaded_functions: List[FunctionValue]) -> None: ...
    def py__call__(self, arguments: Any) -> ValueSet: ...
    def get_signature_functions(self) -> List[FunctionValue]: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...


def _find_overload_functions(context: ValueContext, tree_node: Any) -> Iterator[Any]: ...