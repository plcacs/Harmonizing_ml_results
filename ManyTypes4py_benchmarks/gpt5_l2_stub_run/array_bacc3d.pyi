from __future__ import annotations

import decimal
from typing import Any, Callable, Iterable, Sequence

import numpy as np
from pandas.core.arraylike import OpsMixin
from pandas.core.arrays import ExtensionArray, ExtensionScalarOpsMixin
from pandas.core.dtypes.base import ExtensionDtype


class DecimalDtype(ExtensionDtype):
    type: type[decimal.Decimal]
    name: str
    na_value: decimal.Decimal
    _metadata: tuple[str, ...]

    def __init__(self, context: decimal.Context | None = ...) -> None: ...
    def __repr__(self) -> str: ...
    @classmethod
    def construct_array_type(cls) -> type[DecimalArray]: ...
    @property
    def _is_numeric(self) -> bool: ...


class DecimalArray(OpsMixin, ExtensionScalarOpsMixin, ExtensionArray):
    __array_priority__: int
    _HANDLED_TYPES: tuple[type[object], ...]

    def __init__(
        self,
        values: list[object] | np.ndarray,
        dtype: object | None = ...,
        copy: bool = ...,
        context: decimal.Context | None = ...,
    ) -> None: ...
    @property
    def dtype(self) -> DecimalDtype: ...
    @classmethod
    def _from_sequence(
        cls, scalars: Iterable[object], *, dtype: object | None = ..., copy: bool = ...
    ) -> DecimalArray: ...
    @classmethod
    def _from_sequence_of_strings(
        cls, strings: Sequence[str], *, dtype: DecimalDtype, copy: bool = ...
    ) -> DecimalArray: ...
    @classmethod
    def _from_factorized(
        cls, values: Iterable[decimal.Decimal] | np.ndarray, original: ExtensionArray
    ) -> DecimalArray: ...
    def to_numpy(
        self,
        dtype: object | None = ...,
        copy: bool = ...,
        na_value: object = ...,
        decimals: int | None = ...,
    ) -> np.ndarray: ...
    def __array_ufunc__(self, ufunc: np.ufunc, method: str, *inputs: object, **kwargs: object) -> object: ...
    def __getitem__(self, item: object) -> decimal.Decimal | DecimalArray: ...
    def take(
        self, indexer: Sequence[int] | np.ndarray, allow_fill: bool = ..., fill_value: object | None = ...
    ) -> DecimalArray: ...
    def copy(self) -> DecimalArray: ...
    def astype(self, dtype: object, copy: bool = ...) -> DecimalArray | np.ndarray: ...
    def __setitem__(self, key: object, value: object) -> None: ...
    def __len__(self) -> int: ...
    def __contains__(self, item: object) -> bool: ...
    @property
    def nbytes(self) -> int: ...
    def isna(self) -> np.ndarray: ...
    @property
    def _na_value(self) -> decimal.Decimal: ...
    def _formatter(self, boxed: bool = ...) -> Callable[[object], str]: ...
    @classmethod
    def _concat_same_type(cls, to_concat: Sequence[DecimalArray]) -> DecimalArray: ...
    def _reduce(self, name: str, *, skipna: bool = ..., keepdims: bool = ..., **kwargs: object) -> decimal.Decimal | DecimalArray: ...
    def _cmp_method(self, other: object, op: Callable[[object, object], bool]) -> np.ndarray: ...
    def value_counts(self, dropna: bool = ...) -> tuple[np.ndarray, np.ndarray]: ...
    def fillna(self, value: object | None = ..., limit: int | None = ...) -> DecimalArray: ...


def to_decimal(values: Iterable[object], context: decimal.Context | None = ...) -> DecimalArray: ...
def make_data() -> list[decimal.Decimal]: ...