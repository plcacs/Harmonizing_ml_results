def numpy_rolling_std(data: np.ndarray, window: int, as_source: bool = ...) -> np.ndarray: ...
def numpy_rolling_std(data: Union[pd.Series, np.ndarray], window: int, as_source: bool = ...) -> Union[pd.Series, np.ndarray]: ...

