from typing import Callable, Literal, NoReturn, Optional, Union, overload
import numpy as np
import pandas as pd

def numpy_rolling_window(data: np.ndarray, window: int) -> np.ndarray: ...
def numpy_rolling_series(func: Callable[[np.ndarray, int], np.ndarray]) -> Callable[[Union[pd.Series, np.ndarray], int, bool], Union[pd.Series, np.ndarray]]: ...

@overload
def numpy_rolling_mean(data: pd.Series, window: int, as_source: Literal[True]) -> pd.Series: ...
