def numpy_rolling_mean(data: np.ndarray, window: int, as_source: bool = ...) -> np.ndarray: ...
def numpy_rolling_mean(data: Union[pd.Series, np.ndarray], window: int, as_source: bool = ...) -> Union[pd.Series, np.ndarray]: ...

@overload
def numpy_rolling_std(data: pd.Series, window: int, as_source: Literal[True]) -> pd.Series: ...
