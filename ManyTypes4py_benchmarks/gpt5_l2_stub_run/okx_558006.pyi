    def fetch_stoploss_order(self, order_id: str, pair: str, params: Optional[Dict[str, Any]] = ...) -> CcxtOrder: ...
    def _fetch_stop_order_fallback(self, order_id: str, pair: str) -> CcxtOrder: ...
    def get_order_id_conditional(self, order: Dict[str, Any]) -> str: ...
    def cancel_stoploss_order(self, order_id: str, pair: str, params: Optional[Dict[str, Any]] = ...) -> CcxtOrder: ...
    def _fetch_orders_emulate(self, pair: str, since_ms: int) -> List[CcxtOrder]: ...