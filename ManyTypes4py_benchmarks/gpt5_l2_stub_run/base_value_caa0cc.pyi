def iterate_values(values: "ValueSet", contextualized_node: Optional["ContextualizedNode"] = ..., is_async: bool = ...) -> "ValueSet": ...

_VT = TypeVar("_VT", bound="_ValueWrapperBase")

class _ValueWrapperBase(HelperValueMixin):
    @property
    def name(self) -> Any: ...
    @classmethod
    def create_cached(cls: Type[_VT], inference_state: Any, *args: Any, **kwargs: Any) -> _VT: ...
    def __getattr__(self, name: str) -> Any: ...

class LazyValueWrapper(_ValueWrapperBase):
    @property
    def _wrapped_value(self) -> "Value": ...
    def __repr__(self) -> str: ...
    def _get_wrapped_value(self) -> "Value": ...

class ValueWrapper(_ValueWrapperBase):
    _wrapped_value: "Value"
    def __init__(self, wrapped_value: "Value") -> None: ...
    def __repr__(self) -> str: ...

class TreeValue(Value):
    def __init__(self, inference_state: Any, parent_context: Any, tree_node: Any) -> None: ...
    def __repr__(self) -> str: ...

