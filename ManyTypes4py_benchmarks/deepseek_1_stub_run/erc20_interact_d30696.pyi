    def mine_block(self, chain: MiningChain, block_number: int, num_tx: int) -> Any: ...
    
    def _deploy_simple_token(self, chain: MiningChain, nonce: Any = ...) -> Tuple[Any, Callable]: ...
    
    def _erc_transfer(self, addr: str, chain: MiningChain, nonce: Any = ...) -> Tuple[Any, Callable]: ...
    
    def _erc_approve(self, addr2: str, chain: MiningChain, nonce: Any = ...) -> Tuple[Any, Callable]: ...
    
    def _erc_transfer_from(self, addr1: str, addr2: str, chain: MiningChain, nonce: Any = ...) -> Tuple[Any, Callable]: ...

