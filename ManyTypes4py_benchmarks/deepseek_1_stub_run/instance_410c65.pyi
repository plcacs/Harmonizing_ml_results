```python
from typing import Any, Iterator, Optional, Union
from abc import abstractproperty
from parso.tree import NodeOrLeaf
from jedi.inference import compiled
from jedi.inference.arguments import AbstractArguments
from jedi.inference.base_value import Value, NO_VALUES, ValueSet
from jedi.inference.cache import CachedMetaClass
from jedi.inference.context import AbstractContext
from jedi.inference.filters import AbstractFilter
from jedi.inference.lazy_value import LazyValue
from jedi.inference.names import AbstractNameDefinition, ParamName, NameWrapper
from jedi.inference.signature import AbstractSignature
from jedi.inference.value.function import (
    FunctionValue,
    BaseFunctionExecutionContext,
    FunctionExecutionContext,
    FunctionNameInClass,
)
from jedi.inference.value.klass import ClassFilter

class InstanceExecutedParamName(ParamName):
    _instance: Any
    def __init__(self, instance: Any, function_value: Any, tree_name: Any) -> None: ...
    def infer(self) -> ValueSet: ...
    def matches_signature(self) -> bool: ...

class AnonymousMethodExecutionFilter(AnonymousFunctionExecutionFilter):
    _instance: Any
    def __init__(self, instance: Any, *args: Any, **kwargs: Any) -> None: ...
    def _convert_param(self, param: Any, name: Any) -> Any: ...

class AnonymousMethodExecutionContext(BaseFunctionExecutionContext):
    instance: Any
    def __init__(self, instance: Any, value: Any) -> None: ...
    def get_filters(
        self, until_position: Any = ..., origin_scope: Any = ...
    ) -> Iterator[AnonymousMethodExecutionFilter]: ...
    def get_param_names(self) -> list[InstanceExecutedParamName]: ...

class MethodExecutionContext(FunctionExecutionContext):
    instance: Any
    def __init__(self, instance: Any, *args: Any, **kwargs: Any) -> None: ...

class AbstractInstanceValue(Value, metaclass=CachedMetaClass):
    api_type: str = ...
    class_value: Any
    def __init__(
        self,
        inference_state: Any,
        parent_context: Any,
        class_value: Any,
    ) -> None: ...
    def is_instance(self) -> bool: ...
    def get_qualified_names(self) -> Any: ...
    def get_annotated_class_object(self) -> Any: ...
    def py__class__(self) -> Any: ...
    def py__bool__(self) -> Any: ...
    @abstractproperty
    def name(self) -> Any: ...
    def get_signatures(self) -> list[AbstractSignature]: ...
    def get_function_slot_names(self, name: str) -> list[Any]: ...
    def execute_function_slots(self, names: list[Any], *inferred_args: Any) -> ValueSet: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...
    def py__getitem__(
        self, index_value_set: ValueSet, contextualized_node: Any
    ) -> ValueSet: ...
    def py__iter__(self, contextualized_node: Any = ...) -> Iterator[Any]: ...
    def py__getattribute__alternatives(self, string_name: str) -> ValueSet: ...
    def py__next__(self, contextualized_node: Any = ...) -> Iterator[LazyValue]: ...
    def py__call__(self, arguments: AbstractArguments) -> ValueSet: ...
    def py__get__(self, instance: Any, class_value: Any) -> ValueSet: ...

class CompiledInstance(AbstractInstanceValue):
    _arguments: Any
    def __init__(
        self,
        inference_state: Any,
        parent_context: Any,
        class_value: Any,
        arguments: Any,
    ) -> None: ...
    def get_filters(
        self, origin_scope: Any = ..., include_self_names: bool = ...
    ) -> Iterator[CompiledInstanceClassFilter]: ...
    @property
    def name(self) -> compiled.CompiledValueName: ...
    def is_stub(self) -> bool: ...

class _BaseTreeInstance(AbstractInstanceValue):
    @property
    def array_type(self) -> Optional[str]: ...
    @property
    def name(self) -> Any: ...
    def get_filters(
        self, origin_scope: Any = ..., include_self_names: bool = ...
    ) -> Iterator[Union[SelfAttributeFilter, InstanceClassFilter, CompiledInstanceClassFilter, AbstractFilter]]: ...
    def create_instance_context(self, class_context: Any, node: NodeOrLeaf) -> Any: ...

class TreeInstance(_BaseTreeInstance):
    _arguments: Any
    tree_node: Any
    def __init__(
        self,
        inference_state: Any,
        parent_context: Any,
        class_value: Any,
        arguments: Any,
    ) -> None: ...
    def _get_annotated_class_object(self) -> Any: ...
    def get_annotated_class_object(self) -> Any: ...
    def get_key_values(self) -> ValueSet: ...
    def py__simple_getitem__(self, index: Any) -> ValueSet: ...

class AnonymousInstance(_BaseTreeInstance):
    _arguments: Any = ...

class CompiledInstanceName(NameWrapper):
    def infer(self) -> ValueSet: ...

class CompiledInstanceClassFilter(AbstractFilter):
    _instance: Any
    _class_filter: Any
    def __init__(self, instance: Any, f: Any) -> None: ...
    def get(self, name: str) -> list[CompiledInstanceName]: ...
    def values(self) -> list[CompiledInstanceName]: ...
    def _convert(self, names: list[Any]) -> list[CompiledInstanceName]: ...

class BoundMethod(FunctionMixin, ValueWrapper):
    instance: Any
    _class_context: Any
    def __init__(self, instance: Any, class_context: Any, function: Any) -> None: ...
    def is_bound_method(self) -> bool: ...
    @property
    def name(self) -> FunctionNameInClass: ...
    def py__class__(self) -> Any: ...
    def _get_arguments(self, arguments: AbstractArguments) -> InstanceArguments: ...
    def _as_context(self, arguments: AbstractArguments = ...) -> Union[AnonymousMethodExecutionContext, MethodExecutionContext]: ...
    def py__call__(self, arguments: AbstractArguments) -> ValueSet: ...
    def get_signature_functions(self) -> list[BoundMethod]: ...
    def get_signatures(self) -> list[AbstractSignature]: ...

class CompiledBoundMethod(ValueWrapper):
    def is_bound_method(self) -> bool: ...
    def get_signatures(self) -> list[AbstractSignature]: ...

class SelfName(TreeNameDefinition):
    _instance: Any
    class_context: Any
    tree_name: Any
    def __init__(self, instance: Any, class_context: Any, tree_name: Any) -> None: ...
    @property
    def parent_context(self) -> Any: ...
    def get_defining_qualified_value(self) -> Any: ...
    def infer(self) -> ValueSet: ...

class LazyInstanceClassName(NameWrapper):
    _instance: Any
    def __init__(self, instance: Any, class_member_name: Any) -> None: ...
    def infer(self) -> ValueSet: ...
    def get_signatures(self) -> list[AbstractSignature]: ...
    def get_defining_qualified_value(self) -> Any: ...

class InstanceClassFilter(AbstractFilter):
    _instance: Any
    _class_filter: Any
    def __init__(self, instance: Any, class_filter: Any) -> None: ...
    def get(self, name: str) -> list[LazyInstanceClassName]: ...
    def values(self) -> list[LazyInstanceClassName]: ...
    def _convert(self, names: list[Any]) -> list[LazyInstanceClassName]: ...

class SelfAttributeFilter(ClassFilter):
    _instance: Any
    def __init__(
        self,
        instance: Any,
        instance_class: Any,
        node_context: Any,
        origin_scope: Any,
    ) -> None: ...
    def _filter(self, names: list[Any]) -> Iterator[Any]: ...
    def _filter_self_names(self, names: list[Any]) -> Iterator[Any]: ...
    def _is_in_right_scope(self, self_name: Any, name: Any) -> bool: ...
    def _convert_names(self, names: list[Any]) -> list[SelfName]: ...
    def _check_flows(self, names: list[Any]) -> list[Any]: ...

class InstanceArguments(TreeArgumentsWrapper):
    instance: Any
    def __init__(self, instance: Any, arguments: Any) -> None: ...
    def unpack(self, func: Any = ...) -> Iterator[tuple[Optional[str], LazyValue]]: ...
