from jedi.inference.context import ClassContext
from jedi.inference.gradual.generics import TupleGenericManager
from jedi.inference.gradual.type_var import TypeVar

_T = TypeVar("_T")

class _BoundTypeVarName(AbstractNameDefinition):
    parent_context: Any
    _type_var: Any
    _value_set: ValueSet
    
    def __init__(self, type_var: Any, value_set: ValueSet) -> None: ...
    def infer(self) -> ValueSet: ...
    def py__name__(self) -> str: ...
    def __repr__(self) -> str: ...

class _TypeVarFilter:
    _generics: Any
    _type_vars: Any
    
    def __init__(self, generics: Any, type_vars: Any) -> None: ...
    def get(self, name: str) -> list: ...
    def values(self) -> list: ...

class _AnnotatedClassContext(ClassContext):
    _value: Any
    
    def get_filters(self, *args: Any, **kwargs: Any) -> Iterator[Any]: ...

class DefineGenericBaseClass(LazyValueWrapper):
    _generics_manager: Any
    
    def __init__(self, generics_manager: Any) -> None: ...
    def _create_instance_with_generics(self, generics_manager: Any) -> Any: ...
    @inference_state_method_cache()
    def get_generics(self) -> Tuple[Any, ...]: ...
    def define_generics(self, type_var_dict: Any) -> ValueSet: ...
    def is_same_class(self, other: Any) -> bool: ...
    def get_signatures(self) -> list: ...
    def __repr__(self) -> str: ...

class GenericClass(DefineGenericBaseClass, ClassMixin):
    _class_value: Any
    
    def __init__(self, class_value: Any, generics_manager: Any) -> None: ...
    def _get_wrapped_value(self) -> Any: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...
    def get_type_var_filter(self) -> _TypeVarFilter: ...
    def py__call__(self, arguments: Any) -> ValueSet: ...
    def _as_context(self) -> _AnnotatedClassContext: ...
    @to_list
    def py__bases__(self) -> Iterator[Any]: ...
    def _create_instance_with_generics(self, generics_manager: Any) -> "GenericClass": ...
    def is_sub_class_of(self, class_value: Any) -> bool: ...
    def with_generics(self, generics_tuple: Any) -> Any: ...
    def infer_type_vars(self, value_set: ValueSet) -> dict: ...
    @classmethod
    def create_cached(cls, inference_state: Any, wrapped_value: Any, generics_manager: Any) -> "GenericClass": ...

class _LazyGenericBaseClass:
    _class_value: Any
    _lazy_base_class: Any
    _generics_manager: Any
    
    def __init__(self, class_value: Any, lazy_base_class: Any, generics_manager: Any) -> None: ...
    def infer(self) -> ValueSet: ...
    def _remap_type_vars(self, base: Any) -> Iterator[ValueSet]: ...
    def __repr__(self) -> str: ...

class _GenericInstanceWrapper(ValueWrapper):
    def py__stop_iteration_returns(self) -> ValueSet: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...

class _PseudoTreeNameClass(Value):
