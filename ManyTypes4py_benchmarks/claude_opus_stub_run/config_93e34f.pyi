from __future__ import annotations
import os
import sys
import json
from typing import Dict, Any, Optional, List, Union

from chalice.app import Chalice
from chalice.constants import DEFAULT_STAGE_NAME, DEFAULT_HANDLER_NAME

StrMap = Dict[str, Any]

class Config:
    chalice_stage: str
    function_name: str
    _user_provided_params: StrMap
    _config_from_disk: StrMap
    _default_params: StrMap
    _chalice_app: Optional[Chalice]
    _layers: Optional[Any]

    def __init__(
        self,
        chalice_stage: str = ...,
        function_name: str = ...,
        user_provided_params: Optional[StrMap] = ...,
        config_from_disk: Optional[StrMap] = ...,
        default_params: Optional[StrMap] = ...,
        layers: Optional[Any] = ...,
    ) -> None: ...

    @classmethod
    def create(
        cls,
        chalice_stage: str = ...,
        function_name: str = ...,
        **kwargs: Any,
    ) -> Config: ...

    @property
    def profile(self) -> Optional[str]: ...
    @property
    def app_name(self) -> Optional[str]: ...
    @property
    def project_dir(self) -> Optional[str]: ...
    @property
    def chalice_app(self) -> Chalice: ...
    @property
    def config_from_disk(self) -> StrMap: ...
    @property
    def lambda_python_version(self) -> str: ...
    @property
    def log_retention_in_days(self) -> Optional[int]: ...
    @property
    def layers(self) -> Optional[List[str]]: ...
    @property
    def api_gateway_custom_domain(self) -> Optional[StrMap]: ...
    @property
    def websocket_api_custom_domain(self) -> Optional[StrMap]: ...

    def _chain_lookup(
        self,
        name: str,
        varies_per_chalice_stage: bool = ...,
        varies_per_function: bool = ...,
    ) -> Any: ...

    def _chain_merge(self, name: str) -> StrMap: ...

    @property
    def config_file_version(self) -> str: ...
    @property
    def api_gateway_stage(self) -> Optional[str]: ...
    @property
    def api_gateway_endpoint_type(self) -> Optional[str]: ...
    @property
    def api_gateway_endpoint_vpce(self) -> Optional[List[str]]: ...
    @property
    def api_gateway_policy_file(self) -> Optional[str]: ...
    @property
    def minimum_compression_size(self) -> Optional[int]: ...
    @property
    def iam_policy_file(self) -> Optional[str]: ...
    @property
    def lambda_memory_size(self) -> Optional[int]: ...
    @property
    def lambda_timeout(self) -> Optional[int]: ...
    @property
    def automatic_layer(self) -> bool: ...
    @property
    def iam_role_arn(self) -> Optional[str]: ...
    @property
    def manage_iam_role(self) -> bool: ...
    @property
    def autogen_policy(self) -> Optional[bool]: ...
    @property
    def xray_enabled(self) -> Optional[bool]: ...
    @property
    def environment_variables(self) -> StrMap: ...
    @property
    def tags(self) -> Dict[str, str]: ...
    @property
    def security_group_ids(self) -> Optional[List[str]]: ...
    @property
    def subnet_ids(self) -> Optional[List[str]]: ...
    @property
    def reserved_concurrency(self) -> Optional[int]: ...

    def scope(self, chalice_stage: str, function_name: str) -> Config: ...
    def deployed_resources(self, chalice_stage_name: str) -> Optional[DeployedResources]: ...
    def _try_old_deployer_values(self, chalice_stage_name: str) -> DeployedResources: ...
    def _load_json_file(self, deployed_file: str) -> Optional[StrMap]: ...
    def _upgrade_deployed_values(self, chalice_stage_name: str, data: StrMap) -> DeployedResources: ...
    def _upgrade_lambda_functions(self, resources: List[StrMap], deployed: StrMap, prefix: str) -> None: ...
    def _upgrade_rest_api(self, resources: List[StrMap], deployed: StrMap) -> None: ...

class DeployedResources:
    _deployed_values: List[StrMap]
    _deployed_values_by_name: Dict[str, StrMap]

    def __init__(self, deployed_values: StrMap) -> None: ...

    @classmethod
    def empty(cls) -> DeployedResources: ...

    def resource_values(self, name: str) -> StrMap: ...
    def resource_names(self) -> List[str]: ...