from typing import Iterator, List, Optional, Tuple

from jedi.inference.base_value import ValueSet, NO_VALUES
from jedi.inference.cache import CachedMetaClass, inference_state_method_cache, inference_state_method_generator_cache
from jedi.inference.context import ClassContext
from jedi.inference.filters import ParserTreeFilter
from jedi.inference.lazy_value import LazyKnownValues, LazyTreeValue
from jedi.inference.names import TreeNameDefinition, ValueName
from jedi.inference.arguments import ValuesArguments
from jedi.inference.value.function import FunctionAndClassBase
from jedi.inference.gradual.generics import LazyGenericManager, TupleGenericManager


class ClassName(TreeNameDefinition):
    _apply_decorators: bool
    _class_value: ClassMixin

    def __init__(self, class_value: ClassMixin, tree_name: object, name_context: object, apply_decorators: bool) -> None: ...

    def infer(self) -> ValueSet: ...

    @property
    def api_type(self) -> str: ...


class ClassFilter(ParserTreeFilter):
    _class_value: ClassMixin
    _is_instance: bool

    def __init__(
        self,
        class_value: ClassMixin,
        node_context: object = ...,
        until_position: Optional[Tuple[int, int]] = ...,
        origin_scope: Optional[object] = ...,
        is_instance: bool = ...,
    ) -> None: ...

    def _convert_names(self, names: list) -> List[ClassName]: ...
    def _equals_origin_scope(self) -> bool: ...
    def _access_possible(self, name: object) -> bool: ...
    def _filter(self, names: list) -> list: ...


class ClassMixin:
    inference_state: object
    parent_context: object
    tree_node: object

    def is_class(self) -> bool: ...
    def is_class_mixin(self) -> bool: ...
    def py__call__(self, arguments: object) -> ValueSet: ...
    def py__class__(self) -> object: ...

    @property
    def name(self) -> ValueName: ...

    def py__name__(self) -> str: ...
    def py__mro__(self) -> Iterator[object]: ...
    def get_filters(
        self,
        origin_scope: Optional[object] = ...,
        is_instance: bool = ...,
        include_metaclasses: bool = ...,
        include_type_when_class: bool = ...,
    ) -> Iterator[object]: ...
    def get_signatures(self) -> list: ...
    def _as_context(self) -> ClassContext: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...
    def is_typeddict(self) -> bool: ...
    def py__getitem__(self, index_value_set: ValueSet, contextualized_node: object) -> ValueSet: ...
    def with_generics(self, generics_tuple: tuple) -> object: ...
    def define_generics(self, type_var_dict: dict) -> ValueSet: ...


class ClassValue(ClassMixin, FunctionAndClassBase, metaclass=CachedMetaClass):
    api_type: str

    def list_type_vars(self) -> list: ...
    def _get_bases_arguments(self) -> Optional[object]: ...
    def py__bases__(self) -> list: ...
    def get_metaclass_filters(self, metaclasses: object, is_instance: bool) -> list: ...
    def get_metaclasses(self) -> ValueSet: ...
    def get_metaclass_signatures(self, metaclasses: object) -> list: ...