from typing import Iterator, Optional, Sequence
from parso.python import tree as tree_module
from jedi.inference.cache import CachedMetaClass
from jedi.inference.names import AbstractNameDefinition, ValueName, NameWrapper, AnonymousParamName, ParamName
from jedi.inference.base_value import NO_VALUES, ValueSet, TreeValue, ValueWrapper
from jedi.inference.lazy_value import LazyKnownValues, LazyKnownValue, LazyTreeValue
from jedi.inference.context import ValueContext, TreeContextMixin
from jedi.inference.filters import ParserTreeFilter, FunctionExecutionFilter, AnonymousFunctionExecutionFilter
from jedi.inference.signature import TreeSignature


class LambdaName(AbstractNameDefinition):
    string_name: str
    api_type: str

    def __init__(self, lambda_value: FunctionMixin) -> None: ...

    @property
    def start_pos(self) -> tuple[int, int]: ...

    def infer(self) -> ValueSet: ...


class FunctionAndClassBase(TreeValue):
    def get_qualified_names(self) -> Optional[tuple[str, ...]]: ...


class FunctionMixin:
    api_type: str

    def get_filters(self, origin_scope: object = ...) -> Iterator[object]: ...
    def py__get__(self, instance: object, class_value: object) -> ValueSet: ...
    def get_param_names(self) -> list[AnonymousParamName]: ...

    @property
    def name(self) -> LambdaName | ValueName: ...

    def is_function(self) -> bool: ...
    def py__name__(self) -> str: ...
    def get_type_hint(self, add_class_info: bool = ...) -> Optional[str]: ...
    def py__call__(self, arguments: object) -> ValueSet: ...
    def _as_context(self, arguments: object = ...) -> BaseFunctionExecutionContext: ...
    def get_signatures(self) -> list[TreeSignature]: ...


class FunctionValue(FunctionMixin, FunctionAndClassBase, metaclass=CachedMetaClass):
    @classmethod
    def from_context(cls, context: object, tree_node: object) -> FunctionValue | OverloadedFunctionValue: ...
    def py__class__(self) -> object: ...
    def get_default_param_context(self) -> object: ...
    def get_signature_functions(self) -> list[FunctionValue]: ...


class FunctionNameInClass(NameWrapper):
    def __init__(self, class_context: object, name: object) -> None: ...
    def get_defining_qualified_value(self) -> object: ...


class MethodValue(FunctionValue):
    class_context: object

    def __init__(self, inference_state: object, class_context: object, *args: object, **kwargs: object) -> None: ...
    def get_default_param_context(self) -> object: ...
    def get_qualified_names(self) -> Optional[tuple[str, ...]]: ...

    @property
    def name(self) -> FunctionNameInClass: ...  # type: ignore[override]


class BaseFunctionExecutionContext(ValueContext, TreeContextMixin):
    def infer_annotations(self) -> ValueSet: ...
    def get_return_values(self, check_yields: bool = ...) -> ValueSet: ...
    def _get_yield_lazy_value(self, yield_expr: object) -> Iterator[LazyKnownValue | LazyTreeValue]: ...
    def get_yield_lazy_values(self, is_async: bool = ...) -> Iterator[object]: ...
    def merge_yield_values(self, is_async: bool = ...) -> ValueSet: ...
    def is_generator(self) -> bool: ...
    def infer(self) -> ValueSet: ...


class FunctionExecutionContext(BaseFunctionExecutionContext):
    _arguments: object

    def __init__(self, function_value: object, arguments: object) -> None: ...
    def get_filters(self, until_position: object = ..., origin_scope: object = ...) -> Iterator[FunctionExecutionFilter]: ...
    def infer_annotations(self) -> ValueSet: ...
    def get_param_names(self) -> list[ParamName]: ...


class AnonymousFunctionExecution(BaseFunctionExecutionContext):
    def infer_annotations(self) -> ValueSet: ...
    def get_filters(self, until_position: object = ..., origin_scope: object = ...) -> Iterator[AnonymousFunctionExecutionFilter]: ...
    def get_param_names(self) -> list[AnonymousParamName]: ...


class OverloadedFunctionValue(FunctionMixin, ValueWrapper):
    _overloaded_functions: list[FunctionValue]

    def __init__(self, function: FunctionValue, overloaded_functions: list[FunctionValue]) -> None: ...
    def py__call__(self, arguments: object) -> ValueSet: ...
    def get_signature_functions(self) -> list[FunctionValue]: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...


def _find_overload_functions(context: object, tree_node: object) -> Iterator[object]: ...