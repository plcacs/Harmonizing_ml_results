from __future__ import annotations

import re
from typing import TYPE_CHECKING, Literal

import numpy as np

from pandas._libs import lib
from pandas.core.strings.base import BaseStringArrayMethods

if TYPE_CHECKING:
    from collections.abc import Callable, Sequence

    from pandas._typing import NpDtype, Scalar


class ObjectStringArrayMixin(BaseStringArrayMethods):
    def __len__(self) -> int: ...
    def _str_map(
        self,
        f: Callable,
        na_value: Scalar = ...,
        dtype: NpDtype | None = ...,
        convert: bool = ...,
    ) -> np.ndarray: ...
    def _str_count(self, pat: str, flags: int = ...) -> np.ndarray: ...
    def _str_pad(
        self,
        width: int,
        side: Literal["left", "right", "both"] = ...,
        fillchar: str = ...,
    ) -> np.ndarray: ...
    def _str_contains(
        self,
        pat: str | re.Pattern,
        case: bool = ...,
        flags: int = ...,
        na: Scalar = ...,
        regex: bool = ...,
    ) -> np.ndarray: ...
    def _str_startswith(self, pat: str | tuple[str, ...], na: Scalar = ...) -> np.ndarray: ...
    def _str_endswith(self, pat: str | tuple[str, ...], na: Scalar = ...) -> np.ndarray: ...
    def _str_replace(
        self,
        pat: str | re.Pattern,
        repl: str | Callable,
        n: int = ...,
        case: bool = ...,
        flags: int = ...,
        regex: bool = ...,
    ) -> np.ndarray: ...
    def _str_repeat(self, repeats: int | Sequence[int]) -> np.ndarray: ...
    def _str_match(
        self,
        pat: str,
        case: bool = ...,
        flags: int = ...,
        na: Scalar = ...,
    ) -> np.ndarray: ...
    def _str_fullmatch(
        self,
        pat: str,
        case: bool = ...,
        flags: int = ...,
        na: Scalar = ...,
    ) -> np.ndarray: ...
    def _str_encode(self, encoding: str, errors: str = ...) -> np.ndarray: ...
    def _str_find(self, sub: str, start: int = ..., end: int | None = ...) -> np.ndarray: ...
    def _str_rfind(self, sub: str, start: int = ..., end: int | None = ...) -> np.ndarray: ...
    def _str_find_(
        self,
        sub: str,
        start: int,
        end: int | None,
        side: Literal["left", "right"],
    ) -> np.ndarray: ...
    def _str_findall(self, pat: str, flags: int = ...) -> np.ndarray: ...
    def _str_get(self, i: int | str) -> np.ndarray: ...
    def _str_index(self, sub: str, start: int = ..., end: int | None = ...) -> np.ndarray: ...
    def _str_rindex(self, sub: str, start: int = ..., end: int | None = ...) -> np.ndarray: ...
    def _str_join(self, sep: str) -> np.ndarray: ...
    def _str_partition(self, sep: str, expand: bool) -> np.ndarray: ...
    def _str_rpartition(self, sep: str, expand: bool) -> np.ndarray: ...
    def _str_len(self) -> np.ndarray: ...
    def _str_slice(
        self,
        start: int | None = ...,
        stop: int | None = ...,
        step: int | None = ...,
    ) -> np.ndarray: ...
    def _str_slice_replace(
        self,
        start: int | None = ...,
        stop: int | None = ...,
        repl: str | None = ...,
    ) -> np.ndarray: ...
    def _str_split(
        self,
        pat: str | re.Pattern | None = ...,
        n: int | None = ...,
        expand: bool = ...,
        regex: bool | None = ...,
    ) -> np.ndarray: ...
    def _str_rsplit(self, pat: str | None = ..., n: int | None = ...) -> np.ndarray: ...
    def _str_translate(self, table: dict[int, str | int | None]) -> np.ndarray: ...
    def _str_wrap(self, width: int, **kwargs: object) -> np.ndarray: ...
    def _str_get_dummies(
        self, sep: str = ..., dtype: NpDtype | None = ...
    ) -> tuple[np.ndarray, list[str]]: ...
    def _str_upper(self) -> np.ndarray: ...
    def _str_isalnum(self) -> np.ndarray: ...
    def _str_isalpha(self) -> np.ndarray: ...
    def _str_isascii(self) -> np.ndarray: ...
    def _str_isdecimal(self) -> np.ndarray: ...
    def _str_isdigit(self) -> np.ndarray: ...
    def _str_islower(self) -> np.ndarray: ...
    def _str_isnumeric(self) -> np.ndarray: ...
    def _str_isspace(self) -> np.ndarray: ...
    def _str_istitle(self) -> np.ndarray: ...
    def _str_isupper(self) -> np.ndarray: ...
    def _str_capitalize(self) -> np.ndarray: ...
    def _str_casefold(self) -> np.ndarray: ...
    def _str_title(self) -> np.ndarray: ...
    def _str_swapcase(self) -> np.ndarray: ...
    def _str_lower(self) -> np.ndarray: ...
    def _str_normalize(self, form: str) -> np.ndarray: ...
    def _str_strip(self, to_strip: str | None = ...) -> np.ndarray: ...
    def _str_lstrip(self, to_strip: str | None = ...) -> np.ndarray: ...
    def _str_rstrip(self, to_strip: str | None = ...) -> np.ndarray: ...
    def _str_removeprefix(self, prefix: str) -> np.ndarray: ...
    def _str_removesuffix(self, suffix: str) -> np.ndarray: ...
    def _str_extract(
        self, pat: str, flags: int = ..., expand: bool = ...
    ) -> np.ndarray | list[list[Scalar]]: ...