from typing import Iterator, Optional, Sequence
from abc import abstractproperty

from parso.python.tree import Name as TreeName, Module

from jedi.inference.base_value import Value, ValueSet, NO_VALUES, ValueWrapper
from jedi.inference.lazy_value import LazyKnownValue, LazyKnownValues
from jedi.inference.names import ValueName, TreeNameDefinition, ParamName, NameWrapper
from jedi.inference.filters import AbstractFilter, AnonymousFunctionExecutionFilter
from jedi.inference.compiled.value import CompiledValueFilter
from jedi.inference.value.function import (
    FunctionValue,
    FunctionMixin,
    OverloadedFunctionValue,
    BaseFunctionExecutionContext,
    FunctionExecutionContext,
    FunctionNameInClass,
)
from jedi.inference.value.klass import ClassFilter
from jedi.inference.arguments import ValuesArguments, TreeArgumentsWrapper
from jedi.inference.context import AbstractContext


class InstanceExecutedParamName(ParamName):
    _instance: Value

    def __init__(self, instance: Value, function_value: FunctionValue, tree_name: TreeName) -> None: ...
    def infer(self) -> ValueSet: ...
    def matches_signature(self) -> bool: ...


class AnonymousMethodExecutionFilter(AnonymousFunctionExecutionFilter):
    _instance: AbstractInstanceValue

    def __init__(self, instance: AbstractInstanceValue, *args: object, **kwargs: object) -> None: ...
    def _convert_param(self, param: object, name: TreeName) -> ParamName: ...


class AnonymousMethodExecutionContext(BaseFunctionExecutionContext):
    instance: AbstractInstanceValue

    def __init__(self, instance: AbstractInstanceValue, value: BoundMethod) -> None: ...
    def get_filters(self, until_position: Optional[tuple[int, int]] = ..., origin_scope: Optional[object] = ...) -> Iterator[AnonymousMethodExecutionFilter]: ...
    def get_param_names(self) -> list[ParamName]: ...


class MethodExecutionContext(FunctionExecutionContext):
    instance: AbstractInstanceValue

    def __init__(self, instance: AbstractInstanceValue, *args: object, **kwargs: object) -> None: ...


class AbstractInstanceValue(Value):
    api_type: str
    class_value: Value

    def __init__(self, inference_state: object, parent_context: object, class_value: Value) -> None: ...
    def is_instance(self) -> bool: ...
    def get_qualified_names(self) -> Optional[tuple[str, ...]]: ...
    def get_annotated_class_object(self) -> Value: ...
    def py__class__(self) -> Value: ...
    def py__bool__(self) -> Optional[bool]: ...

    @abstractproperty
    def name(self) -> object: ...

    def get_signatures(self) -> list[object]: ...
    def get_function_slot_names(self, name: str) -> list[object]: ...
    def execute_function_slots(self, names: object, *inferred_args: object) -> ValueSet: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...
    def py__getitem__(self, index_value_set: ValueSet, contextualized_node: object) -> ValueSet: ...
    def py__iter__(self, contextualized_node: Optional[object] = ...) -> Iterator[object]: ...
    def __repr__(self) -> str: ...


class CompiledInstance(AbstractInstanceValue):
    _arguments: object

    def __init__(self, inference_state: object, parent_context: object, class_value: Value, arguments: object) -> None: ...
    def get_filters(self, origin_scope: Optional[object] = ..., include_self_names: bool = ...) -> Iterator[CompiledInstanceClassFilter]: ...

    @property
    def name(self) -> object: ...

    def is_stub(self) -> bool: ...


class _BaseTreeInstance(AbstractInstanceValue):
    @property
    def array_type(self) -> Optional[str]: ...

    @property
    def name(self) -> ValueName: ...

    def get_filters(self, origin_scope: Optional[object] = ..., include_self_names: bool = ...) -> Iterator[object]: ...
    def create_instance_context(self, class_context: object, node: object) -> object: ...
    def py__getattribute__alternatives(self, string_name: str) -> ValueSet: ...
    def py__next__(self, contextualized_node: Optional[object] = ...) -> Iterator[LazyKnownValues]: ...
    def py__call__(self, arguments: object) -> ValueSet: ...
    def py__get__(self, instance: Optional[Value], class_value: Value) -> ValueSet: ...


class TreeInstance(_BaseTreeInstance):
    _arguments: object
    tree_node: object

    def __init__(self, inference_state: object, parent_context: object, class_value: Value, arguments: object) -> None: ...
    def _get_annotated_class_object(self) -> Optional[Value]: ...
    def get_annotated_class_object(self) -> Value: ...
    def get_key_values(self) -> ValueSet: ...
    def py__simple_getitem__(self, index: object) -> ValueSet: ...
    def __repr__(self) -> str: ...


class AnonymousInstance(_BaseTreeInstance):
    _arguments: None


class CompiledInstanceName(NameWrapper):
    def infer(self) -> ValueSet: ...


class CompiledInstanceClassFilter(AbstractFilter):
    _instance: AbstractInstanceValue
    _class_filter: object

    def __init__(self, instance: AbstractInstanceValue, f: object) -> None: ...
    def get(self, name: str) -> list[CompiledInstanceName]: ...
    def values(self) -> list[CompiledInstanceName]: ...
    def _convert(self, names: object) -> list[CompiledInstanceName]: ...


class BoundMethod(FunctionMixin, ValueWrapper):
    instance: AbstractInstanceValue
    _class_context: object

    def __init__(self, instance: AbstractInstanceValue, class_context: object, function: object) -> None: ...
    def is_bound_method(self) -> bool: ...

    @property
    def name(self) -> FunctionNameInClass: ...

    def py__class__(self) -> Value: ...
    def _get_arguments(self, arguments: object) -> InstanceArguments: ...
    def _as_context(self, arguments: Optional[object] = ...) -> object: ...
    def py__call__(self, arguments: object) -> ValueSet: ...
    def get_signature_functions(self) -> list[BoundMethod]: ...
    def get_signatures(self) -> list[object]: ...
    def __repr__(self) -> str: ...


class CompiledBoundMethod(ValueWrapper):
    def is_bound_method(self) -> bool: ...
    def get_signatures(self) -> list[object]: ...


class SelfName(TreeNameDefinition):
    _instance: _BaseTreeInstance
    class_context: object
    tree_name: TreeName

    def __init__(self, instance: _BaseTreeInstance, class_context: object, tree_name: TreeName) -> None: ...

    @property
    def parent_context(self) -> object: ...

    def get_defining_qualified_value(self) -> _BaseTreeInstance: ...
    def infer(self) -> ValueSet: ...


class LazyInstanceClassName(NameWrapper):
    _instance: AbstractInstanceValue

    def __init__(self, instance: AbstractInstanceValue, class_member_name: object) -> None: ...
    def infer(self) -> ValueSet: ...
    def get_signatures(self) -> list[object]: ...
    def get_defining_qualified_value(self) -> AbstractInstanceValue: ...


class InstanceClassFilter(AbstractFilter):
    _instance: AbstractInstanceValue
    _class_filter: ClassFilter

    def __init__(self, instance: AbstractInstanceValue, class_filter: ClassFilter) -> None: ...
    def get(self, name: str) -> list[LazyInstanceClassName]: ...
    def values(self) -> list[LazyInstanceClassName]: ...
    def _convert(self, names: object) -> list[LazyInstanceClassName]: ...
    def __repr__(self) -> str: ...


class SelfAttributeFilter(ClassFilter):
    _instance: _BaseTreeInstance

    def __init__(self, instance: _BaseTreeInstance, instance_class: Value, node_context: object, origin_scope: Optional[object]) -> None: ...
    def _filter(self, names: list[object]) -> Iterator[object]: ...
    def _filter_self_names(self, names: list[object]) -> Iterator[object]: ...
    def _is_in_right_scope(self, self_name: object, name: object) -> bool: ...
    def _convert_names(self, names: object) -> list[SelfName]: ...
    def _check_flows(self, names: object) -> object: ...


class InstanceArguments(TreeArgumentsWrapper):
    instance: AbstractInstanceValue

    def __init__(self, instance: AbstractInstanceValue, arguments: object) -> None: ...
    def unpack(self, func: Optional[object] = ...) -> Iterator[tuple[Optional[str], object]]: ...