class WindowedKeysView(KeysView):
    _mapping: WindowWrapperT
    event: Optional[EventT]

    def __init__(self, mapping: WindowWrapperT, event: Optional[EventT] = ...) -> None: ...
    def __iter__(self) -> Iterator[Any]: ...
    def __len__(self) -> int: ...
    def now(self) -> Iterator[Any]: ...
    def current(self, event: Optional[EventT] = ...) -> Iterator[Any]: ...
    def delta(self, d: Seconds, event: Optional[EventT] = ...) -> Iterator[Any]: ...

class WindowedItemsView(WindowedItemsViewT):
    _mapping: WindowWrapperT
    event: Optional[EventT]

    def __init__(self, mapping: WindowWrapperT, event: Optional[EventT] = ...) -> None: ...
    def __iter__(self) -> Iterator[Tuple[Any, Any]]: ...
    def now(self) -> Iterator[Tuple[Any, Any]]: ...
    def current(self, event: Optional[EventT] = ...) -> Iterator[Tuple[Any, Any]]: ...
    def delta(self, d: Seconds, event: Optional[EventT] = ...) -> Iterator[Tuple[Any, Any]]: ...

class WindowedValuesView(WindowedValuesViewT):
