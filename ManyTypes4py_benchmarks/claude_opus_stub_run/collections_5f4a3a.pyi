import copy
from collections.abc import Iterable
from typing import Any, Callable, overload

from hypothesis.internal.conjecture.utils import combine_labels
from hypothesis.strategies._internal.strategies import (
    Ex,
    MappedStrategy,
    SearchStrategy,
    T,
    T3,
    T4,
    T5,
    filter_not_satisfied,
)

class TupleStrategy(SearchStrategy):
    element_strategies: tuple[SearchStrategy, ...]

    def __init__(self, strategies: Iterable[SearchStrategy]) -> None: ...
    def do_validate(self) -> None: ...
    def calc_label(self) -> int: ...
    def __repr__(self) -> str: ...
    def calc_has_reusable_values(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def do_draw(self, data: Any) -> tuple[Any, ...]: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...

@overload
def tuples() -> SearchStrategy[tuple[()]]: ...
@overload
def tuples(__a1: SearchStrategy[Ex]) -> SearchStrategy[tuple[Ex]]: ...
@overload
def tuples(__a1: SearchStrategy[Ex], __a2: SearchStrategy[T]) -> SearchStrategy[tuple[Ex, T]]: ...
@overload
def tuples(__a1: SearchStrategy[Ex], __a2: SearchStrategy[T], __a3: SearchStrategy[T3]) -> SearchStrategy[tuple[Ex, T, T3]]: ...
@overload
def tuples(__a1: SearchStrategy[Ex], __a2: SearchStrategy[T], __a3: SearchStrategy[T3], __a4: SearchStrategy[T4]) -> SearchStrategy[tuple[Ex, T, T3, T4]]: ...
@overload
def tuples(__a1: SearchStrategy[Ex], __a2: SearchStrategy[T], __a3: SearchStrategy[T3], __a4: SearchStrategy[T4], __a5: SearchStrategy[T5]) -> SearchStrategy[tuple[Ex, T, T3, T4, T5]]: ...
@overload
def tuples(*args: SearchStrategy[Any]) -> SearchStrategy[tuple[Any, ...]]: ...
def tuples(*args: SearchStrategy[Any]) -> SearchStrategy[tuple[Any, ...]]: ...

class ListStrategy(SearchStrategy):
    _nonempty_filters: tuple[type, ...]
    min_size: int
    max_size: float
    average_size: float
    element_strategy: SearchStrategy

    def __init__(self, elements: SearchStrategy, min_size: int = ..., max_size: float = ...) -> None: ...
    def calc_label(self) -> int: ...
    def do_validate(self) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def do_draw(self, data: Any) -> list[Any]: ...
    def __repr__(self) -> str: ...
    def filter(self, condition: Callable[[Any], Any]) -> SearchStrategy: ...

class UniqueListStrategy(ListStrategy):
    keys: Any
    tuple_suffixes: Any

    def __init__(self, elements: SearchStrategy, min_size: int, max_size: float, keys: Any, tuple_suffixes: Any) -> None: ...
    def do_draw(self, data: Any) -> list[Any]: ...

class UniqueSampledListStrategy(UniqueListStrategy):
    def do_draw(self, data: Any) -> list[Any]: ...

class FixedKeysDictStrategy(MappedStrategy):
    keys: tuple[Any, ...]

    def __init__(self, strategy_dict: dict[Any, SearchStrategy]) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def __repr__(self) -> str: ...

class FixedAndOptionalKeysDictStrategy(SearchStrategy):
    required: dict[Any, SearchStrategy]
    fixed: FixedKeysDictStrategy
    optional: dict[Any, SearchStrategy]

    def __init__(self, strategy_dict: dict[Any, SearchStrategy], optional: dict[Any, SearchStrategy]) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def __repr__(self) -> str: ...
    def do_draw(self, data: Any) -> dict[Any, Any]: ...