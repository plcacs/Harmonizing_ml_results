from typing import Any, Dict, Generator as TypingGenerator, Iterator, List, Optional, Sequence as TypingSequence, Tuple, Union

from jedi.inference.base_value import ValueSet, Value, ContextualizedNode, LazyValueWrapper
from jedi.inference.filters import LazyAttributeOverwrite
from jedi.inference.lazy_value import LazyKnownValue, LazyKnownValues, LazyTreeValue
from jedi.inference.compiled import CompiledValueName
from jedi.inference.context import CompForContext


class IterableMixin:
    inference_state: Any
    def py__next__(self, contextualized_node: Optional[ContextualizedNode] = ...) -> Any: ...
    def py__stop_iteration_returns(self) -> ValueSet: ...
    get_safe_value: Any


class GeneratorBase(LazyAttributeOverwrite, IterableMixin):
    array_type: None
    def _get_wrapped_value(self) -> Any: ...
    def _get_cls(self) -> Any: ...
    def py__bool__(self) -> bool: ...
    def _iter(self, arguments: Any) -> ValueSet: ...
    def _next(self, arguments: Any) -> ValueSet: ...
    def py__stop_iteration_returns(self) -> ValueSet: ...
    @property
    def name(self) -> CompiledValueName: ...
    def get_annotated_class_object(self) -> Any: ...


class Generator(GeneratorBase):
    _func_execution_context: Any
    def __init__(self, inference_state: Any, func_execution_context: Any) -> None: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = ...) -> Any: ...
    def py__stop_iteration_returns(self) -> ValueSet: ...
    def __repr__(self) -> str: ...


def comprehension_from_atom(inference_state: Any, value: Any, atom: Any) -> Union[DictComprehension, SetComprehension, GeneratorComprehension, ListComprehension]: ...


class ComprehensionMixin:
    _defining_context: Any
    _sync_comp_for_node: Any
    _entry_node: Any
    _value_node: Any
    array_type: str

    def _get_comp_for_context(self, parent_context: Any, comp_for: Any) -> CompForContext: ...
    def _nested(self, comp_fors: TypingSequence[Any], parent_context: Optional[Any] = ...) -> TypingGenerator[Any, None, None]: ...
    def _iterate(self) -> List[Any]: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = ...) -> TypingGenerator[LazyKnownValues, None, None]: ...
    def __repr__(self) -> str: ...


class _DictMixin:
    def _get_generics(self) -> Tuple[ValueSet, ...]: ...


class Sequence(LazyAttributeOverwrite, IterableMixin):
    api_type: str
    array_type: str

    @property
    def name(self) -> CompiledValueName: ...
    def _get_generics(self) -> Tuple[ValueSet, ...]: ...
    def _cached_generics(self) -> Tuple[ValueSet, ...]: ...
    def _get_wrapped_value(self) -> Any: ...
    def py__bool__(self) -> None: ...
    @property
    def parent(self) -> Any: ...
    def py__getitem__(self, index_value_set: Any, contextualized_node: Any) -> ValueSet: ...


class _BaseComprehension(ComprehensionMixin):
    _defining_context: Any
    _sync_comp_for_node: Any
    _entry_node: Any
    def __init__(self, inference_state: Any, defining_context: Any, sync_comp_for_node: Any, entry_node: Any) -> None: ...


class ListComprehension(_BaseComprehension, Sequence):
    array_type: str
    def py__simple_getitem__(self, index: Union[int, slice]) -> ValueSet: ...


class SetComprehension(_BaseComprehension, Sequence):
    array_type: str


class GeneratorComprehension(_BaseComprehension, GeneratorBase): ...


class _DictKeyMixin:
    def get_mapping_item_values(self) -> Tuple[ValueSet, ValueSet]: ...
    def get_key_values(self) -> ValueSet: ...


class DictComprehension(ComprehensionMixin, Sequence, _DictKeyMixin):
    array_type: str
    _defining_context: Any
    _sync_comp_for_node: Any
    _entry_node: Any
    _value_node: Any

    def __init__(self, inference_state: Any, defining_context: Any, sync_comp_for_node: Any, key_node: Any, value_node: Any) -> None: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = ...) -> TypingGenerator[LazyKnownValues, None, None]: ...
    def py__simple_getitem__(self, index: Any) -> ValueSet: ...
    def _dict_keys(self) -> ValueSet: ...
    def _dict_values(self) -> ValueSet: ...
    def _imitate_values(self, arguments: Any) -> ValueSet: ...
    def _imitate_items(self, arguments: Any) -> ValueSet: ...
    def exact_key_items(self) -> List[Any]: ...


class SequenceLiteralValue(Sequence):
    _TUPLE_LIKE: Tuple[str, ...]
    mapping: Dict[str, str]
    atom: Any
    _defining_context: Any
    array_type: str

    def __init__(self, inference_state: Any, defining_context: Any, atom: Any) -> None: ...
    def _get_generics(self) -> Tuple[ValueSet, ...]: ...
    def py__simple_getitem__(self, index: Union[int, str, slice]) -> ValueSet: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = ...) -> TypingGenerator[Union[LazyKnownValue, LazyTreeValue], None, None]: ...
    def py__len__(self) -> int: ...
    def get_tree_entries(self) -> List[Any]: ...
    def __repr__(self) -> str: ...


class DictLiteralValue(_DictMixin, SequenceLiteralValue, _DictKeyMixin):
    array_type: str
    _defining_context: Any
    atom: Any

    def __init__(self, inference_state: Any, defining_context: Any, atom: Any) -> None: ...
    def py__simple_getitem__(self, index: Any) -> ValueSet: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = ...) -> TypingGenerator[LazyKnownValues, None, None]: ...
    def _imitate_values(self, arguments: Any) -> ValueSet: ...
    def _imitate_items(self, arguments: Any) -> ValueSet: ...
    def exact_key_items(self) -> TypingGenerator[Tuple[str, LazyTreeValue], None, None]: ...
    def _dict_values(self) -> ValueSet: ...
    def _dict_keys(self) -> ValueSet: ...


class _FakeSequence(Sequence):
    _lazy_value_list: List[Any]

    def __init__(self, inference_state: Any, lazy_value_list: List[Any]) -> None: ...
    def py__simple_getitem__(self, index: Union[int, slice]) -> ValueSet: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = ...) -> List[Any]: ...
    def py__bool__(self) -> bool: ...
    def __repr__(self) -> str: ...


class FakeTuple(_FakeSequence):
    array_type: str


class FakeList(_FakeSequence):
    array_type: str


class FakeDict(_DictMixin, Sequence, _DictKeyMixin):
    array_type: str
    _dct: Dict[Any, Any]

    def __init__(self, inference_state: Any, dct: Dict[Any, Any]) -> None: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = ...) -> TypingGenerator[LazyKnownValue, None, None]: ...
    def py__simple_getitem__(self, index: Any) -> ValueSet: ...
    def _values(self, arguments: Any) -> ValueSet: ...
    def _dict_values(self) -> ValueSet: ...
    def _dict_keys(self) -> ValueSet: ...
    def exact_key_items(self) -> Any: ...
    def __repr__(self) -> str: ...


class MergedArray(Sequence):
    array_type: str
    _arrays: List[Any]

    def __init__(self, inference_state: Any, arrays: List[Any]) -> None: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = ...) -> TypingGenerator[Any, None, None]: ...
    def py__simple_getitem__(self, index: Any) -> ValueSet: ...


def unpack_tuple_to_dict(context: Any, types: ValueSet, exprlist: Any) -> Dict[str, ValueSet]: ...


class Slice(LazyValueWrapper):
    inference_state: Any
    _context: Any
    _start: Any
    _stop: Any
    _step: Any

    def __init__(self, python_context: Any, start: Any, stop: Any, step: Any) -> None: ...
    def _get_wrapped_value(self) -> Any: ...
    def get_safe_value(self, default: Any = ...) -> slice: ...