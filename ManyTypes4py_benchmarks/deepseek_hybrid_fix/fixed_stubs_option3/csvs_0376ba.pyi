_DEFAULT_CHUNKSIZE_CELLS: int = 100000

class CSVFormatter:
    def __init__(
        self,
        formatter: DataFrameFormatter,
        path_or_buf: Union[str, WriteBuffer[str]] = ...,
        sep: str = ...,
        cols: Optional[Union[Sequence[Hashable], ABCIndex]] = ...,
        index_label: Union[bool, str, Sequence[str], None] = ...,
        mode: str = ...,
        encoding: Optional[str] = ...,
        errors: str = ...,
        compression: CompressionOptions = ...,
        quoting: Optional[int] = ...,
        lineterminator: Optional[str] = ...,
        chunksize: Optional[int] = ...,
        quotechar: str = ...,
        date_format: Optional[str] = ...,
        doublequote: bool = ...,
        escapechar: Optional[str] = ...,
        storage_options: Optional[StorageOptions] = ...,
    ) -> None: ...
    @property
    def na_rep(self) -> Union[str, None]: ...
    @property
    def float_format(self) -> Optional[FloatFormatType]: ...
    @property
    def decimal(self) -> str: ...
    @property
    def header(self) -> Union[bool, Sequence[Hashable]]: ...
    @property
    def index(self) -> bool: ...
    def _initialize_index_label(self, index_label: Union[bool, str, Sequence[str], None]) -> Union[bool, Sequence[str], None]: ...
    def _get_index_label_from_obj(self) -> Union[Sequence[str], None]: ...
    def _get_index_label_multiindex(self) -> list[str]: ...
    def _get_index_label_flat(self) -> list[str]: ...
    def _initialize_quotechar(self, quotechar: str) -> Optional[str]: ...
    @property
    def has_mi_columns(self) -> bool: ...
    def _initialize_columns(self, cols: Optional[Union[Sequence[Hashable], ABCIndex]]) -> Sequence[Hashable]: ...
    def _initialize_chunksize(self, chunksize: Optional[int]) -> int: ...
    @property
    def _number_format(self) -> dict[str, Any]: ...
    @cache_readonly
    def data_index(self) -> Union[Index, ABCMultiIndex]: ...
    @property
    def nlevels(self) -> int: ...
    @property
    def _has_aliases(self) -> bool: ...
    @property
    def _need_to_save_header(self) -> bool: ...
    @property
    def write_cols(self) -> SequenceNotStr[Hashable]: ...
    @property
    def encoded_labels(self) -> Sequence[Hashable]: ...
    def save(self) -> None: ...
    def _save(self) -> None: ...
    def _save_header(self) -> None: ...
    def _generate_multiindex_header_rows(self) -> Iterator[Sequence[Hashable]]: ...
    def _save_body(self) -> None: ...
    def _save_chunk(self, start_i: int, end_i: int) -> None: ...