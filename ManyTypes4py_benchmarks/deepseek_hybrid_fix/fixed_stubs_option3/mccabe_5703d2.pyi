from __future__ import annotations
import optparse
import sys
import tokenize
from collections import defaultdict
from typing import Any, Dict, Generator, List, Optional, Tuple
import ast
from ast import iter_child_nodes

__version__: str

class ASTVisitor:
    node: Any
    _cache: Dict[Any, Any]
    visitor: Any

    def __init__(self) -> None: ...
    def default(self, node: ast.AST, *args: Any) -> None: ...
    def dispatch(self, node: ast.AST, *args: Any) -> Any: ...
    def preorder(self, tree: ast.AST, visitor: Any, *args: Any) -> None: ...

class PathNode:
    name: str
    look: str

    def __init__(self, name: str, look: str = ...) -> None: ...
    def to_dot(self) -> None: ...
    def dot_id(self) -> int: ...

class PathGraph:
    name: str
    entity: str
    lineno: int
    column: int
    nodes: Dict[Any, list[Any]]

    def __init__(self, name: str, entity: str, lineno: int, column: int = ...) -> None: ...
    def connect(self, n1: PathNode, n2: PathNode) -> None: ...
    def to_dot(self) -> None: ...
    def complexity(self) -> int: ...

class PathGraphingAstVisitor(ASTVisitor):
    classname: str
    graphs: Dict[str, PathGraph]
    graph: Any
    tail: Any

    def __init__(self) -> None: ...
    def reset(self) -> None: ...
    def dispatch_list(self, node_list: list[ast.AST]) -> None: ...
    def visitFunctionDef(self, node: ast.FunctionDef) -> None: ...
    visitAsyncFunctionDef: Any
    def visitClassDef(self, node: ast.ClassDef) -> None: ...
    def appendPathNode(self, name: str) -> Any: ...
    def visitSimpleStatement(self, node: ast.stmt) -> None: ...
    def default(self, node: ast.AST, *args: Any) -> None: ...
    def visitLoop(self, node: Any) -> None: ...
    visitAsyncFor: Any
    visitFor: Any
    visitWhile: Any
    def visitIf(self, node: ast.If) -> None: ...
    def _subgraph(self, node: Any, name: str, extra_blocks: Any = ...) -> None: ...
    def _subgraph_parse(self, node: Any, pathnode: Any, extra_blocks: Any) -> None: ...
    def visitTryExcept(self, node: Any) -> None: ...
    visitTry: Any
    def visitWith(self, node: Any) -> None: ...
    visitAsyncWith: Any

class McCabeChecker:
    name: str
    version: str
    _code: str
    _error_tmpl: str
    max_complexity: int
    tree: ast.AST

    def __init__(self, tree: ast.AST, filename: str) -> None: ...
    @classmethod
    def add_options(cls, parser: Any) -> None: ...
    @classmethod
    def parse_options(cls, options: Any) -> None: ...
    def run(self) -> Generator[Tuple[int, int, str, type], None, None]: ...

def get_code_complexity(code: str, threshold: int = ..., filename: str = ...) -> int: ...
def get_module_complexity(module_path: str, threshold: int = ...) -> int: ...
def _read(filename: str) -> str: ...
def main(argv: Optional[List[str]] = ...) -> None: ...