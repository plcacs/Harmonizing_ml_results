from typing import Any, Awaitable, Dict, List, Optional, Set
from types import SimpleNamespace
from pyee import EventEmitter
from pyppeteer.connection import CDPSession
from pyppeteer.errors import NetworkError
from pyppeteer.frame_manager import FrameManager, Frame
from pyppeteer.helper import debugError
from pyppeteer.multimap import Multimap

CredentialsDict = Dict[str, str]
EventDict = Dict[str, Any]
RequestPayload = Dict[str, Any]
ContinueOverrides = Dict[str, Any]
ResponseOverrides = Dict[str, Any]

class NetworkManager(EventEmitter):
    Events: SimpleNamespace
    def __init__(self, client: CDPSession, frameManager: FrameManager) -> None: ...
    async def authenticate(self, credentials: CredentialsDict) -> None: ...
    async def setExtraHTTPHeaders(self, extraHTTPHeaders: Dict[str, str]) -> None: ...
    def extraHTTPHeaders(self) -> Dict[str, str]: ...
    async def setOfflineMode(self, value: bool) -> None: ...
    async def setUserAgent(self, userAgent: str) -> None: ...
    async def setRequestInterception(self, value: bool) -> None: ...
    async def _updateProtocolRequestInterception(self) -> None: ...
    async def _onRequestWillBeSent(self, event: EventDict) -> None: ...
    async def _send(self, method: str, msg: Dict[str, Any]) -> None: ...
    def _onRequestIntercepted(self, event: EventDict) -> None: ...
    def _onRequest(self, event: EventDict, interceptionId: Optional[str]) -> None: ...
    def _onRequestServedFromCache(self, event: EventDict) -> None: ...
    def _handleRequestRedirect(self, request: 'Request', redirectStatus: int, redirectHeaders: Dict[str, str], fromDiskCache: bool, fromServiceWorker: bool, securityDetails: Optional[Dict[str, Any]] = ...) -> None: ...
    def _handleRequestStart(self, requestId: str, interceptionId: Optional[str], url: str, isNavigationRequest: bool, resourceType: str, requestPayload: RequestPayload, frameId: Optional[str], redirectChain: List['Request']) -> None: ...
    def _onResponseReceived(self, event: EventDict) -> None: ...
    def _onLoadingFinished(self, event: EventDict) -> None: ...
    def _onLoadingFailed(self, event: EventDict) -> None: ...

class Request:
    def __init__(self, client: CDPSession, requestId: str, interceptionId: Optional[str], isNavigationRequest: bool, allowInterception: bool, url: str, resourceType: str, payload: RequestPayload, frame: Optional[Frame], redirectChain: List['Request']) -> None: ...
    @property
    def url(self) -> str: ...
    @property
    def resourceType(self) -> str: ...
    @property
    def method(self) -> str: ...
    @property
    def postData(self) -> Optional[str]: ...
    @property
    def headers(self) -> Dict[str, str]: ...
    @property
    def response(self) -> Optional['Response']: ...
    @property
    def frame(self) -> Optional[Frame]: ...
    def isNavigationRequest(self) -> bool: ...
    @property
    def redirectChain(self) -> List['Request']: ...
    def failure(self) -> Optional[Dict[str, str]]: ...
    async def continue_(self, overrides: Optional[ContinueOverrides] = ...) -> None: ...
    async def respond(self, response: ResponseOverrides) -> None: ...
    async def abort(self, errorCode: str = ...) -> None: ...

class Response:
    def __init__(self, client: CDPSession, request: Request, status: int, headers: Dict[str, str], fromDiskCache: bool, fromServiceWorker: bool, securityDetails: Optional[Dict[str, Any]] = ...) -> None: ...
    def _bodyLoadedPromiseFulfill(self, value: Any) -> None: ...
    @property
    def url(self) -> str: ...
    @property
    def ok(self) -> bool: ...
    @property
    def status(self) -> int: ...
    @property
    def headers(self) -> Dict[str, str]: ...
    @property
    def securityDetails(self) -> Optional['SecurityDetails']: ...
    async def _bufread(self) -> bytes: ...
    def buffer(self) -> Awaitable[bytes]: ...
    async def text(self) -> str: ...
    async def json(self) -> Any: ...
    @property
    def request(self) -> Request: ...
    @property
    def fromCache(self) -> bool: ...
    @property
    def fromServiceWorker(self) -> bool: ...

def generateRequestHash(request: Dict[str, Any]) -> str: ...

class SecurityDetails:
    def __init__(self, subjectName: str, issuer: str, validFrom: float, validTo: float, protocol: str) -> None: ...
    @property
    def subjectName(self) -> str: ...
    @property
    def issuer(self) -> str: ...
    @property
    def validFrom(self) -> float: ...
    @property
    def validTo(self) -> float: ...
    @property
    def protocol(self) -> str: ...

errorReasons: Dict[str, str]
statusTexts: Dict[str, str]