from __future__ import annotations
from typing import final, Any, Callable, Literal, Type, TypeVar
import numpy as np
import pandas as pd
import pandas._testing as tm
from pandas.core import ops

from typing import Callable
_ComparisonOp = Callable[[Any, Any], Any]

class BaseOpsUtil:
    series_scalar_exc: Type[Exception]
    frame_scalar_exc: Type[Exception]
    series_array_exc: Type[Exception]
    divmod_exc: Type[Exception]
    def _get_expected_exception(self, op_name: str, obj: pd.Series | pd.DataFrame, other: Any) -> Type[Exception] | None: ...
    def _cast_pointwise_result(self, op_name: str, obj: pd.Series | pd.DataFrame, other: Any, pointwise_result: pd.Series | pd.DataFrame) -> pd.Series | pd.DataFrame: ...
    def get_op_from_name(self, op_name: str) -> Callable[[Any, Any], Any]: ...
    @final
    def check_opname(self, ser: pd.Series | pd.DataFrame, op_name: str, other: Any) -> None: ...
    @final
    def _combine(self, obj: pd.Series | pd.DataFrame, other: Any, op: Callable[[Any, Any], Any]) -> pd.Series | pd.DataFrame: ...
    @final
    def _check_op(self, ser: pd.Series | pd.DataFrame, op: Callable[[Any, Any], Any], other: Any, op_name: str, exc: Type[Exception] | None = ...) -> None: ...
    @final
    def _check_divmod_op(self, ser: pd.Series, op: Callable[[Any, Any], tuple[Any, Any]], other: Any) -> None: ...

class BaseArithmeticOpsTests(BaseOpsUtil):
    series_scalar_exc: Type[Exception]
    frame_scalar_exc: Type[Exception]
    series_array_exc: Type[Exception]
    divmod_exc: Type[Exception]
    def test_arith_series_with_scalar(self, data: pd.core.arrays.ExtensionArray, all_arithmetic_operators: str) -> None: ...
    def test_arith_frame_with_scalar(self, data: pd.core.arrays.ExtensionArray, all_arithmetic_operators: str) -> None: ...
    def test_arith_series_with_array(self, data: pd.core.arrays.ExtensionArray, all_arithmetic_operators: str) -> None: ...
    def test_divmod(self, data: pd.core.arrays.ExtensionArray) -> None: ...
    def test_divmod_series_array(self, data: pd.core.arrays.ExtensionArray, data_for_twos: pd.core.arrays.ExtensionArray) -> None: ...
    def test_add_series_with_extension_array(self, data: pd.core.arrays.ExtensionArray) -> None: ...
    def test_direct_arith_with_ndframe_returns_not_implemented(self, data: pd.core.arrays.ExtensionArray, box: Type[pd.Series] | Type[pd.DataFrame] | Type[pd.Index], op_name: str) -> None: ...

class BaseComparisonOpsTests(BaseOpsUtil):
    def _compare_other(self, ser: pd.Series, data: pd.core.arrays.ExtensionArray, op: _ComparisonOp, other: Any) -> None: ...
    def test_compare_scalar(self, data: pd.core.arrays.ExtensionArray, comparison_op: _ComparisonOp) -> None: ...
    def test_compare_array(self, data: pd.core.arrays.ExtensionArray, comparison_op: _ComparisonOp) -> None: ...

class BaseUnaryOpsTests(BaseOpsUtil):
    def test_invert(self, data: pd.core.arrays.ExtensionArray) -> None: ...
    def test_unary_ufunc_dunder_equivalence(self, data: pd.core.arrays.ExtensionArray, ufunc: Callable[[Any], Any]) -> None: ...