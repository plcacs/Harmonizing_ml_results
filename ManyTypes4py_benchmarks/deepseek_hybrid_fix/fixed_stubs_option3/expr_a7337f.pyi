class BaseExprVisitor(ast.NodeVisitor):
    const_type: type[Constant]
    term_type: type[Term]
    binary_ops: ClassVar[list[str]]
    binary_op_nodes: ClassVar[tuple[str, ...]]
    binary_op_nodes_map: ClassVar[dict[str, str]]
    unary_ops: ClassVar[list[str]]
    unary_op_nodes: ClassVar[tuple[str, ...]]
    unary_op_nodes_map: ClassVar[dict[str, str]]
    rewrite_map: ClassVar[dict[type[ast.cmpop], type[ast.cmpop]]]
    assigner: str | None
    
    def __init__(self, env: Scope, engine: str, parser: str, preparser: Callable[[str], str] = ...) -> None: ...
    def visit(self, node: str | ast.AST, **kwargs: Any) -> Term | Op | Constant | slice | None: ...
    def visit_Module(self, node: ast.Module, **kwargs: Any) -> Term | Op | Constant | slice | None: ...
    def visit_Expr(self, node: ast.Expr, **kwargs: Any) -> Term | Op | Constant | slice | None: ...
    def _rewrite_membership_op(self, node: ast.Compare, left: Term | Constant, right: Term | Constant) -> tuple[Callable, ast.cmpop, Term | Constant, Term | Constant]: ...
    def _maybe_transform_eq_ne(self, node: ast.Compare | ast.BinOp, left: Term | Constant | None = None, right: Term | Constant | None = None) -> tuple[Callable, ast.cmpop, Term | Constant, Term | Constant]: ...
    def _maybe_downcast_constants(self, left: Term | Constant, right: Term | Constant) -> tuple[Term | Constant, Term | Constant]: ...
    def _maybe_eval(self, binop: BinOp, eval_in_python: tuple[str, ...]) -> Any: ...
    def _maybe_evaluate_binop(self, op: Callable, op_class: ast.cmpop, lhs: Term | Constant, rhs: Term | Constant, eval_in_python: tuple[str, ...] = ..., maybe_eval_in_python: tuple[str, ...] = ...) -> Term | Op | Constant: ...
    def visit_BinOp(self, node: ast.BinOp, **kwargs: Any) -> Term | Op | Constant: ...
    def visit_UnaryOp(self, node: ast.UnaryOp, **kwargs: Any) -> UnaryOp: ...
    def visit_Name(self, node: ast.Name, **kwargs: Any) -> Term: ...
    def visit_NameConstant(self, node: ast.NameConstant, **kwargs: Any) -> Constant: ...
    def visit_Num(self, node: ast.Num, **kwargs: Any) -> Constant: ...
    def visit_Constant(self, node: ast.Constant, **kwargs: Any) -> Constant: ...
    def visit_Str(self, node: ast.Str, **kwargs: Any) -> Term: ...
    def visit_List(self, node: ast.List, **kwargs: Any) -> Term: ...
    def visit_Tuple(self, node: ast.Tuple, **kwargs: Any) -> Term: ...
    def visit_Index(self, node: ast.Index, **kwargs: Any) -> Term | Op | Constant | slice | None: ...
    def visit_Subscript(self, node: ast.Subscript, **kwargs: Any) -> Term: ...
    def visit_Slice(self, node: ast.Slice, **kwargs: Any) -> slice: ...
    def visit_Assign(self, node: ast.Assign, **kwargs: Any) -> Term | Op | Constant | slice | None: ...
    def visit_Attribute(self, node: ast.Attribute, **kwargs: Any) -> Term: ...
    def visit_Call(self, node: ast.Call, side: Literal["left", "right"] | None = None, **kwargs: Any) -> Term: ...
    def translate_In(self, op: ast.cmpop) -> ast.cmpop: ...
    def visit_Compare(self, node: ast.Compare, **kwargs: Any) -> Term | Op | Constant: ...
    def _try_visit_binop(self, bop: Op | Term | ast.AST) -> Op | Term: ...
    def visit_BoolOp(self, node: ast.BoolOp, **kwargs: Any) -> Term | Op | Constant: ...

_python_not_supported: frozenset[str]
_numexpr_supported_calls: frozenset[str]

class PandasExprVisitor(BaseExprVisitor):
    def __init__(self, env: Scope, engine: str, parser: str, preparser: Callable[[str], str] = ...) -> None: ...

class PythonExprVisitor(BaseExprVisitor):
    def __init__(self, env: Scope, engine: str, parser: str, preparser: Callable[[str], str] = ...) -> None: ...

class Expr:
    expr: str
    env: Scope
    engine: str
    parser: str
    _visitor: BaseExprVisitor
    terms: Term | Op | Constant | slice | None
    
    def __init__(self, expr: str, engine: str = "numexpr", parser: str = "pandas", env: Scope | None = None, level: int = 0) -> None: ...
    @property
    def assigner(self) -> str | None: ...
    def __call__(self) -> Any: ...
    def __repr__(self) -> str: ...
    def __len__(self) -> int: ...
    def parse(self) -> Term | Op | Constant | slice | None: ...
    @property
    def names(self) -> frozenset[str]: ...

PARSERS: dict[str, type[BaseExprVisitor]]