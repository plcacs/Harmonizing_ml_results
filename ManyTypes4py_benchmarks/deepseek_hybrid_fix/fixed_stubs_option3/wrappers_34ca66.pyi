"""Wrappers for windowed tables."""
import typing
from datetime import datetime
from typing import Any, Callable, ClassVar, Iterator, KeysView, Optional, Tuple, Type, cast
from mode import Seconds
from mode.utils.typing import NoReturn
from faust.exceptions import ImproperlyConfigured
from faust.streams import current_event
from faust.types import EventT, FieldDescriptorT
from faust.types.tables import KT, RecoverCallback, RelativeArg, RelativeHandler, TableT, VT, WindowSetT, WindowWrapperT, WindowedItemsViewT, WindowedValuesViewT
from faust.utils.terminal.tables import dict_as_ansitable

_KT = typing.TypeVar("_KT")
_VT = typing.TypeVar("_VT")

class WindowedKeysView(KeysView):
    def __init__(self, mapping: Any, event: Optional[EventT] = ...) -> None: ...
    def __iter__(self) -> Iterator: ...
    def __len__(self) -> int: ...
    def now(self) -> Iterator: ...
    def current(self, event: Optional[EventT] = ...) -> Iterator: ...
    def delta(self, d: Seconds, event: Optional[EventT] = ...) -> Iterator: ...

class WindowedItemsView(WindowedItemsViewT):
    def __init__(self, mapping: Any, event: Optional[EventT] = ...) -> None: ...
    def __iter__(self) -> Iterator: ...
    def now(self) -> Iterator: ...
    def current(self, event: Optional[EventT] = ...) -> Iterator: ...
    def delta(self, d: Seconds, event: Optional[EventT] = ...) -> Iterator: ...

class WindowedValuesView(WindowedValuesViewT):
    def __init__(self, mapping: Any, event: Optional[EventT] = ...) -> None: ...
    def __iter__(self) -> Iterator: ...
    def now(self) -> Iterator: ...
    def current(self, event: Optional[EventT] = ...) -> Iterator: ...
    def delta(self, d: Seconds, event: Optional[EventT] = ...) -> Iterator: ...

class WindowSet(WindowSetT):
    ValueType: ClassVar[Type]
    def __init__(self, key: KT, table: TableT, wrapper: WindowWrapperT, event: Optional[EventT] = ...) -> None: ...
    def apply(self, op: Callable[[Any, Any], Any], value: VT, event: Optional[EventT] = ...) -> WindowSet: ...
    def value(self, event: Optional[EventT] = ...) -> VT: ...
    def now(self) -> VT: ...
    def current(self, event: Optional[EventT] = ...) -> VT: ...
    def delta(self, d: Seconds, event: Optional[EventT] = ...) -> VT: ...
    def keys(self) -> NoReturn: ...
    def items(self) -> NoReturn: ...
    def values(self) -> NoReturn: ...
    def __getitem__(self, w: Any) -> object: ...
    def __setitem__(self, w: Any, value: VT) -> None: ...
    def __delitem__(self, w: Any) -> None: ...
    def __iadd__(self, other: VT) -> WindowSet: ...
    def __isub__(self, other: VT) -> WindowSet: ...
    def __imul__(self, other: VT) -> WindowSet: ...
    def __itruediv__(self, other: VT) -> WindowSet: ...
    def __ifloordiv__(self, other: VT) -> WindowSet: ...
    def __imod__(self, other: VT) -> WindowSet: ...
    def __ipow__(self, other: VT) -> WindowSet: ...
    def __ilshift__(self, other: VT) -> WindowSet: ...
    def __irshift__(self, other: VT) -> WindowSet: ...
    def __iand__(self, other: VT) -> WindowSet: ...
    def __ixor__(self, other: VT) -> WindowSet: ...
    def __ior__(self, other: VT) -> WindowSet: ...
    def __repr__(self) -> str: ...

class WindowWrapper(WindowWrapperT):
    ValueType: ClassVar[Type[WindowSet]]
    key_index: bool
    key_index_table: Optional[TableT]
    def __init__(self, table: TableT, *, relative_to: Optional[RelativeArg] = ..., key_index: bool = ..., key_index_table: Optional[TableT] = ...) -> None: ...
    def clone(self, relative_to: Optional[RelativeArg]) -> WindowWrapper: ...
    @property
    def name(self) -> str: ...
    def relative_to(self, ts: RelativeArg) -> WindowWrapper: ...
    def relative_to_now(self) -> WindowWrapper: ...
    def relative_to_field(self, field: FieldDescriptorT) -> WindowWrapper: ...
    def relative_to_stream(self) -> WindowWrapper: ...
    def get_timestamp(self, event: Optional[EventT] = ...) -> float: ...
    def on_recover(self, fun: RecoverCallback) -> RecoverCallback: ...
    def __contains__(self, key: KT) -> bool: ...
    def __getitem__(self, key: KT) -> WindowSet: ...
    def __setitem__(self, key: KT, value: VT) -> None: ...
    def on_set_key(self, key: KT, value: VT) -> None: ...
    def on_del_key(self, key: KT) -> None: ...
    def __delitem__(self, key: KT) -> None: ...
    def __len__(self) -> int: ...
    def __iter__(self) -> Iterator: ...
    def keys(self) -> WindowedKeysView: ...
    def _keys(self) -> Iterator: ...
    def values(self, event: Optional[EventT] = ...) -> WindowedValuesView: ...
    def items(self, event: Optional[EventT] = ...) -> WindowedItemsView: ...
    def _items(self, event: Optional[EventT] = ...) -> Iterator: ...
    def _items_now(self) -> Iterator: ...
    def _items_current(self, event: Optional[EventT] = ...) -> Iterator: ...
    def _items_delta(self, d: Seconds, event: Optional[EventT] = ...) -> Iterator: ...
    def as_ansitable(self, title: str = ..., **kwargs: Any) -> str: ...
    @property
    def get_relative_timestamp(self) -> Optional[RelativeHandler]: ...
    @get_relative_timestamp.setter
    def get_relative_timestamp(self, relative_to: RelativeArg) -> None: ...