from __future__ import annotations
from collections.abc import Callable
import re
from typing import Any, Literal
import pyarrow as pa
import pyarrow.compute as pc
from pandas._libs import lib

class ArrowStringArrayMixin:
    _pa_array: pa.Array | pa.ChunkedArray
    dtype: Any

    def __init__(self, *args: Any, **kwargs: Any) -> None: ...
    def _convert_bool_result(self, result: pa.Array | pa.ChunkedArray, na: Any = ..., method_name: str | None = ...) -> Any: ...
    def _convert_int_result(self, result: pa.Array | pa.ChunkedArray) -> Any: ...
    def _apply_elementwise(self, func: Callable[[str], Any]) -> list[Any]: ...
    def astype(self, dtype: Any, copy: bool = ...) -> Any: ...
    @classmethod
    def _from_sequence(cls, seq: Any, dtype: Any = ...) -> ArrowStringArrayMixin: ...
    def _str_len(self) -> Any: ...
    def _str_lower(self) -> ArrowStringArrayMixin: ...
    def _str_upper(self) -> ArrowStringArrayMixin: ...
    def _str_strip(self, to_strip: str | None = ...) -> ArrowStringArrayMixin: ...
    def _str_lstrip(self, to_strip: str | None = ...) -> ArrowStringArrayMixin: ...
    def _str_rstrip(self, to_strip: str | None = ...) -> ArrowStringArrayMixin: ...
    def _str_pad(self, width: int, side: Literal['left', 'right', 'both'] = ..., fillchar: str = ...) -> ArrowStringArrayMixin: ...
    def _str_get(self, i: int) -> ArrowStringArrayMixin: ...
    def _str_slice(self, start: int | None = ..., stop: int | None = ..., step: int | None = ...) -> ArrowStringArrayMixin: ...
    def _str_slice_replace(self, start: int | None = ..., stop: int | None = ..., repl: str | None = ...) -> ArrowStringArrayMixin: ...
    def _str_replace(self, pat: str | re.Pattern[str], repl: str | Callable[[str], str], n: int = ..., case: bool = ..., flags: int = ..., regex: bool = ...) -> ArrowStringArrayMixin: ...
    def _str_capitalize(self) -> ArrowStringArrayMixin: ...
    def _str_title(self) -> ArrowStringArrayMixin: ...
    def _str_swapcase(self) -> ArrowStringArrayMixin: ...
    def _str_removeprefix(self, prefix: str) -> ArrowStringArrayMixin: ...
    def _str_removesuffix(self, suffix: str) -> ArrowStringArrayMixin: ...
    def _str_startswith(self, pat: str | tuple[str, ...], na: Any = ...) -> Any: ...
    def _str_endswith(self, pat: str | tuple[str, ...], na: Any = ...) -> Any: ...
    def _str_isalnum(self) -> Any: ...
    def _str_isalpha(self) -> Any: ...
    def _str_isascii(self) -> Any: ...
    def _str_isdecimal(self) -> Any: ...
    def _str_isdigit(self) -> Any: ...
    def _str_islower(self) -> Any: ...
    def _str_isnumeric(self) -> Any: ...
    def _str_isspace(self) -> Any: ...
    def _str_istitle(self) -> Any: ...
    def _str_isupper(self) -> Any: ...
    def _str_contains(self, pat: str, case: bool = ..., flags: int = ..., na: Any = ..., regex: bool = ...) -> Any: ...
    def _str_match(self, pat: str, case: bool = ..., flags: int = ..., na: Any = ...) -> Any: ...
    def _str_fullmatch(self, pat: str, case: bool = ..., flags: int = ..., na: Any = ...) -> Any: ...
    def _str_find(self, sub: str, start: int = ..., end: int | None = ...) -> Any: ...