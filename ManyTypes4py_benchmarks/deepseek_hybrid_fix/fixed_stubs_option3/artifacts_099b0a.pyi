class Artifact(ArtifactRequest):
    if TYPE_CHECKING:
        key: Optional[str]
        description: Optional[str]
        data: Any
        type: str

    async def acreate(self, client: Optional[PrefectClient] = ...) -> ArtifactResponse: ...
    @async_dispatch(acreate)
    def create(self, client: Optional[PrefectClient] = ...) -> ArtifactResponse: ...
    @classmethod
    async def aget(cls, key: Optional[str] = ..., client: Optional[PrefectClient] = ...) -> Optional[ArtifactResponse]: ...
    @classmethod
    @async_dispatch(aget)
    def get(cls, key: Optional[str] = ..., client: Optional[PrefectClient] = ...) -> Optional[ArtifactResponse]: ...
    @classmethod
    async def aget_or_create(cls, key: Optional[str] = ..., description: Optional[str] = ..., data: Any = ..., client: Optional[PrefectClient] = ..., **kwargs: Any) -> tuple[ArtifactResponse, bool]: ...
    @classmethod
    @async_dispatch(aget_or_create)
    def get_or_create(cls, key: Optional[str] = ..., description: Optional[str] = ..., data: Any = ..., client: Optional[PrefectClient] = ..., **kwargs: Any) -> tuple[ArtifactResponse, bool]: ...
    async def aformat(self) -> str: ...
    @async_dispatch(aformat)
    def format(self) -> str: ...

