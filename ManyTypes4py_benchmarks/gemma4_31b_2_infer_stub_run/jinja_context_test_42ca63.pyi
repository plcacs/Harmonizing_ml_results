class ExtraCache:
    def __init__(self, dialect: Optional[Dialect] = None, database: Optional[Database] = None, table: Optional[SqlaTable] = None) -> None: ...
    def filter_values(self, col: str, default: Optional[Any] = None, remove_filter: bool = False) -> List[Any]: ...
    def get_filters(self, col: str, remove_filter: bool = False) -> List[Dict[str, Any]]: ...
    def url_param(self, key: str, default: Optional[str] = None, escape_result: bool = True) -> Optional[str]: ...
    def current_user_id(self, add_to_cache_keys: bool = True) -> Optional[int]: ...
    def current_username(self, add_to_cache_keys: bool = True) -> Optional[str]: ...
    def current_user_email(self, add_to_cache_keys: bool = True) -> Optional[str]: ...
    def get_time_filter(self, *args: Any, **kwargs: Any) -> TimeFilter: ...
    @staticmethod
    def cache_key_wrapper(*args: Any, **kwargs: Any) -> Any: ...
    applied_filters: List[str]
    removed_filters: List[str]

