import os
from typing import Any, Generator, Iterable, Optional, Sequence, Set, Tuple, Union
from pathlib import Path
from parso.python import tree
from jedi.inference.names import ImportName, SubModuleName
from jedi.inference.base_value import ValueSet
from jedi.file_io import FileIO, FolderIO

class ModuleCache:
    _name_cache: dict[str, ValueSet]
    def __init__(self) -> None: ...
    def add(self, string_names: Optional[str], value_set: ValueSet) -> None: ...
    def get(self, string_names: str) -> Optional[ValueSet]: ...

def infer_import(context: Any, tree_name: tree.Node) -> ValueSet: ...

def goto_import(context: Any, tree_name: tree.Node) -> Set[str]: ...

def _prepare_infer_import(module_context: Any, tree_name: tree.Node) -> Tuple[Optional[str], Tuple[Union[str, tree.Name], ...], int, ValueSet]: ...

def _add_error(value: Any, name: Any, message: str) -> None: ...

def _level_to_base_import_path(project_path: str, directory: str, level: int) -> Tuple[Optional[Sequence[str]], Optional[str]]: ...

class Importer:
    level: int
    import_path: Sequence[Union[str, tree.Name]]
    def __init__(self, inference_state: Any, import_path: Sequence[Union[str, tree.Name]], module_context: Any, level: int = 0) -> None: ...
    @property
    def _str_import_path(self) -> Tuple[str, ...]: ...
    def _sys_path_with_modifications(self, is_completion: bool) -> list[str]: ...
    def follow(self) -> ValueSet: ...
    def _get_module_names(self, search_path: Optional[list[str]] = None, in_module: Optional[Any] = None) -> list[Union[ImportName, SubModuleName]]: ...
    def completion_names(self, inference_state: Any, only_modules: bool = False) -> list[ImportName]: ...

def import_module_by_names(inference_state: Any, import_names: Sequence[Union[str, tree.Name]], sys_path: Optional[list[str]] = None, module_context: Optional[Any] = None, prefer_stubs: bool = True) -> ValueSet: ...

def import_module(inference_state: Any, import_names: Sequence[str], parent_module_value: Optional[Any], sys_path: list[str]) -> ValueSet: ...

def _load_python_module(inference_state: Any, file_io: FileIO, import_names: Optional[Sequence[str]] = None, is_package: bool = False) -> Any: ...

def _load_builtin_module(inference_state: Any, import_names: Optional[Sequence[str]] = None, sys_path: Optional[list[str]] = None) -> Optional[Any]: ...

def load_module_from_path(inference_state: Any, file_io: FileIO, import_names: Optional[Sequence[str]] = None, is_package: Optional[bool] = None) -> Any: ...

def load_namespace_from_path(inference_state: Any, folder_io: FolderIO) -> Any: ...

def follow_error_node_imports_if_possible(context: Any, name: tree.Node) -> Optional[ValueSet]: ...

def iter_module_names(inference_state: Any, module_context: Any, search_path: list[str], module_cls: Any = ImportName, add_builtin_modules: bool = True) -> Generator[Union[ImportName, SubModuleName], None, None]: ...