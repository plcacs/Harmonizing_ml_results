from typing import Any, Generator, Tuple, Union, TypeVar, Protocol, Sequence

# Define Protocols for the complex 'spec' and 'state' objects to provide concrete-like typing
class SpecProtocol(Protocol):
    FULL_EXIT_REQUEST_AMOUNT: int
    FAR_FUTURE_EPOCH: int
    MIN_ACTIVATION_BALANCE: int
    PENDING_PARTIAL_WITHDRAWALS_LIMIT: int
    EFFECTIVE_BALANCE_INCREMENT: int
    MAX_EFFECTIVE_BALANCE_ELECTRA: int
    BLS_WITHDRAWAL_PREFIX: bytes
    SLOTS_PER_EPOCH: int
    config: Any
    def process_withdrawal_request(self, state: Any, withdrawal_request: 'WithdrawalRequest') -> None: ...
    def get_pending_balance_to_withdraw(self, state: Any, index: int) -> int: ...
    def get_current_epoch(self, state: Any) -> int: ...
    def get_active_validator_indices(self, state: Any, epoch: int) -> Sequence[int]: ...
    def initiate_validator_exit(self, state: Any, index: int) -> None: ...
    def compute_activation_exit_epoch(self, epoch: int) -> int: ...
    def get_activation_exit_churn_limit(self, state: Any) -> int: ...
    def is_active_validator(self, validator: Any, epoch: int) -> bool: ...
    def WithdrawalRequest(self, source_address: bytes, validator_pubkey: Any, amount: int) -> 'WithdrawalRequest': ...
    def PendingPartialWithdrawal(self, validator_index: int, amount: int, withdrawable_epoch: int) -> 'PendingPartialWithdrawal': ...
    def BLSPubkey(self, data: bytes) -> Any: ...

class WithdrawalRequest:
    source_address: bytes
    validator_pubkey: Any
    amount: int

class PendingPartialWithdrawal:
    validator_index: int
    amount: int
    withdrawable_epoch: int

class StateProtocol(Protocol):
    slot: int
    balances: list[int]
    validators: list[Any]
    pending_partial_withdrawals: list[PendingPartialWithdrawal]
    earliest_exit_epoch: int
    def copy(self) -> 'StateProtocol': ...

T_Spec = TypeVar('T_Spec', bound=SpecProtocol)
T_State = TypeVar('T_State', bound=StateProtocol)

def run_withdrawal_request_processing(
    spec: T_Spec, 
    state: T_State, 
    withdrawal_request: WithdrawalRequest, 
    valid: bool = True, 
    success: bool = True
) -> Generator[Tuple[str, Union[T_State, WithdrawalRequest, None]], None, None]: ...

def compute_amount_to_withdraw(spec: T_Spec, state: T_State, index: int, amount: int) -> int: ...

