from typing import Any, List, Tuple, Union, overload

class Matrix:
    nRows: int
    nCols: int
    _: List[List[float]]

    def __init__(self, nRows: int, nCols: int, elements: List[List[float]] = []) -> None: ...
    def __matmul__(self, other: 'Matrix') -> 'Matrix': ...
    def __imatmul__(self, other: 'Matrix') -> 'Matrix': ...
    def __mul__(self, other: Union['Matrix', float]) -> 'Matrix': ...
    def __rmul__(self, scalar: float) -> 'Matrix': ...
    def __imul__(self, other: Union['Matrix', float]) -> 'Matrix': ...
    def __add__(self, other: 'Matrix') -> 'Matrix': ...
    def __getitem__(self, index: int) -> List[float]: ...
    def __setitem__(self, index: int, value: List[float]) -> None: ...
    def __repr__(self) -> str: ...
    def __floordiv__(self, other: Any) -> str: ...
    def __truediv__(self, other: Any) -> str: ...

class Functor:
    factor: float

    def __init__(self, factor: float) -> None: ...
    def __call__(
        self, 
        x: float, 
        y: float = -1, 
        *args: float, 
        m: float = -2, 
        n: float, 
        **kwargs: Any
    ) -> Tuple[float, float, List[float], float, float]: ...

f: Functor

def g(x: Any, y: Any = -1, *args: Any, m: Any = -2, n: Any, **kwargs: Any) -> Tuple[Any, Any, Tuple[Any, ...], Any, Any]: ...

def run(autoTester: Any) -> None: ...