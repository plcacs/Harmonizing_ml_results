class RequestsCookieJar(cookielib.CookieJar, MutableMapping[str, str]):
    """Compatibility class; is a cookielib.CookieJar, but exposes a dict interface."""
    def get(self, name: str, default: Optional[str] = ..., domain: Optional[str] = ..., path: Optional[str] = ...) -> Optional[str]: ...
    def set(self, name: str, value: Optional[str], **kwargs: Any) -> Optional[cookielib.Cookie]: ...
    def iterkeys(self) -> Iterator[str]: ...
    def keys(self) -> list[str]: ...
    def itervalues(self) -> Iterator[str]: ...
    def values(self) -> list[str]: ...
    def iteritems(self) -> Iterator[tuple[str, str]]: ...
    def items(self) -> list[tuple[str, str]]: ...
    def list_domains(self) -> list[str]: ...
    def list_paths(self) -> list[str]: ...
    def multiple_domains(self) -> bool: ...
    def get_dict(self, domain: Optional[str] = ..., path: Optional[str] = ...) -> dict[str, str]: ...
    def __contains__(self, name: str) -> bool: ...
    def __getitem__(self, name: str) -> str: ...
    def __setitem__(self, name: str, value: str) -> None: ...
    def __delitem__(self, name: str) -> None: ...
    def set_cookie(self, cookie: cookielib.Cookie, *args: Any, **kwargs: Any) -> cookielib.Cookie: ...
    def update(self, other: Union[cookielib.CookieJar, MutableMapping[str, str]]) -> None: ...
    def _find(self, name: str, domain: Optional[str] = ..., path: Optional[str] = ...) -> str: ...
    def _find_no_duplicates(self, name: str, domain: Optional[str] = ..., path: Optional[str] = ...) -> str: ...
    def __getstate__(self) -> dict[str, Any]: ...
    def __setstate__(self, state: dict[str, Any]) -> None: ...
    def copy(self) -> 'RequestsCookieJar': ...
    def get_policy(self) -> Any: ...

def _copy_cookie_jar(jar: Optional[cookielib.CookieJar]) -> Optional[cookielib.CookieJar]: ...
def create_cookie(name: str, value: str, **kwargs: Any) -> cookielib.Cookie: ...
def morsel_to_cookie(morsel: Morsel) -> cookielib.Cookie: ...
def cookiejar_from_dict(cookie_dict: Optional[dict[str, str]], cookiejar: Optional[cookielib.CookieJar] = ..., overwrite: bool = ...) -> cookielib.CookieJar: ...
def merge_cookies(cookiejar: cookielib.CookieJar, cookies: Union[dict[str, str], cookielib.CookieJar]) -> cookielib.CookieJar: ...