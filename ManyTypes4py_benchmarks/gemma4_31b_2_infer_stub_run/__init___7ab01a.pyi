class error(Exception):
    """ Regular Expression Exception Class """
    def __init__(self, msg: str, error: Any, pattern: Optional[str] = ..., flags: int = ..., pos: Optional[int] = ...) -> None: ...
    pattern: Optional[str]
    flags: int
    pos: Optional[int]

class ReIndexError(IndexError):
    """ Index Error variant for the re module - primarily used for
    the group method in the Match Object.
    """
    def __init__(self) -> None: ...

class Match:
    """ Resulting Match from a Regex Operation """
    def __init__(self, mObj: Any, string: str, pos: int, endpos: int, rObj: 'Regex', namedGroups: Optional[Dict[str, int]] = ...) -> None: ...
    
    @property
    def pos(self) -> int: ...
    
    @property
    def endpos(self) -> int: ...
    
    @property
    def re(self) -> 'Regex': ...
    
    @property
    def string(self) -> str: ...
    
    @property
    def lastgroup(self) -> Optional[str]: ...
    
    @property
    def lastindex(self) -> Optional[int]: ...

    def expand(self, template: str) -> str: ...

    @overload
    def group(self, *args: int) -> Union[str, Tuple[str, ...]]: ...
    @overload
    def group(self, *args: str) -> Union[str, Tuple[str, ...]]: ...
    @overload
    def group(self, *args: Union[int, str]) -> Union[str, Tuple[str, ...]]: ...
    def group(self, *args: Any) -> Union[str, Tuple[str, ...]]: ...

    def groups(self, default: Optional[str] = ...) -> Tuple[Optional[str], ...]: ...

    def groupdict(self, default: Optional[str] = ...) -> Dict[str, Optional[str]]: ...

    @overload
    def start(self, group: int = 0) -> int: ...
    @overload
    def start(self, group: str = ...) -> int: ...
    def start(self, group: Union[int, str] = 0) -> int: ...

    @overload
    def end(self, group: int = 0) -> int: ...
    @overload
    def end(self, group: str = ...) -> int: ...
    def end(self, group: Union[int, str] = 0) -> int: ...

    @overload
    def span(self, group: int = 0) -> Tuple[int, int]: ...
    @overload
    def span(self, group: str = ...) -> Tuple[int, int]: ...
    def span(self, group: Union[int, str] = 0) -> Tuple[int, int]: ...

class Regex:
    """ Regular Expression Object """
    def __init__(self, pattern: str, flags: int) -> None: ...

    @property
    def pattern(self) -> str: ...

    @property
    def flags(self) -> int: ...

    @property
    def groups(self) -> int: ...

    @property
    def groupindex(self) -> Dict[str, int]: ...

    def search(self, string: str, pos: int = 0, endpos: Optional[int] = ...) -> Optional[Match]: ...

    def match(self, string: str, pos: int = 0, endpos: Optional[int] = ...) -> Optional[Match]: ...

    def fullmatch(self, string: str, pos: int = 0, endpos: Optional[int] = ...) -> Optional[Match]: ...

    def split(self, string: str, maxsplit: int = 0) -> List[str]: ...

    def findall(self, string: str, pos: int = 0, endpos: Optional[int] = ...) -> Union[List[str], List[Tuple[str, ...]]]: ...

    def finditer(self, string: str, pos: int, endpos: Optional[int] = ...) -> Iterable[Match]: ...

    def sub(self, repl: Union[str, Callable[[Match], str]], string: str, count: int = 0) -> str: ...

    def subn(self, repl: Union[str, Callable[[Match], str]], string: str, count: int = 0) -> Tuple[str, int]: ...

class PyRegExp(Regex):
    """ Python Regular Expression object which translates a python
    regex syntax string into a format that can be passed to the
    js regex engine.
    """
    def __init__(self, pyPattern: str, flags: int) -> None: ...

def compile(pattern: str, flags: int = 0) -> Union[Regex, PyRegExp]: ...

def search(pattern: str, string: str, flags: int = 0) -> Optional[Match]: ...

def match(pattern: str, string: str, flags: int = 0) -> Optional[Match]: ...

def fullmatch(pattern: str, string: str, flags: int = 0) -> Optional[Match]: ...

def split(pattern: str, string: str, maxsplit: int = 0, flags: int = 0) -> List[str]: ...

def findall(pattern: str, string: str, flags: int = 0) -> Union[List[str], List[Tuple[str, ...]]]: ...

def finditer(pattern: str, string: str, flags: int = 0) -> Iterable[Match]: ...

def sub(pattern: str, repl: Union[str, Callable[[Match], str]], string: str, count: int = 0, flags: int = 0) -> str: ...

def subn(pattern: str, repl: Union[str, Callable[[Match], str]], string: str, count: int = 0, flags: int = 0) -> Tuple[str, int]: ...

def escape(string: str) -> str: ...

def purge() -> None: ...