from __future__ import annotations
import typing
from urllib.parse import SplitResult
from starlette.types import Scope

_KeyType = typing.TypeVar('_KeyType')
_CovariantValueType = typing.TypeVar('_CovariantValueType', covariant=True)

class Address(typing.NamedTuple): ...

class URL:
    def __init__(self, url: str = '', scope: Optional[Scope] = None, **components: typing.Any) -> None: ...
    @property
    def components(self) -> SplitResult: ...
    @property
    def scheme(self) -> str: ...
    @property
    def netloc(self) -> str: ...
    @property
    def path(self) -> str: ...
    @property
    def query(self) -> str: ...
    @property
    def fragment(self) -> str: ...
    @property
    def username(self) -> Optional[str]: ...
    @property
    def password(self) -> Optional[str]: ...
    @property
    def hostname(self) -> Optional[str]: ...
    @property
    def port(self) -> Optional[int]: ...
    @property
    def is_secure(self) -> bool: ...
    def replace(self, **kwargs: typing.Any) -> URL: ...
    def include_query_params(self, **kwargs: typing.Any) -> URL: ...
    def replace_query_params(self, **kwargs: typing.Any) -> URL: ...
    def remove_query_params(self, keys: typing.Union[str, typing.Iterable[str]]) -> URL: ...
    def __eq__(self, other: object) -> bool: ...
    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...

class URLPath(str):
    def __new__(cls, path: str, protocol: str = '', host: str = '') -> URLPath: ...
    def __init__(self, path: str, protocol: str = '', host: str = '') -> None: ...
    protocol: str
    host: str
    def make_absolute_url(self, base_url: typing.Union[str, URL]) -> URL: ...

class Secret:
    def __init__(self, value: str) -> None: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...
    def __bool__(self) -> bool: ...

class CommaSeparatedStrings(typing.Sequence[str]):
    def __init__(self, value: typing.Union[str, typing.Iterable[str]]) -> None: ...
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> str: ...
    def __iter__(self) -> typing.Iterator[str]: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...

class ImmutableMultiDict(typing.Mapping[_KeyType, _CovariantValueType]):
    def __init__(self, *args: typing.Any, **kwargs: typing.Any) -> None: ...
    def getlist(self, key: _KeyType) -> list[_CovariantValueType]: ...
    def keys(self) -> typing.KeysView[_KeyType]: ...
    def values(self) -> typing.ValuesView[_CovariantValueType]: ...
    def items(self) -> typing.ItemsView[_KeyType, _CovariantValueType]: ...
    def multi_items(self) -> list[tuple[_KeyType, _CovariantValueType]]: ...
    def __getitem__(self, key: _KeyType) -> _CovariantValueType: ...
    def __contains__(self, key: object) -> bool: ...
    def __iter__(self) -> typing.Iterator[_KeyType]: ...
    def __len__(self) -> int: ...
    def __eq__(self, other: object) -> bool: ...
    def __repr__(self) -> str: ...

class MultiDict(ImmutableMultiDict[typing.Any, typing.Any]):
    def __setitem__(self, key: typing.Any, value: typing.Any) -> None: ...
    def __delitem__(self, key: typing.Any) -> None: ...
    def pop(self, key: typing.Any, default: typing.Any = None) -> typing.Any: ...
    def popitem(self) -> tuple[typing.Any, typing.Any]: ...
    def poplist(self, key: typing.Any) -> list[typing.Any]: ...
    def clear(self) -> None: ...
    def setdefault(self, key: typing.Any, default: typing.Any = None) -> typing.Any: ...
    def setlist(self, key: typing.Any, values: typing.Iterable[typing.Any]) -> None: ...
    def append(self, key: typing.Any, value: typing.Any) -> None: ...
    def update(self, *args: typing.Any, **kwargs: typing.Any) -> None: ...

class QueryParams(ImmutableMultiDict[str, str]):
    def __init__(self, *args: typing.Any, **kwargs: typing.Any) -> None: ...
    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...

class UploadFile:
    def __init__(self, file: typing.Any, *, size: Optional[int] = None, filename: Optional[str] = None, headers: Optional[Headers] = None) -> None: ...
    filename: Optional[str]
    file: typing.Any
    size: Optional[int]
    headers: Headers
    @property
    def content_type(self) -> Optional[str]: ...
    @property
    def _in_memory(self) -> bool: ...
    async def write(self, data: bytes) -> None: ...
    async def read(self, size: int = -1) -> bytes: ...
    async def seek(self, offset: int) -> None: ...
    async def close(self) -> None: ...
    def __repr__(self) -> str: ...

class FormData(ImmutableMultiDict[str, typing.Union[UploadFile, str]]):
    def __init__(self, *args: typing.Any, **kwargs: typing.Any) -> None: ...
    async def close(self) -> None: ...

class Headers(typing.Mapping[str, str]):
    def __init__(self, headers: Optional[typing.Mapping[str, str]] = None, raw: Optional[list[tuple[bytes, bytes]]] = None, scope: Optional[Scope] = None) -> None: ...
    @property
    def raw(self) -> list[tuple[bytes, bytes]]: ...
    def keys(self) -> list[str]: ...
    def values(self) -> list[str]: ...
    def items(self) -> list[tuple[str, str]]: ...
    def getlist(self, key: str) -> list[str]: ...
    def mutablecopy(self) -> MutableHeaders: ...
    def __getitem__(self, key: str) -> str: ...
    def __contains__(self, key: object) -> bool: ...
    def __iter__(self) -> typing.Iterator[str]: ...
    def __len__(self) -> int: ...
    def __eq__(self, other: object) -> bool: ...
    def __repr__(self) -> str: ...

class MutableHeaders(Headers):
    def __setitem__(self, key: str, value: str) -> None: ...
    def __delitem__(self, key: str) -> None: ...
    def __ior__(self, other: typing.Mapping[str, str]) -> MutableHeaders: ...
    def __or__(self, other: typing.Mapping[str, str]) -> MutableHeaders: ...
    @property
    def raw(self) -> list[tuple[bytes, bytes]]: ...
    def setdefault(self, key: str, value: str) -> str: ...
    def update(self, other: typing.Mapping[str, str]) -> None: ...
    def append(self, key: str, value: str) -> None: ...
    def add_vary_header(self, vary: str) -> None: ...

class State:
    def __init__(self, state: Optional[typing.Dict[str, typing.Any]] = None) -> None: ...
    def __setattr__(self, key: str, value: typing.Any) -> None: ...
    def __getattr__(self, key: str) -> typing.Any: ...
    def __delattr__(self, key: str) -> None: ...