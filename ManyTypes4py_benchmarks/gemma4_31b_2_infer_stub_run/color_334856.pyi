import math
from typing import Dict, Optional, Tuple, Union, overload

ColorTuple = Union[Tuple[int, int, int], Tuple[int, int, int, float]]
ColorType = Union[ColorTuple, str]
HslColorTuple = Union[Tuple[float, float, float], Tuple[float, float, float, float]]

class RGBA:
    r: float
    g: float
    b: float
    alpha: Optional[float]
    _tuple: Tuple[float, float, float, Optional[float]]

    def __init__(self, r: float, g: float, b: float, alpha: Optional[float]) -> None: ...
    def __getitem__(self, item: int) -> Optional[float]: ...

class Color:
    _original: Union[ColorTuple, str, 'Color']
    _rgba: RGBA

    def __init__(self, value: Union[Tuple[Union[int, float], ...], list[Union[int, float]], str, 'Color']) -> None: ...
    
    @classmethod
    def __modify_schema__(cls, field_schema: Dict[str, Any]) -> None: ...

    def original(self) -> Union[ColorTuple, str, 'Color']: ...

    def as_named(self, *, fallback: bool = False) -> str: ...

    def as_hex(self) -> str: ...

    def as_rgb(self) -> str: ...

    @overload
    def as_rgb_tuple(self, *, alpha: None = None) -> Union[Tuple[int, int, int], Tuple[int, int, int, float]]: ...
    @overload
    def as_rgb_tuple(self, *, alpha: bool) -> Tuple[int, int, int, float] if alpha else Tuple[int, int, int]: ...
    def as_rgb_tuple(self, *, alpha: Optional[bool] = None) -> Union[Tuple[int, int, int], Tuple[int, int, int, float]]: ...

    def as_hsl(self) -> str: ...

    @overload
    def as_hsl_tuple(self, *, alpha: None = None) -> Union[Tuple[float, float, float], Tuple[float, float, float, float]]: ...
    @overload
    def as_hsl_tuple(self, *, alpha: bool) -> Tuple[float, float, float, float] if alpha else Tuple[float, float, float]: ...
    def as_hsl_tuple(self, *, alpha: Optional[bool] = None) -> Union[Tuple[float, float, float], Tuple[float, float, float, float]]: ...

    def _alpha_float(self) -> float: ...

    @classmethod
    def __get_validators__(cls): ...

    def __str__(self) -> str: ...

    def __repr_args__(self) -> list[Tuple[Optional[str], Any]]: ...

    def __eq__(self, other: object) -> bool: ...

    def __hash__(self) -> int: ...

def parse_tuple(value: Union[Tuple[Union[int, float], ...], list[Union[int, float]]]) -> RGBA: ...

def parse_str(value: str) -> RGBA: ...

def ints_to_rgba(r: Union[int, float, str], g: Union[int, float, str], b: Union[int, float, str], alpha: Optional[Union[int, float, str]]) -> RGBA: ...

def parse_color_value(value: Union[int, float, str], max_val: float = 255) -> float: ...

def parse_float_alpha(value: Optional[Union[int, float, str]]) -> Optional[float]: ...

def parse_hsl(h: str, h_units: Optional[str], sat: str, light: str, alpha: Optional[Union[int, float, str]] = None) -> RGBA: ...

def float_to_255(c: float) -> int: ...

r_hex_short: str
r_hex_long: str
r_rgb: str
r_rgba: str
r_hsl: str
r_hsla: str
repeat_colors: set[int]
rads: float

COLORS_BY_NAME: Dict[str, Tuple[int, int, int]]
COLORS_BY_VALUE: Dict[Tuple[int, int, int], str]