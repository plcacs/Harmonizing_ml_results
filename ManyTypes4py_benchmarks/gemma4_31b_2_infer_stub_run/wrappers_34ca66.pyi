"""Wrappers for windowed tables."""
import operator
from datetime import datetime
from typing import Any, Callable, Generator, Iterator, Optional, Tuple, Union, overload
from mode import Seconds
from faust.types import EventT, FieldDescriptorT
from faust.types.tables import KT, VT, WindowSetT, WindowWrapperT, WindowedItemsViewT, WindowedValuesViewT

if typing.TYPE_CHECKING:
    from .table import Table as _Table
else:
    class _Table:
        ...

__all__ = ['WindowSet', 'WindowWrapper', 'WindowedItemsView', 'WindowedKeysView', 'WindowedValuesView']

class WindowedKeysView(typing.KeysView):
    """The object returned by ``windowed_table.keys()``."""

    def __init__(self, mapping: 'WindowWrapper', event: Optional[EventT] = ...) -> None: ...
    def __iter__(self) -> Iterator[KT]: ...
    def __len__(self) -> int: ...
    def now(self) -> Generator[KT, None, None]: ...
    def current(self, event: Optional[EventT] = ...) -> Generator[KT, None, None]: ...
    def delta(self, d: Union[Seconds, float], event: Optional[EventT] = ...) -> Generator[KT, None, None]: ...

class WindowedItemsView(WindowedItemsViewT):
    """The object returned by ``windowed_table.items()``."""

    def __init__(self, mapping: 'WindowWrapper', event: Optional[EventT] = ...) -> None: ...
    def __iter__(self) -> Iterator[Tuple[KT, VT]]: ...
    def now(self) -> Iterator[Tuple[KT, VT]]: ...
    def current(self, event: Optional[EventT] = ...) -> Iterator[Tuple[KT, VT]]: ...
    def delta(self, d: Union[Seconds, float], event: Optional[EventT] = ...) -> Iterator[Tuple[KT, VT]]: ...

class WindowedValuesView(WindowedValuesViewT):
    """The object returned by ``windowed_table.values()``."""

    def __init__(self, mapping: 'WindowWrapper', event: Optional[EventT] = ...) -> None: ...
    def __iter__(self) -> Iterator[VT]: ...
    def now(self) -> Generator[VT, None, None]: ...
    def current(self, event: Optional[EventT] = ...) -> Generator[VT, None, None]: ...
    def delta(self, d: Union[Seconds, float], event: Optional[EventT] = ...) -> Generator[VT, None, None]: ...

class WindowSet(WindowSetT[KT, VT]):
    """Represents the windows available for table key."""

    key: KT
    table: '_Table'
    wrapper: 'WindowWrapper'
    event: Optional[EventT]
    data: '_Table'

    def __init__(self, key: KT, table: Any, wrapper: 'WindowWrapper', event: Optional[EventT] = ...) -> None: ...
    def apply(self, op: Callable[[Any, Any], Any], value: Any, event: Optional[EventT] = ...) -> 'WindowSet': ...
    def value(self, event: Optional[EventT] = ...) -> VT: ...
    def now(self) -> VT: ...
    def current(self, event: Optional[EventT] = ...) -> VT: ...
    def delta(self, d: Union[Seconds, float], event: Optional[EventT] = ...) -> VT: ...
    def keys(self) -> None: ...
    def items(self) -> None: ...
    def values(self) -> None: ...
    def __getitem__(self, w: Union[EventT, Any]) -> Union['WindowSet', VT]: ...
    def __setitem__(self, w: Any, value: VT) -> None: ...
    def __delitem__(self, w: Any) -> None: ...
    def __iadd__(self, other: Any) -> 'WindowSet': ...
    def __isub__(self, other: Any) -> 'WindowSet': ...
    def __imul__(self, other: Any) -> 'WindowSet': ...
    def __itruediv__(self, other: Any) -> 'WindowSet': ...
    def __ifloordiv__(self, other: Any) -> 'WindowSet': ...
    def __imod__(self, other: Any) -> 'WindowSet': ...
    def __ipow__(self, other: Any) -> 'WindowSet': ...
    def __ilshift__(self, other: Any) -> 'WindowSet': ...
    def __irshift__(self, other: Any) -> 'WindowSet': ...
    def __iand__(self, other: Any) -> 'WindowSet': ...
    def __ixor__(self, other: Any) -> 'WindowSet': ...
    def __ior__(self, other: Any) -> 'WindowSet': ...
    def __repr__(self) -> str: ...

class WindowWrapper(WindowWrapperT):
    """Windowed table wrapper."""
    ValueType: java.lang.Class['WindowSet']
    key_index: bool
    key_index_table: Optional[Any]

    def __init__(self, table: Any, *, relative_to: Optional[Union[datetime, float, FieldDescriptorT, Callable]] = None, key_index: bool = False, key_index_table: Optional[Any] = None) -> None: ...
    def clone(self, relative_to: Optional[Callable[[Optional[EventT]], float]] = None) -> 'WindowWrapper': ...
    @property
    def name(self) -> str: ...
    def relative_to(self, ts: Union[datetime, float, FieldDescriptorT, Callable]) -> 'WindowWrapper': ...
    def relative_to_now(self) -> 'WindowWrapper': ...
    def relative_to_field(self, field: FieldDescriptorT) -> 'WindowWrapper': ...
    def relative_to_stream(self) -> 'WindowWrapper': ...
    def get_timestamp(self, event: Optional[EventT] = ...) -> float: ...
    def on_recover(self, fun: Callable[..., None]) -> Any: ...
    def __contains__(self, key: KT) -> bool: ...
    def __getitem__(self, key: KT) -> 'WindowSet': ...
    def __setitem__(self, key: KT, value: Any) -> None: ...
    def on_set_key(self, key: KT, value: Any) -> None: ...
    def on_del_key(self, key: KT) -> None: ...
    def __delitem__(self, key: KT) -> None: ...
    def __len__(self) -> int: ...
    def __iter__(self) -> Iterator[KT]: ...
    def keys(self) -> WindowedKeysView: ...
    def _keys(self) -> Generator[KT, None, None]: ...
    def values(self, event: Optional[EventT] = ...) -> WindowedValuesView: ...
    def items(self, event: Optional[EventT] = ...) -> WindowedItemsView: ...
    def _items(self, event: Optional[EventT] = ...) -> Generator[Tuple[KT, VT], None, None]: ...
    def _items_now(self) -> Generator[Tuple[KT, VT], None, None]: ...
    def _items_current(self, event: Optional[EventT] = ...) -> Generator[Tuple[KT, VT], None, None]: ...
    def _items_delta(self, d: Union[Seconds, float], event: Optional[EventT] = ...) -> Generator[Tuple[KT, VT], None, None]: ...
    def as_ansitable(self, title: str = '{table.name}', **kwargs: Any) -> str: ...
    @property
    def get_relative_timestamp(self) -> Optional[Callable[[Optional[EventT]], float]]: ...
    @get_relative_timestamp.setter
    def get_relative_timestamp(self, relative_to: Union[datetime, float, FieldDescriptorT, Callable]) -> None: ...