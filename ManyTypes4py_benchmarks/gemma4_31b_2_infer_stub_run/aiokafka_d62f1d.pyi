    async def earliest_offsets(self, *partitions: TP) -> Mapping[TP, int]: ...
    async def highwaters(self, *partitions: TP) -> Mapping[TP, int]: ...
    async def _highwaters(self, partitions: Iterable[TP]) -> Mapping[TP, int]: ...
    def _ensure_consumer(self) -> Any: ...
    async def getmany(self, active_partitions: Iterable[TP], timeout: float) -> Mapping[TP, List[ConsumerMessage]]: ...
    async def _fetch_records(self, consumer: Any, active_partitions: Iterable[TP], timeout: Optional[float] = None, max_records: Optional[int] = None) -> Mapping[TP, List[ConsumerMessage]]: ...
    async def create_topic(self, topic: str, partitions: int, replication: int, *, config: Optional[Mapping[str, str]] = None, timeout: float = 30.0, retention: Optional[Union[int, float, str]] = None, compacting: Optional[bool] = None, deleting: Optional[bool] = None, ensure_created: bool = False) -> None: ...
    def key_partition(self, topic: str, key: Any, partition: Optional[int] = None) -> Optional[int]: ...

