from __future__ import annotations
from abc import ABC, abstractmethod
from typing import TYPE_CHECKING, Any, Optional, Union, overload, cast
import numpy as np
from pandas._libs import NaT, Timedelta
from pandas._libs.tslibs import BaseOffset, Resolution, Tick
from pandas.core.dtypes.dtypes import CategoricalDtype
from pandas.core.arrays import ExtensionArray
from pandas.core.indexes.base import Index
from pandas.core.indexes.extension import NDArrayBackedExtensionIndex
from pandas.core.indexes.range import RangeIndex

if TYPE_CHECKING:
    from collections.abc import Sequence
    from datetime import datetime
    from pandas._typing import Self, npt
    from pandas import CategoricalIndex

class DatetimeIndexOpsMixin(NDArrayBackedExtensionIndex, ABC):
    """
    Common ops mixin to support a unified interface datetimelike Index.
    """
    _can_hold_strings: bool
    _default_na_rep: str

    def mean(self, *, skipna: bool = True, axis: int = 0) -> Any: ...

    @property
    def freq(self) -> Optional[BaseOffset]: ...

    @freq.setter
    def freq(self, value: Optional[BaseOffset]) -> None: ...

    @property
    def asi8(self) -> npt.NDArray[np.int64]: ...

    @property
    def freqstr(self) -> Optional[str]: ...

    @abstractmethod
    def _resolution_obj(self) -> Resolution: ...

    @property
    def resolution(self) -> Resolution: ...

    @property
    def hasnans(self) -> bool: ...

    def equals(self, other: Any) -> bool: ...

    def __contains__(self, key: Any) -> bool: ...

    def _convert_tolerance(self, tolerance: Any, target: Any) -> Any: ...

    def _format_with_header(self, *, header: list[str], na_rep: str, date_format: Optional[str] = None) -> list[Any]: ...

    @property
    def _formatter_func(self) -> Any: ...

    def _format_attrs(self) -> list[tuple[str, Any]]: ...

    def _summary(self, name: Optional[str] = None) -> str: ...

    def _can_partial_date_slice(self, reso: Resolution) -> bool: ...

    def _parsed_string_to_bounds(self, reso: Resolution, parsed: datetime) -> tuple[Any, Any]: ...

    def _parse_with_reso(self, label: str) -> tuple[datetime, Resolution]: ...

    def _get_string_slice(self, key: str) -> Union[slice, npt.NDArray[np.intp]]: ...

    def _partial_date_slice(self, reso: Resolution, parsed: datetime) -> Union[slice, npt.NDArray[np.intp]]: ...

    def _maybe_cast_slice_bound(self, label: Any, side: str) -> Any: ...

    def shift(self, periods: int = 1, freq: Optional[Union[BaseOffset, Timedelta, str]] = None) -> Index: ...

    def _maybe_cast_listlike_indexer(self, keyarr: Any) -> Index: ...

class DatetimeTimedeltaMixin(DatetimeIndexOpsMixin, ABC):
    """
    Mixin class for methods shared by DatetimeIndex and TimedeltaIndex,
    but not PeriodIndex
    """
    _comparables: list[str]
    _attributes: list[str]

    @property
    def unit(self) -> str: ...

    def as_unit(self, unit: str) -> Self: ...

    def _with_freq(self, freq: Optional[Union[BaseOffset, str]]) -> Self: ...

    @property
    def values(self) -> npt.NDArray[Any]: ...

    def shift(self, periods: int = 1, freq: Optional[Union[BaseOffset, Timedelta, str]] = None) -> Self: ...

    @property
    def inferred_freq(self) -> Optional[str]: ...

    def _as_range_index(self) -> RangeIndex: ...

    def _can_range_setop(self, other: DatetimeTimedeltaMixin) -> bool: ...

    def _wrap_range_setop(self, other: DatetimeTimedeltaMixin, res_i8: RangeIndex) -> Self: ...

    def _range_intersect(self, other: DatetimeTimedeltaMixin, sort: bool) -> Self: ...

    def _range_union(self, other: DatetimeTimedeltaMixin, sort: bool) -> Self: ...

    def _intersection(self, other: DatetimeTimedeltaMixin, sort: bool = False) -> Self: ...

    def _fast_intersect(self, other: DatetimeTimedeltaMixin, sort: bool) -> Self: ...

    def _can_fast_intersect(self, other: DatetimeTimedeltaMixin) -> bool: ...

    def _can_fast_union(self, other: DatetimeTimedeltaMixin) -> bool: ...

    def _fast_union(self, other: DatetimeTimedeltaMixin, sort: Optional[bool] = None) -> Self: ...

    def _union(self, other: DatetimeTimedeltaMixin, sort: bool) -> Self: ...

    def _get_join_freq(self, other: DatetimeTimedeltaMixin) -> Optional[BaseOffset]: ...

    def _wrap_join_result(self, joined: Index, other: DatetimeTimedeltaMixin, lidx: npt.NDArray[np.intp], ridx: npt.NDArray[np.intp], how: str) -> tuple[Index, npt.NDArray[np.intp], npt.NDArray[np.intp]]: ...

    def _get_engine_target(self) -> npt.NDArray[np.int64]: ...

    def _from_join_target(self, result: npt.NDArray[Any]) -> Any: ...

    def _get_delete_freq(self, loc: Any) -> Optional[BaseOffset]: ...

    def _get_insert_freq(self, loc: int, item: Any) -> Optional[BaseOffset]: ...

    def delete(self, loc: Any) -> Self: ...

    def insert(self, loc: int, item: Any) -> Self: ...

    def take(self, indices: Sequence[int], axis: int = 0, allow_fill: bool = True, fill_value: Any = None, **kwargs: Any) -> Self: ...