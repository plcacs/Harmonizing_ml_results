from typing import Any, Optional, Tuple, TypeVar, Protocol, Dict
from eth2spec.test.helpers.constants import CAPELLA, DENEB, ELECTRA

# Define Protocols for the 'spec' and 'state' objects to provide concrete typing
# based on the attribute access patterns in the implementation.

class SpecProtocol(Protocol):
    FINALIZED_ROOT_GINDEX: int
    FINALIZED_ROOT_GINDEX_ELECTRA: int
    CURRENT_SYNC_COMMITTEE_GINDEX: int
    CURRENT_SYNC_COMMITTEE_GINDEX_ELECTRA: int
    NEXT_SYNC_COMMITTEE_GINDEX: int
    NEXT_SYNC_COMMITTEE_GINDEX_ELECTRA: int
    EPOCHS_PER_SYNC_COMMITTEE_PERIOD: int
    SYNC_COMMITTEE_SIZE: int
    def normalize_merkle_branch(self, branch: Any, gindex: int) -> Any: ...
    def compute_start_slot_at_epoch(self, epoch: int) -> int: ...
    def compute_sync_committee_period_at_slot(self, slot: int) -> int: ...
    def compute_merkle_proof(self, state: Any, gindex: int) -> Any: ...
    def block_to_light_client_header(self, block: Any) -> Any: ...
    def get_lc_execution_root(self, header: Any) -> Any: ...
    class SyncAggregate:
        def __init__(self, sync_committee_bits: list[bool], sync_committee_signature: Any) -> None: ...
    class LightClientUpdate:
        attested_header: Any
        next_sync_committee: Any
        next_sync_committee_branch: Any
        finalized_header: Any
        finality_branch: Any
        sync_aggregate: Any
        signature_slot: int
        def __init__(self) -> None: ...
    class Root: ...

class StateProtocol(Protocol):
    slot: int
    next_sync_committee: Any

Spec = TypeVar("Spec", bound=SpecProtocol)
State = TypeVar("State", bound=StateProtocol)

def latest_finalized_root_gindex(spec: Spec) -> int: ...
def latest_current_sync_committee_gindex(spec: Spec) -> int: ...
def latest_next_sync_committee_gindex(spec: Spec) -> int: ...
def latest_normalize_merkle_branch(spec: Spec, branch: Any, gindex: int) -> Any: ...
def compute_start_slot_at_sync_committee_period(spec: Spec, sync_committee_period: int) -> int: ...
def compute_start_slot_at_next_sync_committee_period(spec: Spec, state: State) -> int: ...

def get_sync_aggregate(
    spec: Spec, 
    state: State, 
    num_participants: Optional[int] = None, 
    signature_slot: Optional[int] = None, 
    phases: Optional[Any] = None
) -> Tuple[Any, int]: ...

def create_update(
    spec: Spec, 
    attested_state: State, 
    attested_block: Any, 
    finalized_block: Any, 
    with_next: bool, 
    with_finality: bool, 
    participation_rate: float, 
    signature_slot: Optional[int] = None
) -> Any: ...

def needs_upgrade_to_capella(spec: Spec, new_spec: Spec) -> bool: ...
def needs_upgrade_to_deneb(spec: Spec, new_spec: Spec) -> bool: ...
def needs_upgrade_to_electra(spec: Spec, new_spec: Spec) -> bool: ...

def check_merkle_branch_equal(spec: Spec, new_spec: Spec, data: Any, upgraded: Any, gindex: int) -> None: ...
def check_lc_header_equal(spec: Spec, new_spec: Spec, data: Any, upgraded: Any) -> None: ...

def upgrade_lc_header_to_new_spec(spec: Spec, new_spec: Spec, data: Any, phases: Dict[Any, Any]) -> Any: ...

def check_lc_bootstrap_equal(spec: Spec, new_spec: Spec, data: Any, upgraded: Any) -> None: ...
def upgrade_lc_bootstrap_to_new_spec(spec: Spec, new_spec: Spec, data: Any, phases: Dict[Any, Any]) -> Any: ...

def check_lc_update_equal(spec: Spec, new_spec: Spec, data: Any, upgraded: Any) -> None: ...
def upgrade_lc_update_to_new_spec(spec: Spec, new_spec: Spec, data: Any, phases: Dict[Any, Any]) -> Any: ...

def check_lc_finality_update_equal(spec: Spec, new_spec: Spec, data: Any, upgraded: Any) -> None: ...
def upgrade_lc_finality_update_to_new_spec(spec: Spec, new_spec: Spec, data: Any, phases: Dict[Any, Any]) -> Any: ...

def check_lc_store_equal(spec: Spec, new_spec: Spec, data: Any, upgraded: Any) -> None: ...
def upgrade_lc_store_to_new_spec(spec: Spec, new_spec: Spec, data: Any, phases: Dict[Any, Any]) -> Any: ...