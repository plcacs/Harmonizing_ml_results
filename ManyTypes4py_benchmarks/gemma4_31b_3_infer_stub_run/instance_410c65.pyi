from typing import Any, Generator, Iterable, Optional, Union, Iterator, Sequence
from abc import abstractproperty
from parso.tree import Node
from jedi.inference.filters import AbstractFilter, AnonymousFunctionExecutionFilter
from jedi.inference.names import ValueName, TreeNameDefinition, ParamName, NameWrapper
from jedi.inference.base_value import Value, ValueSet
from jedi.inference.lazy_value import LazyKnownValue, LazyKnownValues
from jedi.inference.arguments import ValuesArguments, TreeArgumentsWrapper
from jedi.inference.value.function import (
    FunctionValue,
    FunctionMixin,
    OverloadedFunctionValue,
    BaseFunctionExecutionContext,
    FunctionExecutionContext,
    FunctionNameInClass,
)
from jedi.inference.value.klass import ClassFilter
from jedi.inference.compiled.value import CompiledValueFilter

class InstanceExecutedParamName(ParamName):
    def __init__(self, instance: 'AbstractInstanceValue', function_value: FunctionValue, tree_name: Node) -> None: ...
    def infer(self) -> ValueSet['AbstractInstanceValue']: ...
    def matches_signature(self) -> bool: ...

class AnonymousMethodExecutionFilter(AnonymousFunctionExecutionFilter):
    def __init__(self, instance: 'AbstractInstanceValue', *args: Any, **kwargs: Any) -> None: ...
    def _convert_param(self, param: Any, name: Any) -> Any: ...

class AnonymousMethodExecutionContext(BaseFunctionExecutionContext):
    instance: 'AbstractInstanceValue'
    def __init__(self, instance: 'AbstractInstanceValue', value: Any) -> None: ...
    def get_filters(self, until_position: Optional[int] = None, origin_scope: Optional[Any] = None) -> Generator[AnonymousMethodExecutionFilter, None, None]: ...
    def get_param_names(self) -> list[ParamName]: ...

class MethodExecutionContext(FunctionExecutionContext):
    instance: 'AbstractInstanceValue'
    def __init__(self, instance: 'AbstractInstanceValue', *args: Any, **kwargs: Any) -> None: ...

class AbstractInstanceValue(Value):
    api_type: str
    class_value: Any
    def __init__(self, inference_state: Any, parent_context: Any, class_value: Any) -> None: ...
    def is_instance(self) -> bool: ...
    def get_qualified_names(self) -> Iterable[str]: ...
    def get_annotated_class_object(self) -> Any: ...
    def py__class__(self) -> Any: ...
    def py__bool__(self) -> None: ...
    @abstractproperty
    def name(self) -> Any: ...
    def get_signatures(self) -> list[Any]: ...
    def get_function_slot_names(self, name: str) -> list[Any]: ...
    def execute_function_slots(self, names: Iterable[Any], *inferred_args: Any) -> ValueSet[Any]: ...
    def get_type_hint(self, add_class_info: bool = True) -> str: ...
    def py__getitem__(self, index_value_set: ValueSet[Any], contextualized_node: Optional[Node]) -> ValueSet[Any]: ...
    def py__iter__(self, contextualized_node: Optional[Node] = None) -> Iterator[Any]: ...
    def __repr__(self) -> str: ...

class CompiledInstance(AbstractInstanceValue):
    def __init__(self, inference_state: Any, parent_context: Any, class_value: Any, arguments: Any) -> None: ...
    def get_filters(self, origin_scope: Optional[Any] = None, include_self_names: bool = True) -> Generator[CompiledInstanceClassFilter, None, None]: ...
    @property
    def name(self) -> Any: ...
    def is_stub(self) -> bool: ...

class _BaseTreeInstance(AbstractInstanceValue):
    @property
    def array_type(self) -> Optional[str]: ...
    @property
    def name(self) -> ValueName: ...
    def get_filters(self, origin_scope: Optional[Any] = None, include_self_names: bool = True) -> Generator[Any, None, None]: ...
    def create_instance_context(self, class_context: Any, node: Node) -> Any: ...
    def py__getattribute__alternatives(self, string_name: str) -> ValueSet[Any]: ...
    def py__next__(self, contextualized_node: Optional[Node] = None) -> Generator[LazyKnownValues, None, None]: ...
    def py__call__(self, arguments: Any) -> ValueSet[Any]: ...
    def py__get__(self, instance: Optional[Any], class_value: Any) -> Union[Any, ValueSet[Any]]: ...

class TreeInstance(_BaseTreeInstance):
    def __init__(self, inference_state: Any, parent_context: Any, class_value: Any, arguments: Any) -> None: ...
    def _get_annotated_class_object(self) -> Optional[Any]: ...
    def get_annotated_class_object(self) -> Any: ...
    def get_key_values(self) -> ValueSet[Any]: ...
    def py__simple_getitem__(self, index: Any) -> ValueSet[Any]: ...
    def __repr__(self) -> str: ...

class AnonymousInstance(_BaseTreeInstance):
    _arguments: Optional[Any]

class CompiledInstanceName(NameWrapper):
    @iterator_to_value_set
    def infer(self) -> Generator[Any, None, None]: ...

class CompiledInstanceClassFilter(AbstractFilter):
    def __init__(self, instance: 'AbstractInstanceValue', f: AbstractFilter) -> None: ...
    def get(self, name: str) -> list[CompiledInstanceName]: ...
    def values(self) -> list[CompiledInstanceName]: ...
    def _convert(self, names: list[Any]) -> list[CompiledInstanceName]: ...

class BoundMethod(FunctionMixin, ValueWrapper):
    instance: 'AbstractInstanceValue'
    def __init__(self, instance: 'AbstractInstanceValue', class_context: Any, function: Any) -> None: ...
    def is_bound_method(self) -> bool: ...
    @property
    def name(self) -> FunctionNameInClass: ...
    def py__class__(self) -> Any: ...
    def _get_arguments(self, arguments: Any) -> 'InstanceArguments': ...
    def _as_context(self, arguments: Optional[Any] = None) -> Union[AnonymousMethodExecutionContext, MethodExecutionContext]: ...
    def py__call__(self, arguments: Any) -> Any: ...
    def get_signature_functions(self) -> list['BoundMethod']: ...
    def get_signatures(self) -> list[Any]: ...
    def __repr__(self) -> str: ...

class CompiledBoundMethod(ValueWrapper):
    def is_bound_method(self) -> bool: ...
    def get_signatures(self) -> list[Any]: ...

class SelfName(TreeNameDefinition):
    def __init__(self, instance: 'AbstractInstanceValue', class_context: Any, tree_name: Node) -> None: ...
    @property
    def parent_context(self) -> Any: ...
    def get_defining_qualified_value(self) -> 'AbstractInstanceValue': ...
    def infer(self) -> ValueSet[Any]: ...

class LazyInstanceClassName(NameWrapper):
    def __init__(self, instance: 'AbstractInstanceValue', class_member_name: Any) -> None: ...
    @iterator_to_value_set
    def infer(self) -> Generator[Any, None, None]: ...
    def get_signatures(self) -> list[Any]: ...
    def get_defining_qualified_value(self) -> 'AbstractInstanceValue': ...

class InstanceClassFilter(AbstractFilter):
    def __init__(self, instance: 'AbstractInstanceValue', class_filter: AbstractFilter) -> None: ...
    def get(self, name: str) -> list[LazyInstanceClassName]: ...
    def values(self) -> list[LazyInstanceClassName]: ...
    def _convert(self, names: list[Any]) -> list[LazyInstanceClassName]: ...
    def __repr__(self) -> str: ...

class SelfAttributeFilter(ClassFilter):
    def __init__(self, instance: 'AbstractInstanceValue', instance_class: Any, node_context: Any, origin_scope: Any) -> None: ...
    def _filter(self, names: list[Any]) -> Generator[Any, None, None]: ...
    def _filter_self_names(self, names: list[Any]) -> Generator[Any, None, None]: ...
    def _is_in_right_scope(self, self_name: Any, name: Any) -> bool: ...
    def _convert_names(self, names: list[Any]) -> list[SelfName]: ...
    def _check_flows(self, names: list[Any]) -> list[Any]: ...

class InstanceArguments(TreeArgumentsWrapper):
    instance: 'AbstractInstanceValue'
    def __init__(self, instance: 'AbstractInstanceValue', arguments: Any) -> None: ...
    def unpack(self, func: Optional[Any] = None) -> Generator[tuple[Optional[Any], Any], None, None]: ...