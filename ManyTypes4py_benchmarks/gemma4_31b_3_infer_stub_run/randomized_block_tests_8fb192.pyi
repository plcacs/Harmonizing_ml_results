def no_op_validation(_spec: T_Spec, _state: T_State) -> bool: ...

def validate_is_leaking(spec: T_Spec, state: T_State) -> bool: ...

def validate_is_not_leaking(spec: T_Spec, state: T_State) -> bool: ...

def with_validation(transition: Union[Callable[[], dict[str, Any]], dict[str, Any]], validation: Callable[[T_Spec, T_State], bool]) -> dict[str, Any]: ...

def no_op_transition() -> dict[str, Any]: ...

def epoch_transition(n: int = 0) -> dict[str, int]: ...

def slot_transition(n: int = 0) -> dict[str, int]: ...

def transition_to_leaking() -> dict[str, Any]: ...

transition_without_leak: dict[str, Any]

def transition_with_random_block(block_randomizer: Callable[[T_Spec, T_State, list[Any], dict[str, Any]], Optional[BlockProtocol]]) -> dict[str, Any]: ...

def _randomized_scenario_setup(state_randomizer: Callable[[T_Spec, T_State, dict[str, int]], Optional[dict[str, Any]]]) -> tuple[tuple[Callable[[T_Spec, T_State, dict[str, int]], Optional[dict[str, Any]]], Callable[[T_Spec, T_State], bool]], ...]: ...

def _resolve_ref(ref: Union[str, Any]) -> Any: ...

def _iter_temporal(spec: T_Spec, description: Union[str, int, Callable[[T_Spec], int]]) -> Generator[int, None, None]: ...

