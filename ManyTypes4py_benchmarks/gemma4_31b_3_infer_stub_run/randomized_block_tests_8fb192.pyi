"""
Utility code to generate randomized block tests
"""
from typing import Any, Callable, Generator, Optional, Union, Protocol, TypeVar, cast
from random import Random

# Define Protocols for the complex domain objects to avoid Any
class SpecProtocol(Protocol):
    MAX_DEPOSITS: int
    MIN_EPOCHS_TO_INACTIVITY_PENALTY: int
    SLOTS_PER_EPOCH: int
    MAX_BLS_TO_EXECUTION_CHANGES: int
    config: Any
    def get_beacon_proposer_index(self, state: Any) -> int: ...
    def is_in_inactivity_leak(self, state: Any) -> bool: ...

class StateProtocol(Protocol):
    slot: int
    validators: Any
    def copy(self) -> 'StateProtocol': ...

class BlockProtocol(Protocol):
    slot: int
    parent_root: Any
    body: Any

T_Spec = TypeVar('T_Spec', bound=SpecProtocol)
T_State = TypeVar('T_State', bound=StateProtocol)

def _randomize_deposit_state(spec: T_Spec, state: T_State, stats: dict[str, int]) -> dict[str, list[Any]]: ...

def randomize_state(spec: T_Spec, state: T_State, stats: dict[str, int], exit_fraction: float = 0.1, slash_fraction: float = 0.1) -> dict[str, list[Any]]: ...

def randomize_state_altair(spec: T_Spec, state: T_State, stats: dict[str, int], exit_fraction: float = 0.1, slash_fraction: float = 0.1) -> dict[str, list[Any]]: ...

def randomize_state_bellatrix(spec: T_Spec, state: T_State, stats: dict[str, int], exit_fraction: float = 0.1, slash_fraction: float = 0.1) -> dict[str, list[Any]]: ...

def randomize_state_capella(spec: T_Spec, state: T_State, stats: dict[str, int], exit_fraction: float = 0.1, slash_fraction: float = 0.1) -> dict[str, list[Any]]: ...

def randomize_state_deneb(spec: T_Spec, state: T_State, stats: dict[str, int], exit_fraction: float = 0.1, slash_fraction: float = 0.1) -> dict[str, list[Any]]: ...

def randomize_state_electra(spec: T_Spec, state: T_State, stats: dict[str, int], exit_fraction: float = 0.1, slash_fraction: float = 0.1) -> dict[str, list[Any]]: ...

def randomize_state_fulu(spec: T_Spec, state: T_State, stats: dict[str, int], exit_fraction: float = 0.1, slash_fraction: float = 0.1) -> dict[str, list[Any]]: ...

def epochs_until_leak(spec: T_Spec) -> int: ...

def epochs_for_shard_committee_period(spec: T_Spec) -> int: ...

def last_slot_in_epoch(spec: T_Spec) -> int: ...

def random_slot_in_epoch(spec: T_Spec, rng: Random = ...) -> int: ...

def penultimate_slot_in_epoch(spec: T_Spec) -> int: ...

def no_block(_spec: T_Spec, _pre_state: T_State, _signed_blocks: list[Any], _scenario_state: dict[str, Any]) -> None: ...

BLOCK_ATTEMPTS: int

def _warn_if_empty_operations(block: BlockProtocol) -> None: ...

def _pull_deposits_from_scenario_state(spec: T_Spec, scenario_state: dict[str, Any], existing_block_count: int) -> list[Any]: ...

def random_block(spec: T_Spec, state: T_State, signed_blocks: list[Any], scenario_state: dict[str, Any]) -> BlockProtocol: ...

SYNC_AGGREGATE_PARTICIPATION_BUCKETS: int

def random_block_altair_with_cycling_sync_committee_participation(spec: T_Spec, state: T_State, signed_blocks: list[Any], scenario_state: dict[str, Any]) -> BlockProtocol: ...

def random_block_bellatrix(spec: T_Spec, state: T_State, signed_blocks: list[Any], scenario_state: dict[str, Any], rng: Random = ...) -> BlockProtocol: ...

def random_block_capella(spec: T_Spec, state: T_State, signed_blocks: list[Any], scenario_state: dict[str, Any], rng: Random = ...) -> BlockProtocol: ...

def random_block_deneb(spec: T_Spec, state: T_State, signed_blocks: list[Any], scenario_state: dict[str, Any], rng: Random = ...) -> BlockProtocol: ...

def random_block_electra(spec: T_Spec, state: T_State, signed_blocks: list[Any], scenario_state: dict[str, Any], rng: Random = ...) -> BlockProtocol: ...

