from __future__ import annotations
from typing import TYPE_CHECKING, Optional, Union, Any, overload
import numpy as np
from pandas.core.dtypes.generic import ABCSeries
from pandas.core.accessor import PandasDelegate
from pandas.core.base import PandasObject, NoNewAttributesMixin
from pandas.core.arrays.arrow.array import ArrowExtensionArray
from pandas import DataFrame, Series

if TYPE_CHECKING:
    from pandas.core.indexes.datetimes import DatetimeIndex
    from pandas.core.indexes.timedeltas import TimedeltaIndex
    from pandas.core.arrays import PeriodArray

class Properties(PandasDelegate, PandasObject, NoNewAttributesMixin):
    orig: Any
    name: Optional[str]

    def __init__(self, data: ABCSeries, orig: Any) -> None: ...
    def _get_values(self) -> Union[DatetimeIndex, TimedeltaIndex, PeriodArray] -> None: ...
    def _delegate_property_get(self, name: str) -> Any: ...
    def _delegate_property_set(self, name: str, value: Any, *args: Any, **kwargs: Any) -> None: ...
    def _delegate_method(self, name: str, *args: Any, **kwargs: Any) -> Any: ...

class ArrowTemporalProperties(PandasDelegate, PandasObject, NoNewAttributesMixin):
    def __init__(self, data: ABCSeries, orig: Any) -> None: ...
    def _delegate_property_get(self, name: str) -> Any: ...
    def _delegate_method(self, name: str, *args: Any, **kwargs: Any) -> Any: ...
    def to_pytimedelta(self) -> np.ndarray: ...
    def to_pydatetime(self) -> np.ndarray: ...
    def isocalendar(self) -> DataFrame: ...
    @property
    def components(self) -> DataFrame: ...

class DatetimeProperties(Properties):
    def to_pydatetime(self) -> Series: ...
    @property
    def freq(self) -> Optional[str]: ...
    def isocalendar(self) -> DataFrame: ...

class TimedeltaProperties(Properties):
    def to_pytimedelta(self) -> np.ndarray: ...
    @property
    def components(self) -> DataFrame: ...
    @property
    def freq(self) -> Optional[str]: ...

class PeriodProperties(Properties): ...

class CombinedDatetimelikeProperties:
    def __new__(cls, data: ABCSeries) -> Union[ArrowTemporalProperties, DatetimeProperties, TimedeltaProperties, PeriodProperties]: ...