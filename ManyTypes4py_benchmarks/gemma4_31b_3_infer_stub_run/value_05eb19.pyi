"""
Imitate the parser representation.
"""
import re
from functools import partial
from inspect import Parameter
from pathlib import Path
from typing import Optional, Any, Union, Iterable, Generator, Sequence, Tuple, Callable, Type, TypeVar

from jedi.inference.utils import to_list
from jedi.inference.filters import AbstractFilter
from jedi.inference.names import AbstractNameDefinition, ValueNameMixin, ParamNameInterface
from jedi.inference.base_value import Value, ValueSet, NO_VALUES
from jedi.inference.lazy_value import LazyKnownValue
from jedi.inference.compiled.access import _sentinel
from jedi.inference.signature import BuiltinSignature
from jedi.inference.context import CompiledContext, CompiledModuleContext

T = TypeVar("T")

class CheckAttribute:
    """Raises :exc:`AttributeError` if the attribute X is not available."""
    check_name: Optional[str]
    func: Callable[..., Any]

    def __init__(self, check_name: Optional[str] = None) -> None: ...
    def __call__(self, func: Callable[..., Any]) -> 'CheckAttribute': ...
    def __get__(self, instance: Any, owner: Type[Any]) -> Union['CheckAttribute', Callable[..., Any]]: ...

class CompiledValue(Value):
    access_handle: Any

    def __init__(self, inference_state: Any, access_handle: Any, parent_context: Optional[Any] = None) -> None: ...
    def py__call__(self, arguments: Any) -> ValueSet[Value]: ...
    def py__class__(self) -> 'CompiledValue': ...
    def py__mro__(self) -> Tuple['CompiledValue', ...]: ...
    def py__bases__(self) -> Tuple['CompiledValue', ...]: ...
    def get_qualified_names(self) -> Optional[Tuple[str, ...]]: ...
    def py__bool__(self) -> bool: ...
    def is_class(self) -> bool: ...
    def is_function(self) -> bool: ...
    def is_module(self) -> bool: ...
    def is_compiled(self) -> bool: ...
    def is_stub(self) -> bool: ...
    def is_instance(self) -> bool: ...
    def py__doc__(self) -> Optional[str]: ...
    def get_param_names(self) -> Generator[Union['SignatureParamName', 'UnresolvableParamName'], None, None]: ...
    def get_signatures(self) -> list[BuiltinSignature]: ...
    def __repr__(self) -> str: ...
    def _parse_function_doc(self) -> Tuple[str, str]: ...
    @property
    def api_type(self) -> str: ...
    def get_filters(self, is_instance: bool = False, origin_scope: Optional[Any] = None) -> Generator['CompiledValueFilter', None, None]: ...
    def _ensure_one_filter(self, is_instance: bool) -> 'CompiledValueFilter': ...
    def py__simple_getitem__(self, index: Any) -> ValueSet[Value]: ...
    def py__getitem__(self, index_value_set: ValueSet[Value], contextualized_node: Any) -> ValueSet[Value]: ...
    def py__iter__(self, contextualized_node: Optional[Any] = None) -> Generator[LazyKnownValue, None, None]: ...
    def py__name__(self) -> Optional[str]: ...
    @property
    def name(self) -> 'CompiledValueName': ...
    def _execute_function(self, params: Any) -> Generator[Value, None, None]: ...
    def get_safe_value(self, default: Any = _sentinel) -> Any: ...
    def execute_operation(self, other: Value, operator: str) -> ValueSet[Value]: ...
    def execute_annotation(self) -> ValueSet[Value]: ...
    def negate(self) -> 'CompiledValue': ...
    def get_metaclasses(self) -> ValueSet[Value]: ...
    def _as_context(self) -> CompiledContext: ...
    @property
    def array_type(self) -> Any: ...
    def get_key_values(self) -> list['CompiledValue']: ...
    def get_type_hint(self, add_class_info: bool = True) -> Optional[str]: ...

class CompiledModule(CompiledValue):
    file_io: Optional[Any]
    def _as_context(self) -> CompiledModuleContext: ...
    def py__path__(self) -> Optional[str]: ...
    def is_package(self) -> bool: ...
    @property
    def string_names(self) -> Tuple[str, ...]: ...
    def py__file__(self) -> Optional[str]: ...

class CompiledName(AbstractNameDefinition):
    _inference_state: Any
    parent_context: Any
    _parent_value: CompiledValue
    string_name: str

    def __init__(self, inference_state: Any, parent_value: CompiledValue, name: str) -> None: ...
    def py__doc__(self) -> Optional[str]: ...
    def _get_qualified_names(self) -> Optional[Tuple[str, ...]]: ...
    def get_defining_qualified_value(self) -> Optional[Any]: ...
    def __repr__(self) -> str: ...
    @property
    def api_type(self) -> str: ...
    def infer(self) -> ValueSet[Value]: ...
    def infer_compiled_value(self) -> CompiledValue: ...

class SignatureParamName(ParamNameInterface, AbstractNameDefinition):
    parent_context: Any
    _signature_param: Any

    def __init__(self, compiled_value: CompiledValue, signature_param: Any) -> None: ...
    @property
    def string_name(self) -> str: ...
    def to_string(self) -> str: ...
    def get_kind(self) -> Parameter: ...
    def infer(self) -> ValueSet[Value]: ...

class UnresolvableParamName(ParamNameInterface, AbstractNameDefinition):
    parent_context: Any
    string_name: str
    _default: Optional[str]

    def __init__(self, compiled_value: CompiledValue, name: str, default: Optional[str]) -> None: ...
    def get_kind(self) -> Parameter: ...
    def to_string(self) -> str: ...
    def infer(self) -> ValueSet[Value]: ...

class CompiledValueName(ValueNameMixin, AbstractNameDefinition):
    string_name: str
    _value: CompiledValue
    parent_context: Any

    def __init__(self, value: CompiledValue, name: str) -> None: ...

class EmptyCompiledName(AbstractNameDefinition):
    parent_context: Any
    string_name: str

    def __init__(self, inference_state: Any, name: str) -> None: ...
    def infer(self) -> ValueSet[Value]: ...

class CompiledValueFilter(AbstractFilter):
    _inference_state: Any
    compiled_value: CompiledValue
    is_instance: bool

    def __init__(self, inference_state: Any, compiled_value: CompiledValue, is_instance: bool = False) -> None: ...
    def get(self, name: str) -> list[Union[CompiledName, EmptyCompiledName]]: ...
    def _get(self, name: str, allowed_getattr_callback: Callable[[str, Any], Tuple[bool, bool]], in_dir_callback: Callable[[str], bool], check_has_attribute: bool = False) -> list[Union[CompiledName, EmptyCompiledName]]: ...
    def _get_cached_name(self, name: str, is_empty: bool = False) -> Union[CompiledName, EmptyCompiledName]: ...
    def values(self) -> list[Union[CompiledName, EmptyCompiledName]]: ...
    def _create_name(self, name: str) -> CompiledName: ...
    def __repr__(self) -> str: ...

docstr_defaults: dict[str, str]

def _parse_function_doc(doc: str) -> Tuple[str, str]: ...
def create_from_name(inference_state: Any, compiled_value: CompiledValue, name: str) -> Optional[CompiledValue]: ...
def _normalize_create_args(func: Callable[..., T]) -> Callable[..., T]: ...
def create_from_access_path(inference_state: Any, access_path: Any) -> CompiledValue: ...
def create_cached_compiled_value(inference_state: Any, access_handle: Any, parent_context: Optional[Any]) -> Union[CompiledValue, CompiledModule]: ...