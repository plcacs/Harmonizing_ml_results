"""
Spark related features. Usually, the features here are missing in pandas
but Spark has it.
"""

from abc import ABCMeta
from distutils.version import LooseVersion
from typing import TYPE_CHECKING, Optional, Union, List, cast, Any
import pyspark
from pyspark import StorageLevel
from pyspark.sql import Column, DataFrame as SparkDataFrame
from pyspark.sql.types import DataType, StructType
from databricks.koalas import MultiIndex, Index
from databricks.koalas.base import IndexOpsMixin
from databricks.koalas.frame import DataFrame, CachedDataFrame
from databricks.koalas.series import Series

if TYPE_CHECKING:
    import databricks.koalas as ks

class SparkIndexOpsMethods(metaclass=ABCMeta):
    def __init__(self, data: IndexOpsMixin) -> None: ...
    @property
    def data_type(self) -> DataType: ...
    @property
    def nullable(self) -> bool: ...
    @property
    def column(self) -> Column: ...
    def transform(self, func: callable) -> Union[Series, Index]: ...
    @property
    @abstractmethod
    def analyzed(self) -> Any: ...

class SparkSeriesMethods(SparkIndexOpsMethods):
    def transform(self, func: callable) -> Series: ...
    def apply(self, func: callable) -> Series: ...
    @property
    def analyzed(self) -> Series: ...

class SparkIndexMethods(SparkIndexOpsMethods):
    def transform(self, func: callable) -> Index: ...
    @property
    def analyzed(self) -> Index: ...

class SparkFrameMethods:
    def __init__(self, frame: DataFrame) -> None: ...
    def schema(self, index_col: Optional[Union[str, List[str]]] = None) -> StructType: ...
    def print_schema(self, index_col: Optional[Union[str, List[str]]] = None) -> None: ...
    def frame(self, index_col: Optional[Union[str, List[str]]] = None) -> SparkDataFrame: ...
    def cache(self) -> CachedDataFrame: ...
    def persist(self, storage_level: StorageLevel = StorageLevel.MEMORY_AND_DISK) -> CachedDataFrame: ...
    def hint(self, name: str, *parameters: Any) -> DataFrame: ...
    def to_table(self, name: str, format: Optional[str] = None, mode: str = 'overwrite', partition_cols: Optional[Union[str, List[str]]] = None, index_col: Optional[Union[str, List[str]]] = None, **options: Any) -> None: ...
    def to_spark_io(self, path: Optional[str] = None, format: Optional[str] = None, mode: str = 'overwrite', partition_cols: Optional[Union[str, List[str]]] = None, index_col: Optional[Union[str, List[str]]] = None, **options: Any) -> None: ...
    def explain(self, extended: Optional[Union[bool, str]] = None, mode: Optional[str] = None) -> None: ...
    def apply(self, func: callable, index_col: Optional[Union[str, List[str]]] = None) -> DataFrame: ...
    def repartition(self, num_partitions: int) -> DataFrame: ...
    def coalesce(self, num_partitions: int) -> DataFrame: ...
    def checkpoint(self, eager: bool = True) -> DataFrame: ...
    def local_checkpoint(self, eager: bool = True) -> DataFrame: ...
    @property
    def analyzed(self) -> DataFrame: ...

class CachedSparkFrameMethods(SparkFrameMethods):
    @property
    def storage_level(self) -> StorageLevel: ...
    def unpersist(self) -> None: ...