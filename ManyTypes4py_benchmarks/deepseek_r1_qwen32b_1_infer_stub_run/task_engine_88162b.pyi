async def run_generator_task_async(task: Task, task_run_id: Optional[UUID] = None, task_run: Optional[TaskRun] = None, parameters: Optional[dict] = None, wait_for: Optional[Any] = None, return_type: Literal['result'] = 'result', dependencies: Optional[dict] = None, context: Optional[dict] = None) -> AsyncGenerator[R, None]: ...

