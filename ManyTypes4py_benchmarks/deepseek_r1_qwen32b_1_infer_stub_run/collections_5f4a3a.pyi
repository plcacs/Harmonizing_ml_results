import copy
from collections.abc import Iterable
from typing import Any, Callable, Iterable, List, Optional, Tuple, Union, overload
from hypothesis.errors import InvalidArgument
from hypothesis.internal.conjecture.utils import LazySequenceCopy
from hypothesis.strategies._internal.strategies import (
    T, T3, T4, T5, Ex, MappedStrategy, SearchStrategy, check_strategy, filter_not_satisfied
)

class TupleStrategy(SearchStrategy):
    def __init__(self, strategies: Tuple[SearchStrategy, ...]) -> None: ...
    def do_validate(self) -> None: ...
    def calc_label(self) -> str: ...
    def __repr__(self) -> str: ...
    def calc_has_reusable_values(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def do_draw(self, data: Any) -> Tuple[Any, ...]: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...

@overload
def tuples() -> SearchStrategy[Any]: ...
@overload
def tuples(__a1: SearchStrategy[Any]) -> TupleStrategy: ...
@overload
def tuples(__a1: SearchStrategy[Any], __a2: SearchStrategy[Any]) -> TupleStrategy: ...
@overload
def tuples(__a1: SearchStrategy[Any], __a2: SearchStrategy[Any], __a3: SearchStrategy[Any]) -> TupleStrategy: ...
@overload
def tuples(__a1: SearchStrategy[Any], __a2: SearchStrategy[Any], __a3: SearchStrategy[Any], __a4: SearchStrategy[Any]) -> TupleStrategy: ...
@overload
def tuples(__a1: SearchStrategy[Any], __a2: SearchStrategy[Any], __a3: SearchStrategy[Any], __a4: SearchStrategy[Any], __a5: SearchStrategy[Any]) -> TupleStrategy: ...
@overload
def tuples(*args: SearchStrategy[Any]) -> TupleStrategy: ...
def tuples(*args: SearchStrategy[Any]) -> TupleStrategy: ...

class ListStrategy(SearchStrategy):
    def __init__(self, elements: SearchStrategy[Any], min_size: int = 0, max_size: Union[int, float] = float('inf')) -> None: ...
    def calc_label(self) -> str: ...
    def do_validate(self) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def do_draw(self, data: Any) -> List[Any]: ...
    def filter(self, condition: Callable[[Any], bool]) -> ListStrategy: ...

class UniqueListStrategy(ListStrategy):
    def __init__(self, elements: SearchStrategy[Any], min_size: int, max_size: Union[int, float], keys: List[Callable[[Any], Any]], tuple_suffixes: Optional[SearchStrategy[Any]]) -> None: ...
    def do_draw(self, data: Any) -> List[Any]: ...

class UniqueSampledListStrategy(UniqueListStrategy):
    def do_draw(self, data: Any) -> List[Any]: ...

class FixedKeysDictStrategy(MappedStrategy):
    def __init__(self, strategy_dict: dict[Any, SearchStrategy[Any]]) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def __repr__(self) -> str: ...

class FixedAndOptionalKeysDictStrategy(SearchStrategy):
    def __init__(self, strategy_dict: dict[Any, SearchStrategy[Any]], optional: dict[Any, SearchStrategy[Any]]) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def __repr__(self) -> str: ...
    def do_draw(self, data: Any) -> dict[Any, Any]: ...