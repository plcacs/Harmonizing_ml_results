from typing import Any, Dict, List, Optional, Set, Tuple, Union
from dbt.contracts.graph.manifest import Manifest
from dbt.contracts.graph.nodes import GraphMemberNode
from dbt.contracts.state import PreviousState
from dbt.node_types import NodeType
from dbt_common.events.functions import NoNodesForSelectionCriteria, SelectorReportInvalidSelector
from dbt.exceptions import DbtInternalError, InvalidSelectorError
from .graph import Graph, UniqueId
from .queue import GraphQueue
from .selector_methods import MethodManager
from .selector_spec import IndirectSelection, SelectionCriteria, SelectionSpec

def get_package_names(nodes: List[str]) -> Set[str]: ...

def can_select_indirectly(node: GraphMemberNode) -> bool: ...

class NodeSelector(MethodManager):
    def __init__(self, graph: Graph, manifest: Manifest, previous_state: Optional[PreviousState] = ..., include_empty_nodes: bool = ...) -> None: ...
    def select_included(self, included_nodes: Set[str], spec: SelectionSpec) -> Set[str]: ...
    def get_nodes_from_criteria(self, spec: SelectionCriteria) -> Tuple[Set[str], Set[str]]: ...
    def collect_specified_neighbors(self, spec: SelectionSpec, selected: Set[str]) -> Set[str]: ...
    def select_nodes_recursively(self, spec: Union[SelectionCriteria, Any]) -> Tuple[Set[str], Set[str]]: ...
    def select_nodes(self, spec: Union[SelectionCriteria, Any]) -> Tuple[Set[str], Set[str]]: ...
    def _is_graph_member(self, unique_id: str) -> bool: ...
    def _is_empty_node(self, unique_id: str) -> bool: ...
    def node_is_match(self, node: GraphMemberNode) -> bool: ...
    def _is_match(self, unique_id: str) -> bool: ...
    def filter_selection(self, selected: Set[str]) -> Set[str]: ...
    def expand_selection(self, selected: Set[str], indirect_selection: IndirectSelection = ...) -> Tuple[Set[str], Set[str]]: ...
    def incorporate_indirect_nodes(self, direct_nodes: Set[str], indirect_nodes: Set[str] = ..., indirect_selection: IndirectSelection = ...) -> Set[str]: ...
    def get_selected(self, spec: Union[SelectionCriteria, Any]) -> Set[str]: ...
    def get_graph_queue(self, spec: Union[SelectionCriteria, Any], preserve_edges: bool = ...) -> GraphQueue: ...

class ResourceTypeSelector(NodeSelector):
    def __init__(self, graph: Graph, manifest: Manifest, previous_state: PreviousState, resource_types: List[NodeType], include_empty_nodes: bool = ...) -> None: ...
    def node_is_match(self, node: GraphMemberNode) -> bool: ...