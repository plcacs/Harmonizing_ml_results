    def hashed_name(self) -> str: ...
    def get_selector(self, name: str) -> Dict[str, Any]: ...
    def get_default_selector_name(self) -> Optional[str]: ...
    def get_macro_search_order(self, macro_namespace: str) -> Optional[List[str]]: ...
