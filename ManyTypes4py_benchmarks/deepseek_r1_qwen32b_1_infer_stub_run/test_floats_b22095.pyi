import numpy as np
import pytest
from pandas import DataFrame, Index, RangeIndex, Series, date_range, period_range, timedelta_range
import pandas._testing as tm

def gen_obj(klass: type[Union[Series, DataFrame]], index: Index) -> Union[Series, DataFrame]: ...

class TestFloatIndexers:
    def check(self, result: Union[Series, DataFrame], original: Union[Series, DataFrame], indexer: int, getitem: bool) -> None: ...

    @pytest.mark.parametrize('index', [Index(list('abcde')), Index(list('abcde'), dtype='category'), date_range('2020-01-01', periods=5), timedelta_range('1 day', periods=5), period_range('2020-01-01', periods=5)])
    def test_scalar_non_numeric(self, index: Index, frame_or_series: type[Union[Series, DataFrame]], indexer_sl: Union[tm.loc, tm.setitem]) -> None: ...

    @pytest.mark.parametrize('index', [Index(list('abcde')), Index(list('abcde'), dtype='category'), date_range('2020-01-01', periods=5), timedelta_range('1 day', periods=5), period_range('2020-01-01', periods=5)])
    def test_scalar_non_numeric_series_fallback(self, index: Index) -> None: ...

    def test_scalar_with_mixed(self, indexer_sl: Union[tm.loc, tm.setitem]) -> None: ...

    @pytest.mark.parametrize('index', [Index(np.arange(5), dtype=np.int64), RangeIndex(5)])
    def test_scalar_integer(self, index: Index, frame_or_series: type[Union[Series, DataFrame]], indexer_sl: Union[tm.loc, tm.setitem]) -> None: ...

    @pytest.mark.parametrize('index', [Index(np.arange(5), dtype=np.int64), RangeIndex(5)])
    def test_scalar_integer_contains_float(self, index: Index, frame_or_series: type[Union[Series, DataFrame]]) -> None: ...

    def test_scalar_float(self, frame_or_series: type[Union[Series, DataFrame]]) -> None: ...

    @pytest.mark.parametrize('index', [Index(list('abcde'), dtype=object), date_range('2020-01-01', periods=5), timedelta_range('1 day', periods=5), period_range('2020-01-01', periods=5)])
    @pytest.mark.parametrize('idx', [slice(3.0, 4), slice(3, 4.0), slice(3.0, 4.0)])
    def test_slice_non_numeric(self, index: Index, idx: slice, frame_or_series: type[Union[Series, DataFrame]], indexer_sli: Union[tm.iloc, tm.loc]) -> None: ...

    def test_slice_integer(self) -> None: ...

    def test_integer_positional_indexing(self, idx: slice) -> None: ...

    @pytest.mark.parametrize('index', [Index(np.arange(5), dtype=np.int64), RangeIndex(5)])
    def test_slice_integer_frame_getitem(self, index: Index) -> None: ...

    @pytest.mark.parametrize('idx', [slice(3.0, 4), slice(3, 4.0), slice(3.0, 4.0)])
    @pytest.mark.parametrize('index', [Index(np.arange(5), dtype=np.int64), RangeIndex(5)])
    def test_float_slice_getitem_with_integer_index_raises(self, idx: slice, index: Index) -> None: ...

    @pytest.mark.parametrize('idx', [slice(3.0, 4), slice(3, 4.0), slice(3.0, 4.0)])
    def test_slice_float(self, idx: slice, frame_or_series: type[Union[Series, DataFrame]], indexer_sl: Union[tm.loc, tm.setitem]) -> None: ...

    def test_floating_index_doc_example(self) -> None: ...

    def test_floating_misc(self, indexer_sl: Union[tm.loc, tm.setitem]) -> None: ...

    def test_floatindex_slicing_bug(self, float_numpy_dtype: np.dtype) -> None: ...