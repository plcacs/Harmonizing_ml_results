import inspect
import pickle
from collections.abc import Hashable
from types import SimpleNamespace
from typing import Any, Callable, Dict, List, Mapping, Optional, Union
import numpy as np
import pandas as pd
from snorkel.types import DataPoint, FieldMap, HashingFunction

MapFunction = Callable[[DataPoint], Optional[DataPoint]]

def get_parameters(f: Callable, allow_args: bool = ..., allow_kwargs: bool = ...) -> List[str]: ...

def is_hashable(obj: Any) -> bool: ...

def get_hashable(obj: Any) -> Hashable: ...

class BaseMapper:
    def __init__(self, name: str, pre: List['BaseMapper'], memoize: bool, memoize_key: Optional[HashingFunction] = None) -> None: ...
    def __call__(self, x: DataPoint) -> DataPoint: ...
    def reset_cache(self) -> None: ...
    def __repr__(self) -> str: ...
    memoize: bool

class Mapper(BaseMapper):
    def __init__(self, name: str, field_names: Optional[Dict[str, str]] = ..., mapped_field_names: Optional[Dict[str, str]] = ..., pre: Optional[List['BaseMapper']] = ..., memoize: bool = ..., memoize_key: Optional[HashingFunction] = ...) -> None: ...
    def run(self, **kwargs: Any) -> Optional[FieldMap]: ...
    def _generate_mapped_data_point(self, x: DataPoint) -> DataPoint: ...
    field_names: Dict[str, str]
    mapped_field_names: Optional[Dict[str, str]]

class LambdaMapper(BaseMapper):
    def __init__(self, name: str, f: MapFunction, pre: Optional[List['BaseMapper']] = ..., memoize: bool = ..., memoize_key: Optional[HashingFunction] = ...) -> None: ...
    def _generate_mapped_data_point(self, x: DataPoint) -> DataPoint: ...
    _f: MapFunction

class lambda_mapper:
    def __init__(self, name: Optional[str] = ..., pre: Optional[List['BaseMapper']] = ..., memoize: bool = ..., memoize_key: Optional[HashingFunction] = ...) -> None: ...
    def __call__(self, f: MapFunction) -> LambdaMapper: ...
    name: Optional[str]
    pre: Optional[List['BaseMapper']]
    memoize: bool
    memoize_key: Optional[HashingFunction]