from typing import Any, Callable, List, Optional, Tuple
from datetime import datetime

class Gauge:
    group: str
    name: str
    title: Optional[str]
    description: Optional[str]
    type: str
    value: int

    def __init__(self, group: str, name: str, title: Optional[str] = None, description: Optional[str] = None, value: int = 0) -> None: ...
    def serialize(self, format: str = 'json') -> str: ...
    def __repr__(self) -> str: ...
    @classmethod
    def from_document(cls, doc: dict) -> Gauge: ...
    @classmethod
    def from_record(cls, rec: Tuple) -> Gauge: ...
    @classmethod
    def from_db(cls, r: Any) -> Optional[Gauge]: ...
    def set(self, value: int) -> Gauge: ...
    @classmethod
    def find_all(cls) -> List[Gauge]: ...

class Counter:
    group: str
    name: str
    title: Optional[str]
    description: Optional[str]
    type: str
    count: int

    def __init__(self, group: str, name: str, title: Optional[str] = None, description: Optional[str] = None, count: int = 0) -> None: ...
    def serialize(self, format: str = 'json') -> str: ...
    def __repr__(self) -> str: ...
    @classmethod
    def from_document(cls, doc: dict) -> Counter: ...
    @classmethod
    def from_record(cls, rec: Tuple) -> Counter: ...
    @classmethod
    def from_db(cls, r: Any) -> Optional[Counter]: ...
    def inc(self, count: int = 1) -> None: ...
    @classmethod
    def find_all(cls) -> List[Counter]: ...

class Timer:
    group: str
    name: str
    title: Optional[str]
    description: Optional[str]
    type: str
    start: Optional[int]
    count: int
    total_time: int

    def __init__(self, group: str, name: str, title: Optional[str] = None, description: Optional[str] = None, count: int = 0, total_time: int = 0) -> None: ...
    def serialize(self, format: str = 'json') -> str: ...
    def __repr__(self) -> str: ...
    @classmethod
    def from_document(cls, doc: dict) -> Timer: ...
    @classmethod
    def from_record(cls, rec: Tuple) -> Timer: ...
    @classmethod
    def from_db(cls, r: Any) -> Optional[Timer]: ...
    def _time_in_millis(self) -> int: ...
    def start_timer(self) -> int: ...
    def stop_timer(self, start: int, count: int = 1) -> None: ...
    @classmethod
    def find_all(cls) -> List[Timer]: ...

def timer(metric: Timer) -> Callable[[Callable], Callable]:
    def decorated(f: Callable) -> Callable:
        @wraps(f)
        def wrapped(*args: Any, **kwargs: Any) -> Any:
            ...
        return wrapped
    return decorated