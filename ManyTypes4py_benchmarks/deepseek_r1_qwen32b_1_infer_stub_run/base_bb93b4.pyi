    def _str_repeat(self, repeats: int) -> Self: ...
    def _str_match(self, pat: str, case: bool = True, flags: int = 0, na: Any = lib.no_default) -> NDArray[np_bool_]: ...
    def _str_fullmatch(self, pat: str, case: bool = True, flags: int = 0, na: Any = lib.no_default) -> NDArray[np_bool_]: ...
    def _str_encode(self, encoding: str, errors: str = 'strict') -> Self: ...
    def _str_find(self, sub: str, start: int = 0, end: Optional[int] = None) -> NDArray[np_int64]: ...
    def _str_rfind(self, sub: str, start: int = 0, end: Optional[int] = None) -> NDArray[np_int64]: ...
    def _str_findall(self, pat: str, flags: int = 0) -> Any: ...
    def _str_get(self, i: int) -> Any: ...
    def _str_index(self, sub: str, start: int = 0, end: Optional[int] = None) -> NDArray[np_int64]: ...
    def _str_rindex(self, sub: str, start: int = 0, end: Optional[int] = None) -> NDArray[np_int64]: ...
    def _str_join(self, sep: str) -> Self: ...
    def _str_partition(self, sep: str, expand: bool) -> Any: ...
    def _str_rpartition(self, sep: str, expand: bool) -> Any: ...
    def _str_len(self) -> NDArray[np_int64]: ...
    def _str_slice(self, start: Optional[int] = None, stop: Optional[int] = None, step: Optional[int] = None) -> Self: ...
    def _str_slice_replace(self, start: Optional[int] = None, stop: Optional[int] = None, repl: Optional[str] = None) -> Self: ...
    def _str_translate(self, table: Any) -> Self: ...
    def _str_wrap(self, width: int, **kwargs: Any) -> Self: ...
    def _str_get_dummies(self, sep: str = '|', dtype: Optional[Any] = None) -> Any: ...
    def _str_isalnum(self) -> NDArray[np_bool_]: ...
    def _str_isalpha(self) -> NDArray[np_bool_]: ...
    def _str_isascii(self) -> NDArray[np_bool_]: ...
    def _str_isdecimal(self) -> NDArray[np_bool_]: ...
    def _str_isdigit(self) -> NDArray[np_bool_]: ...
    def _str_islower(self) -> NDArray[np_bool_]: ...
    def _str_isnumeric(self) -> NDArray[np_bool_]: ...
    def _str_isspace(self) -> NDArray[np_bool_]: ...
    def _str_istitle(self) -> NDArray[np_bool_]: ...
    def _str_isupper(self) -> NDArray[np_bool_]: ...
    def _str_capitalize(self) -> Self: ...
    def _str_casefold(self) -> Self: ...
    def _str_title(self) -> Self: ...
    def _str_swapcase(self) -> Self: ...
    def _str_lower(self) -> Self: ...
    def _str_upper(self) -> Self: ...
    def _str_normalize(self, form: str) -> Self: ...
    def _str_strip(self, to_strip: Optional[str] = None) -> Self: ...
