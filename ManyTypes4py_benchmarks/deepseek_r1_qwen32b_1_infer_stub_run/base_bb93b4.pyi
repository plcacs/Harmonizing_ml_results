from __future__ import annotations
from typing import (
    Any,
    Callable,
    Literal,
    Optional,
    Sequence,
    Union,
    Self,
    NDArray,
    Tuple,
)
from numpy import int64 as np_int64, bool_ as np_bool_
from pandas._libs import lib

class BaseStringArrayMethods:
    def _str_getitem(self, key: Union[slice, int]) -> Any: ...
    def _str_count(self, pat: str, flags: int = 0) -> NDArray[np_int64]: ...
    def _str_pad(self, width: int, side: Literal['left', 'right', 'both'] = 'left', fillchar: str = ' ') -> Self: ...
