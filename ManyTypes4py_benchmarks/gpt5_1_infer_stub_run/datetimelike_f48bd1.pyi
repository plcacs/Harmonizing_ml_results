from __future__ import annotations

from abc import ABC
from datetime import datetime
from typing import Any, Callable, Literal, Self
from collections.abc import Sequence

import numpy as np
from numpy.typing import NDArray
from pandas._libs import Timedelta
from pandas._libs.tslibs import BaseOffset, Resolution, Tick
from pandas.core.arrays import ExtensionArray
from pandas.core.indexes.base import Index
from pandas.core.indexes.extension import NDArrayBackedExtensionIndex
from pandas.core.indexes.range import RangeIndex


class DatetimeIndexOpsMixin(NDArrayBackedExtensionIndex, ABC):
    _can_hold_strings: bool = ...

    def mean(self, *, skipna: bool = ..., axis: int = ...) -> Any: ...
    @property
    def freq(self) -> BaseOffset | None: ...
    @freq.setter
    def freq(self, value: BaseOffset | None) -> None: ...
    @property
    def asi8(self) -> NDArray[np.int64]: ...
    @property
    def freqstr(self) -> str | None: ...
    @property
    def _resolution_obj(self) -> Resolution: ...
    @property
    def resolution(self) -> str: ...
    @property
    def hasnans(self) -> bool: ...
    def equals(self, other: object) -> bool: ...
    def __contains__(self, key: object) -> bool: ...
    def _convert_tolerance(self, tolerance: object, target: Any) -> Any: ...
    _default_na_rep: str
    def _format_with_header(self, *, header: list[str], na_rep: str, date_format: str | None = ...) -> list[str]: ...
    @property
    def _formatter_func(self) -> Callable[[Any], str]: ...
    def _format_attrs(self) -> list[tuple[str, object]]: ...
    def _summary(self, name: str | None = ...) -> str: ...
    def _can_partial_date_slice(self, reso: Resolution) -> bool: ...
    def _parsed_string_to_bounds(self, reso: Resolution, parsed: datetime) -> tuple[object, object]: ...
    def _parse_with_reso(self, label: object) -> tuple[datetime, Resolution]: ...
    def _get_string_slice(self, key: str) -> slice | NDArray[np.intp]: ...
    def _partial_date_slice(self, reso: Resolution, parsed: datetime) -> slice | NDArray[np.intp]: ...
    def _maybe_cast_slice_bound(self, label: object, side: Literal["left", "right"]) -> object: ...
    def shift(self, periods: int = ..., freq: BaseOffset | Timedelta | str | None = ...) -> Self: ...
    def _maybe_cast_listlike_indexer(self, keyarr: object) -> Index: ...


class DatetimeTimedeltaMixin(DatetimeIndexOpsMixin, ABC):
    _comparables: list[str] = ...
    _attributes: list[str] = ...

    @property
    def unit(self) -> str: ...
    def as_unit(self, unit: Literal["s", "ms", "us", "ns"]) -> Self: ...
    def _with_freq(self, freq: BaseOffset | str | None) -> Self: ...
    @property
    def values(self) -> NDArray[Any]: ...
    def shift(self, periods: int = ..., freq: BaseOffset | Timedelta | str | None = ...) -> Self: ...
    @property
    def inferred_freq(self) -> str | None: ...
    @property
    def _as_range_index(self) -> RangeIndex: ...
    def _can_range_setop(self, other: DatetimeTimedeltaMixin) -> bool: ...
    def _wrap_range_setop(self, other: DatetimeTimedeltaMixin, res_i8: RangeIndex) -> Self: ...
    def _range_intersect(self, other: DatetimeTimedeltaMixin, sort: bool | None) -> Self: ...
    def _range_union(self, other: DatetimeTimedeltaMixin, sort: bool | None) -> Self: ...
    def _intersection(self, other: DatetimeTimedeltaMixin, sort: bool = ...) -> Self: ...
    def _fast_intersect(self, other: DatetimeTimedeltaMixin, sort: bool | None) -> Self: ...
    def _can_fast_intersect(self, other: DatetimeTimedeltaMixin) -> bool: ...
    def _can_fast_union(self, other: DatetimeTimedeltaMixin) -> bool: ...
    def _fast_union(self, other: DatetimeTimedeltaMixin, sort: bool | None = ...) -> Self: ...
    def _union(self, other: DatetimeTimedeltaMixin, sort: bool | None) -> Self: ...
    def _get_join_freq(self, other: DatetimeTimedeltaMixin) -> BaseOffset | None: ...
    def _wrap_join_result(
        self,
        joined: Index,
        other: DatetimeTimedeltaMixin,
        lidx: NDArray[np.intp] | None,
        ridx: NDArray[np.intp] | None,
        how: Literal["left", "right", "inner", "outer"],
    ) -> tuple[Self, NDArray[np.intp] | None, NDArray[np.intp] | None]: ...
    def _get_engine_target(self) -> NDArray[np.int64]: ...
    def _from_join_target(self, result: NDArray[np.int64]) -> ExtensionArray: ...
    def _get_delete_freq(self, loc: object) -> BaseOffset | None: ...
    def _get_insert_freq(self, loc: int, item: object) -> BaseOffset | None: ...
    def delete(self, loc: object) -> Self: ...
    def insert(self, loc: int, item: object) -> Index: ...
    def take(
        self,
        indices: Sequence[int] | NDArray[np.intp],
        axis: int = ...,
        allow_fill: bool = ...,
        fill_value: object | None = ...,
        **kwargs: Any,
    ) -> Self: ...