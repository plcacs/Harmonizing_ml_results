from typing import Any, Callable, Deque, Dict, IO, List, Mapping, Optional, Tuple
from threading import Thread
from queue import Queue
import subprocess
import weakref
from jedi.inference.compiled.access import DirectObjectAccess

_MAIN_PATH: str
PICKLE_PROTOCOL: int

def _GeneralizedPopen(*args: Any, **kwargs: Any) -> subprocess.Popen[Any]: ...
def _enqueue_output(out: IO[bytes], queue_: Queue[bytes]) -> None: ...
def _add_stderr_to_debug(stderr_queue: Queue[bytes]) -> None: ...
def _get_function(name: str) -> Callable[..., Any]: ...
def _cleanup_process(process: subprocess.Popen[Any], thread: Thread) -> None: ...

class _InferenceStateProcess:
    _inference_state_weakref: weakref.ReferenceType[Any]
    _inference_state_id: int
    _handles: Dict[int, "AccessHandle"]
    def __init__(self, inference_state: Any) -> None: ...
    def get_or_create_access_handle(self, obj: object) -> "AccessHandle": ...
    def get_access_handle(self, id_: int) -> "AccessHandle": ...
    def set_access_handle(self, handle: "AccessHandle") -> None: ...

class InferenceStateSameProcess(_InferenceStateProcess):
    def __getattr__(self, name: str) -> Callable[..., Any]: ...

class InferenceStateSubprocess(_InferenceStateProcess):
    _used: bool
    _compiled_subprocess: "CompiledSubprocess"
    def __init__(self, inference_state: Any, compiled_subprocess: "CompiledSubprocess") -> None: ...
    def __getattr__(self, name: str) -> Callable[..., Any]: ...
    def _convert_access_handles(self, obj: Any) -> Any: ...
    def __del__(self) -> None: ...

class CompiledSubprocess:
    is_crashed: bool
    _executable: str
    _env_vars: Optional[Mapping[str, str]]
    _inference_state_deletion_queue: Deque[int]
    _cleanup_callable: Callable[[], None]
    _stderr_queue: Queue[bytes]
    _stderr_thread: Thread
    def __init__(self, executable: str, env_vars: Optional[Mapping[str, str]] = ...) -> None: ...
    def __repr__(self) -> str: ...
    def _get_process(self) -> subprocess.Popen[Any]: ...
    def run(self, inference_state: Any, function: Callable[..., Any], args: Tuple[Any, ...] = ..., kwargs: Dict[str, Any] = ...) -> Any: ...
    def get_sys_path(self) -> List[str]: ...
    def _kill(self) -> None: ...
    def _send(self, inference_state_id: Optional[int], function: Optional[Callable[..., Any]], args: Tuple[Any, ...] = ..., kwargs: Dict[str, Any] = ...) -> Any: ...
    def delete_inference_state(self, inference_state_id: int) -> None: ...

class Listener:
    _inference_states: Dict[int, Any]
    _process: _InferenceStateProcess
    def __init__(self) -> None: ...
    def _get_inference_state(self, function: Callable[..., Any], inference_state_id: int) -> Any: ...
    def _run(self, inference_state_id: Optional[int], function: Optional[Callable[..., Any]], args: Tuple[Any, ...], kwargs: Dict[str, Any]) -> Any: ...
    def listen(self) -> None: ...

class AccessHandle:
    access: DirectObjectAccess
    id: int
    _subprocess: Any
    def __init__(self, subprocess: Any, access: DirectObjectAccess, id_: int) -> None: ...
    def add_subprocess(self, subprocess: Any) -> None: ...
    def __repr__(self) -> str: ...
    def __getstate__(self) -> int: ...
    def __setstate__(self, state: int) -> None: ...
    def __getattr__(self, name: str) -> Callable[..., Any]: ...
    def _workaround(self, name: str, *args: Any, **kwargs: Any) -> Any: ...
    def _cached_results(self, name: str, *args: Any, **kwargs: Any) -> Any: ...