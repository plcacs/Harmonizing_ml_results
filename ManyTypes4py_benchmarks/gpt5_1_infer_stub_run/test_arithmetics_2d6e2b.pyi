        mix: bool,
        all_arithmetic_functions: Callable[[Any, Any], Any],
    ) -> None: ...
    def test_float_array_different_kind(
        self,
        mix: bool,
        all_arithmetic_functions: Callable[[Any, Any], Any],
    ) -> None: ...
    def test_float_array_comparison(self, kind: str) -> None: ...
    def test_int_array(
        self,
        kind: str,
        mix: bool,
        all_arithmetic_functions: Callable[[Any, Any], Any],
