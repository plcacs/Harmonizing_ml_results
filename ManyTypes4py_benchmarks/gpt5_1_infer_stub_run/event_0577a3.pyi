from __future__ import annotations

import datetime as dt
from collections.abc import Iterable
from typing import Any, Awaitable

from aiohttp.web import Request
from homeassistant.config_entries import ConfigEntry
from homeassistant.core import CALLBACK_TYPE, HomeAssistant
from onvif import ONVIFCamera

from .models import Event, PullPointManagerState, WebHookManagerState

UNHANDLED_TOPICS: set[str] = ...
SUBSCRIPTION_ERRORS: tuple[type[BaseException], ...] = ...
CREATE_ERRORS: tuple[type[BaseException], ...] = ...
SET_SYNCHRONIZATION_POINT_ERRORS: tuple[type[BaseException], ...] = ...
UNSUBSCRIBE_ERRORS: tuple[type[BaseException], ...] = ...
RENEW_ERRORS: tuple[type[BaseException], ...] = ...
SUBSCRIPTION_TIME: dt.timedelta = ...
SUBSCRIPTION_RENEW_INTERVAL: int = ...
SUBSCRIPTION_ATTEMPTS: int = ...
SUBSCRIPTION_RESTART_INTERVAL_ON_ERROR: int = ...
PULLPOINT_POLL_TIME: dt.timedelta = ...
PULLPOINT_MESSAGE_LIMIT: int = ...
PULLPOINT_COOLDOWN_TIME: float = ...


class EventManager:
    """ONVIF Event Manager."""

    hass: HomeAssistant
    device: ONVIFCamera
    config_entry: ConfigEntry
    unique_id: str | None
    name: str
    webhook_manager: WebHookManager
    pullpoint_manager: PullPointManager

    def __init__(self, hass: HomeAssistant, device: ONVIFCamera, config_entry: ConfigEntry, name: str) -> None: ...
    @property
    def started(self) -> bool: ...
    def async_add_listener(self, update_callback: CALLBACK_TYPE) -> CALLBACK_TYPE: ...
    def async_remove_listener(self, update_callback: CALLBACK_TYPE) -> None: ...
    def async_start(self, try_pullpoint: bool, try_webhook: bool) -> Awaitable[bool]: ...
    def async_stop(self) -> Awaitable[None]: ...
    def async_callback_listeners(self) -> None: ...
    def async_parse_messages(self, messages: Iterable[Any]) -> Awaitable[None]: ...
    def get_uid(self, uid: str) -> Event | None: ...
    def get_platform(self, platform: str) -> list[Event]: ...
    def get_uids_by_platform(self, platform: str) -> set[str]: ...
    def async_webhook_failed(self) -> None: ...
    def async_webhook_working(self) -> None: ...
    def async_mark_events_stale(self) -> None: ...


class PullPointManager:
    """ONVIF PullPoint Manager."""

    state: PullPointManagerState

    def __init__(self, event_manager: EventManager) -> None: ...
    def async_start(self) -> Awaitable[bool]: ...
    def async_pause(self) -> None: ...
    def async_resume(self) -> None: ...
    def async_stop(self) -> Awaitable[None]: ...
    def _async_start_pullpoint(self) -> Awaitable[bool]: ...
    def _async_cancel_and_unsubscribe(self) -> Awaitable[None]: ...
    def _async_create_pullpoint_subscription(self) -> Awaitable[None]: ...
    def _async_unsubscribe_pullpoint(self) -> Awaitable[None]: ...
    def _async_pull_messages(self) -> Awaitable[None]: ...
    def async_cancel_pull_messages(self) -> None: ...
    def async_schedule_pull_messages(self, delay: float | dt.timedelta | None = ...) -> None: ...
    def _async_background_pull_messages_or_reschedule(self, _now: dt.datetime | None = ...) -> None: ...


class WebHookManager:
    """Manage ONVIF webhook subscriptions."""

    state: WebHookManagerState

    def __init__(self, event_manager: EventManager) -> None: ...
    def async_start(self) -> Awaitable[bool]: ...
    def async_stop(self) -> Awaitable[None]: ...
    def _async_create_webhook_subscription(self) -> Awaitable[None]: ...
    def _async_start_webhook(self) -> Awaitable[bool]: ...
    def _async_register_webhook(self) -> None: ...
    def _async_unregister_webhook(self) -> None: ...
    def _async_handle_webhook(self, hass: HomeAssistant, webhook_id: str, request: Request) -> Awaitable[None]: ...
    def _async_process_webhook(self, hass: HomeAssistant, webhook_id: str, content: bytes | None) -> Awaitable[None]: ...
    def _async_unsubscribe_webhook(self) -> Awaitable[None]: ...