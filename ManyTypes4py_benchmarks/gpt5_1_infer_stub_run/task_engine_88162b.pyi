from __future__ import annotations
import logging
from contextlib import AbstractAsyncContextManager, AbstractContextManager
from typing import Any, AsyncGenerator, ContextManager, Coroutine, Dict, Generator, Generic, Optional, Union, TypeVar, Literal, AsyncContextManager
from uuid import UUID
from typing_extensions import ParamSpec, Self
from prefect.client.orchestration import PrefectClient, SyncPrefectClient
from prefect.client.schemas import TaskRun
from prefect.client.schemas.objects import State, TaskRunInput
from prefect.events.schemas.events import Event as PrefectEvent
from prefect.logging.loggers import get_logger
from prefect.results import ResultRecord
from prefect.telemetry.run_telemetry import RunTelemetry
from prefect.transactions import Transaction
from prefect.tasks import OneOrManyFutureOrResult, Task

P = ParamSpec("P")
R = TypeVar("R")

BACKOFF_MAX: int

class TaskRunTimeoutError(TimeoutError): ...

class BaseTaskRunEngine(Generic[P, R]):
    logger: logging.LoggerAdapter
    parameters: Optional[Dict[str, Any]]
    task_run: Optional[TaskRun]
    retries: int
    wait_for: Optional[OneOrManyFutureOrResult]
    context: Optional[Dict[str, Any]]
    _return_value: Any
    _raised: Any
    _initial_run_context: Any
    _is_started: bool
    _task_name_set: bool
    _last_event: Optional[PrefectEvent]
    _telemetry: RunTelemetry
    task: Task[P, R]

    def __post_init__(self) -> None: ...
    @property
    def state(self) -> State: ...
    def is_cancelled(self) -> bool: ...
    def compute_transaction_key(self) -> Optional[str]: ...
    def _resolve_parameters(self) -> None: ...
    def _set_custom_task_run_name(self) -> None: ...
    def _wait_for_dependencies(self) -> None: ...
    def record_terminal_state_timing(self, state: State) -> None: ...
    def is_running(self) -> bool: ...
    def log_finished_message(self) -> None: ...
    def handle_rollback(self, txn: Transaction) -> None: ...

class SyncTaskRunEngine(BaseTaskRunEngine[P, R]):
    task_run: Optional[TaskRun]
    _client: Optional[SyncPrefectClient]

    @property
    def client(self) -> SyncPrefectClient: ...
    def can_retry(self, exc: BaseException) -> bool: ...
    def call_hooks(self, state: Optional[State] = ...) -> None: ...
    def begin_run(self) -> None: ...
    def set_state(self, state: State, force: bool = ...) -> State: ...
    def result(self, raise_on_failure: bool = ...) -> Any: ...
    def handle_success(self, result: R, transaction: Transaction) -> R: ...
    def handle_retry(self, exc: BaseException) -> bool: ...
    def handle_exception(self, exc: BaseException) -> None: ...
    def handle_timeout(self, exc: BaseException) -> None: ...
    def handle_crash(self, exc: BaseException) -> None: ...
    def setup_run_context(self, client: Optional[SyncPrefectClient] = ...) -> ContextManager[None]: ...
    def initialize_run(self, task_run_id: Optional[UUID] = ..., dependencies: Optional[Dict[str, TaskRunInput]] = ...) -> ContextManager[SyncTaskRunEngine[P, R]]: ...
    async def wait_until_ready(self) -> None: ...
    def start(self, task_run_id: Optional[UUID] = ..., dependencies: Optional[Dict[str, TaskRunInput]] = ...) -> ContextManager[None]: ...
    def transaction_context(self) -> ContextManager[Transaction]: ...
    def run_context(self) -> ContextManager[Self]: ...
    def call_task_fn(self, transaction: Transaction) -> Union[R, Coroutine[Any, Any, R]]: ...

class AsyncTaskRunEngine(BaseTaskRunEngine[P, R]):
    task_run: Optional[TaskRun]
    _client: Optional[PrefectClient]

    @property
    def client(self) -> PrefectClient: ...
    async def can_retry(self, exc: BaseException) -> bool: ...
    async def call_hooks(self, state: Optional[State] = ...) -> None: ...
    async def begin_run(self) -> None: ...
    async def set_state(self, state: State, force: bool = ...) -> State: ...
    async def result(self, raise_on_failure: bool = ...) -> Any: ...
    async def handle_success(self, result: R, transaction: Transaction) -> R: ...
    async def handle_retry(self, exc: BaseException) -> bool: ...
    async def handle_exception(self, exc: BaseException) -> None: ...
    async def handle_timeout(self, exc: BaseException) -> None: ...
    async def handle_crash(self, exc: BaseException) -> None: ...
    def setup_run_context(self, client: Optional[PrefectClient] = ...) -> AsyncContextManager[None]: ...
    def initialize_run(self, task_run_id: Optional[UUID] = ..., dependencies: Optional[Dict[str, TaskRunInput]] = ...) -> AsyncContextManager[AsyncTaskRunEngine[P, R]]: ...
    async def wait_until_ready(self) -> None: ...
    def start(self, task_run_id: Optional[UUID] = ..., dependencies: Optional[Dict[str, TaskRunInput]] = ...) -> AsyncContextManager[None]: ...
    def transaction_context(self) -> AsyncContextManager[Transaction]: ...
    def run_context(self) -> AsyncContextManager[Self]: ...
    async def call_task_fn(self, transaction: Transaction) -> R: ...

def run_task_sync(
    task: Task[P, R],
    task_run_id: Optional[UUID] = ...,
    task_run: Optional[TaskRun] = ...,
    parameters: Optional[Dict[str, Any]] = ...,
    wait_for: Optional[OneOrManyFutureOrResult] = ...,
    return_type: Literal["result", "state"] = ...,
    dependencies: Optional[Dict[str, TaskRunInput]] = ...,
    context: Optional[Dict[str, Any]] = ...,
) -> Union[State, R]: ...

async def run_task_async(
    task: Task[P, R],
    task_run_id: Optional[UUID] = ...,
    task_run: Optional[TaskRun] = ...,
    parameters: Optional[Dict[str, Any]] = ...,
    wait_for: Optional[OneOrManyFutureOrResult] = ...,
    return_type: Literal["result", "state"] = ...,
    dependencies: Optional[Dict[str, TaskRunInput]] = ...,
    context: Optional[Dict[str, Any]] = ...,
) -> Union[State, R]: ...

def run_generator_task_sync(
    task: Task[P, R],
    task_run_id: Optional[UUID] = ...,
    task_run: Optional[TaskRun] = ...,
    parameters: Optional[Dict[str, Any]] = ...,
    wait_for: Optional[OneOrManyFutureOrResult] = ...,
    return_type: Literal["result"] = ...,
    dependencies: Optional[Dict[str, TaskRunInput]] = ...,
    context: Optional[Dict[str, Any]] = ...,
) -> Generator[Any, None, R]: ...

async def run_generator_task_async(
    task: Task[P, R],
    task_run_id: Optional[UUID] = ...,
    task_run: Optional[TaskRun] = ...,
    parameters: Optional[Dict[str, Any]] = ...,
    wait_for: Optional[OneOrManyFutureOrResult] = ...,
    return_type: Literal["result"] = ...,
    dependencies: Optional[Dict[str, TaskRunInput]] = ...,
    context: Optional[Dict[str, Any]] = ...,
) -> AsyncGenerator[Any, None]: ...

def run_task(
    task: Task[P, R],
    task_run_id: Optional[UUID] = ...,
    task_run: Optional[TaskRun] = ...,
    parameters: Optional[Dict[str, Any]] = ...,
    wait_for: Optional[OneOrManyFutureOrResult] = ...,
    return_type: Literal["result", "state"] = ...,
    dependencies: Optional[Dict[str, TaskRunInput]] = ...,
    context: Optional[Dict[str, Any]] = ...,
) -> Union[
    State,
    R,
    Generator[Any, None, R],
    AsyncGenerator[Any, None],
    Coroutine[Any, Any, Union[State, R]],
]: ...