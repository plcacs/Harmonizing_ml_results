from typing import Any, Callable, Mapping, Match, NoReturn, Optional, Pattern, Union

import databricks.koalas as ks

class StringMethods:
    def __init__(self, series: ks.Series) -> None: ...
    def capitalize(self) -> ks.Series: ...
    def title(self) -> ks.Series: ...
    def lower(self) -> ks.Series: ...
    def upper(self) -> ks.Series: ...
    def swapcase(self) -> ks.Series: ...
    def startswith(self, pattern: str, na: object | None = ...) -> ks.Series: ...
    def endswith(self, pattern: str, na: object | None = ...) -> ks.Series: ...
    def strip(self, to_strip: str | None = ...) -> ks.Series: ...
    def lstrip(self, to_strip: str | None = ...) -> ks.Series: ...
    def rstrip(self, to_strip: str | None = ...) -> ks.Series: ...
    def get(self, i: int) -> ks.Series: ...
    def isalnum(self) -> ks.Series: ...
    def isalpha(self) -> ks.Series: ...
    def isdigit(self) -> ks.Series: ...
    def isspace(self) -> ks.Series: ...
    def islower(self) -> ks.Series: ...
    def isupper(self) -> ks.Series: ...
    def istitle(self) -> ks.Series: ...
    def isnumeric(self) -> ks.Series: ...
    def isdecimal(self) -> ks.Series: ...
    def cat(self, others: Any | None = ..., sep: str | None = ..., na_rep: Any | None = ..., join: str | None = ...) -> NoReturn: ...
    def center(self, width: int, fillchar: str = ...) -> ks.Series: ...
    def contains(self, pat: str, case: bool = ..., flags: int = ..., na: object | None = ..., regex: bool = ...) -> ks.Series: ...
    def count(self, pat: str, flags: int = ...) -> ks.Series: ...
    def decode(self, encoding: str, errors: str = ...) -> NoReturn: ...
    def encode(self, encoding: str, errors: str = ...) -> NoReturn: ...
    def extract(self, pat: str, flags: int = ..., expand: bool = ...) -> NoReturn: ...
    def extractall(self, pat: str, flags: int = ...) -> NoReturn: ...
    def find(self, sub: str, start: int = ..., end: int | None = ...) -> ks.Series: ...
    def findall(self, pat: str, flags: int = ...) -> ks.Series: ...
    def index(self, sub: str, start: int = ..., end: int | None = ...) -> ks.Series: ...
    def join(self, sep: str) -> ks.Series: ...
    def len(self) -> ks.Series: ...
    def ljust(self, width: int, fillchar: str = ...) -> ks.Series: ...
    def match(self, pat: str, case: bool = ..., flags: int = ..., na: object = ...) -> ks.Series: ...
    def normalize(self, form: str) -> ks.Series: ...
    def pad(self, width: int, side: str = ..., fillchar: str = ...) -> ks.Series: ...
    def partition(self, sep: str = ..., expand: bool = ...) -> NoReturn: ...
    def repeat(self, repeats: int) -> ks.Series: ...
    def replace(
        self,
        pat: str | Pattern[str],
        repl: str | Callable[[Match[str]], str],
        n: int = ...,
        case: Optional[bool] = ...,
        flags: int = ...,
        regex: bool = ...,
    ) -> ks.Series: ...
    def rfind(self, sub: str, start: int = ..., end: int | None = ...) -> ks.Series: ...
    def rindex(self, sub: str, start: int = ..., end: int | None = ...) -> ks.Series: ...
    def rjust(self, width: int, fillchar: str = ...) -> ks.Series: ...
    def rpartition(self, sep: str = ..., expand: bool = ...) -> NoReturn: ...
    def slice(self, start: Optional[int] = ..., stop: Optional[int] = ..., step: Optional[int] = ...) -> ks.Series: ...
    def slice_replace(self, start: Optional[int] = ..., stop: Optional[int] = ..., repl: Optional[str] = ...) -> ks.Series: ...
    def split(self, pat: Optional[str] = ..., n: int = ..., expand: bool = ...) -> Union[ks.Series, ks.DataFrame]: ...
    def rsplit(self, pat: Optional[str] = ..., n: int = ..., expand: bool = ...) -> Union[ks.Series, ks.DataFrame]: ...
    def translate(self, table: Mapping[int, int | str | None]) -> ks.Series: ...
    def wrap(self, width: int, **kwargs: Any) -> ks.Series: ...
    def zfill(self, width: int) -> ks.Series: ...
    def get_dummies(self, sep: str = ...) -> NoReturn: ...