from __future__ import annotations

from typing import Any, Dict, Iterable, Iterator, Mapping, Sequence, Tuple

from jedi.inference.base_value import LazyValueWrapper, Value, ValueSet, ValueWrapper
from jedi.inference.context import ClassContext
from jedi.inference.names import AbstractNameDefinition, ValueName
from jedi.inference.value.klass import ClassFilter, ClassMixin
from jedi.inference.gradual.generics import TupleGenericManager
from jedi.inference.gradual.type_var import TypeVar as _JediTypeVar


class _BoundTypeVarName(AbstractNameDefinition):
    def __init__(self, type_var: _JediTypeVar, value_set: ValueSet) -> None: ...
    def infer(self) -> ValueSet: ...
    def py__name__(self) -> str: ...
    def __repr__(self) -> str: ...


class _TypeVarFilter:
    def __init__(self, generics: Tuple[ValueSet, ...], type_vars: Sequence[_JediTypeVar]) -> None: ...
    def get(self, name: str) -> list[AbstractNameDefinition]: ...
    def values(self) -> list[AbstractNameDefinition]: ...


class _AnnotatedClassContext(ClassContext):
    def get_filters(self, *args: Any, **kwargs: Any) -> Iterator[object]: ...


class DefineGenericBaseClass(LazyValueWrapper):
    def __init__(self, generics_manager: TupleGenericManager) -> None: ...
    def _create_instance_with_generics(self, generics_manager: TupleGenericManager) -> DefineGenericBaseClass: ...
    def get_generics(self) -> Tuple[ValueSet, ...]: ...
    def define_generics(self, type_var_dict: Mapping[_JediTypeVar, ValueSet]) -> ValueSet: ...
    def is_same_class(self, other: object) -> bool: ...
    def get_signatures(self) -> list[object]: ...
    def __repr__(self) -> str: ...


class GenericClass(DefineGenericBaseClass, ClassMixin):
    def __init__(self, class_value: ClassMixin, generics_manager: TupleGenericManager) -> None: ...
    def _get_wrapped_value(self) -> ClassMixin: ...
    def get_type_hint(self, add_class_info: bool = True) -> str: ...
    def get_type_var_filter(self) -> _TypeVarFilter: ...
    def py__call__(self, arguments: object) -> ValueSet: ...
    def _as_context(self) -> _AnnotatedClassContext: ...
    def py__bases__(self) -> list[_LazyGenericBaseClass]: ...
    def _create_instance_with_generics(self, generics_manager: TupleGenericManager) -> GenericClass: ...
    def is_sub_class_of(self, class_value: ClassMixin) -> bool: ...
    def with_generics(self, generics_tuple: Tuple[ValueSet, ...]) -> GenericClass: ...
    def infer_type_vars(self, value_set: ValueSet) -> Dict[_JediTypeVar, ValueSet]: ...


class _LazyGenericBaseClass:
    def __init__(self, class_value: GenericClass, lazy_base_class: object, generics_manager: TupleGenericManager) -> None: ...
    def infer(self) -> ValueSet: ...
    def _remap_type_vars(self, base: GenericClass) -> Iterable[ValueSet]: ...
    def __repr__(self) -> str: ...


class _GenericInstanceWrapper(ValueWrapper):
    def py__stop_iteration_returns(self) -> ValueSet: ...
    def get_type_hint(self, add_class_info: bool = True) -> str: ...


class _PseudoTreeNameClass(Value):
    api_type: str
    def __init__(self, parent_context: object, tree_name: object) -> None: ...
    @property
    def tree_node(self) -> object: ...
    def get_filters(self, *args: Any, **kwargs: Any) -> Iterator[ClassFilter]: ...
    def py__class__(self) -> Value: ...
    @property
    def name(self) -> ValueName: ...
    def get_qualified_names(self) -> tuple[str, ...]: ...
    def __repr__(self) -> str: ...


class BaseTypingValue(LazyValueWrapper):
    def __init__(self, parent_context: object, tree_name: object) -> None: ...
    @property
    def name(self) -> ValueName: ...
    def _get_wrapped_value(self) -> _PseudoTreeNameClass: ...
    def get_signatures(self) -> list[object]: ...
    def __repr__(self) -> str: ...


class BaseTypingClassWithGenerics(DefineGenericBaseClass):
    def __init__(self, parent_context: object, tree_name: object, generics_manager: TupleGenericManager) -> None: ...
    def _get_wrapped_value(self) -> _PseudoTreeNameClass: ...
    def __repr__(self) -> str: ...


class BaseTypingInstance(LazyValueWrapper):
    def __init__(self, parent_context: object, class_value: BaseTypingClassWithGenerics, tree_name: object, generics_manager: TupleGenericManager) -> None: ...
    def py__class__(self) -> BaseTypingClassWithGenerics: ...
    def get_annotated_class_object(self) -> BaseTypingClassWithGenerics: ...
    def get_qualified_names(self) -> tuple[str, ...]: ...
    @property
    def name(self) -> ValueName: ...
    def _get_wrapped_value(self) -> Value: ...
    def __repr__(self) -> str: ...