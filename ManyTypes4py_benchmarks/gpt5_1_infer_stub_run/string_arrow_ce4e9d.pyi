from typing import Any, Callable, ClassVar, Sequence, Union, NoReturn, Self
import numpy as np
from numpy.typing import NDArray
from pandas._libs import missing as libmissing
from pandas.core.arrays.arrow import ArrowExtensionArray
from pandas.core.arrays.string_ import BaseStringArray, StringDtype
from pandas.core.strings.object_array import ObjectStringArrayMixin
from pandas.core.arrays.base import ExtensionArray
from pandas._typing import ArrayLike, Dtype, NpDtype
from pandas import Series

ArrowStringScalarOrNAT = Union[str, libmissing.NAType]

def _chk_pyarrow_available() -> None: ...
def _is_string_view(typ: object) -> bool: ...

class ArrowStringArray(ObjectStringArrayMixin, ArrowExtensionArray, BaseStringArray):
    _storage: ClassVar[str]
    _na_value: ClassVar[object]

    def __init__(self, values: object) -> None: ...
    @classmethod
    def _box_pa_scalar(cls, value: object, pa_type: object | None = ...) -> object: ...
    @classmethod
    def _box_pa_array(cls, value: object, pa_type: object | None = ..., copy: bool = ...) -> object: ...
    def __len__(self) -> int: ...
    @classmethod
    def _from_sequence(
        cls, scalars: object, *, dtype: Dtype | NpDtype | type | str | None = ..., copy: bool = ...
    ) -> Self: ...
    @classmethod
    def _from_sequence_of_strings(
        cls, strings: Sequence[str] | object, *, dtype: Dtype | NpDtype | type | str, copy: bool = ...
    ) -> Self: ...
    @property
    def dtype(self) -> StringDtype: ...
    def insert(self, loc: int, item: ArrowStringScalarOrNAT | float) -> ArrowStringArray: ...
    def _convert_bool_result(self, values: object, na: object = ..., method_name: str | None = ...) -> ArrayLike: ...
    def _maybe_convert_setitem_value(self, value: object) -> object: ...
    def isin(self, values: Sequence[object]) -> NDArray[np.bool_]: ...
    def astype(
        self, dtype: Dtype | NpDtype | type | str, copy: bool = ...
    ) -> ArrowStringArray | ExtensionArray | NDArray[Any]: ...

    _str_isalnum: Callable[..., ArrayLike]
    _str_isalpha: Callable[..., ArrayLike]
    _str_isdecimal: Callable[..., ArrayLike]
    _str_isdigit: Callable[..., ArrayLike]
    _str_islower: Callable[..., ArrayLike]
    _str_isnumeric: Callable[..., ArrayLike]
    _str_isspace: Callable[..., ArrayLike]
    _str_istitle: Callable[..., ArrayLike]
    _str_isupper: Callable[..., ArrayLike]
    _str_map: Callable[..., "ArrowStringArray"]
    _str_startswith: Callable[..., ArrayLike]
    _str_endswith: Callable[..., ArrayLike]
    _str_pad: Callable[..., "ArrowStringArray"]
    _str_match: Callable[..., ArrayLike]
    _str_fullmatch: Callable[..., ArrayLike]
    _str_lower: Callable[..., "ArrowStringArray"]
    _str_upper: Callable[..., "ArrowStringArray"]
    _str_strip: Callable[..., "ArrowStringArray"]
    _str_lstrip: Callable[..., "ArrowStringArray"]
    _str_rstrip: Callable[..., "ArrowStringArray"]
    _str_removesuffix: Callable[..., "ArrowStringArray"]
    _str_get: Callable[..., "ArrowStringArray"]
    _str_capitalize: Callable[..., "ArrowStringArray"]
    _str_title: Callable[..., "ArrowStringArray"]
    _str_swapcase: Callable[..., "ArrowStringArray"]
    _str_slice_replace: Callable[..., "ArrowStringArray"]
    _str_len: Callable[..., ArrayLike]
    _str_slice: Callable[..., "ArrowStringArray"]

    def _str_contains(
        self, pat: object, case: bool = ..., flags: int = ..., na: object = ..., regex: bool = ...
    ) -> ArrayLike: ...
    def _str_replace(
        self, pat: object, repl: object, n: int = ..., case: bool = ..., flags: int = ..., regex: bool = ...
    ) -> "ArrowStringArray": ...
    def _str_repeat(self, repeats: object) -> "ArrowStringArray": ...
    def _str_removeprefix(self, prefix: object) -> "ArrowStringArray": ...
    def _str_count(self, pat: object, flags: int = ...) -> ArrayLike: ...
    def _str_find(self, sub: object, start: int = ..., end: int | None = ...) -> ArrayLike: ...
    def _str_get_dummies(
        self, sep: str = ..., dtype: Dtype | NpDtype | type | None = ...
    ) -> tuple[NDArray[Any], list[str]]: ...
    def _convert_int_result(self, result: object) -> ArrayLike: ...
    def _convert_rank_result(self, result: object) -> ArrayLike: ...
    def _reduce(self, name: str, *, skipna: bool = ..., keepdims: bool = ..., **kwargs: Any) -> object: ...
    def value_counts(self, dropna: bool = ...) -> Series: ...
    def _cmp_method(self, other: object, op: Callable[[object, object], Any]) -> ArrayLike: ...
    def __pos__(self) -> NoReturn: ...

class ArrowStringArrayNumpySemantics(ArrowStringArray):
    _na_value: ClassVar[object]