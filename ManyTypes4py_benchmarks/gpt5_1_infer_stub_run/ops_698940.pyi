from __future__ import annotations
from typing import Any, Callable, Optional, TypeVar, Union, final
import numpy as np
import pandas as pd
from pandas.api.extensions import ExtensionArray

T = TypeVar("T")

class BaseOpsUtil:
    series_scalar_exc: Optional[type[BaseException]] = ...
    frame_scalar_exc: Optional[type[BaseException]] = ...
    series_array_exc: Optional[type[BaseException]] = ...
    divmod_exc: Optional[type[BaseException]] = ...

    def _get_expected_exception(self, op_name: str, obj: object, other: object) -> Optional[type[BaseException]]: ...
    def _cast_pointwise_result(self, op_name: str, obj: object, other: object, pointwise_result: T) -> T: ...
    def get_op_from_name(self, op_name: str) -> Callable[[Any, Any], Any]: ...
    @final
    def check_opname(self, ser: Union[pd.Series, pd.DataFrame], op_name: str, other: object) -> None: ...
    @final
    def _combine(self, obj: Union[pd.Series, pd.DataFrame], other: object, op: Callable[[Any, Any], Any]) -> Union[pd.Series, pd.DataFrame]: ...
    @final
    def _check_op(self, ser: Union[pd.Series, pd.DataFrame], op: Callable[[Any, Any], Any], other: object, op_name: str, exc: Optional[type[BaseException]] = NotImplementedError) -> None: ...
    @final
    def _check_divmod_op(self, ser: object, op: Callable[[object, object], Any], other: object) -> None: ...

class BaseArithmeticOpsTests(BaseOpsUtil):
    series_scalar_exc: Optional[type[BaseException]] = ...
    frame_scalar_exc: Optional[type[BaseException]] = ...
    series_array_exc: Optional[type[BaseException]] = ...
    divmod_exc: Optional[type[BaseException]] = ...

    def test_arith_series_with_scalar(self, data: ExtensionArray, all_arithmetic_operators: str) -> None: ...
    def test_arith_frame_with_scalar(self, data: ExtensionArray, all_arithmetic_operators: str) -> None: ...
    def test_arith_series_with_array(self, data: ExtensionArray, all_arithmetic_operators: str) -> None: ...
    def test_divmod(self, data: ExtensionArray) -> None: ...
    def test_divmod_series_array(self, data: ExtensionArray, data_for_twos: ExtensionArray) -> None: ...
    def test_add_series_with_extension_array(self, data: ExtensionArray) -> None: ...
    def test_direct_arith_with_ndframe_returns_not_implemented(self, data: ExtensionArray, box: type[Union[pd.Series, pd.DataFrame, pd.Index]], op_name: str) -> None: ...

class BaseComparisonOpsTests(BaseOpsUtil):
    def _compare_other(self, ser: pd.Series, data: ExtensionArray, op: Callable[[Any, Any], Any], other: object) -> None: ...
    def test_compare_scalar(self, data: ExtensionArray, comparison_op: Callable[[Any, Any], Any]) -> None: ...
    def test_compare_array(self, data: ExtensionArray, comparison_op: Callable[[Any, Any], Any]) -> None: ...

class BaseUnaryOpsTests(BaseOpsUtil):
    def test_invert(self, data: ExtensionArray) -> None: ...
    def test_unary_ufunc_dunder_equivalence(self, data: ExtensionArray, ufunc: np.ufunc) -> None: ...