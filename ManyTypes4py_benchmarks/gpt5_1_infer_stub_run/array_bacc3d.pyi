from __future__ import annotations

import decimal
from typing import Any, Callable, ClassVar, Iterable, Sequence, overload

import numpy as np
from numpy.typing import NDArray
from pandas.core.arraylike import OpsMixin
from pandas.core.arrays import ExtensionArray, ExtensionScalarOpsMixin
from pandas.core.dtypes.base import ExtensionDtype


class DecimalDtype(ExtensionDtype):
    type: ClassVar[type[decimal.Decimal]]
    name: ClassVar[str]
    na_value: ClassVar[decimal.Decimal]
    _metadata: ClassVar[tuple[str, ...]]

    def __init__(self, context: decimal.Context | None = ...) -> None: ...
    def __repr__(self) -> str: ...
    @classmethod
    def construct_array_type(cls) -> type[DecimalArray]: ...
    @property
    def _is_numeric(self) -> bool: ...


class DecimalArray(OpsMixin, ExtensionScalarOpsMixin, ExtensionArray):
    __array_priority__: ClassVar[int]
    _HANDLED_TYPES: ClassVar[tuple[type[object], ...]]
    _data: NDArray[object]
    data: NDArray[object]
    _dtype: DecimalDtype

    def __init__(
        self,
        values: Sequence[decimal.Decimal | int | float] | NDArray[Any],
        dtype: DecimalDtype | None = ...,
        copy: bool = ...,
        context: decimal.Context | None = ...,
    ) -> None: ...
    @property
    def dtype(self) -> DecimalDtype: ...
    @classmethod
    def _from_sequence(
        cls,
        scalars: Sequence[decimal.Decimal | int | float],
        *,
        dtype: DecimalDtype | None = ...,
        copy: bool = ...,
    ) -> DecimalArray: ...
    @classmethod
    def _from_sequence_of_strings(
        cls,
        strings: Sequence[str],
        *,
        dtype: DecimalDtype,
        copy: bool = ...,
    ) -> DecimalArray: ...
    @classmethod
    def _from_factorized(cls, values: Sequence[decimal.Decimal], original: DecimalArray) -> DecimalArray: ...
    def to_numpy(
        self,
        dtype: Any = ...,
        copy: bool = ...,
        na_value: Any = ...,
        decimals: int | None = ...,
    ) -> NDArray[object]: ...
    def __array_ufunc__(self, ufunc: np.ufunc, method: str, *inputs: Any, **kwargs: Any) -> Any: ...
    @overload
    def __getitem__(self, item: int) -> decimal.Decimal: ...
    @overload
    def __getitem__(self, item: slice | Sequence[int] | Sequence[bool] | NDArray[Any]) -> DecimalArray: ...
    def __getitem__(self, item: Any) -> decimal.Decimal | DecimalArray: ...
    def take(
        self,
        indexer: Sequence[int] | NDArray[np.intp],
        allow_fill: bool = ...,
        fill_value: decimal.Decimal | None = ...,
    ) -> DecimalArray: ...
    def copy(self) -> DecimalArray: ...
    def astype(self, dtype: object, copy: bool = ...) -> object: ...
    def __setitem__(self, key: int | slice | Sequence[int] | Sequence[bool] | NDArray[Any], value: Any) -> None: ...
    def __len__(self) -> int: ...
    def __contains__(self, item: object) -> bool: ...
    @property
    def nbytes(self) -> int: ...
    def isna(self) -> NDArray[np.bool_]: ...
    @property
    def _na_value(self) -> decimal.Decimal: ...
    def _formatter(self, boxed: bool = ...) -> Callable[[object], str]: ...
    @classmethod
    def _concat_same_type(cls, to_concat: Sequence[DecimalArray]) -> DecimalArray: ...
    def _reduce(self, name: str, *, skipna: bool = ..., keepdims: bool = ..., **kwargs: Any) -> decimal.Decimal | DecimalArray: ...
    def _cmp_method(self, other: object, op: Callable[[Any, Any], Any]) -> NDArray[np.bool_]: ...
    def value_counts(self, dropna: bool = ...) -> tuple[NDArray[object], NDArray[np.intp]]: ...
    def fillna(self, value: decimal.Decimal | None = ..., limit: int | None = ...) -> DecimalArray: ...


def to_decimal(values: Iterable[object], context: decimal.Context | None = ...) -> DecimalArray: ...
def make_data() -> list[decimal.Decimal]: ...