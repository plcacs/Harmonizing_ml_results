class SonosMockEventListener:
    address: list[str]
    def __init__(self, ip_address: str) -> None: ...

class SonosMockSubscribe:
    event_listener: SonosMockEventListener
    service: Mock
    callback_future: Optional[asyncio.Future[Callable[[SonosEvent], Any]]]
    _callback: Optional[Callable[[SonosEvent], Any]]
    def __init__(self, ip_address: str, *args: Any, **kwargs: Any) -> None: ...
    @property
    def callback(self) -> Optional[Callable[[SonosEvent], Any]]: ...
    @callback.setter
    def callback(self, callback: Callable[[SonosEvent], Any]) -> None: ...
    def _get_callback_future(self) -> asyncio.Future[Callable[[SonosEvent], Any]]: ...
    async def wait_for_callback_to_be_set(self) -> Callable[[SonosEvent], Any]: ...
    async def unsubscribe(self) -> None: ...

class SonosMockService:
    service_type: str
    subscribe: Callable[[], Awaitable[SonosMockSubscribe]]
    def __init__(self, service_type: str, ip_address: str = '192.168.42.2') -> None: ...

class SonosMockEvent:
    sid: str
    seq: str
