from __future__ import annotations

from collections.abc import Callable, Sequence
from re import Pattern
from typing import Any, Literal, Self
from pandas._libs import lib


class ArrowStringArrayMixin:
    def __init__(self, *args: Any, **kwargs: Any) -> None: ...
    def _convert_bool_result(self, result: Any, na: object = lib.no_default, method_name: str | None = None) -> Any: ...
    def _convert_int_result(self, result: Any) -> Any: ...
    def _apply_elementwise(self, func: Callable[[str], Any]) -> list[Any]: ...

    def _str_len(self) -> Any: ...
    def _str_lower(self) -> Self: ...
    def _str_upper(self) -> Self: ...
    def _str_strip(self, to_strip: str | None = None) -> Self: ...
    def _str_lstrip(self, to_strip: str | None = None) -> Self: ...
    def _str_rstrip(self, to_strip: str | None = None) -> Self: ...
    def _str_pad(self, width: int, side: Literal["left", "right", "both"] = "left", fillchar: str = " ") -> Self: ...
    def _str_get(self, i: int) -> Self: ...
    def _str_slice(self, start: int | None = None, stop: int | None = None, step: int | None = None) -> Self: ...
    def _str_slice_replace(self, start: int | None = None, stop: int | None = None, repl: str | None = None) -> Self: ...
    def _str_replace(self, pat: str | Pattern[str], repl: str, n: int = -1, case: bool = True, flags: int = 0, regex: bool = True) -> Self: ...
    def _str_capitalize(self) -> Self: ...
    def _str_title(self) -> Self: ...
    def _str_swapcase(self) -> Self: ...
    def _str_removeprefix(self, prefix: str) -> Self: ...
    def _str_removesuffix(self, suffix: str) -> Self: ...

    def _str_startswith(self, pat: str | Sequence[str], na: object = lib.no_default) -> Any: ...
    def _str_endswith(self, pat: str | Sequence[str], na: object = lib.no_default) -> Any: ...

    def _str_isalnum(self) -> Any: ...
    def _str_isalpha(self) -> Any: ...
    def _str_isascii(self) -> Any: ...
    def _str_isdecimal(self) -> Any: ...
    def _str_isdigit(self) -> Any: ...
    def _str_islower(self) -> Any: ...
    def _str_isnumeric(self) -> Any: ...
    def _str_isspace(self) -> Any: ...
    def _str_istitle(self) -> Any: ...
    def _str_isupper(self) -> Any: ...

    def _str_contains(self, pat: str, case: bool = True, flags: int = 0, na: object = lib.no_default, regex: bool = True) -> Any: ...
    def _str_match(self, pat: str, case: bool = True, flags: int = 0, na: object = lib.no_default) -> Any: ...
    def _str_fullmatch(self, pat: str, case: bool = True, flags: int = 0, na: object = lib.no_default) -> Any: ...
    def _str_find(self, sub: str, start: int | None = 0, end: int | None = None) -> Any: ...