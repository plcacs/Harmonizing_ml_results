from typing import ClassVar, Iterable, Iterator, Optional, Type, Union

from jedi.inference.base_value import LazyValueWrapper, Value, ValueSet, ValueWrapper
from jedi.inference.compiled.value import CompiledValueName
from jedi.inference.filters import FilterWrapper
from jedi.inference.gradual.base import BaseTypingClassWithGenerics, BaseTypingInstance, BaseTypingValue
from jedi.inference.gradual.generics import LazyGenericManager, TupleGenericManager
from jedi.inference.lazy_value import LazyKnownValues
from jedi.inference.names import NameWrapper, ValueName
from jedi.inference.value.klass import ClassMixin


class TypingModuleName(NameWrapper):
    def infer(self) -> ValueSet: ...
    def _remap(self) -> Iterable[Value]: ...


class TypingModuleFilterWrapper(FilterWrapper):
    name_wrapper_class: ClassVar[Type[NameWrapper]]


class ProxyWithGenerics(BaseTypingClassWithGenerics):
    def execute_annotation(self) -> ValueSet: ...
    def gather_annotation_classes(self) -> ValueSet: ...
    def _create_instance_with_generics(
        self, generics_manager: Union[LazyGenericManager, TupleGenericManager]
    ) -> "ProxyWithGenerics": ...
    def infer_type_vars(self, value_set: ValueSet) -> dict[object, object]: ...


class ProxyTypingValue(BaseTypingValue):
    index_class: ClassVar[Type[ProxyWithGenerics]]
    def with_generics(self, generics_tuple: tuple[object, ...]) -> ProxyWithGenerics: ...
    def py__getitem__(self, index_value_set: ValueSet, contextualized_node: object) -> ValueSet: ...


class _TypingClassMixin(ClassMixin):
    def py__bases__(self) -> list[LazyKnownValues]: ...
    def get_metaclasses(self) -> list[object]: ...
    @property
    def name(self) -> ValueName: ...


class TypingClassWithGenerics(ProxyWithGenerics, _TypingClassMixin):
    def infer_type_vars(self, value_set: ValueSet) -> dict[object, object]: ...
    def _create_instance_with_generics(
        self, generics_manager: Union[LazyGenericManager, TupleGenericManager]
    ) -> "TypingClassWithGenerics": ...


class ProxyTypingClassValue(ProxyTypingValue, _TypingClassMixin):
    index_class: ClassVar[Type[TypingClassWithGenerics]]


class TypeAlias(LazyValueWrapper):
    def __init__(self, parent_context: object, origin_tree_name: object, actual: str) -> None: ...
    @property
    def name(self) -> ValueName: ...
    def py__name__(self) -> str: ...
    def __repr__(self) -> str: ...
    def _get_wrapped_value(self) -> Value: ...
    def gather_annotation_classes(self) -> ValueSet: ...
    def get_signatures(self) -> list[object]: ...


class Callable(BaseTypingInstance):
    def py__call__(self, arguments: object) -> ValueSet: ...
    def py__get__(self, instance: Optional[object], class_value: object) -> ValueSet: ...


class Tuple(BaseTypingInstance):
    def _is_homogenous(self) -> bool: ...
    def py__simple_getitem__(self, index: object) -> ValueSet: ...
    def py__iter__(self, contextualized_node: Optional[object] = ...) -> Iterator[LazyKnownValues]: ...
    def py__getitem__(self, index_value_set: ValueSet, contextualized_node: object) -> ValueSet: ...
    def _get_wrapped_value(self) -> Value: ...
    @property
    def name(self) -> ValueName: ...
    def infer_type_vars(self, value_set: ValueSet) -> dict[object, object]: ...


class Generic(BaseTypingInstance):
    ...


class Protocol(BaseTypingInstance):
    ...


class AnyClass(BaseTypingValue):
    def execute_annotation(self) -> ValueSet: ...


class OverloadFunction(BaseTypingValue):
    def py__call__(self, func_value_set: ValueSet) -> ValueSet: ...


class NewTypeFunction(ValueWrapper):
    def py__call__(self, arguments: object) -> ValueSet: ...


class NewType(Value):
    def __init__(self, inference_state: object, parent_context: object, tree_node: object, type_value_set: ValueSet) -> None: ...
    def py__class__(self) -> Value: ...
    def py__call__(self, arguments: object) -> ValueSet: ...
    @property
    def name(self) -> CompiledValueName: ...
    def __repr__(self) -> str: ...


class CastFunction(ValueWrapper):
    def py__call__(self, type_value_set: ValueSet, object_value_set: ValueSet) -> ValueSet: ...


class TypedDictClass(BaseTypingValue):
    ...


class TypedDict(LazyValueWrapper):
    def __init__(self, definition_class: TypedDictClass) -> None: ...
    @property
    def name(self) -> ValueName: ...
    def py__simple_getitem__(self, index: object) -> ValueSet: ...
    def get_key_values(self) -> ValueSet: ...
    def _get_wrapped_value(self) -> Value: ...