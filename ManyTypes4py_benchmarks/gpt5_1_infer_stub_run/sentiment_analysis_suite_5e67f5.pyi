from numpy import ndarray
from checklist.test_suite import TestSuite
from allennlp.confidence_checks.task_checklists.task_suite import TaskSuite
from allennlp.data.instance import Instance
from allennlp.predictors import Predictor

def _add_phrase_function(phrases: Sequence[str], num_samples: int = ...) -> Callable[[str], list[str]]: ...

class SentimentAnalysisSuite(TaskSuite):
    def __init__(self, suite: Optional[TestSuite] = ..., positive: int = ..., negative: int = ..., **kwargs: Any) -> None: ...
    def _prediction_and_confidence_scores(self, predictor: Predictor) -> Callable[[Union[Sequence[Instance], Sequence[str]]], Tuple[ndarray, ndarray]]: ...
    def _format_failing_examples(self, inputs: str, pred: int, conf: Sequence[float], label: Optional[int] = ..., *args: Any, **kwargs: Any) -> str: ...
    def _default_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _setup_editor(self) -> None: ...
    def _default_vocabulary_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _default_robustness_tests(self, data: Sequence[str], num_test_cases: int = ...) -> None: ...
    def _default_ner_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _default_temporal_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _default_fairness_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _default_negation_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _positive_change(self, orig_conf: Sequence[float], conf: Sequence[float]) -> float: ...
    def _diff_up(self, orig_pred: int, pred: int, orig_conf: Sequence[float], conf: Sequence[float], labels: Any = ..., meta: Any = ...) -> Union[bool, float]: ...
    def _diff_down(self, orig_pred: int, pred: int, orig_conf: Sequence[float], conf: Sequence[float], labels: Any = ..., meta: Any = ...) -> Union[bool, float]: ...