from typing import Any, Callable, Iterable, Iterator, Optional, Tuple
from jedi.inference.base_value import ContextualizedNode, ValueSet
from jedi.inference.lazy_value import LazyKnownValues
from jedi.inference.names import TreeNameDefinition

class ParamIssue(Exception): ...

class _AbstractArgumentsMixin:
    def unpack(self, funcdef: Any | None = ...) -> Iterator[tuple[Optional[str], Any]]: ...
    def get_calling_nodes(self) -> list[ContextualizedNode]: ...

class AbstractArguments(_AbstractArgumentsMixin):
    context: Any
    argument_node: Any
    trailer: Any

class TreeArguments(AbstractArguments):
    def __init__(self, inference_state: Any, context: Any, argument_node: Any, trailer: Any | None = ...) -> None: ...
    @classmethod
    def create_cached(cls, *args: Any, **kwargs: Any) -> "TreeArguments": ...
    def unpack(self, funcdef: Any | None = ...) -> Iterator[tuple[Optional[str], Any]]: ...
    def _as_tree_tuple_objects(self) -> Iterator[tuple[Any, Any | None, int]]: ...
    def iter_calling_names_with_star(self) -> Iterator[TreeNameDefinition]: ...
    def __repr__(self) -> str: ...
    def get_calling_nodes(self) -> list[ContextualizedNode]: ...

class ValuesArguments(AbstractArguments):
    def __init__(self, values_list: Iterable[ValueSet]) -> None: ...
    def unpack(self, funcdef: Any | None = ...) -> Iterator[tuple[None, LazyKnownValues]]: ...
    def __repr__(self) -> str: ...

class TreeArgumentsWrapper(_AbstractArgumentsMixin):
    def __init__(self, arguments: AbstractArguments) -> None: ...
    @property
    def context(self) -> Any: ...
    @property
    def argument_node(self) -> Any: ...
    @property
    def trailer(self) -> Any: ...
    def unpack(self, func: Any | None = ...) -> Iterator[tuple[Optional[str], Any]]: ...
    def get_calling_nodes(self) -> list[ContextualizedNode]: ...
    def __repr__(self) -> str: ...

def try_iter_content(types: Iterable[Any], depth: int = ...) -> None: ...
def repack_with_argument_clinic(clinic_string: str) -> Callable[[Callable[..., ValueSet]], Callable[[Any, AbstractArguments], ValueSet]]: ...
def iterate_argument_clinic(inference_state: Any, arguments: AbstractArguments, clinic_string: str) -> Iterator[ValueSet]: ...
def _parse_argument_clinic(string: str) -> Iterator[tuple[str, bool, bool, int]]: ...
def unpack_arglist(arglist: Any | None) -> Iterator[tuple[int, Any]]: ...
def _iterate_star_args(context: Any, array: Any, input_node: Any, funcdef: Any | None = ...) -> Iterator[Any]: ...
def _star_star_dict(context: Any, array: Any, input_node: Any, funcdef: Any) -> Iterable[tuple[str, Any]]: ...