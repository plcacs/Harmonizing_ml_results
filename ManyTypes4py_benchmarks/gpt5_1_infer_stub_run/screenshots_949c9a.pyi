from typing import ClassVar, Optional, TypedDict
import logging
from io import BytesIO
from enum import Enum
from flask_caching import Cache
from flask_appbuilder.security.sqla.models import User
from superset.dashboards.permalink.types import DashboardPermalinkState
from superset.utils.webdriver import WebDriver

logger: logging.Logger = ...
DEFAULT_SCREENSHOT_WINDOW_SIZE: tuple[int, int] = ...
DEFAULT_SCREENSHOT_THUMBNAIL_SIZE: tuple[int, int] = ...
DEFAULT_CHART_WINDOW_SIZE: tuple[int, int] = ...
DEFAULT_CHART_THUMBNAIL_SIZE: tuple[int, int] = ...
DEFAULT_DASHBOARD_WINDOW_SIZE: tuple[int, int] = ...
DEFAULT_DASHBOARD_THUMBNAIL_SIZE: tuple[int, int] = ...

class StatusValues(Enum):
    PENDING: ClassVar["StatusValues"]
    COMPUTING: ClassVar["StatusValues"]
    UPDATED: ClassVar["StatusValues"]
    ERROR: ClassVar["StatusValues"]

class ScreenshotCachePayloadType(TypedDict):
    image: Optional[bytes]
    timestamp: str
    status: str

class ScreenshotCachePayload:
    _image: Optional[bytes]
    _timestamp: str
    status: StatusValues

    def __init__(self, image: Optional[bytes] = ..., status: StatusValues = ..., timestamp: str = ...) -> None: ...
    @classmethod
    def from_dict(cls, payload: ScreenshotCachePayloadType) -> "ScreenshotCachePayload": ...
    def to_dict(self) -> ScreenshotCachePayloadType: ...
    def update_timestamp(self) -> None: ...
    def pending(self) -> None: ...
    def computing(self) -> None: ...
    def update(self, image: bytes) -> None: ...
    def error(self) -> None: ...
    def get_image(self) -> Optional[BytesIO]: ...
    def get_timestamp(self) -> str: ...
    def get_status(self) -> str: ...
    def is_error_cache_ttl_expired(self) -> bool: ...
    def should_trigger_task(self, force: bool = ...) -> bool: ...

class BaseScreenshot:
    driver_type: ClassVar[str]
    thumbnail_type: ClassVar[str]
    element: ClassVar[str]
    window_size: ClassVar[tuple[int, int]]
    thumb_size: ClassVar[tuple[int, int]]
    cache: ClassVar[Cache]

    digest: str
    url: str
    screenshot: Optional[bytes]

    def __init__(self, url: str, digest: str) -> None: ...
    def driver(self, window_size: Optional[tuple[int, int]] = ...) -> WebDriver: ...
    def get_screenshot(self, user: Optional[User], window_size: Optional[tuple[int, int]] = ...) -> bytes: ...
    def get_cache_key(self, window_size: Optional[tuple[int, int]] = ..., thumb_size: Optional[tuple[int, int]] = ...) -> str: ...
    def get_from_cache(self, window_size: Optional[tuple[int, int]] = ..., thumb_size: Optional[tuple[int, int]] = ...) -> Optional[ScreenshotCachePayload]: ...
    @classmethod
    def get_from_cache_key(cls, cache_key: str) -> Optional[ScreenshotCachePayload]: ...
    def compute_and_cache(self, force: bool, user: Optional[User] = ..., window_size: Optional[tuple[int, int]] = ..., thumb_size: Optional[tuple[int, int]] = ..., cache_key: Optional[str] = ...) -> None: ...
    @classmethod
    def resize_image(cls, img_bytes: bytes, output: str = ..., thumb_size: Optional[tuple[int, int]] = ..., crop: bool = ...) -> bytes: ...

class ChartScreenshot(BaseScreenshot):
    thumbnail_type: ClassVar[str]
    element: ClassVar[str]

    def __init__(self, url: str, digest: str, window_size: Optional[tuple[int, int]] = ..., thumb_size: Optional[tuple[int, int]] = ...) -> None: ...

class DashboardScreenshot(BaseScreenshot):
    thumbnail_type: ClassVar[str]
    element: ClassVar[str]

    def __init__(self, url: str, digest: str, window_size: Optional[tuple[int, int]] = ..., thumb_size: Optional[tuple[int, int]] = ...) -> None: ...
    def get_cache_key(self, window_size: Optional[tuple[int, int]] = ..., thumb_size: Optional[tuple[int, int]] = ..., dashboard_state: Optional[DashboardPermalinkState] = ...) -> str: ...