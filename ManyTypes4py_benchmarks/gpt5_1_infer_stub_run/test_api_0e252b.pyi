from typing import Any, Callable, List, Literal, Optional, Tuple, TypeVar, Union, TextIO
from pyflakes.test.harness import TestCase

_T = TypeVar("_T")

LogEntry = Union[
    Tuple[Literal["flake"], str],
    Tuple[Literal["unexpectedError"], str, str],
    Tuple[Literal["syntaxError"], str, str, int, Optional[int], str],
]

def withStderrTo(stderr: TextIO, f: Callable[..., _T], *args: Any, **kwargs: Any) -> _T: ...

class Node:
    lineno: int
    col_offset: int
    def __init__(self, lineno: int, col_offset: int = ...) -> None: ...

class LoggingReporter:
    log: List[LogEntry]
    def __init__(self, log: List[LogEntry]) -> None: ...
    def flake(self, message: object) -> None: ...
    def unexpectedError(self, filename: str, message: str) -> None: ...
    def syntaxError(self, filename: str, msg: str, lineno: int, offset: Optional[int], line: str) -> None: ...

