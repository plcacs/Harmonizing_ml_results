from __future__ import annotations
from enum import Enum
from typing import Any, AsyncContextManager, Awaitable, Callable, ContextManager, Dict, Iterable, Iterator, List, Optional, Pattern, Sequence, Set, Tuple, TypeVar, Union
from starlette.convertors import Convertor
from starlette.datastructures import URLPath
from starlette.requests import Request
from starlette.responses import Response
from starlette.types import ASGIApp, Lifespan, Receive, Scope, Send
from starlette.websockets import WebSocket

class NoMatchFound(Exception):
    def __init__(self, name: str, path_params: Dict[str, Any]) -> None: ...

class Match(Enum):
    NONE: int
    PARTIAL: int
    FULL: int

def iscoroutinefunction_or_partial(obj: object) -> bool: ...
def request_response(func: Callable[[Request], Union[Response, Awaitable[Response]]]) -> ASGIApp: ...
def websocket_session(func: Callable[[WebSocket], Awaitable[None]]) -> ASGIApp: ...
def get_name(endpoint: object) -> str: ...
def replace_params(path: str, param_convertors: Dict[str, Convertor], path_params: Dict[str, Any]) -> Tuple[str, Dict[str, Any]]: ...
PARAM_REGEX: Pattern[str]
def compile_path(path: str) -> Tuple[Pattern[str], str, Dict[str, Convertor]]: ...

class BaseRoute:
    def matches(self, scope: Scope) -> Tuple[Match, Dict[str, Any]]: ...
    def url_path_for(self, name, /, **path_params: Any) -> URLPath: ...
    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None: ...

class Route(BaseRoute):
    path: str
    endpoint: Union[ASGIApp, Callable[[Request], Union[Response, Awaitable[Response]]]]
    name: str
    include_in_schema: bool
    app: ASGIApp
    methods: Optional[Set[str]]
    path_regex: Pattern[str]
    path_format: str
    param_convertors: Dict[str, Convertor]

    def __init__(
        self,
        path: str,
        endpoint: Union[ASGIApp, Callable[[Request], Union[Response, Awaitable[Response]]]],
        *,
        methods: Optional[Iterable[str]] = ...,
        name: Optional[str] = ...,
        include_in_schema: bool = ...,
        middleware: Optional[Sequence[Tuple[Callable[..., ASGIApp], Tuple[Any, ...], Dict[str, Any]]]] = ...,
    ) -> None: ...
    def matches(self, scope: Scope) -> Tuple[Match, Dict[str, Any]]: ...
    def url_path_for(self, name, /, **path_params: Any) -> URLPath: ...
    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def __eq__(self, other: object) -> bool: ...
    def __repr__(self) -> str: ...

class WebSocketRoute(BaseRoute):
    path: str
    endpoint: Union[ASGIApp, Callable[[WebSocket], Awaitable[None]]]
    name: str
    app: ASGIApp
    path_regex: Pattern[str]
    path_format: str
    param_convertors: Dict[str, Convertor]

    def __init__(
        self,
        path: str,
        endpoint: Union[ASGIApp, Callable[[WebSocket], Awaitable[None]]],
        *,
        name: Optional[str] = ...,
        middleware: Optional[Sequence[Tuple[Callable[..., ASGIApp], Tuple[Any, ...], Dict[str, Any]]]] = ...,
    ) -> None: ...
    def matches(self, scope: Scope) -> Tuple[Match, Dict[str, Any]]: ...
    def url_path_for(self, name, /, **path_params: Any) -> URLPath: ...
    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def __eq__(self, other: object) -> bool: ...
    def __repr__(self) -> str: ...

class Mount(BaseRoute):
    path: str
    _base_app: ASGIApp
    app: ASGIApp
    name: Optional[str]
    path_regex: Pattern[str]
    path_format: str
    param_convertors: Dict[str, Convertor]

    def __init__(
        self,
        path: str,
        app: Optional[ASGIApp] = ...,
        routes: Optional[Sequence[BaseRoute]] = ...,
        name: Optional[str] = ...,
        *,
        middleware: Optional[Sequence[Tuple[Callable[..., ASGIApp], Tuple[Any, ...], Dict[str, Any]]]] = ...,
    ) -> None: ...
    @property
    def routes(self) -> List[BaseRoute]: ...
    def matches(self, scope: Scope) -> Tuple[Match, Dict[str, Any]]: ...
    def url_path_for(self, name, /, **path_params: Any) -> URLPath: ...
    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def __eq__(self, other: object) -> bool: ...
    def __repr__(self) -> str: ...

class Host(BaseRoute):
    host: str
    app: ASGIApp
    name: Optional[str]
    host_regex: Pattern[str]
    host_format: str
    param_convertors: Dict[str, Convertor]

    def __init__(self, host: str, app: ASGIApp, name: Optional[str] = ...) -> None: ...
    @property
    def routes(self) -> List[BaseRoute]: ...
    def matches(self, scope: Scope) -> Tuple[Match, Dict[str, Any]]: ...
    def url_path_for(self, name, /, **path_params: Any) -> URLPath: ...
    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def __eq__(self, other: object) -> bool: ...
    def __repr__(self) -> str: ...

_T = TypeVar("_T")

class _AsyncLiftContextManager(AsyncContextManager[_T]):
    _cm: ContextManager[_T]
    def __init__(self, cm: ContextManager[_T]) -> None: ...
    async def __aenter__(self) -> _T: ...
    async def __aexit__(self, exc_type: Optional[type[BaseException]], exc_value: Optional[BaseException], traceback: Optional[Any]) -> Optional[bool]: ...

def _wrap_gen_lifespan_context(
    lifespan_context: Callable[..., Iterator[Any]],
) -> Callable[[Any], AsyncContextManager[Any]]: ...

class _DefaultLifespan:
    _router: Router
    def __init__(self, router: Router) -> None: ...
    async def __aenter__(self) -> None: ...
    async def __aexit__(self, *exc_info: Any) -> None: ...
    def __call__(self, app: Any) -> _DefaultLifespan: ...

E = TypeVar("E", bound=Callable[[Request], Union[Response, Awaitable[Response]]])
W = TypeVar("W", bound=Callable[[WebSocket], Awaitable[None]])
H = TypeVar("H", bound=Callable[[], Union[None, Awaitable[None]]])

class Router:
    routes: List[BaseRoute]
    redirect_slashes: bool
    default: ASGIApp
    on_startup: List[Callable[[], Union[None, Awaitable[None]]]]
    on_shutdown: List[Callable[[], Union[None, Awaitable[None]]]]
    lifespan_context: Lifespan
    middleware_stack: ASGIApp

    def __init__(
        self,
        routes: Optional[Sequence[BaseRoute]] = ...,
        redirect_slashes: bool = ...,
        default: Optional[ASGIApp] = ...,
        on_startup: Optional[Iterable[Callable[[], Union[None, Awaitable[None]]]]] = ...,
        on_shutdown: Optional[Iterable[Callable[[], Union[None, Awaitable[None]]]]] = ...,
        lifespan: Optional[Lifespan] = ...,
        *,
        middleware: Optional[Sequence[Tuple[Callable[..., ASGIApp], Tuple[Any, ...], Dict[str, Any]]]] = ...,
    ) -> None: ...
    async def not_found(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def url_path_for(self, name, /, **path_params: Any) -> URLPath: ...
    async def startup(self) -> None: ...
    async def shutdown(self) -> None: ...
    async def lifespan(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    async def app(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def __eq__(self, other: object) -> bool: ...
    def mount(self, path: str, app: ASGIApp, name: Optional[str] = ...) -> None: ...
    def host(self, host: str, app: ASGIApp, name: Optional[str] = ...) -> None: ...
    def add_route(
        self,
        path: str,
        endpoint: Union[ASGIApp, Callable[[Request], Union[Response, Awaitable[Response]]]],
        methods: Optional[Iterable[str]] = ...,
        name: Optional[str] = ...,
        include_in_schema: bool = ...,
    ) -> None: ...
    def add_websocket_route(
        self,
        path: str,
        endpoint: Union[ASGIApp, Callable[[WebSocket], Awaitable[None]]],
        name: Optional[str] = ...,
    ) -> None: ...
    def route(
        self,
        path: str,
        methods: Optional[Iterable[str]] = ...,
        name: Optional[str] = ...,
        include_in_schema: bool = ...,
    ) -> Callable[[E], E]: ...
    def websocket_route(self, path: str, name: Optional[str] = ...) -> Callable[[W], W]: ...
    def add_event_handler(self, event_type: str, func: Callable[[], Union[None, Awaitable[None]]]) -> None: ...
    def on_event(self, event_type: str) -> Callable[[H], H]: ...