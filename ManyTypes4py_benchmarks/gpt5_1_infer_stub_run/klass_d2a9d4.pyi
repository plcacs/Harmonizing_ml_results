from typing import Any, Dict, Iterable, Iterator, List, Optional, Tuple

from jedi.inference.arguments import TreeArguments, ValuesArguments
from jedi.inference.base_value import ValueSet
from jedi.inference.cache import CachedMetaClass
from jedi.inference.context import ClassContext
from jedi.inference.filters import ParserTreeFilter
from jedi.inference.gradual.base import GenericClass
from jedi.inference.names import TreeNameDefinition, ValueName
from jedi.inference.value.function import FunctionAndClassBase


class ClassName(TreeNameDefinition):
    def __init__(self, class_value: "ClassValue", tree_name: Any, name_context: Any, apply_decorators: bool) -> None: ...
    def infer(self) -> ValueSet: ...
    @property
    def api_type(self) -> str: ...


class ClassFilter(ParserTreeFilter):
    def __init__(
        self,
        class_value: "ClassValue",
        node_context: Any | None = ...,
        until_position: Any | None = ...,
        origin_scope: Any | None = ...,
        is_instance: bool = ...,
    ) -> None: ...
    def _convert_names(self, names: Iterable[Any]) -> list[ClassName]: ...
    def _equals_origin_scope(self) -> bool: ...
    def _access_possible(self, name: Any) -> bool: ...
    def _filter(self, names: list[Any]) -> list[Any]: ...


class ClassMixin:
    def is_class(self) -> bool: ...
    def is_class_mixin(self) -> bool: ...
    def py__call__(self, arguments: ValuesArguments) -> ValueSet: ...
    def py__class__(self) -> "ClassValue": ...
    @property
    def name(self) -> ValueName: ...
    def py__name__(self) -> str: ...
    def py__mro__(self) -> Iterator["ClassValue"]: ...
    def get_filters(
        self,
        origin_scope: Any | None = ...,
        is_instance: bool = ...,
        include_metaclasses: bool = ...,
        include_type_when_class: bool = ...,
    ) -> Iterator[ParserTreeFilter]: ...
    def get_signatures(self) -> list[Any]: ...
    def _as_context(self) -> ClassContext: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...
    def is_typeddict(self) -> bool: ...
    def py__getitem__(self, index_value_set: ValueSet, contextualized_node: Any) -> ValueSet: ...
    def with_generics(self, generics_tuple: Tuple[ValueSet, ...]) -> GenericClass: ...
    def define_generics(self, type_var_dict: Dict[str, ValueSet]) -> ValueSet: ...


class ClassValue(ClassMixin, FunctionAndClassBase, metaclass=CachedMetaClass):
    api_type: str
    def list_type_vars(self) -> list[Any]: ...
    def _get_bases_arguments(self) -> Optional[TreeArguments]: ...
    def py__bases__(self) -> list[Any]: ...
    def get_metaclass_filters(self, metaclasses: ValueSet, is_instance: bool) -> list[ParserTreeFilter]: ...
    def get_metaclasses(self) -> ValueSet: ...
    def get_metaclass_signatures(self, metaclasses: ValueSet) -> list[Any]: ...