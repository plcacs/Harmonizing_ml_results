from __future__ import annotations

from typing import Any, Callable, List, Mapping, Match, Optional, Pattern, Sequence, Tuple, Union, Literal

import numpy as np
from pandas._libs import lib
from pandas._typing import NpDtype, Scalar
from pandas.core.arrays.string_ import BaseStringArray
from pandas.core.strings.base import BaseStringArrayMethods


class ObjectStringArrayMixin(BaseStringArrayMethods):
    def __len__(self) -> int: ...
    def _str_map(
        self,
        f: Callable[[object], Any],
        na_value: Scalar | object = lib.no_default,
        dtype: Optional[NpDtype] = None,
        convert: bool = True,
    ) -> np.ndarray[Any, Any]: ...
    def _str_count(self, pat: str, flags: int = 0) -> np.ndarray[Any, Any]: ...
    def _str_pad(
        self,
        width: int,
        side: Literal["left", "right", "both"] = "left",
        fillchar: str = " ",
    ) -> np.ndarray[Any, Any]: ...
    def _str_contains(
        self,
        pat: str | Pattern[str],
        case: bool = True,
        flags: int = 0,
        na: object = lib.no_default,
        regex: bool = True,
    ) -> np.ndarray[Any, Any]: ...
    def _str_startswith(self, pat: str | tuple[str, ...], na: object = lib.no_default) -> np.ndarray[Any, Any]: ...
    def _str_endswith(self, pat: str | tuple[str, ...], na: object = lib.no_default) -> np.ndarray[Any, Any]: ...
    def _str_replace(
        self,
        pat: str | Pattern[str],
        repl: str | Callable[[Match[str]], str],
        n: int = -1,
        case: bool = True,
        flags: int = 0,
        regex: bool = True,
    ) -> np.ndarray[Any, Any]: ...
    def _str_repeat(self, repeats: int | Sequence[int] | np.ndarray[Any, Any]) -> np.ndarray[Any, Any] | BaseStringArray: ...
    def _str_match(self, pat: str, case: bool = True, flags: int = 0, na: object = lib.no_default) -> np.ndarray[Any, Any]: ...
    def _str_fullmatch(self, pat: str, case: bool = True, flags: int = 0, na: object = lib.no_default) -> np.ndarray[Any, Any]: ...
    def _str_encode(self, encoding: str, errors: str = "strict") -> np.ndarray[Any, Any]: ...
    def _str_find(self, sub: str, start: int = 0, end: Optional[int] = None) -> np.ndarray[Any, Any]: ...
    def _str_rfind(self, sub: str, start: int = 0, end: Optional[int] = None) -> np.ndarray[Any, Any]: ...
    def _str_find_(self, sub: str, start: int, end: Optional[int], side: Literal["left", "right"]) -> np.ndarray[Any, Any]: ...
    def _str_findall(self, pat: str | Pattern[str], flags: int = 0) -> np.ndarray[Any, Any]: ...
    def _str_get(self, i: int) -> np.ndarray[Any, Any]: ...
    def _str_index(self, sub: str, start: int = 0, end: Optional[int] = None) -> np.ndarray[Any, Any]: ...
    def _str_rindex(self, sub: str, start: int = 0, end: Optional[int] = None) -> np.ndarray[Any, Any]: ...
    def _str_join(self, sep: str) -> np.ndarray[Any, Any]: ...
    def _str_partition(self, sep: str, expand: bool) -> np.ndarray[Any, Any]: ...
    def _str_rpartition(self, sep: str, expand: bool) -> np.ndarray[Any, Any]: ...
    def _str_len(self) -> np.ndarray[Any, Any]: ...
    def _str_slice(
        self,
        start: Optional[int] = None,
        stop: Optional[int] = None,
        step: Optional[int] = None,
    ) -> np.ndarray[Any, Any]: ...
    def _str_slice_replace(
        self,
        start: Optional[int] = None,
        stop: Optional[int] = None,
        repl: Optional[str] = None,
    ) -> np.ndarray[Any, Any]: ...
    def _str_split(
        self,
        pat: Optional[str | Pattern[str]] = None,
        n: Optional[int] = -1,
        expand: bool = False,
        regex: Optional[bool] = None,
    ) -> np.ndarray[Any, Any]: ...
    def _str_rsplit(self, pat: Optional[str] = None, n: Optional[int] = -1) -> np.ndarray[Any, Any]: ...
    def _str_translate(self, table: Mapping[int, int | str | None] | Sequence[int]) -> np.ndarray[Any, Any]: ...
    def _str_wrap(self, width: int, **kwargs: Any) -> np.ndarray[Any, Any]: ...
    def _str_get_dummies(self, sep: str = "|", dtype: Optional[NpDtype] = None) -> tuple[np.ndarray[Any, Any], list[str]]: ...
    def _str_upper(self) -> np.ndarray[Any, Any]: ...
    def _str_isalnum(self) -> np.ndarray[Any, Any]: ...
    def _str_isalpha(self) -> np.ndarray[Any, Any]: ...
    def _str_isascii(self) -> np.ndarray[Any, Any]: ...
    def _str_isdecimal(self) -> np.ndarray[Any, Any]: ...
    def _str_isdigit(self) -> np.ndarray[Any, Any]: ...
    def _str_islower(self) -> np.ndarray[Any, Any]: ...
    def _str_isnumeric(self) -> np.ndarray[Any, Any]: ...
    def _str_isspace(self) -> np.ndarray[Any, Any]: ...
    def _str_istitle(self) -> np.ndarray[Any, Any]: ...
    def _str_isupper(self) -> np.ndarray[Any, Any]: ...
    def _str_capitalize(self) -> np.ndarray[Any, Any]: ...
    def _str_casefold(self) -> np.ndarray[Any, Any]: ...
    def _str_title(self) -> np.ndarray[Any, Any]: ...
    def _str_swapcase(self) -> np.ndarray[Any, Any]: ...
    def _str_lower(self) -> np.ndarray[Any, Any]: ...
    def _str_normalize(self, form: Literal["NFC", "NFKC", "NFD", "NFKD"]) -> np.ndarray[Any, Any]: ...
    def _str_strip(self, to_strip: Optional[str] = None) -> np.ndarray[Any, Any]: ...
    def _str_lstrip(self, to_strip: Optional[str] = None) -> np.ndarray[Any, Any]: ...
    def _str_rstrip(self, to_strip: Optional[str] = None) -> np.ndarray[Any, Any]: ...
    def _str_removeprefix(self, prefix: str) -> np.ndarray[Any, Any]: ...
    def _str_removesuffix(self, suffix: str) -> np.ndarray[Any, Any]: ...
    def _str_extract(
        self,
        pat: str | Pattern[str],
        flags: int = 0,
        expand: bool = True,
    ) -> np.ndarray[Any, Any] | list[list[object]]: ...