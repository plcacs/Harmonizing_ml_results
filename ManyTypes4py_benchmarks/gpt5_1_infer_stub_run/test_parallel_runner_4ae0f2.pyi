class LoggingDataset(AbstractDataset[Any, Any]):
    log: MutableSequence[tuple[str, str]]
    name: str
    value: Optional[Any]
    def __init__(self, log: MutableSequence[tuple[str, str]], name: str, value: Optional[Any] = ...) -> None: ...
    def _load(self) -> Optional[Any]: ...
    def _save(self, data: Any) -> None: ...
    def _release(self) -> None: ...
    def _describe(self) -> dict[str, Any]: ...

def logging_dataset_catalog() -> DataCatalog: ...

