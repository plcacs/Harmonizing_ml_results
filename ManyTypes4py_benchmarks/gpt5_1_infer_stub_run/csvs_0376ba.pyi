from __future__ import annotations

from typing import Any, Iterator, Literal, Sequence
from collections.abc import Hashable

from pandas._typing import (
    CompressionOptions,
    FilePath,
    FloatFormatType,
    IndexLabel,
    SequenceNotStr,
    StorageOptions,
    WriteBuffer,
)
from pandas.core.indexes.api import Index
from pandas.io.formats.format import DataFrameFormatter


class CSVFormatter:
    def __init__(
        self,
        formatter: DataFrameFormatter,
        path_or_buf: FilePath | WriteBuffer[str] | None = ...,
        sep: str = ...,
        cols: Sequence[Hashable] | Index | None = ...,
        index_label: IndexLabel | Literal[False] | None = ...,
        mode: str = ...,
        encoding: str | None = ...,
        errors: str = ...,
        compression: CompressionOptions | dict[str, Any] | None = ...,
        quoting: int | None = ...,
        lineterminator: str | None = ...,
        chunksize: int | None = ...,
        quotechar: str | None = ...,
        date_format: str | None = ...,
        doublequote: bool = ...,
        escapechar: str | None = ...,
        storage_options: StorageOptions | None = ...,
    ) -> None: ...
    @property
    def na_rep(self) -> str: ...
    @property
    def float_format(self) -> FloatFormatType | None: ...
    @property
    def decimal(self) -> str: ...
    @property
    def header(self) -> bool | SequenceNotStr[Hashable] | Index | None: ...
    @property
    def index(self) -> bool: ...
    def _initialize_index_label(
        self, index_label: IndexLabel | Literal[False] | None
    ) -> Sequence[Hashable] | Literal[False]: ...
    def _get_index_label_from_obj(self) -> list[Hashable]: ...
    def _get_index_label_multiindex(self) -> list[Hashable]: ...
    def _get_index_label_flat(self) -> list[Hashable]: ...
    def _initialize_quotechar(self, quotechar: str | None) -> str | None: ...
    @property
    def has_mi_columns(self) -> bool: ...
    def _initialize_columns(
        self, cols: Sequence[Hashable] | Index | None
    ) -> SequenceNotStr[Hashable]: ...
    def _initialize_chunksize(self, chunksize: int | None) -> int: ...
    @property
    def _number_format(self) -> dict[str, object]: ...
    @property
    def data_index(self) -> Index: ...
    @property
    def nlevels(self) -> int: ...
    @property
    def _has_aliases(self) -> bool: ...
    @property
    def _need_to_save_header(self) -> bool: ...
    @property
    def write_cols(self) -> SequenceNotStr[Hashable]: ...
    @property
    def encoded_labels(self) -> list[Hashable]: ...
    def save(self) -> None: ...
    def _save(self) -> None: ...
    def _save_header(self) -> None: ...
    def _generate_multiindex_header_rows(self) -> Iterator[list[Hashable]]: ...
    def _save_body(self) -> None: ...
    def _save_chunk(self, start_i: int, end_i: int) -> None: ...