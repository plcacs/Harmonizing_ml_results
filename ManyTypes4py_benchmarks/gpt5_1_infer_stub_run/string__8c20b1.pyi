from typing import Any, Callable, Iterable, Literal, Sequence, Self
import numpy as np
from numpy.typing import NDArray
from pandas import Series
from pandas.arrays import BooleanArray
from pandas.core.dtypes.base import ExtensionDtype, StorageExtensionDtype
from pandas.core.arrays.base import ExtensionArray
from pandas.core.arrays.floating import FloatingArray, FloatingDtype
from pandas.core.arrays.integer import IntegerArray, IntegerDtype
from pandas.core.arrays.numpy_ import NumpyExtensionArray

class StringDtype(StorageExtensionDtype):
    @property
    def name(self) -> str: ...
    @property
    def na_value(self) -> object: ...
    storage: str
    _na_value: object
    def __init__(self, storage: str | None = ..., na_value: object = ...) -> None: ...
    def __repr__(self) -> str: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def __reduce__(self) -> tuple[object, tuple[str, object]]: ...
    @property
    def type(self) -> type[str]: ...
    @classmethod
    def construct_from_string(cls, string: str) -> StringDtype: ...
    def construct_array_type(self) -> type[ExtensionArray]: ...
    def _get_common_dtype(self, dtypes: Sequence[object]) -> StringDtype | None: ...
    def __from_arrow__(self, array: Any) -> "BaseStringArray": ...

class BaseStringArray(ExtensionArray):
    def tolist(self) -> list[object]: ...
    @classmethod
    def _from_scalars(cls, scalars: Iterable[object], dtype: object) -> Self: ...
    def _formatter(self, boxed: bool = ...) -> Callable[[Any], str]: ...
    def _str_map(
        self,
        f: Callable[[Any], Any],
        na_value: object = ...,
        dtype: object | None = ...,
        convert: bool = ...
    ) -> ExtensionArray | NDArray[Any]: ...
    def _str_map_str_or_object(
        self,
        dtype: object,
        na_value: object,
        arr: NDArray[Any],
        f: Callable[[Any], Any],
        mask: NDArray[np.bool_],
    ) -> "BaseStringArray" | NDArray[Any]: ...
    def _str_map_nan_semantics(
        self,
        f: Callable[[Any], Any],
        na_value: object = ...,
        dtype: object | None = ...,
    ) -> ExtensionArray | NDArray[Any]: ...
    def view(self, dtype: object | None = ...) -> Self: ...

class StringArray(BaseStringArray, NumpyExtensionArray):
    def __init__(self, values: object, copy: bool = ...) -> None: ...
    def _validate(self) -> None: ...
    def _validate_scalar(self, value: object) -> object: ...
    @classmethod
    def _from_sequence(cls, scalars: object, *, dtype: object | None = ..., copy: bool = ...) -> Self: ...
    @classmethod
    def _from_sequence_of_strings(cls, strings: Sequence[str], *, dtype: StringDtype, copy: bool = ...) -> Self: ...
    @classmethod
    def _empty(cls, shape: int | tuple[int, ...], dtype: object) -> Self: ...
    def __arrow_array__(self, type: Any = ...) -> Any: ...
    def _values_for_factorize(self) -> tuple[NDArray[Any], object]: ...
    def _maybe_convert_setitem_value(self, value: object) -> object: ...
    def __setitem__(self, key: Any, value: Any) -> None: ...
    def _putmask(self, mask: Any, value: Any) -> None: ...
    def _where(self, mask: Any, value: Any) -> Self: ...
    def isin(self, values: object) -> NDArray[np.bool_]: ...
    def astype(self, dtype: object, copy: bool = ...) -> ExtensionArray | NDArray[Any]: ...
    def _reduce(self, name: str, *, skipna: bool = ..., keepdims: bool = ..., axis: int = ..., **kwargs: Any) -> object: ...
    def _wrap_reduction_result(self, axis: int | None, result: object) -> object: ...
    def min(self, axis: int | None = ..., skipna: bool = ..., **kwargs: Any) -> object: ...
    def max(self, axis: int | None = ..., skipna: bool = ..., **kwargs: Any) -> object: ...
    def sum(self, *, axis: int | None = ..., skipna: bool = ..., min_count: int = ..., **kwargs: Any) -> object: ...
    def value_counts(self, dropna: bool = ...) -> Series: ...
    def memory_usage(self, deep: bool = ...) -> int: ...
    def searchsorted(self, value: object, side: Literal["left", "right"] = ..., sorter: Any | None = ...) -> int | NDArray[np.intp]: ...
    def _cmp_method(self, other: object, op: Callable[..., Any]) -> "BaseStringArray" | BooleanArray | NDArray[np.bool_]: ...
    _arith_method: Callable[..., Any]  # alias of _cmp_method

class StringArrayNumpySemantics(StringArray):
    def _validate(self) -> None: ...
    @classmethod
    def _from_sequence(cls, scalars: object, *, dtype: object | None = ..., copy: bool = ...) -> Self: ...