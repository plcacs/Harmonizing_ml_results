from typing import Any, Literal, Optional, Protocol
from os import PathLike
from pandas import DataFrame
import pytest

pytestmark: Any
xfail_pyarrow: Any
skip_pyarrow: Any

class Parser(Protocol):
    engine: str
    low_memory: bool
    def read_csv(self, *args: Any, **kwargs: Any) -> DataFrame: ...
    def read_table(self, *args: Any, **kwargs: Any) -> DataFrame: ...
    def read_csv_check_warnings(self, warning: type[Warning], match: str, stream: Any, *args: Any, **kwargs: Any) -> DataFrame: ...

