from typing import Any

# === Internal dependency: fastapi._compat ===
PYDANTIC_VERSION_MINOR_TUPLE = tuple(...)
PYDANTIC_V2 = PYDANTIC_VERSION_MINOR_TUPLE[0] == 2

# === Third-party dependency: pydantic.fields ===
class FieldInfo(_repr.Representation):
    def deprecation_message(self) -> str | None: ...
    def default_factory_takes_validated_data(self) -> bool | None: ...
    def get_default(self, *, call_default_factory: Literal[True], validated_data: dict[str, Any] | None = ...) -> Any: ...
    def get_default(self, *, call_default_factory: Literal[False] = ...) -> Any: ...
    def get_default(self, *, call_default_factory: bool = ..., validated_data: dict[str, Any] | None = ...) -> Any: ...