from typing import Any

# === Internal dependency: prefect.blocks.abstract ===
class CredentialsBlock(Block, ABC):
    def logger(self) -> LoggerOrAdapter: ...
    def get_client(self, *args: Any, **kwargs: Any) -> Any: ...
class NotificationBlock(Block, ABC):
    async def notify(self, body: str, subject: str | None = ...) -> None: ...
class JobRun(ABC, Generic[T]):
    async def wait_for_completion(self) -> Logger: ...
    async def fetch_result(self) -> T: ...
class JobBlock(Block, ABC, Generic[T]):
    async def trigger(self) -> JobRun[T]: ...
class DatabaseBlock(Block, ABC):
    async def fetch_one(self, operation: str, parameters: dict[str, Any] | None = ..., **execution_kwargs: Any) -> tuple[Any, ...]: ...
    async def fetch_many(self, operation: str, parameters: dict[str, Any] | None = ..., size: int | None = ..., **execution_kwargs: Any) -> list[tuple[Any, ...]]: ...
    async def fetch_all(self, operation: str, parameters: dict[str, Any] | None = ..., **execution_kwargs: Any) -> list[tuple[Any, ...]]: ...
    async def execute(self, operation: str, parameters: dict[str, Any] | None = ..., **execution_kwargs: Any) -> None: ...
    async def execute_many(self, operation: str, seq_of_parameters: list[dict[str, Any]], **execution_kwargs: Any) -> None: ...
class ObjectStorageBlock(Block, ABC):
    async def download_object_to_path(self, from_path: str, to_path: str | Path, **download_kwargs: Any) -> Path: ...
    async def download_object_to_file_object(self, from_path: str, to_file_object: BinaryIO, **download_kwargs: Any) -> BinaryIO: ...
    async def download_folder_to_path(self, from_folder: str, to_folder: str | Path, **download_kwargs: Any) -> Path: ...
    async def upload_from_path(self, from_path: str | Path, to_path: str, **upload_kwargs: Any) -> str: ...
    async def upload_from_file_object(self, from_file_object: BinaryIO, to_path: str, **upload_kwargs: Any) -> str: ...
    async def upload_from_folder(self, from_folder: str | Path, to_folder: str, **upload_kwargs: Any) -> str: ...
class SecretBlock(Block, ABC):
    async def read_secret(self) -> bytes: ...
    async def write_secret(self, secret_data: bytes) -> str: ...

