from __future__ import annotations
from typing import Any, Dict, List, Optional, Union

from chalice.app import Chalice

StrMap = Dict[str, Any]

class Config:
    chalice_stage: str
    function_name: str
    _user_provided_params: StrMap
    _config_from_disk: StrMap
    _default_params: StrMap
    _chalice_app: Optional[Chalice]
    _layers: Any

    def __init__(
        self,
        chalice_stage: str = ...,
        function_name: str = ...,
        user_provided_params: Optional[StrMap] = ...,
        config_from_disk: Optional[StrMap] = ...,
        default_params: Optional[StrMap] = ...,
        layers: Any = ...,
    ) -> None: ...

    @classmethod
    def create(
        cls,
        chalice_stage: str = ...,
        function_name: str = ...,
        **kwargs: Any,
    ) -> Config: ...

    @property
    def profile(self) -> Optional[Any]: ...
    @property
    def app_name(self) -> Optional[Any]: ...
    @property
    def project_dir(self) -> Optional[Any]: ...
    @property
    def chalice_app(self) -> Chalice: ...
    @property
    def config_from_disk(self) -> StrMap: ...
    @property
    def lambda_python_version(self) -> str: ...
    @property
    def log_retention_in_days(self) -> Optional[Any]: ...
    @property
    def layers(self) -> Optional[Any]: ...
    @property
    def api_gateway_custom_domain(self) -> Optional[Any]: ...
    @property
    def websocket_api_custom_domain(self) -> Optional[Any]: ...

    def _chain_lookup(
        self,
        name: str,
        varies_per_chalice_stage: bool = ...,
        varies_per_function: bool = ...,
    ) -> Optional[Any]: ...

    def _chain_merge(self, name: str) -> Dict[str, Any]: ...

    @property
    def config_file_version(self) -> str: ...
    @property
    def api_gateway_stage(self) -> Optional[Any]: ...
    @property
    def api_gateway_endpoint_type(self) -> Optional[Any]: ...
    @property
    def api_gateway_endpoint_vpce(self) -> Optional[Any]: ...
    @property
    def api_gateway_policy_file(self) -> Optional[Any]: ...
    @property
    def minimum_compression_size(self) -> Optional[Any]: ...
    @property
    def iam_policy_file(self) -> Optional[Any]: ...
    @property
    def lambda_memory_size(self) -> Optional[Any]: ...
    @property
    def lambda_timeout(self) -> Optional[Any]: ...
    @property
    def automatic_layer(self) -> bool: ...
    @property
    def iam_role_arn(self) -> Optional[Any]: ...
    @property
    def manage_iam_role(self) -> bool: ...
    @property
    def autogen_policy(self) -> Optional[Any]: ...
    @property
    def xray_enabled(self) -> Optional[Any]: ...
    @property
    def environment_variables(self) -> Dict[str, Any]: ...
    @property
    def tags(self) -> Dict[str, Any]: ...
    @property
    def security_group_ids(self) -> Optional[Any]: ...
    @property
    def subnet_ids(self) -> Optional[Any]: ...
    @property
    def reserved_concurrency(self) -> Optional[Any]: ...

    def scope(self, chalice_stage: str, function_name: str) -> Config: ...
    def deployed_resources(self, chalice_stage_name: str) -> Optional[DeployedResources]: ...
    def _try_old_deployer_values(self, chalice_stage_name: str) -> DeployedResources: ...
    def _load_json_file(self, deployed_file: str) -> Optional[Any]: ...
    def _upgrade_deployed_values(
        self, chalice_stage_name: str, data: Dict[str, Any]
    ) -> DeployedResources: ...
    def _upgrade_lambda_functions(
        self,
        resources: List[Dict[str, Any]],
        deployed: Dict[str, Any],
        prefix: str,
    ) -> None: ...
    def _upgrade_rest_api(
        self,
        resources: List[Dict[str, Any]],
        deployed: Dict[str, Any],
    ) -> None: ...

class DeployedResources:
    _deployed_values: List[Dict[str, Any]]
    _deployed_values_by_name: Dict[str, Dict[str, Any]]

    def __init__(self, deployed_values: Dict[str, Any]) -> None: ...
    @classmethod
    def empty(cls) -> DeployedResources: ...
    def resource_values(self, name: str) -> Dict[str, Any]: ...
    def resource_names(self) -> List[str]: ...