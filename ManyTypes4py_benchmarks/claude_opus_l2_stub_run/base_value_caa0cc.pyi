from __future__ import annotations

from typing import Any, Callable, Iterator, Iterable, TypeVar
from parso.python.tree import Name

sentinel: object

class HasNoContext(Exception): ...

class HelperValueMixin:
    parent_context: Any
    inference_state: Any
    name: Any

    def get_root_context(self) -> Any: ...
    def execute(self, arguments: Any) -> ValueSet: ...
    def execute_with_values(self, *value_list: Any) -> ValueSet: ...
    def execute_annotation(self) -> ValueSet: ...
    def gather_annotation_classes(self) -> ValueSet: ...
    def merge_types_of_iterate(self, contextualized_node: Any = ..., is_async: bool = ...) -> ValueSet: ...
    def _get_value_filters(self, name_or_str: str | Name) -> Iterator[Any]: ...
    def goto(self, name_or_str: str | Name, name_context: Any = ..., analysis_errors: bool = ...) -> list[Any]: ...
    def py__getattribute__(self, name_or_str: str | Name, name_context: Any = ..., position: tuple[int, int] | None = ..., analysis_errors: bool = ...) -> ValueSet: ...
    def py__await__(self) -> ValueSet: ...
    def py__name__(self) -> str: ...
    def iterate(self, contextualized_node: Any = ..., is_async: bool = ...) -> Any: ...
    def is_sub_class_of(self, class_value: Any) -> bool: ...
    def is_same_class(self, class2: Any) -> bool: ...
    def as_context(self, *args: Any, **kwargs: Any) -> Any: ...

class Value(HelperValueMixin):
    tree_node: Any
    array_type: str | None
    api_type: str
    inference_state: Any
    parent_context: Any

    def __init__(self, inference_state: Any, parent_context: Any = ...) -> None: ...
    def py__getitem__(self, index_value_set: ValueSet, contextualized_node: ContextualizedNode) -> ValueSet: ...
    def py__simple_getitem__(self, index: Any) -> ValueSet: ...
    def py__iter__(self, contextualized_node: ContextualizedNode | None = ...) -> Iterator[Any]: ...
    def py__next__(self, contextualized_node: ContextualizedNode | None = ...) -> Any: ...
    def get_signatures(self) -> list[Any]: ...
    def is_class(self) -> bool: ...
    def is_class_mixin(self) -> bool: ...
    def is_instance(self) -> bool: ...
    def is_function(self) -> bool: ...
    def is_module(self) -> bool: ...
    def is_namespace(self) -> bool: ...
    def is_compiled(self) -> bool: ...
    def is_bound_method(self) -> bool: ...
    def is_builtins_module(self) -> bool: ...
    def py__bool__(self) -> bool: ...
    def py__doc__(self) -> str: ...
    def get_safe_value(self, default: Any = ...) -> Any: ...
    def execute_operation(self, other: Any, operator: str) -> ValueSet: ...
    def py__call__(self, arguments: Any) -> ValueSet: ...
    def py__stop_iteration_returns(self) -> ValueSet: ...
    def py__getattribute__alternatives(self, name_or_str: str) -> ValueSet: ...
    def py__get__(self, instance: Any, class_value: Any) -> ValueSet: ...
    def py__get__on_class(self, calling_instance: Any, instance: Any, class_value: Any) -> Any: ...
    def get_qualified_names(self) -> tuple[str, ...] | None: ...
    def is_stub(self) -> bool: ...
    def _as_context(self) -> Any: ...
    @property
    def name(self) -> Any: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str | None: ...
    def infer_type_vars(self, value_set: ValueSet) -> dict[str, Any]: ...

def iterate_values(values: ValueSet, contextualized_node: Any = ..., is_async: bool = ...) -> ValueSet: ...

class _ValueWrapperBase(HelperValueMixin):
    _wrapped_value: Any

    @property
    def name(self) -> Any: ...
    @classmethod
    def create_cached(cls, inference_state: Any, *args: Any, **kwargs: Any) -> _ValueWrapperBase: ...
    def __getattr__(self, name: str) -> Any: ...

class LazyValueWrapper(_ValueWrapperBase):
    @property
    def _wrapped_value(self) -> Any: ...
    def __repr__(self) -> str: ...
    def _get_wrapped_value(self) -> Any: ...

class ValueWrapper(_ValueWrapperBase):
    _wrapped_value: Any
    def __init__(self, wrapped_value: Any) -> None: ...
    def __repr__(self) -> str: ...

class TreeValue(Value):
    tree_node: Any
    def __init__(self, inference_state: Any, parent_context: Any, tree_node: Any) -> None: ...
    def __repr__(self) -> str: ...

class ContextualizedNode:
    context: Any
    node: Any
    def __init__(self, context: Any, node: Any) -> None: ...
    def get_root_context(self) -> Any: ...
    def infer(self) -> ValueSet: ...
    def __repr__(self) -> str: ...

def _getitem(value: Any, index_values: ValueSet, contextualized_node: ContextualizedNode) -> ValueSet: ...

class ValueSet:
    _set: frozenset[Any]

    def __init__(self, iterable: Iterable[Any]) -> None: ...
    @classmethod
    def _from_frozen_set(cls, frozenset_: frozenset[Any]) -> ValueSet: ...
    @classmethod
    def from_sets(cls, sets: Iterable[ValueSet | Iterable[Any]]) -> ValueSet: ...
    def __or__(self, other: ValueSet) -> ValueSet: ...
    def __and__(self, other: ValueSet) -> ValueSet: ...
    def __iter__(self) -> Iterator[Any]: ...
    def __bool__(self) -> bool: ...
    def __len__(self) -> int: ...
    def __repr__(self) -> str: ...
    def filter(self, filter_func: Callable[..., bool]) -> ValueSet: ...
    def __getattr__(self, name: str) -> Callable[..., ValueSet]: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def py__class__(self) -> ValueSet: ...
    def iterate(self, contextualized_node: Any = ..., is_async: bool = ...) -> Iterator[Any]: ...
    def execute(self, arguments: Any) -> ValueSet: ...
    def execute_with_values(self, *args: Any, **kwargs: Any) -> ValueSet: ...
    def goto(self, *args: Any, **kwargs: Any) -> list[Any]: ...
    def py__getattribute__(self, *args: Any, **kwargs: Any) -> ValueSet: ...
    def get_item(self, *args: Any, **kwargs: Any) -> ValueSet: ...
    def try_merge(self, function_name: str) -> ValueSet: ...
    def gather_annotation_classes(self) -> ValueSet: ...
    def get_signatures(self) -> list[Any]: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str | None: ...
    def infer_type_vars(self, value_set: ValueSet) -> dict[str, Any]: ...

NO_VALUES: ValueSet

_F = TypeVar('_F', bound=Callable[..., Any])
def iterator_to_value_set(func: _F) -> _F: ...