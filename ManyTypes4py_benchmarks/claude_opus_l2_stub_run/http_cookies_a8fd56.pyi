class CookieConflictError(RuntimeError): ...


class RequestsCookieJar(CookieJar, MutableMapping):
    def get(
        self,
        name: str,
        default: Optional[str] = ...,
        domain: Optional[str] = ...,
        path: Optional[str] = ...,
    ) -> Optional[str]: ...
    def set(
        self, name: str, value: Optional[Union[str, Morsel]], **kwargs: Any
    ) -> Optional[Cookie]: ...
    def iterkeys(self) -> Generator[str, None, None]: ...
    def keys(self) -> List[str]: ...
    def itervalues(self) -> Generator[Optional[str], None, None]: ...
    def values(self) -> List[Optional[str]]: ...
    def iteritems(self) -> Generator[Tuple[str, Optional[str]], None, None]: ...
    def items(self) -> List[Tuple[str, Optional[str]]]: ...
    def list_domains(self) -> List[str]: ...
    def list_paths(self) -> List[str]: ...
    def multiple_domains(self) -> bool: ...
    def get_dict(
        self, domain: Optional[str] = ..., path: Optional[str] = ...
    ) -> Dict[str, Optional[str]]: ...
    def __contains__(self, name: Any) -> bool: ...
    def __getitem__(self, name: str) -> str: ...
    def __setitem__(self, name: str, value: Optional[Union[str, Morsel]]) -> None: ...
    def __delitem__(self, name: str) -> None: ...
    def set_cookie(self, cookie: Cookie, *args: Any, **kwargs: Any) -> None: ...
    def update(self, other: Any) -> None: ...
    def _find(
        self, name: str, domain: Optional[str] = ..., path: Optional[str] = ...
    ) -> str: ...
    def _find_no_duplicates(
        self, name: str, domain: Optional[str] = ..., path: Optional[str] = ...
    ) -> str: ...
    def __getstate__(self) -> Dict[str, Any]: ...
    def __setstate__(self, state: Dict[str, Any]) -> None: ...
    def copy(self) -> RequestsCookieJar: ...
    def get_policy(self) -> CookiePolicy: ...


def _copy_cookie_jar(jar: Optional[CookieJar]) -> Optional[CookieJar]: ...
def create_cookie(name: str, value: str, **kwargs: Any) -> Cookie: ...
def morsel_to_cookie(morsel: Morsel) -> Cookie: ...
def cookiejar_from_dict(
