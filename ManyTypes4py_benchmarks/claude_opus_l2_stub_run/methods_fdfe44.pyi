import numpy as np
import pytest
from pandas._typing import Dtype
from pandas.core.dtypes.dtypes import NumpyEADtype
import pandas as pd


class BaseMethodsTests:
    """Various Series and DataFrame methods."""

    def test_hash_pandas_object(self, data: object) -> None: ...
