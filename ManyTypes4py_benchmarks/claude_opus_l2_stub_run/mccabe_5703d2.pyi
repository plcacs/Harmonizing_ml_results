from __future__ import with_statement
import ast
import optparse
from collections import defaultdict
from typing import Any, Dict, Generator, List, Optional, Sequence, Tuple, Type

__version__: str

class ASTVisitor:
    node: Optional[ast.AST]
    _cache: Dict[type, Any]
    visitor: Any
    def __init__(self) -> None: ...
    def default(self, node: ast.AST, *args: Any) -> None: ...
    def dispatch(self, node: ast.AST, *args: Any) -> Any: ...
    def preorder(self, tree: ast.AST, visitor: Any, *args: Any) -> None: ...

class PathNode:
    name: str
    look: str
    def __init__(self, name: str, look: str = ...) -> None: ...
    def to_dot(self) -> None: ...
    def dot_id(self) -> int: ...

class PathGraph:
    name: str
    entity: str
    lineno: int
    column: int
    nodes: defaultdict[PathNode, List[PathNode]]
    def __init__(self, name: str, entity: str, lineno: int, column: int = ...) -> None: ...
    def connect(self, n1: PathNode, n2: PathNode) -> None: ...
    def to_dot(self) -> None: ...
    def complexity(self) -> int: ...

class PathGraphingAstVisitor(ASTVisitor):
    classname: str
    graphs: Dict[str, PathGraph]
    graph: Optional[PathGraph]
    tail: Optional[PathNode]
    def __init__(self) -> None: ...
    def reset(self) -> None: ...
    def dispatch_list(self, node_list: List[ast.AST]) -> None: ...
    def visitFunctionDef(self, node: ast.AST) -> None: ...
    visitAsyncFunctionDef: Any
    def visitClassDef(self, node: ast.AST) -> None: ...
    def appendPathNode(self, name: str) -> Optional[PathNode]: ...
    def visitSimpleStatement(self, node: ast.AST) -> None: ...
    def default(self, node: ast.AST, *args: Any) -> None: ...
    def visitLoop(self, node: ast.AST) -> None: ...
    visitAsyncFor: Any
    visitFor: Any
    visitWhile: Any
    def visitIf(self, node: ast.AST) -> None: ...
    def _subgraph(self, node: ast.AST, name: str, extra_blocks: Sequence[Any] = ...) -> None: ...
    def _subgraph_parse(self, node: ast.AST, pathnode: Optional[PathNode], extra_blocks: Sequence[Any]) -> None: ...
    def visitTryExcept(self, node: ast.AST) -> None: ...
    visitTry: Any
    def visitWith(self, node: ast.AST) -> None: ...
    visitAsyncWith: Any

class McCabeChecker:
    name: str
    version: str
    _code: str
    _error_tmpl: str
    max_complexity: int
    tree: ast.AST
    def __init__(self, tree: ast.AST, filename: str) -> None: ...
    @classmethod
    def add_options(cls, parser: Any) -> None: ...
    @classmethod
    def parse_options(cls, options: Any) -> None: ...
    def run(self) -> Generator[Tuple[int, int, str, Type[McCabeChecker]], None, None]: ...

def get_code_complexity(code: str, threshold: int = ..., filename: str = ...) -> int: ...
def get_module_complexity(module_path: str, threshold: int = ...) -> int: ...
def _read(filename: str) -> str: ...
def main(argv: Optional[List[str]] = ...) -> None: ...