from Xlib import display, X, protocol
from typing import Any, Optional, Union, KeysView, Callable

class EWMH:
    NET_WM_WINDOW_TYPES: tuple[str, ...]
    NET_WM_ACTIONS: tuple[str, ...]
    NET_WM_STATES: tuple[str, ...]

    display: display.Display
    root: Any

    def __init__(self, _display: Optional[display.Display] = ..., root: Optional[Any] = ...) -> None: ...

    def setNumberOfDesktops(self, nb: int) -> None: ...
    def setDesktopGeometry(self, w: int, h: int) -> None: ...
    def setDesktopViewport(self, w: int, h: int) -> None: ...
    def setCurrentDesktop(self, i: int) -> None: ...
    def setActiveWindow(self, win: Any) -> None: ...
    def setShowingDesktop(self, show: int) -> None: ...
    def setCloseWindow(self, win: Any) -> None: ...
    def setWmName(self, win: Any, name: str) -> None: ...
    def setWmVisibleName(self, win: Any, name: str) -> None: ...
    def setWmDesktop(self, win: Any, i: int) -> None: ...
    def setMoveResizeWindow(
        self,
        win: Any,
        gravity: int = ...,
        x: Optional[int] = ...,
        y: Optional[int] = ...,
        w: Optional[int] = ...,
        h: Optional[int] = ...,
    ) -> None: ...
    def setWmState(self, win: Any, action: int, state: Union[int, str], state2: Union[int, str] = ...) -> None: ...

    def getClientList(self) -> list[Any]: ...
    def getClientListStacking(self) -> list[Any]: ...
    def getNumberOfDesktops(self) -> int: ...
    def getDesktopGeometry(self) -> Any: ...
    def getDesktopViewPort(self) -> Any: ...
    def getCurrentDesktop(self) -> int: ...
    def getActiveWindow(self) -> Optional[Any]: ...
    def getWorkArea(self) -> Any: ...
    def getShowingDesktop(self) -> int: ...
    def getWmName(self, win: Any) -> Optional[str]: ...
    def getWmVisibleName(self, win: Any) -> Optional[str]: ...
    def getWmDesktop(self, win: Any) -> Optional[int]: ...
    def getWmWindowType(self, win: Any, str: bool = ...) -> list[Union[int, str]]: ...
    def getWmState(self, win: Any, str: bool = ...) -> list[Union[int, str]]: ...
    def getWmAllowedActions(self, win: Any, str: bool = ...) -> list[Union[int, str]]: ...
    def getWmPid(self, win: Any) -> Optional[int]: ...

    def _getProperty(self, _type: str, win: Optional[Any] = ...) -> Optional[Any]: ...
    def _setProperty(self, _type: str, data: Union[str, list[int]], win: Optional[Any] = ..., mask: Optional[int] = ...) -> None: ...
    def _getAtomName(self, atom: int) -> str: ...
    def _createWindow(self, wId: int) -> Optional[Any]: ...

    def getReadableProperties(self) -> KeysView[str]: ...
    def getProperty(self, prop: str, *args: Any, **kwargs: Any) -> Any: ...
    def getWritableProperties(self) -> KeysView[str]: ...
    def setProperty(self, prop: str, *args: Any, **kwargs: Any) -> None: ...