        connect_args: Dict[str, Any],
        catalog: Optional[str] = ...,
        schema: Optional[str] = ...,
    ) -> Tuple[URL, Dict[str, Any]]: ...
    @classmethod
    def get_schema_from_engine_params(cls, sqlalchemy_uri: URL, connect_args: Dict[str, Any]) -> str: ...
    @classmethod
    def _extract_error_message(cls, ex: Any) -> str: ...
    @classmethod
    def progress(cls, log_lines: Iterable[str]) -> int: ...
    @classmethod
    def get_tracking_url_from_logs(cls, log_lines: Iterable[str]) -> Optional[str]: ...
    @classmethod
    def handle_cursor(cls, cursor: Any, query: Any) -> None: ...
    @classmethod
    def get_columns(cls, inspector: Any, table: Any, options: Any = ...) -> Any: ...
    @classmethod
    def where_latest_partition(cls, database: Any, table: Any, query: Any, columns: Any = ...) -> Any: ...
    @classmethod
    def _get_fields(cls, cols: Any) -> Any: ...
    @classmethod
    def latest_sub_partition(cls, database: Any, table: Any, **kwargs: Any) -> Any: ...
    @classmethod
    def _latest_partition_from_df(cls, df: Any) -> Optional[List[str]]: ...
    @classmethod
    def _partition_query(
