        username: Optional[str],
        access_token: Optional[str],
    ) -> URL: ...
    @classmethod
    def update_impersonation_config(
        cls,
        database: Any,
        connect_args: Dict[str, Any],
        uri: str,
        username: Optional[str],
        access_token: Optional[str],
    ) -> None: ...
    @staticmethod
    def execute(cursor: Any, query: str, database: Any, async_: bool = ...) -> None: ...
    @classmethod
    def get_function_names(cls, database: Any) -> List[str]: ...
    @classmethod
    def has_implicit_cancel(cls) -> bool: ...
    @classmethod
    def get_view_names(cls, database: Any, inspector: Any, schema: Optional[str]) -> Set[str]: ...