from typing import Iterable, Optional, Tuple, Type
from eth_typing import BlockNumber, Hash32
from eth.abc import BlockHeaderAPI, DatabaseAPI, HeaderDatabaseAPI
from eth.constants import GENESIS_PARENT_HASH
from eth.db.chain_gaps import GapChange
from eth.typing import ChainGaps

class HeaderDB(HeaderDatabaseAPI):
    def __init__(self, db: DatabaseAPI) -> None: ...
    def get_header_chain_gaps(self) -> ChainGaps: ...
    @classmethod
    def _get_header_chain_gaps(cls: Type["HeaderDB"], db: DatabaseAPI) -> ChainGaps: ...
    @classmethod
    def _update_header_chain_gaps(
        cls: Type["HeaderDB"],
        db: DatabaseAPI,
        persisted_header: BlockHeaderAPI,
        base_gaps: Optional[ChainGaps] = ...,
    ) -> Tuple[GapChange, ChainGaps]: ...
    def get_canonical_block_hash(self, block_number: BlockNumber) -> Hash32: ...
    @staticmethod
    def _get_canonical_block_hash(db: DatabaseAPI, block_number: BlockNumber) -> Hash32: ...
    def get_canonical_block_header_by_number(self, block_number: BlockNumber) -> BlockHeaderAPI: ...
    @classmethod
    def _get_canonical_block_header_by_number(
        cls: Type["HeaderDB"], db: DatabaseAPI, block_number: BlockNumber
    ) -> BlockHeaderAPI: ...
    def get_canonical_head(self) -> BlockHeaderAPI: ...
    @classmethod
    def _get_canonical_head(cls: Type["HeaderDB"], db: DatabaseAPI) -> BlockHeaderAPI: ...
    @classmethod
    def _get_canonical_head_hash(cls: Type["HeaderDB"], db: DatabaseAPI) -> Hash32: ...
    def get_block_header_by_hash(self, block_hash: Hash32) -> BlockHeaderAPI: ...
    @staticmethod
    def _get_block_header_by_hash(db: DatabaseAPI, block_hash: Hash32) -> BlockHeaderAPI: ...
    def get_score(self, block_hash: Hash32) -> int: ...
    @staticmethod
    def _get_score(db: DatabaseAPI, block_hash: Hash32) -> int: ...
    def header_exists(self, block_hash: Hash32) -> bool: ...
    @staticmethod
    def _header_exists(db: DatabaseAPI, block_hash: Hash32) -> bool: ...
    def persist_header(
        self, header: BlockHeaderAPI
    ) -> Tuple[Tuple[BlockHeaderAPI, ...], Tuple[BlockHeaderAPI, ...]]: ...
    def persist_header_chain(
        self, headers: Iterable[BlockHeaderAPI], genesis_parent_hash: Hash32 = GENESIS_PARENT_HASH
    ) -> Tuple[Tuple[BlockHeaderAPI, ...], Tuple[BlockHeaderAPI, ...]]: ...
    def persist_checkpoint_header(self, header: BlockHeaderAPI, score: int) -> None: ...
    @classmethod
    def _set_hash_scores_to_db(
        cls: Type["HeaderDB"], db: DatabaseAPI, header: BlockHeaderAPI, score: int
    ) -> int: ...
    @classmethod
    def _persist_checkpoint_header(
        cls: Type["HeaderDB"], db: DatabaseAPI, header: BlockHeaderAPI, score: int
    ) -> None: ...
    @classmethod
    def _decanonicalize_descendant_orphans(
        cls: Type["HeaderDB"], db: DatabaseAPI, header: BlockHeaderAPI, checkpoints: Tuple[Hash32, ...]
    ) -> None: ...
    @classmethod
    def _decanonicalize_single(
        cls: Type["HeaderDB"], db: DatabaseAPI, block_num: BlockNumber, base_gaps: ChainGaps
    ) -> ChainGaps: ...
    @classmethod
    def _persist_header_chain(
        cls: Type["HeaderDB"],
        db: DatabaseAPI,
        headers: Iterable[BlockHeaderAPI],
        genesis_parent_hash: Hash32,
    ) -> Tuple[Tuple[BlockHeaderAPI, ...], Tuple[BlockHeaderAPI, ...]]: ...
    @classmethod
    def _handle_gap_change(
        cls: Type["HeaderDB"],
        db: DatabaseAPI,
        gap_info: Tuple[GapChange, ChainGaps],
        header: BlockHeaderAPI,
        genesis_parent_hash: Hash32,
    ) -> ChainGaps: ...
    @classmethod
    def _canonicalize_header(
        cls: Type["HeaderDB"], db: DatabaseAPI, header: BlockHeaderAPI, genesis_parent_hash: Hash32
    ) -> Tuple[Tuple[BlockHeaderAPI, ...], Tuple[BlockHeaderAPI, ...]]: ...
    @classmethod
    def _set_as_canonical_chain_head(
        cls: Type["HeaderDB"], db: DatabaseAPI, header: BlockHeaderAPI, genesis_parent_hash: Hash32
    ) -> Tuple[Tuple[BlockHeaderAPI, ...], Tuple[BlockHeaderAPI, ...]]: ...
    @classmethod
    def _get_checkpoints(cls: Type["HeaderDB"], db: DatabaseAPI) -> Tuple[Hash32, ...]: ...
    @classmethod
    def _find_headers_to_decanonicalize(
        cls: Type["HeaderDB"], db: DatabaseAPI, numbers_to_decanonicalize: Iterable[BlockNumber]
    ) -> Tuple[BlockHeaderAPI, ...]: ...
    @classmethod
    def _find_new_ancestors(
        cls: Type["HeaderDB"], db: DatabaseAPI, header: BlockHeaderAPI, genesis_parent_hash: Hash32
    ) -> Tuple[BlockHeaderAPI, ...]: ...
    @staticmethod
    def _add_block_number_to_hash_lookup(db: DatabaseAPI, header: BlockHeaderAPI) -> None: ...

def _decode_block_header(header_rlp: bytes) -> BlockHeaderAPI: ...