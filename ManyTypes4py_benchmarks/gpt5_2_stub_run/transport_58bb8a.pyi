        queue_identifier: Any
        message: Any
        text: str
        expiration_generator: Iterator[bool]
        address_metadata: Any

    def __init__(self, transport: Any, receiver: Any) -> None: ...
    @property
    def log(self) -> Any: ...
    @staticmethod
    def _expiration_generator(timeout_generator: Iterable[float], now: Callable[[], float] = time.time) -> Iterator[bool]: ...
    def enqueue(self, queue_identifier: Any, messages: List[Tuple[Any, Any]]) -> None: ...
    def enqueue_unordered(self, message: Any, address_metadata: Any = ...) -> None: ...
    def notify(self) -> None: ...
    def _check_and_send(self) -> None: ...
    def _run(self) -> None: ...
    @property
    def is_idle(self) -> bool: ...
    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...

