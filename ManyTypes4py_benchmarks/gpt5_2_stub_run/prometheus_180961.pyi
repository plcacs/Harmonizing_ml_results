    def on_send_initiated(self, producer: Any, topic: Any, message: Any, keysize: Any, valsize: Any) -> Any: ...
    def on_send_completed(self, producer: Any, state: Any, metadata: Any) -> None: ...
    def on_send_error(self, producer: Any, exc: Any, state: Any) -> None: ...
    def on_assignment_error(self, assignor: Any, state: Any, exc: Any) -> None: ...
    def on_assignment_completed(self, assignor: Any, state: Any) -> None: ...
    def on_rebalance_start(self, app: Any) -> Any: ...
    def on_rebalance_return(self, app: Any, state: Any) -> None: ...
    def on_rebalance_end(self, app: Any, state: Any) -> None: ...
    def count(self, metric_name: str, count: Any = ...) -> None: ...
