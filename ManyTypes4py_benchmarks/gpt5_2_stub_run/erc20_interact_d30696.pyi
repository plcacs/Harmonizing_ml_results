from abc import abstractmethod
from typing import Any, Dict, Optional, Tuple
from .base_benchmark import BaseBenchmark

FIRST_TX_GAS_LIMIT: int = ...
SECOND_TX_GAS_LIMIT: int = ...
TRANSFER_AMOUNT: int = ...
TRANSER_FROM_AMOUNT: int = ...
CONTRACT_FILE: str = ...
CONTRACT_NAME: str = ...
W3_TX_DEFAULTS: Dict[str, int] = ...

class BaseERC20Benchmark(BaseBenchmark):
    def __init__(self, num_blocks: int = ..., num_tx: int = ...) -> None: ...
    def _setup_benchmark(self, chain: Any) -> None: ...
    @abstractmethod
    def _next_transaction(self, chain: Any) -> Tuple[Any, Any]: ...
    def execute(self) -> Any: ...
    def mine_blocks(self, chain: Any, num_blocks: int, num_tx: int) -> Tuple[int, int]: ...
    def mine_block(self, chain: Any, block_number: int, num_tx: int) -> Any: ...
    def _deploy_simple_token(self, chain: Any, nonce: Optional[int] = ...) -> Tuple[Any, Any]: ...
    def _erc_transfer(self, addr: Any, chain: Any, nonce: Optional[int] = ...) -> Tuple[Any, Any]: ...
    def _erc_approve(self, addr2: Any, chain: Any, nonce: Optional[int] = ...) -> Tuple[Any, Any]: ...
    def _erc_transfer_from(self, addr1: Any, addr2: Any, chain: Any, nonce: Optional[int] = ...) -> Tuple[Any, Any]: ...

class ERC20DeployBenchmark(BaseERC20Benchmark):
    def __init__(self) -> None: ...
    @property
    def name(self) -> str: ...
    def _setup_benchmark(self, chain: Any) -> None: ...
    def _next_transaction(self, chain: Any) -> Tuple[Any, Any]: ...

