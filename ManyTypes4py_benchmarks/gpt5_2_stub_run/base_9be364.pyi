from __future__ import annotations
import abc
from typing import Any, Callable, Dict, Generic, List, Optional, Set, Type, TypeVar
from typing_extensions import Self
from pydantic import BaseModel
from pydantic.json_schema import GenerateJsonSchema

class BaseJobConfiguration(BaseModel):
    command: Optional[str]
    env: Dict[str, Optional[str]]
    labels: Dict[str, Any]
    name: Optional[str]
    _related_objects: Dict[str, Any]

    @property
    def is_using_a_runner(self) -> bool: ...
    @classmethod
    def _coerce_command(cls, v: Any) -> Any: ...
    @classmethod
    def _coerce_env(cls, v: Any) -> Any: ...
    @staticmethod
    def _get_base_config_defaults(variables: Any) -> Dict[str, Any]: ...
    @classmethod
    async def from_template_and_values(cls, base_job_template: Any, values: Any, client: Any = ...) -> Self: ...
    @classmethod
    def json_template(cls) -> Dict[str, str]: ...
    def prepare_for_flow_run(self, flow_run: Any, deployment: Any = ..., flow: Any = ...) -> None: ...
    @staticmethod
    def _base_flow_run_command() -> str: ...
    @staticmethod
    def _base_flow_run_labels(flow_run: Any) -> Dict[str, str]: ...
    @classmethod
    def _base_environment(cls) -> Dict[str, Any]: ...
    @staticmethod
    def _base_flow_run_environment(flow_run: Any) -> Dict[str, str]: ...
    @staticmethod
    def _base_deployment_labels(deployment: Any) -> Dict[str, str]: ...
    @staticmethod
    def _base_flow_labels(flow: Any) -> Dict[str, str]: ...
    def _related_resources(self) -> List[Any]: ...

class BaseVariables(BaseModel):
    name: Optional[str]
    env: Dict[str, Any]
    labels: Dict[str, Any]
    command: Optional[str]

    @classmethod
    def model_json_schema(
        cls,
        by_alias: bool = ...,
        ref_template: str = ...,
        schema_generator: Type[GenerateJsonSchema] = ...,
        mode: str = ...,
    ) -> Dict[str, Any]: ...

class BaseWorkerResult(BaseModel, abc.ABC):
    def __bool__(self) -> bool: ...

C = TypeVar("C", bound=BaseJobConfiguration)
V = TypeVar("V", bound=BaseVariables)
R = TypeVar("R", bound=BaseWorkerResult)

class BaseWorker(abc.ABC, Generic[C, V, R]):
    job_configuration: Type[BaseJobConfiguration]
    job_configuration_variables: Optional[Type[BaseVariables]]
    _documentation_url: str
    _logo_url: str
    _description: str
    type: str

    def __init__(
        self,
        work_pool_name: Any,
        work_queues: Any = ...,
        name: Optional[str] = ...,
        prefetch_seconds: Optional[int] = ...,
        create_pool_if_not_found: bool = ...,
        limit: Optional[int] = ...,
        heartbeat_interval_seconds: Optional[int] = ...,
        *,
        base_job_template: Any = ...,
    ) -> None: ...
    @classmethod
    def get_documentation_url(cls) -> str: ...
    @classmethod
    def get_logo_url(cls) -> str: ...
    @classmethod
    def get_description(cls) -> str: ...
    @classmethod
    def get_default_base_job_template(cls) -> Dict[str, Any]: ...
    @staticmethod
    def get_worker_class_from_type(type: str) -> Any: ...
    @staticmethod
    def get_all_available_worker_types() -> List[str]: ...
    def get_name_slug(self) -> str: ...
    def get_flow_run_logger(self, flow_run: Any) -> Any: ...
    async def start(self, run_once: bool = ..., with_healthcheck: bool = ..., printer: Callable[[str], None] = ...) -> Any: ...
    @abc.abstractmethod
    async def run(self, flow_run: Any, configuration: Any, task_status: Any = ...) -> Any: ...
    @classmethod
    def __dispatch_key__(cls) -> Any: ...
    async def setup(self) -> Any: ...
    async def teardown(self, *exc_info: Any) -> Any: ...
    def is_worker_still_polling(self, query_interval_seconds: int) -> bool: ...
    async def get_and_submit_flow_runs(self) -> Any: ...
    async def _update_local_work_pool_info(self) -> Any: ...
    async def _worker_metadata(self) -> Any: ...
    async def _send_worker_heartbeat(self) -> Any: ...
    async def sync_with_backend(self) -> Any: ...
    def _should_get_worker_id(self) -> bool: ...
    async def _get_scheduled_flow_runs(self) -> Any: ...
    async def _submit_scheduled_flow_runs(self, flow_run_response: Any) -> Any: ...
    async def _check_flow_run(self, flow_run: Any) -> Any: ...
    async def _submit_run(self, flow_run: Any) -> Any: ...
    async def _submit_run_and_capture_errors(self, flow_run: Any, task_status: Any = ...) -> Any: ...
    def _release_limit_slot(self, flow_run_id: Any) -> None: ...
    def get_status(self) -> Dict[str, Any]: ...
    async def _get_configuration(self, flow_run: Any, deployment: Any = ...) -> Any: ...
    async def _propose_pending_state(self, flow_run: Any) -> bool: ...
    async def _propose_failed_state(self, flow_run: Any, exc: BaseException) -> Any: ...
    async def _propose_crashed_state(self, flow_run: Any, message: str) -> Any: ...
    async def _mark_flow_run_as_cancelled(self, flow_run: Any, state_updates: Optional[Dict[str, Any]] = ...) -> Any: ...
    async def _set_work_pool_template(self, work_pool: Any, job_template: Any) -> Any: ...
    async def _schedule_task(self, __in_seconds: int, fn: Callable[..., Any], *args: Any, **kwargs: Any) -> Any: ...
    async def _give_worker_labels_to_flow_run(self, flow_run_id: Any) -> Any: ...
    async def __aenter__(self) -> Self: ...
    async def __aexit__(self, *exc_info: Any) -> Any: ...
    def __repr__(self) -> str: ...
    def _event_resource(self) -> Dict[str, Any]: ...
    def _event_related_resources(self, configuration: Any = ..., include_self: bool = ...) -> List[Any]: ...
    def _emit_flow_run_submitted_event(self, configuration: Any) -> Any: ...
    def _emit_flow_run_executed_event(self, result: Any, configuration: Any, submitted_event: Any) -> Any: ...
    async def _emit_worker_started_event(self) -> Any: ...
    async def _emit_worker_stopped_event(self, started_event: Any) -> Any: ...