class CookieConflictError(RuntimeError): ...

class RequestsCookieJar(cookielib.CookieJar, MutableMapping[str, Any]):
    def get(self, name: str, default: Any = ..., domain: Optional[str] = ..., path: Optional[str] = ...) -> Any: ...
    def set(self, name: str, value: Any, **kwargs: Any) -> Any: ...
    def iterkeys(self) -> Iterator[str]: ...
    def keys(self) -> List[str]: ...
    def itervalues(self) -> Iterator[Any]: ...
    def values(self) -> List[Any]: ...
    def iteritems(self) -> Iterator[Tuple[str, Any]]: ...
    def items(self) -> List[Tuple[str, Any]]: ...
    def list_domains(self) -> List[str]: ...
    def list_paths(self) -> List[str]: ...
    def multiple_domains(self) -> bool: ...
    def get_dict(self, domain: Optional[str] = ..., path: Optional[str] = ...) -> Dict[str, str]: ...
    def __contains__(self, name: str) -> bool: ...
    def __getitem__(self, name: str) -> Any: ...
    def __setitem__(self, name: str, value: Any) -> None: ...
    def __delitem__(self, name: str) -> None: ...
    def set_cookie(self, cookie: cookielib.Cookie, *args: Any, **kwargs: Any) -> Any: ...
    def update(self, other: Any) -> None: ...
    def _find(self, name: str, domain: Optional[str] = ..., path: Optional[str] = ...) -> Any: ...
    def _find_no_duplicates(self, name: str, domain: Optional[str] = ..., path: Optional[str] = ...) -> Any: ...
    def __getstate__(self) -> Dict[str, Any]: ...
    def __setstate__(self, state: Dict[str, Any]) -> None: ...
    def copy(self) -> "RequestsCookieJar": ...
    def get_policy(self) -> Any: ...

