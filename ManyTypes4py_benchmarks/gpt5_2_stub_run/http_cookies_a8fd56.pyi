def cookiejar_from_dict(cookie_dict: Optional[Mapping[str, str]], cookiejar: Optional[cookielib.CookieJar] = ..., overwrite: bool = ...) -> cookielib.CookieJar: ...
def merge_cookies(cookiejar: cookielib.CookieJar, cookies: Any) -> cookielib.CookieJar: ...