from typing import Any, Iterable, List, Optional, Sequence, Tuple

class ModuleCache:
    def __init__(self) -> None: ...
    def add(self, string_names: Any, value_set: Any) -> None: ...
    def get(self, string_names: Any) -> Any: ...

def infer_import(context: Any, tree_name: Any) -> Any: ...
def goto_import(context: Any, tree_name: Any) -> Any: ...

class Importer:
    def __init__(self, inference_state: Any, import_path: Any, module_context: Any, level: int = ...) -> None: ...
    @property
    def _str_import_path(self) -> Tuple[Any, ...]: ...
    def _sys_path_with_modifications(self, is_completion: bool) -> List[str]: ...
    def follow(self) -> Any: ...
    def _get_module_names(self, search_path: Optional[List[str]] = ..., in_module: Any = ...) -> List[Any]: ...
    def completion_names(self, inference_state: Any, only_modules: bool = ...) -> List[Any]: ...

def import_module_by_names(inference_state: Any, import_names: Any, sys_path: Any = ..., module_context: Any = ..., prefer_stubs: bool = ...) -> Any: ...
def import_module(inference_state: Any, import_names: Any, parent_module_value: Any, sys_path: Any) -> Any: ...

def load_module_from_path(inference_state: Any, file_io: Any, import_names: Any = ..., is_package: Any = ...) -> Any: ...
def load_namespace_from_path(inference_state: Any, folder_io: Any) -> Any: ...
def follow_error_node_imports_if_possible(context: Any, name: Any) -> Optional[Any]: ...
def iter_module_names(inference_state: Any, module_context: Any, search_path: Any, module_cls: Any = ..., add_builtin_modules: bool = ...) -> Iterable[Any]: ...