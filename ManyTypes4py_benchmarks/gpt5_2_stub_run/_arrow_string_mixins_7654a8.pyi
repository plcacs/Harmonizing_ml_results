from typing import Any, Callable, Optional, Literal

class ArrowStringArrayMixin:
    def __init__(self, *args: Any, **kwargs: Any) -> None: ...
    def _convert_bool_result(self, result: Any, na: Any = ..., method_name: Optional[str] = ...) -> Any: ...
    def _convert_int_result(self, result: Any) -> Any: ...
    def _apply_elementwise(self, func: Callable[..., Any]) -> Any: ...
    def _str_len(self) -> Any: ...
    def _str_lower(self) -> ArrowStringArrayMixin: ...
    def _str_upper(self) -> ArrowStringArrayMixin: ...
    def _str_strip(self, to_strip: Optional[str] = ...) -> ArrowStringArrayMixin: ...
    def _str_lstrip(self, to_strip: Optional[str] = ...) -> ArrowStringArrayMixin: ...
    def _str_rstrip(self, to_strip: Optional[str] = ...) -> ArrowStringArrayMixin: ...
    def _str_pad(self, width: int, side: Literal["left", "right", "both"] = ..., fillchar: str = ...) -> ArrowStringArrayMixin: ...
    def _str_get(self, i: int) -> ArrowStringArrayMixin: ...
    def _str_slice(self, start: Optional[int] = ..., stop: Optional[int] = ..., step: Optional[int] = ...) -> ArrowStringArrayMixin: ...
    def _str_slice_replace(self, start: Optional[int] = ..., stop: Optional[int] = ..., repl: Optional[str] = ...) -> ArrowStringArrayMixin: ...
    def _str_replace(self, pat: Any, repl: Any, n: int = ..., case: bool = ..., flags: int = ..., regex: bool = ...) -> ArrowStringArrayMixin: ...
    def _str_capitalize(self) -> ArrowStringArrayMixin: ...
    def _str_title(self) -> ArrowStringArrayMixin: ...
    def _str_swapcase(self) -> ArrowStringArrayMixin: ...
    def _str_removeprefix(self, prefix: str) -> ArrowStringArrayMixin: ...
    def _str_removesuffix(self, suffix: str) -> ArrowStringArrayMixin: ...
    def _str_startswith(self, pat: Any, na: Any = ...) -> Any: ...
    def _str_endswith(self, pat: Any, na: Any = ...) -> Any: ...
    def _str_isalnum(self) -> Any: ...
    def _str_isalpha(self) -> Any: ...
    def _str_isascii(self) -> Any: ...
    def _str_isdecimal(self) -> Any: ...
    def _str_isdigit(self) -> Any: ...
    def _str_islower(self) -> Any: ...
    def _str_isnumeric(self) -> Any: ...
    def _str_isspace(self) -> Any: ...
    def _str_istitle(self) -> Any: ...
    def _str_isupper(self) -> Any: ...
    def _str_contains(self, pat: Any, case: bool = ..., flags: int = ..., na: Any = ..., regex: bool = ...) -> Any: ...
    def _str_match(self, pat: str, case: bool = ..., flags: int = ..., na: Any = ...) -> Any: ...
    def _str_fullmatch(self, pat: str, case: bool = ..., flags: int = ..., na: Any = ...) -> Any: ...
    def _str_find(self, sub: str, start: int = ..., end: Optional[int] = ...) -> Any: ...