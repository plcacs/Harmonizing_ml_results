from typing import Any, Iterable, Iterator, List, Optional, Dict
from jedi.inference.names import TreeNameDefinition
from jedi.inference.filters import ParserTreeFilter
from jedi.inference.value.function import FunctionAndClassBase

class ClassName(TreeNameDefinition):
    def __init__(self, class_value: Any, tree_name: Any, name_context: Any, apply_decorators: bool) -> None: ...
    def infer(self) -> Any: ...
    @property
    def api_type(self) -> str: ...

class ClassFilter(ParserTreeFilter):
    def __init__(self, class_value: Any, node_context: Optional[Any] = ..., until_position: Optional[Any] = ..., origin_scope: Optional[Any] = ..., is_instance: bool = False) -> None: ...
    def _convert_names(self, names: Any) -> Any: ...
    def _equals_origin_scope(self) -> bool: ...
    def _access_possible(self, name: Any) -> bool: ...
    def _filter(self, names: Any) -> Any: ...

class ClassMixin:
    def is_class(self) -> bool: ...
    def is_class_mixin(self) -> bool: ...
    def py__call__(self, arguments: Any) -> Any: ...
    def py__class__(self) -> Any: ...
    @property
    def name(self) -> Any: ...
    def py__name__(self) -> str: ...
    def py__mro__(self) -> Iterable[Any]: ...
    def get_filters(self, origin_scope: Optional[Any] = ..., is_instance: bool = False, include_metaclasses: bool = True, include_type_when_class: bool = True) -> Iterable[Any]: ...
    def get_signatures(self) -> List[Any]: ...
    def _as_context(self) -> Any: ...
    def get_type_hint(self, add_class_info: bool = True) -> str: ...
    def is_typeddict(self) -> bool: ...
    def py__getitem__(self, index_value_set: Any, contextualized_node: Any) -> Any: ...
    def with_generics(self, generics_tuple: Any) -> Any: ...
    def define_generics(self, type_var_dict: Dict[str, Any]) -> Any: ...

class ClassValue(ClassMixin, FunctionAndClassBase):
    api_type: str = ...
    def list_type_vars(self) -> List[Any]: ...
    def _get_bases_arguments(self) -> Optional[Any]: ...
    def py__bases__(self) -> Any: ...
    def get_metaclass_filters(self, metaclasses: Any, is_instance: bool) -> Iterable[Any]: ...
    def get_metaclasses(self) -> Any: ...
    def get_metaclass_signatures(self, metaclasses: Any) -> List[Any]: ...