from typing import Any, overload
from hypothesis.strategies._internal.strategies import MappedStrategy, SearchStrategy

class TupleStrategy(SearchStrategy):
    element_strategies: Any
    def __init__(self, strategies: Any) -> None: ...
    def do_validate(self) -> None: ...
    def calc_label(self) -> Any: ...
    def __repr__(self) -> str: ...
    def calc_has_reusable_values(self, recur: Any) -> bool: ...
    def do_draw(self, data: Any) -> tuple[Any, ...]: ...
    def calc_is_empty(self, recur: Any) -> bool: ...

@overload
def tuples() -> SearchStrategy: ...
@overload
def tuples(__a1: Any) -> SearchStrategy: ...
@overload
def tuples(__a1: Any, __a2: Any) -> SearchStrategy: ...
@overload
def tuples(__a1: Any, __a2: Any, __a3: Any) -> SearchStrategy: ...
@overload
def tuples(__a1: Any, __a2: Any, __a3: Any, __a4: Any) -> SearchStrategy: ...
@overload
def tuples(__a1: Any, __a2: Any, __a3: Any, __a4: Any, __a5: Any) -> SearchStrategy: ...
@overload
def tuples(*args: Any) -> SearchStrategy: ...

class ListStrategy(SearchStrategy):
    def __init__(self, elements: Any, min_size: int = ..., max_size: Any = ...) -> None: ...
    def calc_label(self) -> Any: ...
    def do_validate(self) -> None: ...
    def calc_is_empty(self, recur: Any) -> bool: ...
    def do_draw(self, data: Any) -> list[Any]: ...
    def __repr__(self) -> str: ...
    def filter(self, condition: Any) -> SearchStrategy: ...

class UniqueListStrategy(ListStrategy):
    keys: Any
    tuple_suffixes: Any
    def __init__(self, elements: Any, min_size: Any, max_size: Any, keys: Any, tuple_suffixes: Any) -> None: ...
    def do_draw(self, data: Any) -> list[Any]: ...

class UniqueSampledListStrategy(UniqueListStrategy):
    def do_draw(self, data: Any) -> list[Any]: ...

class FixedKeysDictStrategy(MappedStrategy):
    keys: Any
    mapped_strategy: Any
    def __init__(self, strategy_dict: Any) -> None: ...
    def calc_is_empty(self, recur: Any) -> bool: ...
    def __repr__(self) -> str: ...

class FixedAndOptionalKeysDictStrategy(SearchStrategy):
    required: Any
    fixed: Any
    optional: Any
    def __init__(self, strategy_dict: Any, optional: Any) -> None: ...
    def calc_is_empty(self, recur: Any) -> bool: ...
    def __repr__(self) -> str: ...
    def do_draw(self, data: Any) -> dict[Any, Any]: ...