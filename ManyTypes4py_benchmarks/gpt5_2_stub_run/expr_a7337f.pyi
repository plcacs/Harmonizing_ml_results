from typing import Any, Callable, FrozenSet, Iterable, Optional, TypeVar, Dict, Tuple
import ast

def _rewrite_assign(tok: tuple[int, str]) -> tuple[int, str]: ...
def _replace_booleans(tok: tuple[int, str]) -> tuple[int, str]: ...
def _replace_locals(tok: tuple[int, str]) -> tuple[int, str]: ...
def _compose2(f: Callable[..., Any], g: Callable[..., Any]) -> Callable[..., Any]: ...
def _compose(*funcs: Callable[..., Any]) -> Callable[..., Any]: ...
def _preparse(source: str, f: Callable[[tuple[int, str]], tuple[int, str]] = ...) -> str: ...
def _is_type(t: Any) -> Callable[[Any], bool]: ...
def _filter_nodes(superclass: type[ast.AST], all_nodes: FrozenSet[type[ast.AST]] = ...) -> FrozenSet[str]: ...
def _node_not_implemented(node_name: str) -> Callable[..., Any]: ...
_T = TypeVar('_T')
def disallow(nodes: Iterable[str]) -> Callable[[type[_T]], type[_T]]: ...
def _op_maker(op_class: Any, op_symbol: Any) -> Callable[..., Any]: ...
def add_ops(op_classes: Any) -> Callable[[type[_T]], type[_T]]: ...

class BaseExprVisitor(ast.NodeVisitor):
    const_type: type[Any]
    term_type: type[Any]
    binary_ops: Any
    binary_op_nodes: tuple[str, ...]
    binary_op_nodes_map: Dict[str, str]
    unary_ops: Any
    unary_op_nodes: tuple[str, ...]
    unary_op_nodes_map: Dict[str, str]
    rewrite_map: Dict[type, type]
    env: Any
    engine: str
    parser: str
    preparser: Callable[[str], str]
    assigner: Any
    def __init__(self, env: Any, engine: str, parser: str, preparser: Callable[[str], str] = ...) -> None: ...
    def visit(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Module(self, node: ast.Module, **kwargs: Any) -> Any: ...
    def visit_Expr(self, node: ast.Expr, **kwargs: Any) -> Any: ...
    def _rewrite_membership_op(self, node: Any, left: Any, right: Any) -> tuple[Any, Any, Any, Any]: ...
    def _maybe_transform_eq_ne(self, node: Any, left: Any = ..., right: Any = ...) -> tuple[Any, Any, Any, Any]: ...
    def _maybe_downcast_constants(self, left: Any, right: Any) -> tuple[Any, Any]: ...
    def _maybe_eval(self, binop: Any, eval_in_python: Any) -> Any: ...
    def _maybe_evaluate_binop(self, op: Any, op_class: Any, lhs: Any, rhs: Any, eval_in_python: Any = ..., maybe_eval_in_python: Any = ...) -> Any: ...
    def visit_BinOp(self, node: ast.BinOp, **kwargs: Any) -> Any: ...
    def visit_UnaryOp(self, node: ast.UnaryOp, **kwargs: Any) -> Any: ...
    def visit_Name(self, node: ast.Name, **kwargs: Any) -> Any: ...
    def visit_NameConstant(self, node: ast.AST, **kwargs: Any) -> Any: ...
    def visit_Num(self, node: ast.AST, **kwargs: Any) -> Any: ...
    def visit_Constant(self, node: ast.AST, **kwargs: Any) -> Any: ...
    def visit_Str(self, node: ast.AST, **kwargs: Any) -> Any: ...
    def visit_List(self, node: ast.List, **kwargs: Any) -> Any: ...
    def visit_Tuple(self, node: ast.Tuple, **kwargs: Any) -> Any: ...
    def visit_Index(self, node: ast.AST, **kwargs: Any) -> Any: ...
    def visit_Subscript(self, node: ast.Subscript, **kwargs: Any) -> Any: ...
    def visit_Slice(self, node: ast.Slice, **kwargs: Any) -> slice: ...
    def visit_Assign(self, node: ast.Assign, **kwargs: Any) -> Any: ...
    def visit_Attribute(self, node: ast.Attribute, **kwargs: Any) -> Any: ...
    def visit_Call(self, node: ast.Call, side: Any = ..., **kwargs: Any) -> Any: ...
    def translate_In(self, op: Any) -> Any: ...
    def visit_Compare(self, node: ast.Compare, **kwargs: Any) -> Any: ...
    def _try_visit_binop(self, bop: Any) -> Any: ...
    def visit_BoolOp(self, node: ast.BoolOp, **kwargs: Any) -> Any: ...

class PandasExprVisitor(BaseExprVisitor):
    def __init__(self, env: Any, engine: str, parser: str, preparser: Callable[[str], str] = ...) -> None: ...

class PythonExprVisitor(BaseExprVisitor):
    def __init__(self, env: Any, engine: str, parser: str, preparser: Callable[..., str] = ...) -> None: ...

class Expr:
    expr: str
    env: Any
    engine: str
    parser: str
    _visitor: BaseExprVisitor
    terms: Any
    def __init__(self, expr: str, engine: str = 'numexpr', parser: str = 'pandas', env: Optional[Any] = None, level: int = 0) -> None: ...
    @property
    def assigner(self) -> Any: ...
    def __call__(self) -> Any: ...
    def __repr__(self) -> str: ...
    def __len__(self) -> int: ...
    def parse(self) -> Any: ...
    @property
    def names(self) -> FrozenSet[str]: ...

PARSERS: Dict[str, type[BaseExprVisitor]] = ...