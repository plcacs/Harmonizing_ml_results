from typing import Any, Optional, Type, final

class BaseOpsUtil:
    series_scalar_exc: Optional[Type[BaseException]]
    frame_scalar_exc: Optional[Type[BaseException]]
    series_array_exc: Optional[Type[BaseException]]
    divmod_exc: Optional[Type[BaseException]]
    def _get_expected_exception(self, op_name: Any, obj: Any, other: Any) -> Optional[Type[BaseException]]: ...
    def _cast_pointwise_result(self, op_name: Any, obj: Any, other: Any, pointwise_result: Any) -> Any: ...
    def get_op_from_name(self, op_name: Any) -> Any: ...
    @final
    def check_opname(self, ser: Any, op_name: Any, other: Any) -> None: ...
    @final
    def _combine(self, obj: Any, other: Any, op: Any) -> Any: ...
    @final
    def _check_op(self, ser: Any, op: Any, other: Any, op_name: Any, exc: Optional[Type[BaseException]] = NotImplementedError) -> None: ...
    @final
    def _check_divmod_op(self, ser: Any, op: Any, other: Any) -> None: ...

class BaseArithmeticOpsTests(BaseOpsUtil):
    series_scalar_exc: Optional[Type[BaseException]]
    frame_scalar_exc: Optional[Type[BaseException]]
    series_array_exc: Optional[Type[BaseException]]
    divmod_exc: Optional[Type[BaseException]]
    def test_arith_series_with_scalar(self, data: Any, all_arithmetic_operators: Any) -> None: ...
    def test_arith_frame_with_scalar(self, data: Any, all_arithmetic_operators: Any) -> None: ...
    def test_arith_series_with_array(self, data: Any, all_arithmetic_operators: Any) -> None: ...
    def test_divmod(self, data: Any) -> None: ...
    def test_divmod_series_array(self, data: Any, data_for_twos: Any) -> None: ...
    def test_add_series_with_extension_array(self, data: Any) -> None: ...
    def test_direct_arith_with_ndframe_returns_not_implemented(self, data: Any, box: Any, op_name: Any) -> None: ...

class BaseComparisonOpsTests(BaseOpsUtil):
    def _compare_other(self, ser: Any, data: Any, op: Any, other: Any) -> None: ...
    def test_compare_scalar(self, data: Any, comparison_op: Any) -> None: ...
    def test_compare_array(self, data: Any, comparison_op: Any) -> None: ...

class BaseUnaryOpsTests(BaseOpsUtil):
    def test_invert(self, data: Any) -> None: ...
    def test_unary_ufunc_dunder_equivalence(self, data: Any, ufunc: Any) -> None: ...