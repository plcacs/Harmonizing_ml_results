from typing import Any
from jedi.inference.names import NameWrapper, ValueName
from jedi.inference.filters import FilterWrapper
from jedi.inference.value.klass import ClassMixin
from jedi.inference.base_value import Value, LazyValueWrapper, ValueWrapper, ValueSet
from jedi.inference.gradual.base import BaseTypingValue, BaseTypingClassWithGenerics, BaseTypingInstance

class TypingModuleName(NameWrapper):
    def infer(self) -> Any: ...
    def _remap(self) -> Any: ...

class TypingModuleFilterWrapper(FilterWrapper):
    name_wrapper_class: Any = ...

class ProxyWithGenerics(BaseTypingClassWithGenerics):
    def execute_annotation(self) -> Any: ...
    def gather_annotation_classes(self) -> Any: ...
    def _create_instance_with_generics(self, generics_manager: Any) -> Any: ...
    def infer_type_vars(self, value_set: Any) -> Any: ...

class ProxyTypingValue(BaseTypingValue):
    index_class: Any = ...
    def with_generics(self, generics_tuple: Any) -> Any: ...
    def py__getitem__(self, index_value_set: Any, contextualized_node: Any) -> Any: ...

class _TypingClassMixin(ClassMixin):
    def py__bases__(self) -> Any: ...
    def get_metaclasses(self) -> Any: ...
    @property
    def name(self) -> Any: ...

class TypingClassWithGenerics(ProxyWithGenerics, _TypingClassMixin):
    def infer_type_vars(self, value_set: Any) -> Any: ...
    def _create_instance_with_generics(self, generics_manager: Any) -> Any: ...

class ProxyTypingClassValue(ProxyTypingValue, _TypingClassMixin):
    index_class: Any = ...

class TypeAlias(LazyValueWrapper):
    def __init__(self, parent_context: Any, origin_tree_name: Any, actual: Any) -> None: ...
    @property
    def name(self) -> Any: ...
    def py__name__(self) -> Any: ...
    def __repr__(self) -> str: ...
    def _get_wrapped_value(self) -> Any: ...
    def gather_annotation_classes(self) -> Any: ...
    def get_signatures(self) -> Any: ...

class Callable(BaseTypingInstance):
    def py__call__(self, arguments: Any) -> Any: ...
    def py__get__(self, instance: Any, class_value: Any) -> Any: ...

class Tuple(BaseTypingInstance):
    def _is_homogenous(self) -> Any: ...
    def py__simple_getitem__(self, index: Any) -> Any: ...
    def py__iter__(self, contextualized_node: Any = ...) -> Any: ...
    def py__getitem__(self, index_value_set: Any, contextualized_node: Any) -> Any: ...
    def _get_wrapped_value(self) -> Any: ...
    @property
    def name(self) -> Any: ...
    def infer_type_vars(self, value_set: Any) -> Any: ...

class Generic(BaseTypingInstance): ...

class Protocol(BaseTypingInstance): ...

class AnyClass(BaseTypingValue):
    def execute_annotation(self) -> Any: ...

class OverloadFunction(BaseTypingValue):
    def py__call__(self, func_value_set: Any) -> Any: ...

class NewTypeFunction(ValueWrapper):
    def py__call__(self, arguments: Any) -> Any: ...

class NewType(Value):
    def __init__(self, inference_state: Any, parent_context: Any, tree_node: Any, type_value_set: Any) -> None: ...
    def py__class__(self) -> Any: ...
    def py__call__(self, arguments: Any) -> Any: ...
    @property
    def name(self) -> Any: ...
    def __repr__(self) -> str: ...

class CastFunction(ValueWrapper):
    def py__call__(self, type_value_set: Any, object_value_set: Any) -> Any: ...

class TypedDictClass(BaseTypingValue): ...

class TypedDict(LazyValueWrapper):
    def __init__(self, definition_class: Any) -> None: ...
    @property
    def name(self) -> Any: ...
    def py__simple_getitem__(self, index: Any) -> Any: ...
    def get_key_values(self) -> Any: ...
    def _get_wrapped_value(self) -> Any: ...