from typing import Any, List, Tuple

class _BoundTypeVarName:
    def __init__(self, type_var: Any, value_set: Any) -> None: ...
    def infer(self) -> Any: ...
    def py__name__(self) -> Any: ...
    def __repr__(self) -> str: ...

class _TypeVarFilter:
    def __init__(self, generics: Any, type_vars: Any) -> None: ...
    def get(self, name: Any) -> List[Any]: ...
    def values(self) -> List[Any]: ...

class _AnnotatedClassContext:
    def get_filters(self, *args: Any, **kwargs: Any) -> Any: ...

class DefineGenericBaseClass:
    def __init__(self, generics_manager: Any) -> None: ...
    def _create_instance_with_generics(self, generics_manager: Any) -> Any: ...
    def get_generics(self) -> Any: ...
    def define_generics(self, type_var_dict: Any) -> Any: ...
    def is_same_class(self, other: Any) -> bool: ...
    def get_signatures(self) -> List[Any]: ...
    def __repr__(self) -> str: ...

class GenericClass:
    def __init__(self, class_value: Any, generics_manager: Any) -> None: ...
    def _get_wrapped_value(self) -> Any: ...
    def get_type_hint(self, add_class_info: bool = True) -> str: ...
    def get_type_var_filter(self) -> Any: ...
    def py__call__(self, arguments: Any) -> Any: ...
    def _as_context(self) -> Any: ...
    def py__bases__(self) -> List[Any]: ...
    def _create_instance_with_generics(self, generics_manager: Any) -> Any: ...
    def is_sub_class_of(self, class_value: Any) -> bool: ...
    def with_generics(self, generics_tuple: Any) -> Any: ...
    def infer_type_vars(self, value_set: Any) -> Any: ...

class _LazyGenericBaseClass:
    def __init__(self, class_value: Any, lazy_base_class: Any, generics_manager: Any) -> None: ...
    def infer(self) -> Any: ...
    def _remap_type_vars(self, base: Any) -> Any: ...
    def __repr__(self) -> str: ...

class _GenericInstanceWrapper:
    def py__stop_iteration_returns(self) -> Any: ...
    def get_type_hint(self, add_class_info: bool = True) -> str: ...

class _PseudoTreeNameClass:
    api_type: str
    def __init__(self, parent_context: Any, tree_name: Any) -> None: ...
    @property
    def tree_node(self) -> Any: ...
    def get_filters(self, *args: Any, **kwargs: Any) -> Any: ...
    def py__class__(self) -> Any: ...
    @property
    def name(self) -> Any: ...
    def get_qualified_names(self) -> Tuple[str, ...]: ...
    def __repr__(self) -> str: ...

class BaseTypingValue:
    def __init__(self, parent_context: Any, tree_name: Any) -> None: ...
    @property
    def name(self) -> Any: ...
    def _get_wrapped_value(self) -> Any: ...
    def get_signatures(self) -> Any: ...
    def __repr__(self) -> str: ...

class BaseTypingClassWithGenerics:
    def __init__(self, parent_context: Any, tree_name: Any, generics_manager: Any) -> None: ...
    def _get_wrapped_value(self) -> Any: ...
    def __repr__(self) -> str: ...

class BaseTypingInstance:
    def __init__(self, parent_context: Any, class_value: Any, tree_name: Any, generics_manager: Any) -> None: ...
    def py__class__(self) -> Any: ...
    def get_annotated_class_object(self) -> Any: ...
    def get_qualified_names(self) -> Tuple[str, ...]: ...
    @property
    def name(self) -> Any: ...
    def _get_wrapped_value(self) -> Any: ...
    def __repr__(self) -> str: ...