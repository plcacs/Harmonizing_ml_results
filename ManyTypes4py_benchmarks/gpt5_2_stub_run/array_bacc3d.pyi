from __future__ import annotations
import decimal
import numbers
from typing import Any, Iterable, Optional, Sequence, Tuple, Type, overload
import numpy as np
from pandas.api.extensions import no_default
from pandas.core.arraylike import OpsMixin
from pandas.core.arrays import ExtensionArray, ExtensionScalarOpsMixin
from pandas.core.dtypes.base import ExtensionDtype

class DecimalDtype(ExtensionDtype):
    type: type
    name: str
    na_value: decimal.Decimal
    _metadata: Tuple[str, ...]
    context: decimal.Context
    def __init__(self, context: Optional[decimal.Context] = ...) -> None: ...
    def __repr__(self) -> str: ...
    @classmethod
    def construct_array_type(cls) -> Type[DecimalArray]: ...
    @property
    def _is_numeric(self) -> bool: ...

class DecimalArray(OpsMixin, ExtensionScalarOpsMixin, ExtensionArray):
    __array_priority__: int
    _HANDLED_TYPES: Tuple[type, ...]
    def __init__(self, values: Any, dtype: Any = ..., copy: bool = ..., context: Optional[decimal.Context] = ...) -> None: ...
    @property
    def dtype(self) -> DecimalDtype: ...
    @classmethod
    def _from_sequence(cls, scalars: Any, *, dtype: Any = ..., copy: bool = ...) -> DecimalArray: ...
    @classmethod
    def _from_sequence_of_strings(cls, strings: Sequence[str], *, dtype: Any, copy: bool = ...) -> DecimalArray: ...
    @classmethod
    def _from_factorized(cls, values: Any, original: Any) -> DecimalArray: ...
    def to_numpy(self, dtype: Any = ..., copy: bool = ..., na_value: Any = no_default, decimals: Any = ...) -> np.ndarray: ...
    def __array_ufunc__(self, ufunc: np.ufunc, method: str, *inputs: Any, **kwargs: Any) -> Any: ...
    @overload
    def __getitem__(self, item: numbers.Integral) -> decimal.Decimal: ...
    @overload
    def __getitem__(self, item: Any) -> DecimalArray: ...
    def take(self, indexer: Any, allow_fill: bool = ..., fill_value: Any = ...) -> DecimalArray: ...
    def copy(self) -> DecimalArray: ...
    def astype(self, dtype: Any, copy: bool = ...) -> Any: ...
    def __setitem__(self, key: Any, value: Any) -> None: ...
    def __len__(self) -> int: ...
    def __contains__(self, item: Any) -> bool: ...
    @property
    def nbytes(self) -> int: ...
    def isna(self) -> np.ndarray: ...
    @property
    def _na_value(self) -> decimal.Decimal: ...
    def _formatter(self, boxed: bool = ...) -> Any: ...
    @classmethod
    def _concat_same_type(cls, to_concat: Sequence[DecimalArray]) -> DecimalArray: ...
    def _reduce(self, name: str, *, skipna: bool = ..., keepdims: bool = ..., **kwargs: Any) -> Any: ...
    def _cmp_method(self, other: Any, op: Any) -> np.ndarray: ...
    def value_counts(self, dropna: bool = ...) -> Any: ...
    def fillna(self, value: Any = ..., limit: Any = ...) -> DecimalArray: ...

def to_decimal(values: Iterable[Any], context: Optional[decimal.Context] = ...) -> DecimalArray: ...
def make_data() -> list[decimal.Decimal]: ...