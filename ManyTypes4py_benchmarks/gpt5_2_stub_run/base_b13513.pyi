from abc import ABCMeta, abstractmethod
from pathlib import Path
from types import TracebackType
from typing import Any, Dict, List, Optional, Set, Type, TypeVar

T = TypeVar("T", bound="ConfiguredTask")


def read_profiles(profiles_dir: Optional[str] = ...) -> Dict[str, Any]: ...


class BaseTask(metaclass=ABCMeta):
    args: Any

    def __init__(self, args: Any) -> None: ...
    def __enter__(self) -> "BaseTask": ...
    def __exit__(
        self,
        exc_type: Optional[Type[BaseException]],
        exc_value: Optional[BaseException],
        traceback: Optional[TracebackType],
    ) -> None: ...
    @abstractmethod
    def run(self) -> Any: ...
    def interpret_results(self, results: Any) -> bool: ...


def get_nearest_project_dir(project_dir: Optional[str]) -> Path: ...
def move_to_nearest_project_dir(project_dir: Optional[str]) -> Path: ...


class ConfiguredTask(BaseTask):
    config: Any
    graph: Any
    manifest: Any
    compiler: Any

    def __init__(self, args: Any, config: Any, manifest: Any = ...) -> None: ...
    def compile_manifest(self) -> None: ...
    @classmethod
    def from_args(cls: Type[T], args: Any, *pargs: Any, **kwargs: Any) -> T: ...


class ExecutionContext:
    timing: List[Any]
    node: Any

    def __init__(self, node: Any) -> None: ...


class BaseRunner(metaclass=ABCMeta):
    config: Any
    compiler: Any
    adapter: Any
    node: Any
    node_index: int
    num_nodes: int
    skip: bool
    skip_cause: Any
    run_ephemeral_models: bool

    def __init__(self, config: Any, adapter: Any, node: Any, node_index: int, num_nodes: int) -> None: ...
    @abstractmethod
    def compile(self, manifest: Any) -> Any: ...
    def _node_build_path(self) -> Optional[Any]: ...
    def get_result_status(self, result: Any) -> Dict[str, Any]: ...
    def run_with_hooks(self, manifest: Any) -> Any: ...
    def _build_run_result(
        self,
        node: Any,
        start_time: float,
        status: Any,
        timing_info: Any,
        message: Optional[str],
        agate_table: Any = ...,
        adapter_response: Any = ...,
        failures: Any = ...,
        batch_results: Any = ...,
    ) -> Any: ...
    def error_result(self, node: Any, message: str, start_time: float, timing_info: Any) -> Any: ...
    def ephemeral_result(self, node: Any, start_time: float, timing_info: Any) -> Any: ...
    def from_run_result(self, result: Any, start_time: float, timing_info: Any) -> Any: ...
    def compile_and_execute(self, manifest: Any, ctx: ExecutionContext) -> Any: ...
    def _handle_catchable_exception(self, e: Any, ctx: ExecutionContext) -> str: ...
    def _handle_internal_exception(self, e: Any, ctx: ExecutionContext) -> str: ...
    def _handle_generic_exception(self, e: Any, ctx: ExecutionContext) -> str: ...
    def handle_exception(self, e: Any, ctx: ExecutionContext) -> str: ...
    def safe_run(self, manifest: Any) -> Any: ...
    def _safe_release_connection(self) -> Optional[str]: ...
    def before_execute(self) -> None: ...
    def execute(self, compiled_node: Any, manifest: Any) -> Any: ...
    def run(self, compiled_node: Any, manifest: Any) -> Any: ...
    def after_execute(self, result: Any) -> None: ...
    def _skip_caused_by_ephemeral_failure(self) -> bool: ...
    def on_skip(self) -> Any: ...
    def do_skip(self, cause: Any = ...) -> None: ...


def resource_types_from_args(args: Any, all_resource_values: Any, default_resource_values: Any) -> Set[Any]: ...