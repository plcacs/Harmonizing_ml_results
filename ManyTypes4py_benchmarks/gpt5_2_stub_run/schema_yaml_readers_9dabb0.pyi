def parse_where_filter(where: Any) -> Optional[WhereFilterIntersection]: ...


class ExposureParser(YamlReader):
    schema_parser: Any
    yaml: Any

    def __init__(self, schema_parser: Any, yaml: Any) -> None: ...
    def parse_exposure(self, unparsed: UnparsedExposure) -> None: ...
    def _generate_exposure_config(
        self, target: UnparsedExposure, fqn: List[str], package_name: str, rendered: bool
    ) -> Any: ...
    def parse(self) -> None: ...


class MetricParser(YamlReader):
    schema_parser: Any
    yaml: Any

    def __init__(self, schema_parser: Any, yaml: Any) -> None: ...
    def _get_input_measure(self, unparsed_input_measure: Any) -> MetricInputMeasure: ...
    def _get_optional_input_measure(self, unparsed_input_measure: Any) -> Optional[MetricInputMeasure]: ...
    def _get_input_measures(self, unparsed_input_measures: Optional[Sequence[Any]]) -> List[MetricInputMeasure]: ...
    def _get_period_agg(self, unparsed_period_agg: Any) -> PeriodAggregation: ...
    def _get_optional_time_window(self, unparsed_window: Any) -> Optional[MetricTimeWindow]: ...
    def _get_metric_input(self, unparsed: Any) -> MetricInput: ...
    def _get_optional_metric_input(self, unparsed: Any) -> Optional[MetricInput]: ...
    def _get_metric_inputs(self, unparsed_metric_inputs: Optional[Sequence[Any]]) -> List[MetricInput]: ...
    def _get_optional_conversion_type_params(self, unparsed: Any) -> Optional[ConversionTypeParams]: ...
    def _get_optional_cumulative_type_params(
        self, unparsed_metric: UnparsedMetric
    ) -> Optional[CumulativeTypeParams]: ...
    def _get_metric_type_params(self, unparsed_metric: UnparsedMetric) -> MetricTypeParams: ...
    def parse_metric(self, unparsed: UnparsedMetric, generated_from: Optional[str] = ...) -> None: ...
    def _generate_metric_config(
        self, target: UnparsedMetric, fqn: List[str], package_name: str, rendered: bool
    ) -> Any: ...
    def parse(self) -> None: ...


