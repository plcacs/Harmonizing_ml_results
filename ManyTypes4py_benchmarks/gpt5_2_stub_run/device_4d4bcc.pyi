from typing import Any, List, Optional, Union
from http import HTTPStatus

ATTR_DEVICES: str
ATTR_DURATION: str
PERMISSION_ERROR: str
PAUSE_SERVICE_SCHEMA: Any
RESUME_SERVICE_SCHEMA: Any
STOP_SERVICE_SCHEMA: Any

class RachioPerson:
    rachio: Any
    config_entry: Any
    username: Any
    def __init__(self, rachio: Any, config_entry: Any) -> None: ...
    async def async_setup(self, hass: Any) -> None: ...
    def _setup(self, hass: Any) -> None: ...
    @property
    def user_id(self) -> Any: ...
    @property
    def controllers(self) -> List['RachioIro']: ...
    @property
    def base_stations(self) -> List['RachioBaseStation']: ...
    def start_multiple_zones(self, zones: Any) -> None: ...

class RachioIro:
    hass: Any
    rachio: Any
    name: Any
    serial_number: Any
    mac_address: Any
    model: Any
    def __init__(self, hass: Any, rachio: Any, data: Any, webhooks: Any) -> None: ...
    def setup(self) -> None: ...
    def _init_webhooks(self) -> None: ...
    def __str__(self) -> str: ...
    @property
    def controller_id(self) -> Any: ...
    @property
    def current_schedule(self) -> Any: ...
    @property
    def init_data(self) -> Any: ...
    def list_zones(self, include_disabled: bool = ...) -> List[Any]: ...
    def get_zone(self, zone_id: Any) -> Optional[Any]: ...
    def list_schedules(self) -> List[Any]: ...
    def list_flex_schedules(self) -> List[Any]: ...
    def stop_watering(self) -> None: ...
    def pause_watering(self, duration: Any) -> None: ...
    def resume_watering(self) -> None: ...

class RachioBaseStation:
    rachio: Any
    status_coordinator: Any
    schedule_coordinator: Any
    def __init__(self, rachio: Any, data: Any, status_coordinator: Any, schedule_coordinator: Any) -> None: ...
    def start_watering(self, valve_id: Any, duration: Any) -> None: ...
    def stop_watering(self, valve_id: Any) -> None: ...
    def create_skip(self, program_id: Any, timestamp: Any) -> None: ...

def is_invalid_auth_code(http_status_code: Union[int, HTTPStatus]) -> bool: ...