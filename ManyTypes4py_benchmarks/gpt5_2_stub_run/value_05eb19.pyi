from typing import Any, Optional, Iterable, Iterator, List, Tuple, Dict, Callable

class CheckAttribute:
    def __init__(self, check_name: Any = ...) -> None: ...
    def __call__(self, func: Any) -> "CheckAttribute": ...
    def __get__(self, instance: Any, owner: Any) -> Any: ...

class CompiledValue:
    def __init__(self, inference_state: Any, access_handle: Any, parent_context: Any = ...) -> None: ...
    def py__call__(self, arguments: Any) -> Any: ...
    def py__class__(self) -> Any: ...
    def py__mro__(self) -> Any: ...
    def py__bases__(self) -> Any: ...
    def get_qualified_names(self) -> Any: ...
    def py__bool__(self) -> bool: ...
    def is_class(self) -> bool: ...
    def is_function(self) -> bool: ...
    def is_module(self) -> bool: ...
    def is_compiled(self) -> bool: ...
    def is_stub(self) -> bool: ...
    def is_instance(self) -> bool: ...
    def py__doc__(self) -> Optional[str]: ...
    def get_param_names(self) -> List[Any]: ...
    def get_signatures(self) -> List[Any]: ...
    def __repr__(self) -> str: ...
    def _parse_function_doc(self) -> Tuple[str, str]: ...
    @property
    def api_type(self) -> str: ...
    def get_filters(self, is_instance: bool = ..., origin_scope: Any = ...) -> Iterable[Any]: ...
    def _ensure_one_filter(self, is_instance: Any) -> Any: ...
    def py__simple_getitem__(self, index: Any) -> Any: ...
    def py__getitem__(self, index_value_set: Any, contextualized_node: Any) -> Any: ...
    def py__iter__(self, contextualized_node: Any = ...) -> Iterator[Any]: ...
    def py__name__(self) -> Optional[str]: ...
    @property
    def name(self) -> Any: ...
    def _execute_function(self, params: Any) -> Any: ...
    def get_safe_value(self, default: Any = ...) -> Any: ...
    def execute_operation(self, other: Any, operator: Any) -> Any: ...
    def execute_annotation(self) -> Any: ...
    def negate(self) -> Any: ...
    def get_metaclasses(self) -> Any: ...
    def _as_context(self) -> Any: ...
    @property
    def array_type(self) -> Any: ...
    def get_key_values(self) -> List[Any]: ...
    def get_type_hint(self, add_class_info: bool = ...) -> Optional[str]: ...

class CompiledModule(CompiledValue):
    file_io: Any
    def _as_context(self) -> Any: ...
    def py__path__(self) -> Any: ...
    def is_package(self) -> bool: ...
    @property
    def string_names(self) -> Tuple[str, ...]: ...
    def py__file__(self) -> Any: ...

class CompiledName:
    def __init__(self, inference_state: Any, parent_value: Any, name: str) -> None: ...
    def py__doc__(self) -> Optional[str]: ...
    def _get_qualified_names(self) -> Any: ...
    def get_defining_qualified_value(self) -> Optional[Any]: ...
    def __repr__(self) -> str: ...
    @property
    def api_type(self) -> str: ...
    def infer(self) -> Any: ...
    def infer_compiled_value(self) -> Any: ...

class SignatureParamName:
    def __init__(self, compiled_value: Any, signature_param: Any) -> None: ...
    @property
    def string_name(self) -> str: ...
    def to_string(self) -> str: ...
    def get_kind(self) -> Any: ...
    def infer(self) -> Any: ...

class UnresolvableParamName:
    def __init__(self, compiled_value: Any, name: str, default: Any) -> None: ...
    def get_kind(self) -> Any: ...
    def to_string(self) -> str: ...
    def infer(self) -> Any: ...

class CompiledValueName:
    def __init__(self, value: Any, name: str) -> None: ...

class EmptyCompiledName:
    def __init__(self, inference_state: Any, name: str) -> None: ...
    def infer(self) -> Any: ...

class CompiledValueFilter:
    def __init__(self, inference_state: Any, compiled_value: Any, is_instance: bool = ...) -> None: ...
    def get(self, name: str) -> List[Any]: ...
    def _get(self, name: str, allowed_getattr_callback: Any, in_dir_callback: Any, check_has_attribute: bool = ...) -> List[Any]: ...
    def _get_cached_name(self, name: str, is_empty: bool = ...) -> Any: ...
    def values(self) -> List[Any]: ...
    def _create_name(self, name: str) -> Any: ...
    def __repr__(self) -> str: ...

docstr_defaults: Dict[str, str]

def _parse_function_doc(doc: str) -> Tuple[str, str]: ...
def create_from_name(inference_state: Any, compiled_value: Any, name: str) -> Any: ...
def _normalize_create_args(func: Any) -> Any: ...
def create_from_access_path(inference_state: Any, access_path: Any) -> Any: ...
def create_cached_compiled_value(inference_state: Any, access_handle: Any, parent_context: Any) -> Any: ...