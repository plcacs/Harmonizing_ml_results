from typing import Any, Dict, Iterator, List, Optional, Tuple
import logging
from kedro.io.catalog_config_resolver import CatalogConfigResolver
from kedro.io.core import AbstractDataset, CatalogProtocol, Version

class _LazyDataset:
    def __init__(self, name: str, config: Dict[str, Any], load_version: Optional[Any] = ..., save_version: Optional[Any] = ...) -> None: ...
    def __repr__(self) -> str: ...
    def materialize(self) -> AbstractDataset: ...

class KedroDataCatalog(CatalogProtocol):
    def __init__(
        self,
        datasets: Optional[Dict[str, AbstractDataset]] = ...,
        raw_data: Optional[Dict[str, Any]] = ...,
        config_resolver: Optional[CatalogConfigResolver] = ...,
        load_versions: Optional[Dict[str, Any]] = ...,
        save_version: Optional[str] = ...,
    ) -> None: ...
    @property
    def datasets(self) -> Dict[str, Any]: ...
    @datasets.setter
    def datasets(self, value: Any) -> None: ...
    def __getattribute__(self, key: str) -> Any: ...
    @property
    def config_resolver(self) -> CatalogConfigResolver: ...
    def __repr__(self) -> str: ...
    def __contains__(self, dataset_name: str) -> bool: ...
    def __eq__(self, other: Any) -> bool: ...
    def keys(self) -> List[str]: ...
    def values(self) -> List[Any]: ...
    def items(self) -> List[Tuple[str, Any]]: ...
    def __iter__(self) -> Iterator[str]: ...
    def __getitem__(self, ds_name: str) -> AbstractDataset: ...
    def __setitem__(self, key: str, value: Any) -> None: ...
    def __len__(self) -> int: ...
    def get(self, key: str, default: Any = ...) -> Any: ...
    def _ipython_key_completions_(self) -> List[str]: ...
    @property
    def _logger(self) -> logging.Logger: ...
    @classmethod
    def from_config(
        cls,
        catalog: Optional[Dict[str, Any]] = ...,
        credentials: Optional[Dict[str, Any]] = ...,
        load_versions: Optional[Dict[str, Any]] = ...,
        save_version: Optional[str] = ...,
    ) -> "KedroDataCatalog": ...
    def to_config(self) -> Tuple[Dict[str, Any], Dict[str, Any], Dict[str, Any], Optional[str]]: ...
    @staticmethod
    def _validate_dataset_config(ds_name: str, ds_config: Any) -> None: ...
    def _add_from_config(self, ds_name: str, ds_config: Any) -> None: ...
    def get_dataset(self, ds_name: str, version: Optional[Version] = ..., suggest: bool = ...) -> AbstractDataset: ...
    def _get_dataset(self, dataset_name: str, version: Optional[Version] = ..., suggest: bool = ...) -> AbstractDataset: ...
    def add(self, ds_name: str, dataset: Any, replace: bool = ...) -> None: ...
    def filter(self, name_regex: Any = ..., type_regex: Any = ..., by_type: Any = ...) -> List[str]: ...
    def list(self, regex_search: Optional[str] = ..., regex_flags: int = ...) -> List[str]: ...
    def save(self, name: str, data: Any) -> None: ...
    def load(self, name: str, version: Optional[str] = ...) -> Any: ...
    def release(self, name: str) -> None: ...
    def confirm(self, name: str) -> None: ...
    def add_feed_dict(self, feed_dict: Dict[str, Any], replace: bool = ...) -> None: ...
    def shallow_copy(self, extra_dataset_patterns: Any = ...) -> "KedroDataCatalog": ...
    def exists(self, name: str) -> bool: ...