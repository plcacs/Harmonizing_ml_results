from typing import Any, Optional

class PeriodIndex(object):
    def __new__(cls, data: Any = ..., freq: Any = ..., dtype: Any = ..., copy: bool = ..., name: Optional[str] = ...) -> "PeriodIndex": ...
    def asfreq(self, freq: Any = ..., how: str = ...) -> "PeriodIndex": ...
    def to_timestamp(self, freq: Any = ..., how: str = ...) -> Any: ...
    @property
    def hour(self) -> Any: ...
    @property
    def minute(self) -> Any: ...
    @property
    def second(self) -> Any: ...
    @classmethod
    def from_fields(
        cls,
        *,
        year: Any = ...,
        quarter: Any = ...,
        month: Any = ...,
        day: Any = ...,
        hour: Any = ...,
        minute: Any = ...,
        second: Any = ...,
        freq: Any = ...
    ) -> "PeriodIndex": ...
    @classmethod
    def from_ordinals(cls, ordinals: Any, *, freq: Any, name: Optional[str] = ...) -> "PeriodIndex": ...
    @property
    def values(self) -> Any: ...
    def asof_locs(self, where: Any, mask: Any) -> Any: ...
    @property
    def is_full(self) -> bool: ...
    @property
    def inferred_type(self) -> str: ...
    def get_loc(self, key: Any) -> Any: ...
    def shift(self, periods: int = ..., freq: Any = ...) -> "PeriodIndex": ...
    def strftime(self, date_format: str) -> Any: ...
    @property
    def start_time(self) -> Any: ...
    @property
    def end_time(self) -> Any: ...
    @property
    def is_leap_year(self) -> Any: ...

def period_range(
    start: Any = ...,
    end: Any = ...,
    periods: Optional[int] = ...,
    freq: Any = ...,
    name: Optional[str] = ...
) -> PeriodIndex: ...