from typing import Any, List, Optional, Union
from pathlib import Path

class Script:
    def __init__(self, code: Optional[Any] = ..., *, path: Optional[Union[str, Path]] = ..., environment: Optional[Any] = ..., project: Optional[Any] = ...) -> None: ...
    def _get_module(self) -> Any: ...
    def _get_module_context(self) -> Any: ...
    def __repr__(self) -> str: ...
    def complete(self, line: Optional[int] = ..., column: Optional[int] = ..., *, fuzzy: bool = ...) -> List[Any]: ...
    def infer(self, line: Optional[int] = ..., column: Optional[int] = ..., *, only_stubs: bool = ..., prefer_stubs: bool = ...) -> List[Any]: ...
    def goto(self, line: Optional[int] = ..., column: Optional[int] = ..., *, follow_imports: bool = ..., follow_builtin_imports: bool = ..., only_stubs: bool = ..., prefer_stubs: bool = ...) -> List[Any]: ...
    def search(self, string: str, *, all_scopes: bool = ...) -> List[Any]: ...
    def _search_func(self, string: str, all_scopes: bool = ..., complete: bool = ..., fuzzy: bool = ...) -> List[Any]: ...
    def complete_search(self, string: str, **kwargs: Any) -> List[Any]: ...
    def help(self, line: Optional[int] = ..., column: Optional[int] = ...) -> List[Any]: ...
    def get_references(self, line: Optional[int] = ..., column: Optional[int] = ..., **kwargs: Any) -> List[Any]: ...
    def get_signatures(self, line: Optional[int] = ..., column: Optional[int] = ...) -> List[Any]: ...
    def get_context(self, line: Optional[int] = ..., column: Optional[int] = ...) -> Any: ...
    def _analysis(self) -> List[Any]: ...
    def get_names(self, **kwargs: Any) -> List[Any]: ...
    def get_syntax_errors(self) -> List[Any]: ...
    def _names(self, all_scopes: bool = ..., definitions: bool = ..., references: bool = ...) -> List[Any]: ...
    def rename(self, line: Optional[int] = ..., column: Optional[int] = ..., *, new_name: str) -> Any: ...
    def extract_variable(self, line: int, column: int, *, new_name: str, until_line: Optional[int] = ..., until_column: Optional[int] = ...) -> Any: ...
    def extract_function(self, line: int, column: int, *, new_name: str, until_line: Optional[int] = ..., until_column: Optional[int] = ...) -> Any: ...
    def inline(self, line: Optional[int] = ..., column: Optional[int] = ...) -> Any: ...

class Interpreter(Script):
    _allow_descriptor_getattr_default: bool
    def __init__(self, code: Any, namespaces: Any, *, project: Optional[Any] = ..., **kwds: Any) -> None: ...
    def _get_module_context(self) -> Any: ...

def preload_module(*modules: str) -> None: ...
def set_debug_function(func_cb: Any = ..., warnings: bool = ..., notices: bool = ..., speed: bool = ...) -> None: ...