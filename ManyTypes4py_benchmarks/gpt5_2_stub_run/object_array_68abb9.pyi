from typing import Any, Callable, Optional
from pandas.core.strings.base import BaseStringArrayMethods

class ObjectStringArrayMixin(BaseStringArrayMethods):
    def __len__(self) -> int: ...
    def _str_map(self, f: Callable[[Any], Any], na_value: Any = ..., dtype: Optional[Any] = None, convert: bool = True) -> Any: ...
    def _str_count(self, pat: Any, flags: int = 0) -> Any: ...
    def _str_pad(self, width: int, side: str = "left", fillchar: str = " ") -> Any: ...
    def _str_contains(self, pat: Any, case: bool = True, flags: int = 0, na: Any = ..., regex: bool = True) -> Any: ...
    def _str_startswith(self, pat: Any, na: Any = ...) -> Any: ...
    def _str_endswith(self, pat: Any, na: Any = ...) -> Any: ...
    def _str_replace(self, pat: Any, repl: Any, n: int = -1, case: bool = True, flags: int = 0, regex: bool = True) -> Any: ...
    def _str_repeat(self, repeats: Any) -> Any: ...
    def _str_match(self, pat: Any, case: bool = True, flags: int = 0, na: Any = ...) -> Any: ...
    def _str_fullmatch(self, pat: Any, case: bool = True, flags: int = 0, na: Any = ...) -> Any: ...
    def _str_encode(self, encoding: str, errors: str = "strict") -> Any: ...
    def _str_find(self, sub: Any, start: int = 0, end: Optional[int] = None) -> Any: ...
    def _str_rfind(self, sub: Any, start: int = 0, end: Optional[int] = None) -> Any: ...
    def _str_find_(self, sub: Any, start: int, end: Optional[int], side: str) -> Any: ...
    def _str_findall(self, pat: Any, flags: int = 0) -> Any: ...
    def _str_get(self, i: Any) -> Any: ...
    def _str_index(self, sub: Any, start: int = 0, end: Optional[int] = None) -> Any: ...
    def _str_rindex(self, sub: Any, start: int = 0, end: Optional[int] = None) -> Any: ...
    def _str_join(self, sep: str) -> Any: ...
    def _str_partition(self, sep: str, expand: bool) -> Any: ...
    def _str_rpartition(self, sep: str, expand: bool) -> Any: ...
    def _str_len(self) -> Any: ...
    def _str_slice(self, start: Optional[int] = None, stop: Optional[int] = None, step: Optional[int] = None) -> Any: ...
    def _str_slice_replace(self, start: Optional[int] = None, stop: Optional[int] = None, repl: Any = None) -> Any: ...
    def _str_split(self, pat: Optional[Any] = None, n: int = -1, expand: bool = False, regex: Optional[bool] = None) -> Any: ...
    def _str_rsplit(self, pat: Optional[Any] = None, n: int = -1) -> Any: ...
    def _str_translate(self, table: Any) -> Any: ...
    def _str_wrap(self, width: int, **kwargs: Any) -> Any: ...
    def _str_get_dummies(self, sep: str = "|", dtype: Optional[Any] = None) -> Any: ...
    def _str_upper(self) -> Any: ...
    def _str_isalnum(self) -> Any: ...
    def _str_isalpha(self) -> Any: ...
    def _str_isascii(self) -> Any: ...
    def _str_isdecimal(self) -> Any: ...
    def _str_isdigit(self) -> Any: ...
    def _str_islower(self) -> Any: ...
    def _str_isnumeric(self) -> Any: ...
    def _str_isspace(self) -> Any: ...
    def _str_istitle(self) -> Any: ...
    def _str_isupper(self) -> Any: ...
    def _str_capitalize(self) -> Any: ...
    def _str_casefold(self) -> Any: ...
    def _str_title(self) -> Any: ...
    def _str_swapcase(self) -> Any: ...
    def _str_lower(self) -> Any: ...
    def _str_normalize(self, form: str) -> Any: ...
    def _str_strip(self, to_strip: Optional[str] = None) -> Any: ...
    def _str_lstrip(self, to_strip: Optional[str] = None) -> Any: ...
    def _str_rstrip(self, to_strip: Optional[str] = None) -> Any: ...
    def _str_removeprefix(self, prefix: str) -> Any: ...
    def _str_removesuffix(self, suffix: str) -> Any: ...
    def _str_extract(self, pat: Any, flags: int = 0, expand: bool = True) -> Any: ...