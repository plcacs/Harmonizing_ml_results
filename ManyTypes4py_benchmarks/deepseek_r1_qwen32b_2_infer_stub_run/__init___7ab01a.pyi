JSSTRICT = int

class error(Exception):
    def __init__(self, msg: str, error: Exception, pattern: Optional[str] = ..., flags: int = ..., pos: Optional[int] = ...) -> None: ...
    
class ReIndexError(IndexError):
    def __init__(self) -> None: ...

class Match:
    def __init__(self, mObj: Any, string: str, pos: int, endpos: int, rObj: Regex, namedGroups: Optional[dict] = ...) -> None: ...
    
    @property
    def pos(self) -> int: ...
    
    @property
    def endpos(self) -> int: ...
    
    @property
    def re(self) -> Regex: ...
    
    @property
    def string(self) -> str: ...
    
    @property
    def lastgroup(self) -> Optional[str]: ...
    
    @property
    def lastindex(self) -> Optional[int]: ...
    
    def expand(self, template: str) -> str: ...
    
    def group(self, *args: Union[str, int]) -> Union[str, Tuple[str, ...]]: ...
    
    def groups(self, default: Optional[Any] = ...) -> Tuple[Any, ...]: ...
    
    def groupdict(self, default: Optional[Any] = ...) -> dict: ...
    
    def start(self, group: Union[str, int] = ...) -> int: ...
    
    def end(self, group: Union[str, int] = ...) -> int: ...
    
    def span(self, group: Union[str, int] = ...) -> Tuple[int, int]: ...

class Regex:
    def __init__(self, pattern: str, flags: int) -> None: ...
    
    @property
    def pattern(self) -> str: ...
    
    @property
    def flags(self) -> int: ...
    
    @property
    def groups(self) -> int: ...
    
    @property
    def groupindex(self) -> dict: ...
    
    def search(self, string: str, pos: int = ..., endpos: Optional[int] = ...) -> Optional[Match]: ...
    
    def match(self, string: str, pos: int = ..., endpos: Optional[int] = ...) -> Optional[Match]: ...
    
    def fullmatch(self, string: str, pos: int = ..., endpos: Optional[int] = ...) -> Optional[Match]: ...
    
    def split(self, string: str, maxsplit: int = ...) -> List[str]: ...
    
    def findall(self, string: str, pos: int = ..., endpos: Optional[int] = ...) -> Union[List[str], List[Tuple[str, ...]]]: ...
    
    def finditer(self, string: str, pos: int, endpos: Optional[int] = ...) -> Iterable[Match]: ...
    
    def sub(self, repl: Union[str, Callable[[Match], str]], string: str, count: int = ...) -> str: ...
    
    def subn(self, repl: Union[str, Callable[[Match], str]], string: str, count: int = ...) -> Tuple[str, int]: ...

class PyRegExp(Regex):
    def __init__(self, pyPattern: str, flags: int) -> None: ...

def compile(pattern: str, flags: int = ...) -> Union[Regex, PyRegExp]: ...

def search(pattern: str, string: str, flags: int = ...) -> Optional[Match]: ...

def match(pattern: str, string: str, flags: int = ...) -> Optional[Match]: ...

def fullmatch(pattern: str, string: str, flags: int = ...) -> Optional[Match]: ...

def split(pattern: str, string: str, maxsplit: int = ..., flags: int = ...) -> List[str]: ...

def findall(pattern: str, string: str, flags: int = ...) -> Union[List[str], List[Tuple[str, ...]]]: ...

def finditer(pattern: str, string: str, flags: int = ...) -> Iterable[Match]: ...

def sub(pattern: str, repl: Union[str, Callable[[Match], str]], string: str, count: int = ..., flags: int = ...) -> str: ...

def subn(pattern: str, repl: Union[str, Callable[[Match], str]], string: str, count: int = ..., flags: int = ...) -> Tuple[str, int]: ...

def escape(string: str) -> str: ...

def purge() -> None: ...