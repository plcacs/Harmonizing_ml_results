from __future__ import annotations
from typing import (
    Any,
    Callable,
    Iterable,
    List,
    Optional,
    Tuple,
    Union,
    overload,
)

T = int
TEMPLATE = int
I = int
IGNORECASE = int
L = int
LOCALE = int
M = int
MULTILINE = int
S = int
DOTALL = int
U = int
UNICODE = int
X = int
VERBOSE = int
DEBUG = int
A = int
ASCII = int
Y = int
STICKY = int
