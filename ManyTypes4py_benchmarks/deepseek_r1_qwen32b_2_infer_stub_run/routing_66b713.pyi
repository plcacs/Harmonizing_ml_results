from __future__ import annotations
import contextlib
import functools
import inspect
import re
import traceback
import types
import typing
from contextlib import asynccontextmanager
from enum import Enum
from starlette.types import ASGIApp, Lifespan, Receive, Scope, Send
from typing import (
    Any,
    Callable,
    Dict,
    Iterable,
    List,
    Optional,
    Tuple,
    Union,
    TypeVar,
    overload,
)

_T = TypeVar('_T')

class Match(Enum):
    NONE = 0
    PARTIAL = 1
    FULL = 2

def iscoroutinefunction_or_partial(obj: Any) -> bool: ...

def request_response(func: Callable) -> ASGIApp: ...

def websocket_session(func: Callable) -> ASGIApp: ...

def get_name(endpoint: Union[Callable, type]) -> str: ...

def replace_params(path: str, param_convertors: Dict[str, Any], path_params: Dict[str, Any]) -> Tuple[str, Dict[str, Any]]: ...

class BaseRoute:
    def matches(self, scope: Scope) -> Tuple[Match, Dict[str, Any]]: ...
    def url_path_for(self, name: str, /, **path_params: Any) -> URLPath: ...
    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None: ...

class Route(BaseRoute):
    def __init__(self, path: str, endpoint: Callable, *, methods: Optional[List[str]] = None, name: Optional[str] = None, include_in_schema: bool = True, middleware: Optional[List[Tuple[Type[Middleware], List[Any], Dict[str, Any]]]] = None) -> None: ...
    app: ASGIApp

class WebSocketRoute(BaseRoute):
    def __init__(self, path: str, endpoint: Callable, *, name: Optional[str] = None, middleware: Optional[List[Tuple[Type[Middleware], List[Any], Dict[str, Any]]]] = None) -> None: ...
    app: ASGIApp

class Mount(BaseRoute):
    def __init__(self, path: str, app: Optional[ASGIApp] = None, routes: Optional[List[BaseRoute]] = None, name: Optional[str] = None, *, middleware: Optional[List[Tuple[Type[Middleware], List[Any], Dict[str, Any]]]] = None) -> None: ...
    app: ASGIApp

class Host(BaseRoute):
    def __init__(self, host: str, app: ASGIApp, name: Optional[str] = None) -> None: ...
    app: ASGIApp

class Router:
    def __init__(self, routes: Optional[List[BaseRoute]] = None, redirect_slashes: bool = True, default: Optional[Callable] = None, on_startup: Optional[List[Callable]] = None, on_shutdown: Optional[List[Callable]] = None, lifespan: Optional[Union[AsyncContextManager, Callable]] = None, *, middleware: Optional[List[Tuple[Type[Middleware], List[Any], Dict[str, Any]]]] = None) -> None: ...
    routes: List[BaseRoute]
    middleware_stack: ASGIApp
    app: Callable[[Scope, Receive, Send], Awaitable[None]]
    async def not_found(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def url_path_for(self, name: str, /, **path_params: Any) -> URLPath: ...
    async def startup(self) -> None: ...
    async def shutdown(self) -> None: ...
    async def lifespan(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def mount(self, path: str, app: ASGIApp, name: Optional[str] = None) -> None: ...
    def host(self, host: str, app: ASGIApp, name: Optional[str] = None) -> None: ...
    def add_route(self, path: str, endpoint: Callable, methods: Optional[List[str]] = None, name: Optional[str] = None, include_in_schema: bool = True) -> None: ...
    def add_websocket_route(self, path: str, endpoint: Callable, name: Optional[str] = None) -> None: ...
    def route(self, path: str, methods: Optional[List[str]] = None, name: Optional[str] = None, include_in_schema: bool = True) -> Callable: ...
    def websocket_route(self, path: str, name: Optional[str] = None) -> Callable: ...
    def add_event_handler(self, event_type: str, func: Callable) -> None: ...
    def on_event(self, event_type: str) -> Callable: ...