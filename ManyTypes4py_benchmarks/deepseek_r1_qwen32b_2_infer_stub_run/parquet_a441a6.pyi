"""parquet compat"""

import io
import os
from typing import Any, Optional, Union, List, Tuple, Dict, Literal, overload
from pandas import DataFrame
from pandas._typing import DtypeBackend, FilePath, ReadBuffer, StorageOptions, WriteBuffer

class BaseImpl:
    def validate_dataframe(self, df: DataFrame) -> None: ...
    def write(self, df: DataFrame, path: Union[FilePath, WriteBuffer[bytes]], compression: str = ..., index: Optional[bool] = ..., **kwargs: Any) -> None: ...
    def read(self, path: Union[FilePath, ReadBuffer[bytes]], columns: Optional[List[str]] = ..., **kwargs: Any) -> DataFrame: ...

class PyArrowImpl(BaseImpl):
    def __init__(self) -> None: ...
    def write(self, df: DataFrame, path: Union[FilePath, WriteBuffer[bytes]], compression: str = ..., index: Optional[bool] = ..., storage_options: Optional[StorageOptions] = ..., partition_cols: Optional[List[str]] = ..., filesystem: Any = ..., **kwargs: Any) -> None: ...
    def read(self, path: Union[FilePath, ReadBuffer[bytes]], columns: Optional[List[str]] = ..., filters: Optional[List[Tuple[str, str, Any]]] = ..., dtype_backend: DtypeBackend = ..., storage_options: Optional[StorageOptions] = ..., filesystem: Any = ..., to_pandas_kwargs: Optional[Dict[str, Any]] = ..., **kwargs: Any) -> DataFrame: ...

class FastParquetImpl(BaseImpl):
    def __init__(self) -> None: ...
    def write(self, df: DataFrame, path: Union[FilePath, WriteBuffer[bytes]], compression: str = ..., index: Optional[bool] = ..., partition_cols: Optional[List[str]] = ..., storage_options: Optional[StorageOptions] = ..., filesystem: Any = ..., **kwargs: Any) -> None: ...
    def read(self, path: Union[FilePath, ReadBuffer[bytes]], columns: Optional[List[str]] = ..., filters: Optional[List[Tuple[str, str, Any]]] = ..., storage_options: Optional[StorageOptions] = ..., filesystem: Any = ..., to_pandas_kwargs: Optional[Dict[str, Any]] = ..., **kwargs: Any) -> DataFrame: ...

def get_engine(engine: str = ...) -> Union[PyArrowImpl, FastParquetImpl]: ...

@overload
def to_parquet(df: DataFrame, path: None, engine: str = ..., compression: str = ..., index: Optional[bool] = ..., storage_options: Optional[StorageOptions] = ..., partition_cols: Optional[List[str]] = ..., filesystem: Any = ..., **kwargs: Any) -> bytes: ...
@overload
def to_parquet(df: DataFrame, path: Union[FilePath, WriteBuffer[bytes]], engine: str = ..., compression: str = ..., index: Optional[bool] = ..., storage_options: Optional[StorageOptions] = ..., partition_cols: Optional[List[str]] = ..., filesystem: Any = ..., **kwargs: Any) -> None: ...
def to_parquet(df: DataFrame, path: Optional[Union[FilePath, WriteBuffer[bytes]]] = ..., engine: str = ..., compression: str = ..., index: Optional[bool] = ..., storage_options: Optional[StorageOptions] = ..., partition_cols: Optional[List[str]] = ..., filesystem: Any = ..., **kwargs: Any) -> Optional[bytes]: ...

def read_parquet(path: Union[FilePath, ReadBuffer[bytes]], engine: str = ..., columns: Optional[List[str]] = ..., storage_options: Optional[StorageOptions] = ..., dtype_backend: DtypeBackend = ..., filesystem: Any = ..., filters: Optional[List[Tuple[str, str, Any]]] = ..., to_pandas_kwargs: Optional[Dict[str, Any]] = ..., **kwargs: Any) -> DataFrame: ...