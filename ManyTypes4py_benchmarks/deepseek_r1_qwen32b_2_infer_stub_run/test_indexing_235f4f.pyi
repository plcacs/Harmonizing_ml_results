class TestGetIndexer:
    def test_get_indexer(self: Self) -> None: ...
    @pytest.mark.parametrize('reverse', [True, False])
    @pytest.mark.parametrize('expected,method', [([-1, 0, 0, 1, 1], 'pad'), ([-1, 0, 0, 1, 1], 'ffill'), ([0, 0, 1, 1, 2], 'backfill'), ([0, 0, 1, 1, 2], 'bfill')])
    def test_get_indexer_methods(self: Self, reverse: bool, expected: list[int], method: str) -> None: ...
    def test_get_indexer_invalid(self: Self) -> None: ...
    @pytest.mark.parametrize('method, tolerance, indexer, expected', [('pad', None, [0, 5, 9], [0, 5, 9]), ('backfill', None, [0, 5, 9], [0, 5, 9]), ('nearest', None, [0, 5, 9], [0, 5, 9]), ('pad', 0, [0, 5, 9], [0, 5, 9]), ('backfill', 0, [0, 5, 9], [0, 5, 9]), ('nearest', 0, [0, 5, 9], [0, 5, 9]), ('pad', None, [0.2, 1.8, 8.5], [0, 1, 8]), ('backfill', None, [0.2, 1.8, 8.5], [1, 2, 9]), ('nearest', None, [0.2, 1.8, 8.5], [0, 2, 9]), ('pad', 1, [0.2, 1.8, 8.5], [0, 1, 8]), ('backfill', 1, [0.2, 1.8, 8.5], [1, 2, 9]), ('nearest', 1, [0.2, 1.8, 8.5], [0, 2, 9]), ('pad', 0.2, [0.2, 1.8, 8.5], [0, -1, -1]), ('backfill', 0.2, [0.2, 1.8, 8.5], [-1, 2, -1]), ('nearest', 0.2, [0.2, 1.8, 8.5], [0, 2, -1])])
    def test_get_indexer_nearest(self: Self, method: str, tolerance: float | None, indexer: list[float | int], expected: list[int]) -> None: ...
    @pytest.mark.parametrize('listtype', [list, tuple, Series, np.array])
    @pytest.mark.parametrize('tolerance, expected', [[[0.3, 0.3, 0.1], [0, 2, -1]], [[0.2, 0.1, 0.1], [0, -1, -1]], [[0.1, 0.5, 0.5], [-1, 2, 9]]])
    def test_get_indexer_nearest_listlike_tolerance(self: Self, tolerance: list[float], expected: list[int], listtype: type) -> None: ...
    def test_get_indexer_nearest_error(self: Self) -> None: ...
    @pytest.mark.parametrize('method,expected', [('pad', [8, 7, 0]), ('backfill', [9, 8, 1]), ('nearest', [9, 7, 0])])
    def test_get_indexer_nearest_decreasing(self: Self, method: str, expected: list[int]) -> None: ...
    @pytest.mark.parametrize('idx_dtype', ['int64', 'float64', 'uint64', 'range'])
    @pytest.mark.parametrize('method', ['get_indexer', 'get_indexer_non_unique'])
    def test_get_indexer_numeric_index_boolean_target(self: Self, method: str, idx_dtype: str) -> None: ...
    @pytest.mark.parametrize('method', ['pad', 'backfill', 'nearest'])
    def test_get_indexer_with_method_numeric_vs_bool(self: Self, method: str) -> None: ...
    def test_get_indexer_numeric_vs_bool(self: Self) -> None: ...
    def test_get_indexer_float64(self: Self) -> None: ...
    def test_get_indexer_nan(self: Self) -> None: ...
    def test_get_indexer_int64(self: Self) -> None: ...
    def test_get_indexer_uint64(self: Self) -> None: ...
    @pytest.mark.parametrize('val, val2', [(4, 5), (4, 4), (4, NA), (NA, NA)])
    def test_get_loc_masked(self: Self, val: int | NA, val2: int | NA, any_numeric_ea_and_arrow_dtype: str) -> None: ...
    def test_get_loc_masked_na(self: Self, any_numeric_ea_and_arrow_dtype: str) -> None: ...
    def test_get_loc_masked_na_and_nan(self: Self) -> None: ...
    @pytest.mark.parametrize('val', [4, 2])
    def test_get_indexer_masked_na(self: Self, any_numeric_ea_and_arrow_dtype: str, val: int) -> None: ...
    @pytest.mark.parametrize('dtype', ['boolean', 'bool[pyarrow]'])
    def test_get_indexer_masked_na_boolean(self: Self, dtype: str) -> None: ...
    def test_get_indexer_arrow_dictionary_target(self: Self) -> None: ...

