class StatusValues(Enum):
    PENDING: str
    COMPUTING: str
    UPDATED: str
    ERROR: str

class ScreenshotCachePayloadType(TypedDict):
    pass

class ScreenshotCachePayload:
    def __init__(self, image: Optional[bytes] = ..., status: StatusValues = ..., timestamp: str = ...) -> None: ...
    @classmethod
    def from_dict(cls: Type[ScreenshotCachePayload], payload: Dict[str, Any]) -> ScreenshotCachePayload: ...
    def to_dict(self) -> Dict[str, Any]: ...
    def update_timestamp(self) -> None: ...
    def pending(self) -> None: ...
    def computing(self) -> None: ...
    def update(self, image: bytes) -> None: ...
    def error(self) -> None: ...
    def get_image(self) -> Optional[BytesIO]: ...
    def get_timestamp(self) -> str: ...
    def get_status(self) -> str: ...
    def is_error_cache_ttl_expired(self) -> bool: ...
    def should_trigger_task(self, force: bool = ...) -> bool: ...

class BaseScreenshot:
    driver_type: str
    thumbnail_type: str
    element: str
    window_size: Tuple[int, int]
    thumb_size: Tuple[int, int]
    cache: Cache

    def __init__(self, url: str, digest: str) -> None: ...
    def driver(self, window_size: Optional[Tuple[int, int]] = ...) -> WebDriver: ...
    def get_screenshot(self, user: Any, window_size: Optional[Tuple[int, int]] = ...) -> Optional[bytes]: ...
    def get_cache_key(self, window_size: Optional[Tuple[int, int]] = ..., thumb_size: Optional[Tuple[int, int]] = ...) -> str: ...
    def get_from_cache(self, window_size: Optional[Tuple[int, int]] = ..., thumb_size: Optional[Tuple[int, int]] = ...) -> Optional[ScreenshotCachePayload]: ...
    @classmethod
    def get_from_cache_key(cls: Type[BaseScreenshot], cache_key: str) -> Optional[ScreenshotCachePayload]: ...
    def compute_and_cache(self, force: bool, user: Any = ..., window_size: Optional[Tuple[int, int]] = ..., thumb_size: Optional[Tuple[int, int]] = ..., cache_key: Optional[str] = ...) -> None: ...
    @classmethod
    def resize_image(cls: Type[BaseScreenshot], img_bytes: bytes, output: str = ..., thumb_size: Optional[Tuple[int, int]] = ..., crop: bool = ...) -> Optional[bytes]: ...

class ChartScreenshot(BaseScreenshot):
    def __init__(self, url: str, digest: str, window_size: Optional[Tuple[int, int]] = ..., thumb_size: Optional[Tuple[int, int]] = ...) -> None: ...

class DashboardScreenshot(BaseScreenshot):
    def __init__(self, url: str, digest: str, window_size: Optional[Tuple[int, int]] = ..., thumb_size: Optional[Tuple[int, int]] = ...) -> None: ...
    def get_cache_key(self, window_size: Optional[Tuple[int, int]] = ..., thumb_size: Optional[Tuple[int, int]] = ..., dashboard_state: Optional[DashboardPermalinkState] = ...) -> str: ...