import copy
from collections.abc import Iterable
from typing import Any, overload, Tuple, List, Optional, Union, Set, Dict, TypeVar, FrozenSet, Callable, Type, cast
from hypothesis.errors import InvalidArgument
from hypothesis.internal.conjecture.engine import BUFFER_SIZE
from hypothesis.strategies._internal.strategies import T3, T4, T5, Ex, MappedStrategy, SearchStrategy, T, check_strategy, filter_not_satisfied
from hypothesis.strategies._internal.utils import cacheable, defines_strategy

class TupleStrategy(SearchStrategy):
    element_strategies: Tuple[SearchStrategy, ...]
    def __init__(self, strategies: Tuple[SearchStrategy, ...]) -> None: ...
    def do_validate(self) -> None: ...
    def calc_label(self) -> str: ...
    def __repr__(self) -> str: ...
    def calc_has_reusable_values(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def do_draw(self, data: Any) -> Tuple[Any, ...]: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...

@overload
def tuples() -> SearchStrategy: ...
@overload
def tuples(__a1: SearchStrategy) -> SearchStrategy: ...
@overload
def tuples(__a1: SearchStrategy, __a2: SearchStrategy) -> SearchStrategy: ...
@overload
def tuples(__a1: SearchStrategy, __a2: SearchStrategy, __a3: SearchStrategy) -> SearchStrategy: ...
@overload
def tuples(__a1: SearchStrategy, __a2: SearchStrategy, __a3: SearchStrategy, __a4: SearchStrategy) -> SearchStrategy: ...
@overload
def tuples(__a1: SearchStrategy, __a2: SearchStrategy, __a3: SearchStrategy, __a4: SearchStrategy, __a5: SearchStrategy) -> SearchStrategy: ...
@overload
def tuples(*args: SearchStrategy) -> SearchStrategy: ...

@cacheable
@defines_strategy()
def tuples(*args: SearchStrategy) -> TupleStrategy: ...

class ListStrategy(SearchStrategy):
    min_size: int
    max_size: Union[int, float]
    average_size: float
    element_strategy: SearchStrategy
    _nonempty_filters: Tuple[Callable[..., Any], ...] = (bool, len, tuple, list)
    def __init__(self, elements: SearchStrategy, min_size: int = 0, max_size: Union[int, float] = float('inf')) -> None: ...
    def calc_label(self) -> str: ...
    def do_validate(self) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def do_draw(self, data: Any) -> List[Any]: ...
    def __repr__(self) -> str: ...
    def filter(self, condition: Callable[[Any], bool]) -> SearchStrategy: ...

class UniqueListStrategy(ListStrategy):
    keys: Tuple[Callable[[Any], Any], ...]
    tuple_suffixes: Optional[SearchStrategy]
    def __init__(self, elements: SearchStrategy, min_size: int, max_size: Union[int, float], keys: Tuple[Callable[[Any], Any], ...], tuple_suffixes: Optional[SearchStrategy]) -> None: ...
    def do_draw(self, data: Any) -> List[Any]: ...

class UniqueSampledListStrategy(UniqueListStrategy):
    def do_draw(self, data: Any) -> List[Any]: ...

class FixedKeysDictStrategy(MappedStrategy):
    keys: Tuple[Any, ...]
    mapped_strategy: TupleStrategy
    def __init__(self, strategy_dict: Dict[Any, SearchStrategy]) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def __repr__(self) -> str: ...

class FixedAndOptionalKeysDictStrategy(SearchStrategy):
    required: Dict[Any, SearchStrategy]
    fixed: FixedKeysDictStrategy
    optional: Dict[Any, SearchStrategy]
    def __init__(self, strategy_dict: Dict[Any, SearchStrategy], optional: Dict[Any, SearchStrategy]) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def __repr__(self) -> str: ...
    def do_draw(self, data: Any) -> Dict[Any, Any]: ...