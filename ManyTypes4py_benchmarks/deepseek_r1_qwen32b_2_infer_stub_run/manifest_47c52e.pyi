    def add_disabled_nofile(self, node: GraphMemberNode) -> None: ...
    def add_disabled(self, source_file: Any, node: GraphMemberNode, test_from: Optional[str] = None) -> None: ...
    def add_doc(self, source_file: Any, doc: Documentation) -> None: ...
    def add_semantic_model(self, source_file: Any, semantic_model: SemanticModel) -> None: ...
    def add_unit_test(self, source_file: Any, unit_test: UnitTestDefinition) -> None: ...
