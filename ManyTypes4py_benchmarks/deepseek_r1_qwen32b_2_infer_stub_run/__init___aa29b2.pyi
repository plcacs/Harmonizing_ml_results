from typing import List, Tuple, Union, Optional, overload
from numbers import Number

class Matrix:
    _ : List[List[Number]]
    nRows: int
    nCols: int

    def __init__(self, nRows: int, nCols: int, elements: List[List[Number]] = ...) -> None: ...

    def __matmul__(self, other: Matrix) -> Matrix: ...
    def __imatmul__(self, other: Matrix) -> Matrix: ...

    @overload
    def __mul__(self, other: Matrix) -> Matrix: ...
    @overload
    def __mul__(self, other: Number) -> Matrix: ...

    def __rmul__(self, scalar: Number) -> Matrix: ...
    def __imul__(self, other: Union[Matrix, Number]) -> Matrix: ...

    def __add__(self, other: Matrix) -> Matrix: ...
    def __getitem__(self, index: int) -> List[Number]: ...
    def __setitem__(self, index: int, value: List[Number]) -> None: ...
    def __repr__(self) -> str: ...

    def __floordiv__(self, other: Matrix) -> str: ...
    def __truediv__(self, other: Matrix) -> str: ...

class Functor:
    factor: Number

    def __init__(self, factor: Number) -> None: ...

    def __call__(self, x: Number, y: Number = ..., *args: Number, m: Number = ..., n: Number, **kwargs: Number) -> Tuple[Number, Number, List[Number], Number, Number]: ...

def g(x: Number, y: Number = ..., *args: Number, m: Number = ..., n: Number, **kwargs: Number) -> Tuple[Number, Number, List[Number], Number, Number]: ...

def run(autoTester: object) -> None: ...

class Bitwise:
    def __lshift__(self, other: object) -> None: ...
    def __rlshift__(self, other: object) -> None: ...
    def __rshift__(self, other: object) -> None: ...
    def __rrshift__(self, other: object) -> None: ...
    def __or__(self, other: object) -> None: ...
    def __ror__(self, other: object) -> None: ...
    def __xor__(self, other: object) -> None: ...
    def __rxor__(self, other: object) -> None: ...
    def __and__(self, other: object) -> None: ...
    def __rand__(self, other: object) -> None: ...

f: Functor