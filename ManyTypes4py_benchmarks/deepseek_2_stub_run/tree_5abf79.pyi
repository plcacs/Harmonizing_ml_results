```python
from typing import Any, Optional, Tuple, Union
from abc import abstractmethod, abstractproperty

def search_ancestor(node: Any, *node_types: Any) -> Any: ...

class NodeOrLeaf:
    parent: Optional[Any]
    
    def get_root_node(self) -> Any: ...
    def get_next_sibling(self) -> Optional[Any]: ...
    def get_previous_sibling(self) -> Optional[Any]: ...
    def get_previous_leaf(self) -> Optional[Any]: ...
    def get_next_leaf(self) -> Optional[Any]: ...
    
    @abstractproperty
    def start_pos(self) -> Tuple[int, int]: ...
    
    @abstractproperty
    def end_pos(self) -> Tuple[int, int]: ...
    
    @abstractmethod
    def get_start_pos_of_prefix(self) -> Tuple[int, int]: ...
    
    @abstractmethod
    def get_first_leaf(self) -> Any: ...
    
    @abstractmethod
    def get_last_leaf(self) -> Any: ...
    
    @abstractmethod
    def get_code(self, include_prefix: bool = ...) -> str: ...
    
    def search_ancestor(self, *node_types: Any) -> Any: ...
    
    def dump(self, *, indent: Union[int, str, None] = ...) -> str: ...

class Leaf(NodeOrLeaf):
    value: str
    line: int
    column: int
    prefix: str
    
    def __init__(self, value: str, start_pos: Tuple[int, int], prefix: str = ...) -> None: ...
    
    @property
    def start_pos(self) -> Tuple[int, int]: ...
    
    @start_pos.setter
    def start_pos(self, value: Tuple[int, int]) -> None: ...
    
    def get_start_pos_of_prefix(self) -> Tuple[int, int]: ...
    
    def get_first_leaf(self) -> Any: ...
    
    def get_last_leaf(self) -> Any: ...
    
    def get_code(self, include_prefix: bool = ...) -> str: ...
    
    @property
    def end_pos(self) -> Tuple[int, int]: ...
    
    def __repr__(self) -> str: ...

class TypedLeaf(Leaf):
    type: str
    
    def __init__(self, type: str, value: str, start_pos: Tuple[int, int], prefix: str = ...) -> None: ...

class BaseNode(NodeOrLeaf):
    children: Any
    
    def __init__(self, children: Any) -> None: ...
    
    @property
    def start_pos(self) -> Tuple[int, int]: ...
    
    def get_start_pos_of_prefix(self) -> Tuple[int, int]: ...
    
    @property
    def end_pos(self) -> Tuple[int, int]: ...
    
    def get_code(self, include_prefix: bool = ...) -> str: ...
    
    def get_leaf_for_position(self, position: Tuple[int, int], include_prefixes: bool = ...) -> Optional[Any]: ...
    
    def get_first_leaf(self) -> Any: ...
    
    def get_last_leaf(self) -> Any: ...
    
    def __repr__(self) -> str: ...

class Node(BaseNode):
    type: str
    
    def __init__(self, type: str, children: Any) -> None: ...
    
    def __repr__(self) -> str: ...

class ErrorNode(BaseNode):
    type: str = ...

class ErrorLeaf(Leaf):
    token_type: Any
    type: str = ...
    
    def __init__(self, token_type: Any, value: str, start_pos: Tuple[int, int], prefix: str = ...) -> None: ...
    
    def __repr__(self) -> str: ...
