from collections.abc import Iterable
from typing import (
    Any,
    Callable,
    Dict,
    Iterable,
    List,
    Optional,
    Tuple,
    TypeVar,
    Union,
    overload,
)
from hypothesis.internal.conjecture.utils import LazySequenceCopy
from hypothesis.strategies._internal.strategies import (
    Ex,
    MappedStrategy,
    SearchStrategy,
    T,
    T3,
    T4,
    T5,
)

T = TypeVar("T")
T3 = TypeVar("T3")
T4 = TypeVar("T4")
T5 = TypeVar("T5")
Ex = TypeVar("Ex")

class TupleStrategy(SearchStrategy):
    def __init__(self, strategies: tuple[SearchStrategy, ...]) -> None: ...
    def do_validate(self) -> None: ...
    def calc_label(self) -> str: ...
    def __repr__(self) -> str: ...
    def calc_has_reusable_values(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def do_draw(self, data: cu.Data) -> tuple[Any, ...]: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...

@overload
def tuples() -> TupleStrategy: ...
@overload
def tuples(__a1: SearchStrategy) -> TupleStrategy: ...
@overload
def tuples(__a1: SearchStrategy, __a2: SearchStrategy) -> TupleStrategy: ...
@overload
def tuples(__a1: SearchStrategy, __a2: SearchStrategy, __a3: SearchStrategy) -> TupleStrategy: ...
@overload
def tuples(__a1: SearchStrategy, __a2: SearchStrategy, __a3: SearchStrategy, __a4: SearchStrategy) -> TupleStrategy: ...
@overload
def tuples(__a1: SearchStrategy, __a2: SearchStrategy, __a3: SearchStrategy, __a4: SearchStrategy, __a5: SearchStrategy) -> TupleStrategy: ...
@overload
def tuples(*args: SearchStrategy) -> TupleStrategy: ...

@cacheable
@defines_strategy()
def tuples(*args: SearchStrategy) -> TupleStrategy: ...

class ListStrategy(SearchStrategy):
    def __init__(self, elements: SearchStrategy, min_size: int = 0, max_size: Union[int, float] = float('inf')) -> None: ...
    def calc_label(self) -> str: ...
    def do_validate(self) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def do_draw(self, data: cu.Data) -> list[Any]: ...
    def __repr__(self) -> str: ...
    def filter(self, condition: Union[Callable[[Any], bool], type]) -> Union[SearchStrategy, Self]: ...

class UniqueListStrategy(ListStrategy):
    def __init__(self, elements: SearchStrategy, min_size: int, max_size: Union[int, float], keys: tuple[Callable[[Any], Any], ...], tuple_suffixes: Optional[SearchStrategy]) -> None: ...
    def do_draw(self, data: cu.Data) -> list[Any]: ...

class UniqueSampledListStrategy(UniqueListStrategy):
    def do_draw(self, data: cu.Data) -> list[Any]: ...

class FixedKeysDictStrategy(MappedStrategy):
    def __init__(self, strategy_dict: dict[str, SearchStrategy]) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def __repr__(self) -> str: ...

class FixedAndOptionalKeysDictStrategy(SearchStrategy):
    def __init__(self, strategy_dict: dict[str, SearchStrategy], optional: dict[str, SearchStrategy]) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy], bool]) -> bool: ...
    def __repr__(self) -> str: ...
    def do_draw(self, data: cu.Data) -> dict[str, Any]: ...