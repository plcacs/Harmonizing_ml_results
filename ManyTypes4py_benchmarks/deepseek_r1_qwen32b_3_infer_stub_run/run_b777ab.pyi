@functools.total_ordering
class BiggestName(str):
    def __lt__(self, other: Any) -> bool: ...
    def __eq__(self, other: Any) -> bool: ...

def _hook_list() -> List[Any]: ...

def get_hooks_by_tags(nodes: Iterable[Any], match_tags: Set[str]) -> List[dbt.contracts.graph.nodes.HookNode]: ...

def get_hook(source: str, index: int) -> dbt.artifacts.resources.Hook: ...

def get_execution_status(sql: str, adapter: dbt.adapters.base.BaseAdapter) -> Tuple[dbt.artifacts.schemas.results.RunStatus, str]: ...

def _get_adapter_info(adapter: Optional[dbt.adapters.base.BaseAdapter], run_model_result: dbt.artifacts.schemas.results.RunModelResult) -> Dict[str, Any]: ...

def track_model_run(index: int, num_nodes: int, run_model_result: dbt.artifacts.schemas.results.RunResult, adapter: Optional[dbt.adapters.base.BaseAdapter] = None) -> None: ...

def _validate_materialization_relations_dict(inp: Dict[str, Any], model: dbt.contracts.graph.nodes.ModelNode) -> List[dbt.adapters.base.BaseRelation]: ...

class ModelRunner(dbt.task.compile.CompileRunner):
    def get_node_representation(self) -> str: ...
    def describe_node(self) -> str: ...
    def print_start_line(self) -> None: ...
    def print_result_line(self, result: dbt.artifacts.schemas.results.RunResult) -> None: ...
    def before_execute(self) -> None: ...
    def after_execute(self, result: dbt.artifacts.schemas.results.RunResult) -> None: ...
    def _build_run_model_result(self, model: dbt.contracts.graph.nodes.ModelNode, context: Dict[str, Any], elapsed_time: float = 0.0) -> dbt.artifacts.schemas.results.RunResult: ...
    def _materialization_relations(self, result: Any, model: dbt.contracts.graph.nodes.ModelNode) -> List[dbt.adapters.base.BaseRelation]: ...
    def _execute_model(self, hook_ctx: Any, context_config: Dict[str, Any], model: dbt.contracts.graph.nodes.ModelNode, context: Dict[str, Any], materialization_macro: dbt_common.clients.jinja.MacroProtocol) -> dbt.artifacts.schemas.results.RunResult: ...
    def execute(self, model: dbt.contracts.graph.nodes.ModelNode, manifest: dbt.contracts.graph.manifest.Manifest) -> dbt.artifacts.schemas.results.RunResult: ...

class MicrobatchModelRunner(ModelRunner):
    def __init__(self, config: dbt.config.RuntimeConfig, adapter: dbt.adapters.base.BaseAdapter, node: dbt.contracts.graph.nodes.ModelNode, node_index: int, num_nodes: int) -> None: ...
    def compile(self, manifest: dbt.contracts.graph.manifest.Manifest) -> dbt.contracts.graph.nodes.ModelNode: ...
    def set_batch_idx(self, batch_idx: int) -> None: ...
    def set_relation_exists(self, relation_exists: bool) -> None: ...
    def set_batches(self, batches: Dict[int, Tuple[Any, Any]]) -> None: ...
    @property
    def batch_start(self) -> Optional[Any]: ...
    def describe_node(self) -> str: ...
    def describe_batch(self) -> str: ...
    def print_batch_result_line(self, result: dbt.artifacts.schemas.results.RunResult) -> None: ...
    def print_batch_start_line(self) -> None: ...
    def before_execute(self) -> None: ...
    def after_execute(self, result: dbt.artifacts.schemas.results.RunResult) -> None: ...
    def merge_batch_results(self, result: dbt.artifacts.schemas.results.RunResult, batch_results: List[dbt.artifacts.schemas.results.RunResult]) -> None: ...
    def on_skip(self) -> dbt.artifacts.schemas.results.RunResult: ...
    def _build_succesful_run_batch_result(self, model: dbt.contracts.graph.nodes.ModelNode, context: Dict[str, Any], batch: Tuple[Any, Any], elapsed_time: float = 0.0) -> dbt.artifacts.schemas.results.RunResult: ...
    def _build_failed_run_batch_result(self, model: dbt.contracts.graph.nodes.ModelNode, batch: Tuple[Any, Any], elapsed_time: float = 0.0) -> dbt.artifacts.schemas.results.RunResult: ...
    def _build_run_microbatch_model_result(self, model: dbt.contracts.graph.nodes.ModelNode) -> dbt.artifacts.schemas.results.RunResult: ...
    def _execute_microbatch_materialization(self, model: dbt.contracts.graph.nodes.ModelNode, context: Dict[str, Any], materialization_macro: dbt_common.clients.jinja.MacroProtocol) -> dbt.artifacts.schemas.results.RunResult: ...
    def _has_relation(self, model: dbt.contracts.graph.nodes.ModelNode) -> bool: ...
    def should_run_in_parallel(self) -> bool: ...
    def _is_incremental(self, model: dbt.contracts.graph.nodes.ModelNode) -> bool: ...
    def _execute_model(self, hook_ctx: Any, context_config: Dict[str, Any], model: dbt.contracts.graph.nodes.ModelNode, context: Dict[str, Any], materialization_macro: dbt_common.clients.jinja.MacroProtocol) -> dbt.artifacts.schemas.results.RunResult: ...

class RunTask(dbt.task.compile.CompileTask):
    def __init__(self, args: dbt.cli.flags.Flags, config: dbt.config.RuntimeConfig, manifest: dbt.contracts.graph.manifest.Manifest, batch_map: Optional[Dict[str, Any]] = None) -> None: ...
    def raise_on_first_error(self) -> bool: ...
    def get_hook_sql(self, adapter: dbt.adapters.base.BaseAdapter, hook: dbt.contracts.graph.nodes.HookNode, idx: int, num_hooks: int, extra_context: Dict[str, Any]) -> str: ...
    def handle_job_queue(self, pool: ThreadPool, callback: Any) -> None: ...
    def handle_microbatch_model(self, runner: MicrobatchModelRunner, pool: ThreadPool) -> dbt.artifacts.schemas.results.RunResult: ...
    def _submit_batch(self, node: dbt.contracts.graph.nodes.ModelNode, adapter: dbt.adapters.base.BaseAdapter, relation_exists: bool, batches: Dict[int, Tuple[Any, Any]], batch_idx: int, batch_results: List[dbt.artifacts.schemas.results.RunResult], pool: ThreadPool, force_sequential_run: bool = False, skip: bool = False) -> bool: ...
    def _hook_keyfunc(self, hook: dbt.contracts.graph.nodes.HookNode) -> Tuple[Union[str, BiggestName], int]: ...
    def get_hooks_by_type(self, hook_type: dbt.node_types.RunHookType) -> List[dbt.contracts.graph.nodes.HookNode]: ...
    def safe_run_hooks(self, adapter: dbt.adapters.base.BaseAdapter, hook_type: dbt.node_types.RunHookType, extra_context: Dict[str, Any]) -> dbt.artifacts.schemas.results.RunStatus: ...
    def print_results_line(self, results: List[dbt.artifacts.schemas.results.RunResult], execution_time: Optional[float]) -> None: ...
    def populate_microbatch_batches(self, selected_uids: Iterable[str]) -> None: ...
    def before_run(self, adapter: dbt.adapters.base.BaseAdapter, selected_uids: Iterable[str]) -> dbt.artifacts.schemas.results.RunStatus: ...
    def after_run(self, adapter: dbt.adapters.base.BaseAdapter, results: List[dbt.artifacts.schemas.results.RunResult]) -> None: ...
    def get_node_selector(self) -> dbt.graph.ResourceTypeSelector: ...
    def get_runner_type(self, node: dbt.contracts.graph.nodes.ModelNode) -> Type[Union[ModelRunner, MicrobatchModelRunner]]: ...
    def task_end_messages(self, results: List[dbt.artifacts.schemas.results.RunResult]) -> None: ...