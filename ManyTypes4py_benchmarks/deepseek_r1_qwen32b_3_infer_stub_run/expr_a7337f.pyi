"""
:func:`~pandas.eval` parsers.
"""

from __future__ import annotations
import ast
from functools import partial, reduce
from keyword import iskeyword
import tokenize
from typing import (
    Any,
    Callable,
    ClassVar,
    FrozenSet,
    Generic,
    Iterable,
    List,
    Optional,
    Tuple,
    Type,
    TypeVar,
    Union,
    overload,
)
import numpy as np
from pandas.core.dtypes.common import is_string_dtype
from pandas.core.common import flatten
from pandas.core.computation.scope import Scope
from pandas.core.computation.ops import (
    ARITH_OPS_SYMS,
    BinOp,
    Constant,
    FuncNode,
    Op,
    Term,
    UnaryOp,
    is_term,
)
from pandas.io.formats.printing import pprint_thing

_T = TypeVar("_T")

def _preparse(source: str, f: Callable = ...) -> str: ...

class BaseExprVisitor(ast.NodeVisitor, Generic[_T]):
    const_type: ClassVar[Type[Constant]] = ...
    term_type: ClassVar[Type[Term]] = ...
    binary_ops: ClassVar[Tuple[str, ...]] = ...
    binary_op_nodes: ClassVar[Tuple[str, ...]] = ...
    unary_ops: ClassVar[Tuple[str, ...]] = ...
    unary_op_nodes: ClassVar[Tuple[str, ...]] = ...
    rewrite_map: ClassVar[dict[Type[ast.AST], Type[ast.AST]]] = ...

    def __init__(self, env: Scope, engine: str, parser: str, preparser: Callable = ...) -> None: ...

    def visit(self, node: Union[str, ast.AST], **kwargs: Any) -> Union[Term, Op]: ...
    def visit_Module(self, node: ast.Module, **kwargs: Any) -> Union[Term, Op]: ...
    def visit_Expr(self, node: ast.Expr, **kwargs: Any) -> Union[Term, Op]: ...
    def visit_BinOp(self, node: ast.BinOp, **kwargs: Any) -> Union[Term, Op]: ...
    def visit_UnaryOp(self, node: ast.UnaryOp, **kwargs: Any) -> Union[Term, Op]: ...
    def visit_Name(self, node: ast.Name, **kwargs: Any) -> Term: ...
    def visit_NameConstant(self, node: ast.NameConstant, **kwargs: Any) -> Constant: ...
    def visit_Num(self, node: ast.Num, **kwargs: Any) -> Constant: ...
    def visit_Constant(self, node: ast.Constant, **kwargs: Any) -> Constant: ...
    def visit_Str(self, node: ast.Str, **kwargs: Any) -> Term: ...
    def visit_List(self, node: ast.List, **kwargs: Any) -> Term: ...
    visit_Tuple: Callable[[ast.Tuple, Any], Term] = ...
    def visit_Index(self, node: ast.Index, **kwargs: Any) -> Term: ...
    def visit_Subscript(self, node: ast.Subscript, **kwargs: Any) -> Term: ...
    def visit_Slice(self, node: ast.Slice, **kwargs: Any) -> slice: ...
    def visit_Assign(self, node: ast.Assign, **kwargs: Any) -> Union[Term, Op]: ...
    def visit_Attribute(self, node: ast.Attribute, **kwargs: Any) -> Term: ...
    def visit_Call(self, node: ast.Call, side: Optional[str] = ..., **kwargs: Any) -> Term: ...
    def visit_Compare(self, node: ast.Compare, **kwargs: Any) -> Union[Term, Op]: ...
    def visit_BoolOp(self, node: ast.BoolOp, **kwargs: Any) -> Union[Term, Op]: ...

class PandasExprVisitor(BaseExprVisitor):
    def __init__(self, env: Scope, engine: str, parser: str, preparser: Callable = ...) -> None: ...

class PythonExprVisitor(BaseExprVisitor):
    def __init__(self, env: Scope, engine: str, parser: str, preparser: Callable = ...) -> None: ...

class Expr:
    """
    Object encapsulating an expression.
    """
    def __init__(self, expr: str, engine: str = ..., parser: str = ..., env: Optional[Scope] = ..., level: int = ...) -> None: ...
    assigner: Optional[str] = ...
    terms: Union[Term, List[Term]] = ...

    def __call__(self) -> Union[Term, List[Term]]: ...
    def __repr__(self) -> str: ...
    def __len__(self) -> int: ...
    def parse(self) -> Union[Term, List[Term]]: ...
    @property
    def names(self) -> FrozenSet[str]: ...

PARSERS: dict[str, Type[BaseExprVisitor]] = ...