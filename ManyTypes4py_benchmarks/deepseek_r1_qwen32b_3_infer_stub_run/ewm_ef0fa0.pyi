class ExponentialMovingWindow:
    _deltas: npt.NDArray[np.float64]
    _com: float

    def __init__(self, obj: pd.NDFrame, com: Optional[float] = None, span: Optional[float] = None, halflife: Optional[Union[float, str, datetime.timedelta, np.timedelta64]] = None, alpha: Optional[float] = None, min_periods: int = 0, adjust: bool = True, ignore_na: bool = False, times: Optional[Union[np.ndarray, ABCSeries]] = None, method: str = 'single', *, selection: Optional[Any] = None) -> None: ...

    def aggregate(self, func: Optional[Union[str, Callable]] = None, *args: Any, **kwargs: Any) -> Union[Series, DataFrame]: ...
    agg: Callable[..., Union[Series, DataFrame]] = aggregate

    def mean(self, numeric_only: bool = False, engine: Optional[str] = None, engine_kwargs: Optional[Dict[str, Any]] = None) -> Union[Series, DataFrame]: ...
    def sum(self, numeric_only: bool = False, engine: Optional[str] = None, engine_kwargs: Optional[Dict[str, Any]] = None) -> Union[Series, DataFrame]: ...
    def std(self, bias: bool = False, numeric_only: bool = False) -> Union[Series, DataFrame]: ...
    def var(self, bias: bool = False, numeric_only: bool = False) -> Union[Series, DataFrame]: ...
    def cov(self, other: Optional[Union[Series, DataFrame]] = None, pairwise: Optional[bool] = None, bias: bool = False, numeric_only: bool = False) -> Union[Series, DataFrame]: ...
    def corr(self, other: Optional[Union[Series, DataFrame]] = None, pairwise: Optional[bool] = None, numeric_only: bool = False) -> Union[Series, DataFrame]: ...

    def _get_window_indexer(self) -> BaseIndexer: ...
    def online(self, engine: str = 'numba', engine_kwargs: Optional[Dict[str, Any]] = None) -> 'OnlineExponentialMovingWindow': ...

