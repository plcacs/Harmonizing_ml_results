from __future__ import annotations
from typing import Any, Callable, Optional, Union, List, Dict, Match, overload
from pypinyin.style import Style

class Converter:
    def convert(self, words: str, style: Style, heteronym: bool, errors: str, strict: bool, **kwargs: Any) -> List[List[str]]: ...
    def __init__(self, **kwargs: Any) -> None: ...

class DefaultConverter(Converter):
    def __init__(self, **kwargs: Any) -> None: ...
    def convert(self, words: str, style: Style, heteronym: bool, errors: str, strict: bool, **kwargs: Any) -> List[List[str]]: ...
    def pre_convert_style(self, han: str, orig_pinyin: str, style: Style, strict: bool, **kwargs: Any) -> Optional[str]: ...
    def convert_style(self, han: str, orig_pinyin: str, style: Style, strict: bool, **kwargs: Any) -> str: ...
    def post_convert_style(self, han: str, orig_pinyin: str, converted_pinyin: str, style: Style, strict: bool, **kwargs: Any) -> Optional[str]: ...
    def pre_handle_nopinyin(self, chars: str, style: Style, heteronym: bool, errors: str, strict: bool, **kwargs: Any) -> Optional[Union[str, List[str], List[List[str]]]]: ...
    def handle_nopinyin(self, chars: str, style: Style, heteronym: bool, errors: str, strict: bool, **kwargs: Any) -> List[List[str]]: ...
    def post_handle_nopinyin(self, chars: str, style: Style, heteronym: bool, errors: str, strict: bool, pinyin: List[List[str]], **kwargs: Any) -> Optional[List[List[str]]]: ...
    def post_pinyin(self, han: str, heteronym: bool, pinyin: List[List[str]], **kwargs: Any) -> Optional[List[List[str]]]: ...
    def _phrase_pinyin(self, phrase: str, style: Style, heteronym: bool, errors: str, strict: bool) -> List[List[str]]: ...
    def convert_styles(self, pinyin_list: List[List[str]], phrase: str, style: Style, heteronym: bool, errors: str, strict: bool, **kwargs: Any) -> List[List[str]]: ...
    def _single_pinyin(self, han: str, style: Style, heteronym: bool, errors: str, strict: bool) -> List[List[str]]: ...
    def _convert_style(self, han: str, pinyin: str, style: Style, strict: bool, default: str, **kwargs: Any) -> str: ...
    def _convert_nopinyin_chars(self, chars: str, style: Style, heteronym: bool, errors: str, strict: bool) -> Optional[str]: ...

class _v2UConverter(V2UMixin, DefaultConverter): ...

class _neutralToneWith5Converter(NeutralToneWith5Mixin, DefaultConverter): ...

class _toneSandhiConverter(ToneSandhiMixin, DefaultConverter): ...

class UltimateConverter(DefaultConverter):
    def __init__(self, v_to_u: bool = False, neutral_tone_with_five: bool = False, tone_sandhi: bool = False, **kwargs: Any) -> None: ...
    def post_convert_style(self, han: str, orig_pinyin: str, converted_pinyin: str, style: Style, strict: bool, **kwargs: Any) -> str: ...
    def post_pinyin(self, han: str, heteronym: bool, pinyin: List[List[str]], **kwargs: Any) -> Optional[List[List[str]]]: ...

_mixConverter: type[UltimateConverter] = UltimateConverter

# Imported constants from other modules
PHRASES_DICT: Dict[str, List[List[str]]]
PINYIN_DICT: Dict[int, str]
RE_HANS: Any  # Pattern object from re module