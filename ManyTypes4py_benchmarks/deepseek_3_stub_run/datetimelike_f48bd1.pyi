"""
Base and utility classes for tseries type pandas objects.
"""
from __future__ import annotations
from abc import ABC, abstractmethod
from typing import TYPE_CHECKING, Any, Union, Optional, overload
import numpy as np
from pandas._libs import NaT, Timedelta
from pandas._libs.tslibs import BaseOffset, Resolution, Tick
from pandas.core.arrays import DatetimeArray, ExtensionArray, PeriodArray, TimedeltaArray
from pandas.core.arrays.datetimelike import DatetimeLikeArrayMixin
from pandas.core.indexes.base import Index
from pandas.core.indexes.extension import NDArrayBackedExtensionIndex
from pandas.core.indexes.range import RangeIndex

if TYPE_CHECKING:
    from collections.abc import Sequence
    from datetime import datetime
    from pandas._typing import Axis, JoinHow, Self, npt
    from pandas import CategoricalIndex

class DatetimeIndexOpsMixin(NDArrayBackedExtensionIndex, ABC):
    _can_hold_strings: bool = ...
    
    def mean(self, *, skipna: bool = ..., axis: Axis = ...) -> Any: ...
    
    @property
    def freq(self) -> Optional[BaseOffset]: ...
    
    @freq.setter
    def freq(self, value: Optional[BaseOffset]) -> None: ...
    
    @property
    def asi8(self) -> npt.NDArray[np.int64]: ...
    
    @property
    def freqstr(self) -> Optional[str]: ...
    
    @cache_readonly
    @abstractmethod
    def _resolution_obj(self) -> Resolution: ...
    
    @cache_readonly
    def resolution(self) -> str: ...
    
    @cache_readonly
    def hasnans(self) -> bool: ...
    
    def equals(self, other: Any) -> bool: ...
    
    def __contains__(self, key: Any) -> bool: ...
    
    def _convert_tolerance(self, tolerance: Any, target: Any) -> Any: ...
    
    _default_na_rep: str = ...
    
    def _format_with_header(self, *, header: list[str], na_rep: str, date_format: Optional[str] = ...) -> list[str]: ...
    
    @property
    def _formatter_func(self) -> Any: ...
    
    def _format_attrs(self) -> list[tuple[str, Optional[str]]]: ...
    
    def _summary(self, name: Optional[str] = ...) -> str: ...
    
    def _can_partial_date_slice(self, reso: Resolution) -> bool: ...
    
    def _parsed_string_to_bounds(self, reso: Resolution, parsed: datetime) -> tuple[Any, Any]: ...
    
    def _parse_with_reso(self, label: Union[str, np.str_]) -> tuple[datetime, Resolution]: ...
    
    def _get_string_slice(self, key: str) -> Union[slice, npt.NDArray[np.intp]]: ...
    
    def _partial_date_slice(self, reso: Resolution, parsed: datetime) -> Union[slice, npt.NDArray[np.intp]]: ...
    
    def _maybe_cast_slice_bound(self, label: Any, side: str) -> Any: ...
    
    def shift(self, periods: int = ..., freq: Optional[Union[str, BaseOffset]] = ...) -> Any: ...
    
    def _maybe_cast_listlike_indexer(self, keyarr: Any) -> Index: ...

class DatetimeTimedeltaMixin(DatetimeIndexOpsMixin, ABC):
    _comparables: list[str] = ...
    _attributes: list[str] = ...
    _is_monotonic_increasing: bool = ...
    _is_monotonic_decreasing: bool = ...
    _is_unique: bool = ...
    
    @property
    def unit(self) -> str: ...
    
    def as_unit(self, unit: str) -> Self: ...
    
    def _with_freq(self, freq: Optional[BaseOffset]) -> Self: ...
    
    @property
    def values(self) -> npt.NDArray[Any]: ...
    
    def shift(self, periods: int = ..., freq: Optional[Union[str, BaseOffset]] = ...) -> Self: ...
    
    @cache_readonly
    def inferred_freq(self) -> Optional[str]: ...
    
    @cache_readonly
    def _as_range_index(self) -> RangeIndex: ...
    
    def _can_range_setop(self, other: Any) -> bool: ...
    
    def _wrap_range_setop(self, other: Any, res_i8: Any) -> Self: ...
    
    def _range_intersect(self, other: Self, sort: bool) -> Self: ...
    
    def _range_union(self, other: Self, sort: bool) -> Self: ...
    
    def _intersection(self, other: Index, sort: bool = ...) -> Self: ...
    
    def _fast_intersect(self, other: Self, sort: bool) -> Self: ...
    
    def _can_fast_intersect(self, other: Self) -> bool: ...
    
    def _can_fast_union(self, other: Self) -> bool: ...
    
    def _fast_union(self, other: Self, sort: Optional[bool] = ...) -> Self: ...
    
    def _union(self, other: Index, sort: bool) -> Self: ...
    
    def _get_join_freq(self, other: Self) -> Optional[BaseOffset]: ...
    
    def _wrap_join_result(self, joined: Any, other: Index, lidx: npt.NDArray[np.intp], ridx: npt.NDArray[np.intp], how: JoinHow) -> tuple[Self, npt.NDArray[np.intp], npt.NDArray[np.intp]]: ...
    
    def _get_engine_target(self) -> npt.NDArray[np.int64]: ...
    
    def _from_join_target(self, result: npt.NDArray[np.int64]) -> Union[DatetimeArray, TimedeltaArray]: ...
    
    def _get_delete_freq(self, loc: Union[int, slice, Sequence[int]]) -> Optional[BaseOffset]: ...
    
    def _get_insert_freq(self, loc: int, item: Any) -> Optional[BaseOffset]: ...
    
    def delete(self, loc: Union[int, Sequence[int]]) -> Self: ...
    
    def insert(self, loc: int, item: Any) -> Self: ...
    
    def take(self, indices: Union[Sequence[int], npt.NDArray[np.intp]], axis: Axis = ..., allow_fill: bool = ..., fill_value: Any = ..., **kwargs: Any) -> Self: ...