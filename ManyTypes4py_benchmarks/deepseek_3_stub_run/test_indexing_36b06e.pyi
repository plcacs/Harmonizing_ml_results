    def test_get_loc_scalar(self, closed: str, scalar: float) -> None: ...
    
    @pytest.mark.parametrize('scalar', [-1, 0, 0.5, 3, 4.5, 5, 6])
    def test_get_loc_length_one_scalar(self, scalar: float, closed: str) -> None: ...
    
