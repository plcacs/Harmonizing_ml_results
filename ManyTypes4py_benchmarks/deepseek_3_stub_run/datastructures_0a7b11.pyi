class Address(typing.NamedTuple):
    pass

class URL:
    def __init__(
        self,
        url: str = "",
        scope: Optional[Scope] = None,
        **components: str
    ) -> None: ...
    @property
    def components(self) -> SplitResult: ...
    @property
    def scheme(self) -> str: ...
    @property
    def netloc(self) -> str: ...
    @property
    def path(self) -> str: ...
    @property
    def query(self) -> str: ...
    @property
    def fragment(self) -> str: ...
    @property
    def username(self) -> Optional[str]: ...
    @property
    def password(self) -> Optional[str]: ...
    @property
    def hostname(self) -> Optional[str]: ...
    @property
    def port(self) -> Optional[int]: ...
    @property
    def is_secure(self) -> bool: ...
    def replace(self, **kwargs: str) -> URL: ...
    def include_query_params(self, **kwargs: Union[str, int, float, bool]) -> URL: ...
    def replace_query_params(self, **kwargs: Union[str, int, float, bool]) -> URL: ...
    def remove_query_params(self, keys: Union[str, Sequence[str]]) -> URL: ...
    def __eq__(self, other: object) -> bool: ...
    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...

class URLPath(str):
    def __new__(cls, path: str, protocol: str = "", host: str = "") -> URLPath: ...
    def __init__(self, path: str, protocol: str = "", host: str = "") -> None: ...
    @property
    def protocol(self) -> str: ...
    @property
    def host(self) -> str: ...
    def make_absolute_url(self, base_url: Union[str, URL]) -> URL: ...

