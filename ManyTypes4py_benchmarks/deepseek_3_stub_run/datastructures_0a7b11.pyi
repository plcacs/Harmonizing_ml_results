    def __getitem__(self, key: _KeyType) -> _CovariantValueType: ...
    def __contains__(self, key: object) -> bool: ...
    def __iter__(self) -> Iterator[_KeyType]: ...
    def __len__(self) -> int: ...
    def __eq__(self, other: object) -> bool: ...
    def __repr__(self) -> str: ...

class MultiDict(ImmutableMultiDict[Any, Any]):
    def __setitem__(self, key: Any, value: Any) -> None: ...
    def __delitem__(self, key: Any) -> None: ...
    def pop(self, key: Any, default: Optional[Any] = None) -> Any: ...
    def popitem(self) -> tuple[Any, Any]: ...
    def poplist(self, key: Any) -> list[Any]: ...
    def clear(self) -> None: ...
    def setdefault(self, key: Any, default: Optional[Any] = None) -> Any: ...
    def setlist(self, key: Any, values: Iterable[Any]) -> None: ...
    def append(self, key: Any, value: Any) -> None: ...
    def update(
        self,
        *args: Union[
            Iterable[tuple[Any, Any]],
            Mapping[Any, Any],
            "MultiDict"
        ],
        **kwargs: Any
    ) -> None: ...

class QueryParams(ImmutableMultiDict[str, str]):
    def __init__(
        self,
        *args: Union[str, bytes, Iterable[tuple[str, str]], Mapping[str, str]],
        **kwargs: str
    ) -> None: ...
    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...

class UploadFile:
    def __init__(
        self,
        file: typing.IO[bytes],
        *,
        size: Optional[int] = None,
        filename: Optional[str] = None,
        headers: Optional[Union["Headers", Mapping[str, str]]] = None
    ) -> None: ...
    @property
    def filename(self) -> Optional[str]: ...
    @property
    def file(self) -> typing.IO[bytes]: ...
    @property
    def size(self) -> Optional[int]: ...
    @property
    def headers(self) -> "Headers": ...
    @property
    def content_type(self) -> Optional[str]: ...
    @property
    def _in_memory(self) -> bool: ...
    async def write(self, data: bytes) -> None: ...
    async def read(self, size: int = -1) -> bytes: ...
    async def seek(self, offset: int) -> None: ...
    async def close(self) -> None: ...
    def __repr__(self) -> str: ...

class FormData(ImmutableMultiDict[str, Union[UploadFile, str]]):
    def __init__(
        self,
        *args: Union[
            Iterable[tuple[str, Union[UploadFile, str]]],
            Mapping[str, Union[UploadFile, str]],
            "FormData"
        ],
        **kwargs: Union[UploadFile, str]
    ) -> None: ...
