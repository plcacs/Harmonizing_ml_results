from __future__ import annotations
from typing import Any, Callable, Dict, List, Optional, Union
from sqlalchemy.dialects.postgresql.dialect import PGDialect
from sqlalchemy.engine.interfaces import Dialect
from superset.commands.dataset.exceptions import DatasetNotFoundError
from superset.connectors.sqla.models import SqlaTable, SqlMetric, TableColumn
from superset.exceptions import SupersetTemplateException
from superset.models.core import Database
from superset.models.slice import Slice
from superset.utils import json

class ExtraCache:
    def __init__(
        self,
        dialect: Optional[Dialect] = ...,
        database: Optional[Database] = ...,
        table: Optional[SqlaTable] = ...
    ) -> None: ...
    def filter_values(
        self,
        column: str,
        default: Optional[Union[str, List[str]]] = ...,
        remove_filter: bool = ...
    ) -> List[str]: ...
    @property
    def applied_filters(self) -> List[str]: ...
    @property
    def removed_filters(self) -> List[str]: ...
    def get_filters(
        self,
        column: str,
        remove_filter: bool = ...
    ) -> List[Dict[str, Union[str, List[str]]]]: ...
    def url_param(
        self,
        param: str,
        default: Optional[str] = ...,
        escape_result: bool = ...
    ) -> Optional[str]: ...
    def current_user_id(self, add_to_cache_keys: bool = ...) -> Optional[int]: ...
    def current_username(self, add_to_cache_keys: bool = ...) -> Optional[str]: ...
    def current_user_email(self, add_to_cache_keys: bool = ...) -> Optional[str]: ...
    def cache_key_wrapper(self, *args: Any, **kwargs: Any) -> Any: ...
    def get_time_filter(
        self,
        column: Optional[str] = ...,
        default: Optional[str] = ...,
        target_type: Optional[str] = ...,
        remove_filter: bool = ...,
        strftime: Optional[str] = ...
    ) -> TimeFilter: ...

class WhereInMacro:
    def __init__(self, dialect: Dialect) -> None: ...
    def __call__(self, values: List[Union[int, str]], mark: Optional[str] = ...) -> str: ...

class TimeFilter:
    def __init__(
        self,
        from_expr: Optional[str],
        to_expr: Optional[str],
        time_range: str
    ) -> None: ...
    @property
    def from_expr(self) -> Optional[str]: ...
    @property
    def to_expr(self) -> Optional[str]: ...
    @property
    def time_range(self) -> str: ...

def dataset_macro(
    dataset_id: int,
    include_metrics: bool = ...,
    columns: Optional[List[str]] = ...
) -> str: ...

def metric_macro(
    metric_name: str,
    dataset_id: Optional[int] = ...
) -> str: ...

def safe_proxy(
    func: Callable[..., Any],
    *args: Any,
    **kwargs: Any
) -> Union[str, Dict[str, Any]]: ...