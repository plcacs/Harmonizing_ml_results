class _BoundTypeVarName(AbstractNameDefinition):
    _type_var: "TypeVar"
    parent_context: "ClassContext"
    _value_set: "ValueSet"

    def __init__(self, type_var: "TypeVar", value_set: "ValueSet") -> None: ...
    def infer(self) -> "ValueSet": ...
    def py__name__(self) -> str: ...
    def __repr__(self) -> str: ...

class _TypeVarFilter:
    _generics: Tuple["ValueSet", ...]
    _type_vars: List["TypeVar"]

    def __init__(self, generics: Tuple["ValueSet", ...], type_vars: List["TypeVar"]) -> None: ...
    def get(self, name: str) -> List[Union[_BoundTypeVarName, AbstractNameDefinition]]: ...
    def values(self) -> List[Any]: ...

class _AnnotatedClassContext(ClassContext):
    _value: "GenericClass"

    def get_filters(self, *args: Any, **kwargs: Any) -> Iterator[ClassFilter]: ...

class DefineGenericBaseClass(LazyValueWrapper):
    _generics_manager: "TupleGenericManager"

    def __init__(self, generics_manager: "TupleGenericManager") -> None: ...
    def _create_instance_with_generics(self, generics_manager: "TupleGenericManager") -> "DefineGenericBaseClass": ...
    @inference_state_method_cache()
    def get_generics(self) -> Tuple["ValueSet", ...]: ...
    def define_generics(self, type_var_dict: Dict[str, "ValueSet"]) -> "ValueSet": ...
    def is_same_class(self, other: "BaseValue") -> bool: ...
    def get_signatures(self) -> List["BaseFunction"]: ...
    def __repr__(self) -> str: ...

class GenericClass(DefineGenericBaseClass, ClassMixin):
    _class_value: "ClassValue"

    def __init__(self, class_value: "ClassValue", generics_manager: "TupleGenericManager") -> None: ...
    def _get_wrapped_value(self) -> "ClassValue": ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...
    def get_type_var_filter(self) -> _TypeVarFilter: ...
    def py__call__(self, arguments: "AbstractArguments") -> "ValueSet": ...
    def _as_context(self) -> _AnnotatedClassContext: ...
    @to_list
    def py__bases__(self) -> List["_LazyGenericBaseClass"]: ...
    def _create_instance_with_generics(self, generics_manager: "TupleGenericManager") -> "GenericClass": ...
    def is_sub_class_of(self, class_value: "ClassValue") -> bool: ...
    def with_generics(self, generics_tuple: Tuple["ValueSet", ...]) -> "GenericClass": ...
    def infer_type_vars(self, value_set: "ValueSet") -> Dict[str, "ValueSet"]: ...
    def __repr__(self) -> str: ...

class _LazyGenericBaseClass:
    _class_value: "GenericClass"
    _lazy_base_class: "LazyValue"
    _generics_manager: "TupleGenericManager"

    def __init__(self, class_value: "GenericClass", lazy_base_class: "LazyValue", generics_manager: "TupleGenericManager") -> None: ...
    @iterator_to_value_set
    def infer(self) -> Iterator[Union["GenericClass", "ClassValue", "BaseValue"]]: ...
    def _remap_type_vars(self, base: "GenericClass") -> Iterator["ValueSet"]: ...
    def __repr__(self) -> str: ...

class _GenericInstanceWrapper(ValueWrapper):
    _wrapped_value: "TreeInstance"

    def py__stop_iteration_returns(self) -> "ValueSet": ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...

class _PseudoTreeNameClass(Value):
    api_type: str
    _tree_name: Name

    def __init__(self, parent_context: "ClassContext", tree_name: Name) -> None: ...
    @property
    def tree_node(self) -> Name: ...
    def get_filters(self, *args: Any, **kwargs: Any) -> Iterator[ClassFilter]: ...
    def py__class__(self) -> "CompiledValue": ...
    @property
    def name(self) -> ValueName: ...
    def get_qualified_names(self) -> Tuple[str, ...]: ...
    def __repr__(self) -> str: ...

class BaseTypingValue(LazyValueWrapper):
    inference_state: Any
    parent_context: "ClassContext"
    _tree_name: Name

    def __init__(self, parent_context: "ClassContext", tree_name: Name) -> None: ...
    @property
    def name(self) -> ValueName: ...
    def _get_wrapped_value(self) -> _PseudoTreeNameClass: ...
    def get_signatures(self) -> List["BaseFunction"]: ...
    def __repr__(self) -> str: ...

class BaseTypingClassWithGenerics(DefineGenericBaseClass):
    inference_state: Any
    parent_context: "ClassContext"
    _tree_name: Name

    def __init__(self, parent_context: "ClassContext", tree_name: Name, generics_manager: "TupleGenericManager") -> None: ...
    def _get_wrapped_value(self) -> _PseudoTreeNameClass: ...
    def __repr__(self) -> str: ...

class BaseTypingInstance(LazyValueWrapper):
    inference_state: Any
    parent_context: "ClassContext"
    _class_value: "BaseTypingClassWithGenerics"
    _tree_name: Name
    _generics_manager: "TupleGenericManager"

    def __init__(self, parent_context: "ClassContext", class_value: "BaseTypingClassWithGenerics", tree_name: Name, generics_manager: "TupleGenericManager") -> None: ...
    def py__class__(self) -> "BaseTypingClassWithGenerics": ...
    def get_annotated_class_object(self) -> "BaseTypingClassWithGenerics": ...
    def get_qualified_names(self) -> Tuple[str, ...]: ...
    @property
    def name(self) -> ValueName: ...
    def _get_wrapped_value(self) -> "CompiledObject": ...
    def __repr__(self) -> str: ...