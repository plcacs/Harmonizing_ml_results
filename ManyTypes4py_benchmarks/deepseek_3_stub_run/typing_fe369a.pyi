from typing import (
    Any, Optional, Union, TypeVar, Generic, Protocol, Callable, 
    Tuple as TypingTuple, ClassVar, overload, cast, TypedDict as TypingTypedDict,
    Iterator, Iterable, Sequence, List, Dict, Set, FrozenSet, 
    ChainMap, Counter, DefaultDict, Deque
)
from jedi.inference.base_value import ValueSet, Value, LazyValueWrapper, ValueWrapper
from jedi.inference.lazy_value import LazyKnownValue
from jedi.inference.arguments import Arguments
from jedi.inference.filters import Filter
from jedi.inference.names import AbstractNameDefinition
from jedi.inference.gradual.base import BaseTypingValue, BaseTypingClassWithGenerics, BaseTypingInstance
from jedi.inference.gradual.type_var import TypeVarClass
from jedi.inference.gradual.generics import GenericManager
from jedi.inference.context import Context
from jedi.inference.value import TreeValue
from jedi.api.interpreter import InferenceState
from jedi.inference.compiled.value import CompiledValue
import sys

_T = TypeVar("_T")
_T_co = TypeVar("_T_co", covariant=True)
_T_contra = TypeVar("_T_contra", contravariant=True)

_PROXY_CLASS_TYPES: List[str] = ...
_PROXY_TYPES: List[str] = ...
_TYPE_ALIAS_TYPES: Dict[str, str] = ...

class TypingModuleName:
    def __init__(self, wrapped_name: AbstractNameDefinition, parent_context: Context, tree_name: Any) -> None: ...
    def infer(self) -> ValueSet: ...
    def _remap(self) -> Iterator[Value]: ...

class TypingModuleFilterWrapper:
    name_wrapper_class: type = ...
    def __init__(self, wrapped_filter: Filter) -> None: ...

class ProxyWithGenerics(BaseTypingClassWithGenerics):
    def execute_annotation(self) -> ValueSet: ...
    def gather_annotation_classes(self) -> ValueSet: ...
    def _create_instance_with_generics(self, generics_manager: GenericManager) -> "ProxyWithGenerics": ...
    def infer_type_vars(self, value_set: ValueSet) -> Dict[TypeVar, ValueSet]: ...

class ProxyTypingValue(BaseTypingValue):
    index_class: type = ...
    def with_generics(self, generics_tuple: Tuple[ValueSet, ...]) -> "ProxyWithGenerics": ...
    def py__getitem__(self, index_value_set: ValueSet, contextualized_node: Any) -> ValueSet: ...

class _TypingClassMixin:
    def py__bases__(self) -> List[LazyKnownValue]: ...
    def get_metaclasses(self) -> List[Value]: ...
    @property
    def name(self) -> AbstractNameDefinition: ...

class TypingClassWithGenerics(ProxyWithGenerics, _TypingClassMixin):
    def infer_type_vars(self, value_set: ValueSet) -> Dict[TypeVar, ValueSet]: ...
    def _create_instance_with_generics(self, generics_manager: GenericManager) -> "TypingClassWithGenerics": ...

class ProxyTypingClassValue(ProxyTypingValue, _TypingClassMixin):
    index_class: type = ...

class TypeAlias(LazyValueWrapper):
    def __init__(self, parent_context: Context, origin_tree_name: Any, actual: str) -> None: ...
    @property
    def name(self) -> AbstractNameDefinition: ...
    def py__name__(self) -> str: ...
    def _get_wrapped_value(self) -> Value: ...
    def gather_annotation_classes(self) -> ValueSet: ...
    def get_signatures(self) -> List[Any]: ...

class Callable(BaseTypingInstance):
    def py__call__(self, arguments: Arguments) -> ValueSet: ...
    def py__get__(self, instance: Optional[Value], class_value: Optional[Value]) -> ValueSet: ...

class Tuple(BaseTypingInstance):
    def _is_homogenous(self) -> bool: ...
    def py__simple_getitem__(self, index: int) -> ValueSet: ...
    def py__iter__(self, contextualized_node: Optional[Any] = None) -> Iterator[LazyKnownValue]: ...
    def py__getitem__(self, index_value_set: ValueSet, contextualized_node: Any) -> ValueSet: ...
    def _get_wrapped_value(self) -> Value: ...
    @property
    def name(self) -> AbstractNameDefinition: ...
    def infer_type_vars(self, value_set: ValueSet) -> Dict[TypeVar, ValueSet]: ...

class Generic(BaseTypingInstance): ...

class Protocol(BaseTypingInstance): ...

class AnyClass(BaseTypingValue):
    def execute_annotation(self) -> ValueSet: ...

class OverloadFunction(BaseTypingValue):
    def py__call__(self, func_value_set: ValueSet) -> ValueSet: ...

class NewTypeFunction(ValueWrapper):
    def py__call__(self, arguments: Arguments) -> ValueSet: ...

class NewType(Value):
    def __init__(self, inference_state: InferenceState, parent_context: Context, tree_node: Any, type_value_set: ValueSet) -> None: ...
    def py__class__(self) -> ValueSet: ...
    def py__call__(self, arguments: Arguments) -> ValueSet: ...
    @property
    def name(self) -> AbstractNameDefinition: ...

class CastFunction(ValueWrapper):
    def py__call__(self, type_value_set: ValueSet, object_value_set: ValueSet) -> ValueSet: ...

class TypedDictClass(BaseTypingValue): ...

class TypedDict(LazyValueWrapper):
    def __init__(self, definition_class: TypedDictClass) -> None: ...
    @property
    def name(self) -> AbstractNameDefinition: ...
    def py__simple_getitem__(self, index: str) -> ValueSet: ...
    def get_key_values(self) -> ValueSet: ...
    def _get_wrapped_value(self) -> Value: ...