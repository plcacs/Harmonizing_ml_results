class Properties(PandasDelegate, PandasObject, NoNewAttributesMixin):
    _hidden_attrs: set[str] = ...
    _parent: Series = ...
    orig: Series | None = ...
    name: Any = ...
    
    def __init__(self, data: Series, orig: Series | None) -> None: ...
    def _get_values(self) -> DatetimeIndex | TimedeltaIndex | PeriodArray: ...
    def _delegate_property_get(self, name: str) -> Any: ...
    def _delegate_property_set(self, name: str, value: Any, *args: Any, **kwargs: Any) -> NoReturn: ...
    def _delegate_method(self, name: str, *args: Any, **kwargs: Any) -> Any: ...

class ArrowTemporalProperties(PandasDelegate, PandasObject, NoNewAttributesMixin):
    _parent: Series = ...
    _orig: Series | None = ...
    
    def __init__(self, data: Series, orig: Series | None) -> None: ...
    def _delegate_property_get(self, name: str) -> Any: ...
    def _delegate_method(self, name: str, *args: Any, **kwargs: Any) -> Any: ...
    def to_pytimedelta(self) -> np.ndarray: ...
    def to_pydatetime(self) -> np.ndarray: ...
    def isocalendar(self) -> DataFrame: ...
    @property
    def components(self) -> DataFrame: ...

class DatetimeProperties(Properties):
    def to_pydatetime(self) -> Series: ...
    @property
    def freq(self) -> str | None: ...
    def isocalendar(self) -> DataFrame: ...

class TimedeltaProperties(Properties):
    def to_pytimedelta(self) -> np.ndarray: ...
    @property
    def components(self) -> DataFrame: ...
    @property
    def freq(self) -> str | None: ...

class PeriodProperties(Properties): ...

class CombinedDatetimelikeProperties(DatetimeProperties, TimedeltaProperties, PeriodProperties):
    @overload
    def __new__(cls, data: Series) -> ArrowTemporalProperties: ...
    @overload
    def __new__(cls, data: Series) -> DatetimeProperties: ...
    @overload
    def __new__(cls, data: Series) -> TimedeltaProperties: ...
    @overload
    def __new__(cls, data: Series) -> PeriodProperties: ...
    def __new__(cls, data: Series) -> ArrowTemporalProperties | DatetimeProperties | TimedeltaProperties | PeriodProperties: ...