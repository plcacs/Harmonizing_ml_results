class BaseExprVisitor(ast.NodeVisitor):
    const_type: ClassVar[type] = ...
    term_type: ClassVar[type] = ...
    binary_ops: ClassVar[tuple[str, ...]] = ...
    binary_op_nodes: ClassVar[tuple[str, ...]] = ...
    binary_op_nodes_map: ClassVar[dict[str, str]] = ...
    unary_ops: ClassVar[tuple[str, ...]] = ...
    unary_op_nodes: ClassVar[tuple[str, ...]] = ...
    unary_op_nodes_map: ClassVar[dict[str, str]] = ...
    rewrite_map: ClassVar[dict[type[ast.AST], type[ast.AST]]] = ...
    unsupported_nodes: tuple[str, ...] = ...
    
    def __init__(
        self,
        env: Scope,
        engine: str,
        parser: str,
        preparser: Callable[[str], str] = ...,
    ) -> None: ...
    def visit(
        self,
        node: str | ast.AST,
        **kwargs: Any,
    ) -> Term | Op | Constant | slice | None: ...
    def visit_Module(self, node: ast.Module, **kwargs: Any) -> Term | Op | Constant | slice | None: ...
    def visit_Expr(self, node: ast.Expr, **kwargs: Any) -> Term | Op | Constant | slice | None: ...
    def _rewrite_membership_op(
        self,
        node: ast.Compare | ast.BinOp,
        left: Term | Constant,
        right: Term | Constant,
    ) -> tuple[Callable, ast.AST, Term | Constant, Term | Constant]: ...
    def _maybe_transform_eq_ne(
        self,
        node: ast.Compare | ast.BinOp,
        left: Term | Constant | None = ...,
        right: Term | Constant | None = ...,
    ) -> tuple[Callable, ast.AST, Term | Constant, Term | Constant]: ...
    def _maybe_downcast_constants(
        self,
        left: Term | Constant,
        right: Term | Constant,
    ) -> tuple[Term | Constant, Term | Constant]: ...
    def _maybe_eval(
        self,
        binop: BinOp,
        eval_in_python: tuple[str, ...],
    ) -> Any: ...
    def _maybe_evaluate_binop(
        self,
        op: Callable,
        op_class: ast.AST,
        lhs: Term | Constant,
        rhs: Term | Constant,
        eval_in_python: tuple[str, ...] = ...,
        maybe_eval_in_python: tuple[str, ...] = ...,
    ) -> Term | Op | Constant: ...
    def visit_BinOp(self, node: ast.BinOp, **kwargs: Any) -> Term | Op | Constant: ...
    def visit_UnaryOp(self, node: ast.UnaryOp, **kwargs: Any) -> UnaryOp: ...
    def visit_Name(self, node: ast.Name, **kwargs: Any) -> Term: ...
    def visit_NameConstant(self, node: ast.NameConstant, **kwargs: Any) -> Constant: ...
    def visit_Num(self, node: ast.Num, **kwargs: Any) -> Constant: ...
    def visit_Constant(self, node: ast.Constant, **kwargs: Any) -> Constant: ...
    def visit_Str(self, node: ast.Str, **kwargs: Any) -> Term: ...
    def visit_List(self, node: ast.List, **kwargs: Any) -> Term: ...
    def visit_Tuple(self, node: ast.Tuple, **kwargs: Any) -> Term: ...
    def visit_Index(self, node: ast.Index, **kwargs: Any) -> Term | Op | Constant | slice | None: ...
    def visit_Subscript(self, node: ast.Subscript, **kwargs: Any) -> Term: ...
    def visit_Slice(self, node: ast.Slice, **kwargs: Any) -> slice: ...
    def visit_Assign(self, node: ast.Assign, **kwargs: Any) -> Term | Op | Constant | slice | None: ...
    def visit_Attribute(self, node: ast.Attribute, **kwargs: Any) -> Term: ...
    def visit_Call(
        self,
        node: ast.Call,
        side: Literal["left", "right"] | None = ...,
        **kwargs: Any,
    ) -> Term: ...
    def translate_In(self, op: ast.AST) -> ast.AST: ...
    def visit_Compare(self, node: ast.Compare, **kwargs: Any) -> Term | Op | Constant: ...
    def _try_visit_binop(self, bop: Op | Term | ast.AST) -> Op | Term: ...
    def visit_BoolOp(self, node: ast.BoolOp, **kwargs: Any) -> Term | Op | Constant: ...

_python_not_supported: frozenset[str] = ...
_numexpr_supported_calls: frozenset[str] = ...

