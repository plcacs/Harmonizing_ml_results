_T = TypeVar("_T")
_KT = TypeVar("_KT")
_VT = TypeVar("_VT")

class IterableMixin:
    def py__next__(self, contextualized_node: Optional[ContextualizedNode] = None) -> Iterator[LazyKnownValues]: ...
    def py__stop_iteration_returns(self) -> ValueSet: ...
    def get_safe_value(self, default: Any = sentinel) -> Any: ...

class GeneratorBase(LazyAttributeOverwrite, IterableMixin):
    array_type: Optional[str] = None
    
    def _get_wrapped_value(self) -> Value: ...
    def _get_cls(self) -> Value: ...
    def py__bool__(self) -> bool: ...
    @publish_method('__iter__')
    def _iter(self, arguments: Any) -> ValueSet: ...
    @publish_method('send')
    @publish_method('__next__')
    def _next(self, arguments: Any) -> ValueSet: ...
    @property
    def name(self) -> compiled.CompiledValueName: ...
    def get_annotated_class_object(self) -> Value: ...

class Generator(GeneratorBase):
    def __init__(self, inference_state: Any, func_execution_context: Any) -> None: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = None) -> Iterator[LazyKnownValues]: ...
    def __repr__(self) -> str: ...

def comprehension_from_atom(
    inference_state: Any, value: Any, atom: Any
) -> Union["DictComprehension", "SetComprehension", "GeneratorComprehension", "ListComprehension"]: ...

class ComprehensionMixin:
    @inference_state_method_cache()
    def _get_comp_for_context(self, parent_context: Any, comp_for: Any) -> CompForContext: ...
    def _nested(
        self, comp_fors: Tuple[Any, ...], parent_context: Optional[Any] = None
    ) -> Iterator[Union[ValueSet, Tuple[ValueSet, ValueSet]]]: ...
    @inference_state_method_cache(default=[])
    @to_list
    def _iterate(self) -> List[Union[ValueSet, Tuple[ValueSet, ValueSet]]]: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = None) -> Iterator[LazyKnownValues]: ...
    def __repr__(self) -> str: ...

class _DictMixin:
    def _get_generics(self) -> Tuple[Value, ...]: ...

class Sequence(LazyAttributeOverwrite, IterableMixin):
    api_type: str = "instance"
    
    @property
    def name(self) -> compiled.CompiledValueName: ...
    def _get_generics(self) -> Tuple[Value, ...]: ...
    @inference_state_method_cache(default=())
    def _cached_generics(self) -> Tuple[Value, ...]: ...
    def _get_wrapped_value(self) -> Value: ...
    def py__bool__(self) -> Optional[bool]: ...
    @property
    def parent(self) -> Any: ...
    def py__getitem__(
        self, index_value_set: ValueSet, contextualized_node: ContextualizedNode
    ) -> Union[Iterator[ValueSet], ValueSet]: ...

class _BaseComprehension(ComprehensionMixin):
    def __init__(
        self,
        inference_state: Any,
        defining_context: Any,
        sync_comp_for_node: Any,
        entry_node: Any,
    ) -> None: ...

class ListComprehension(_BaseComprehension, Sequence):
    array_type: str = "list"
    
    def py__simple_getitem__(self, index: Union[int, slice]) -> ValueSet: ...

class SetComprehension(_BaseComprehension, Sequence):
    array_type: str = "set"

class GeneratorComprehension(_BaseComprehension, GeneratorBase): ...

class _DictKeyMixin:
    def get_mapping_item_values(self) -> Tuple[ValueSet, ValueSet]: ...
    def get_key_values(self) -> ValueSet: ...

class DictComprehension(ComprehensionMixin, Sequence, _DictKeyMixin):
    array_type: str = "dict"
    
    def __init__(
        self,
        inference_state: Any,
        defining_context: Any,
        sync_comp_for_node: Any,
        key_node: Any,
        value_node: Any,
    ) -> None: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = None) -> Iterator[LazyKnownValues]: ...
    def py__simple_getitem__(self, index: Any) -> ValueSet: ...
    def _dict_keys(self) -> ValueSet: ...
    def _dict_values(self) -> ValueSet: ...
    @publish_method('values')
    def _imitate_values(self, arguments: Any) -> ValueSet: ...
    @publish_method('items')
    def _imitate_items(self, arguments: Any) -> ValueSet: ...
    def exact_key_items(self) -> List[Tuple[Any, Any]]: ...

class SequenceLiteralValue(Sequence):
    _TUPLE_LIKE: Tuple[str, ...] = ("testlist_star_expr", "testlist", "subscriptlist")
    mapping: Dict[str, str] = {"(": "tuple", "[": "list", "{": "set"}
    
    def __init__(self, inference_state: Any, defining_context: Any, atom: Any) -> None: ...
    def _get_generics(self) -> Tuple[Value, ...]: ...
    def py__simple_getitem__(self, index: Union[int, str, slice]) -> ValueSet: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = None) -> Iterator[Union[LazyKnownValue, LazyTreeValue]]: ...
    def py__len__(self) -> int: ...
    def get_tree_entries(self) -> List[Union[Any, Tuple[Any, Any]]]: ...
    def __repr__(self) -> str: ...

class DictLiteralValue(_DictMixin, SequenceLiteralValue, _DictKeyMixin):
    array_type: str = "dict"
    
    def __init__(self, inference_state: Any, defining_context: Any, atom: Any) -> None: ...
    def py__simple_getitem__(self, index: Union[int, str]) -> ValueSet: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = None) -> Iterator[LazyKnownValues]: ...
    @publish_method('values')
    def _imitate_values(self, arguments: Any) -> ValueSet: ...
    @publish_method('items')
    def _imitate_items(self, arguments: Any) -> ValueSet: ...
    def exact_key_items(self) -> Iterator[Tuple[str, LazyTreeValue]]: ...
    def _dict_values(self) -> ValueSet: ...
    def _dict_keys(self) -> ValueSet: ...

class _FakeSequence(Sequence):
    def __init__(self, inference_state: Any, lazy_value_list: List[Any]) -> None: ...
    def py__simple_getitem__(self, index: Union[int, slice]) -> ValueSet: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = None) -> Iterator[Any]: ...
    def py__bool__(self) -> bool: ...
    def __repr__(self) -> str: ...

class FakeTuple(_FakeSequence):
    array_type: str = "tuple"

class FakeList(_FakeSequence):
    array_type: str = "tuple"

class FakeDict(_DictMixin, Sequence, _DictKeyMixin):
    array_type: str = "dict"
    
    def __init__(self, inference_state: Any, dct: Dict[Any, Any]) -> None: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = None) -> Iterator[LazyKnownValue]: ...
    def py__simple_getitem__(self, index: Any) -> ValueSet: ...
    @publish_method('values')
    def _values(self, arguments: Any) -> ValueSet: ...
    def _dict_values(self) -> ValueSet: ...
    def _dict_keys(self) -> ValueSet: ...
    def exact_key_items(self) -> List[Tuple[Any, Any]]: ...
    def __repr__(self) -> str: ...

class MergedArray(Sequence):
    def __init__(self, inference_state: Any, arrays: List[Sequence]) -> None: ...
    def py__iter__(self, contextualized_node: Optional[ContextualizedNode] = None) -> Iterator[Any]: ...
    def py__simple_getitem__(self, index: Any) -> ValueSet: ...

def unpack_tuple_to_dict(context: Any, types: ValueSet, exprlist: Any) -> Dict[str, ValueSet]: ...

class Slice(LazyValueWrapper):
    def __init__(
        self,
        python_context: Any,
        start: Optional[Any],
        stop: Optional[Any],
        step: Optional[Any],
    ) -> None: ...
    def _get_wrapped_value(self) -> Value: ...
    def get_safe_value(self, default: Any = sentinel) -> slice: ...