from typing import Any, Dict, List, Optional
from dbt.contracts.graph.nodes import GenericTestNode
from dbt.parser.base import SimpleParser

class SchemaGenericTestParser(SimpleParser):
    def __init__(self, project: Any, manifest: Any, root_project: Any) -> None: ...
    @property
    def resource_type(self) -> Any: ...
    @classmethod
    def get_compiled_path(cls, block: Any) -> str: ...
    def parse_file(self, block: Any, dct: Optional[Dict[str, Any]] = ...) -> None: ...
    def parse_from_dict(self, dct: Dict[str, Any], validate: bool = ...) -> GenericTestNode: ...
    def parse_column_tests(self, block: Any, column: Any, version: Any) -> None: ...
    def create_test_node(
        self,
        target: Any,
        path: str,
        config: Any,
        tags: List[str],
        fqn: List[str],
        name: str,
        raw_code: str,
        test_metadata: Dict[str, Any],
        file_key_name: str,
        column_name: Optional[str],
        description: Optional[str],
    ) -> GenericTestNode: ...
    def parse_generic_test(
        self,
        target: Any,
        data_test: Any,
        tags: List[str],
        column_name: Optional[str],
        schema_file_id: str,
        version: Any,
    ) -> GenericTestNode: ...
    def _lookup_attached_node(self, target: Any, version: Any) -> Optional[Any]: ...
    def store_env_vars(self, target: Any, schema_file_id: str, env_vars: Dict[str, Any]) -> None: ...
    def render_test_update(self, node: GenericTestNode, config: Any, builder: Any, schema_file_id: str) -> None: ...
    def parse_node(self, block: Any) -> GenericTestNode: ...
    def add_test_node(self, block: Any, node: GenericTestNode) -> None: ...
    def render_with_context(self, node: GenericTestNode, config: Any) -> None: ...
    def parse_test(self, target_block: Any, data_test: Any, column: Any, version: Any) -> None: ...
    def parse_tests(self, block: Any) -> None: ...
    def parse_versioned_tests(self, block: Any) -> None: ...
    def generate_unique_id(self, resource_name: str, hash: Optional[str] = ...) -> str: ...