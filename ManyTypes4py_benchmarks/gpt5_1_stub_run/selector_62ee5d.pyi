from typing import Any, Iterable, Set, Tuple
from .selector_methods import MethodManager

def get_package_names(nodes: Iterable[str]) -> Set[str]: ...
def can_select_indirectly(node: Any) -> bool: ...

class NodeSelector(MethodManager):
    def __init__(self, graph: Any, manifest: Any, previous_state: Any = ..., include_empty_nodes: bool = ...) -> None: ...
    def select_included(self, included_nodes: Any, spec: Any) -> Set[Any]: ...
    def get_nodes_from_criteria(self, spec: Any) -> Tuple[Set[Any], Set[Any]]: ...
    def collect_specified_neighbors(self, spec: Any, selected: Any) -> Set[Any]: ...
    def select_nodes_recursively(self, spec: Any) -> Tuple[Set[Any], Set[Any]]: ...
    def select_nodes(self, spec: Any) -> Tuple[Set[Any], Set[Any]]: ...
    def _is_graph_member(self, unique_id: Any) -> bool: ...
    def _is_empty_node(self, unique_id: Any) -> bool: ...
    def node_is_match(self, node: Any) -> bool: ...
    def _is_match(self, unique_id: Any) -> bool: ...
    def filter_selection(self, selected: Any) -> Set[Any]: ...
    def expand_selection(self, selected: Any, indirect_selection: Any = ...) -> Tuple[Set[Any], Set[Any]]: ...
    def incorporate_indirect_nodes(self, direct_nodes: Any, indirect_nodes: Any = ..., indirect_selection: Any = ...) -> Set[Any]: ...
    def get_selected(self, spec: Any) -> Set[Any]: ...
    def get_graph_queue(self, spec: Any, preserve_edges: bool = ...) -> Any: ...

class ResourceTypeSelector(NodeSelector):
    resource_types: Set[Any]
    def __init__(self, graph: Any, manifest: Any, previous_state: Any, resource_types: Any, include_empty_nodes: bool = ...) -> None: ...
    def node_is_match(self, node: Any) -> bool: ...