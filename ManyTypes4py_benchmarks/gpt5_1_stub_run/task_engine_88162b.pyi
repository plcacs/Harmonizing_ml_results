from typing import Any, AsyncGenerator, AsyncContextManager, Awaitable, ContextManager, Generator, Generic, Optional, Sequence, TypeVar, Union
from typing_extensions import ParamSpec, Self

P = ParamSpec("P")
R = TypeVar("R")
BACKOFF_MAX: int = ...

class TaskRunTimeoutError(TimeoutError):
    ...

class BaseTaskRunEngine(Generic[P, R]):
    logger: Any
    parameters: Any
    task_run: Any
    retries: int
    wait_for: Any
    context: Any
    _return_value: Any
    _raised: Any
    _initial_run_context: Any
    _is_started: bool
    _task_name_set: bool
    _last_event: Any
    _telemetry: Any
    task: Any

    def __post_init__(self) -> None: ...
    @property
    def state(self) -> Any: ...
    def is_cancelled(self) -> bool: ...
    def compute_transaction_key(self) -> Optional[str]: ...
    def _resolve_parameters(self) -> None: ...
    def _set_custom_task_run_name(self) -> None: ...
    def _wait_for_dependencies(self) -> None: ...
    def record_terminal_state_timing(self, state: Any) -> None: ...
    def is_running(self) -> bool: ...
    def log_finished_message(self) -> None: ...
    def handle_rollback(self, txn: Any) -> None: ...

class SyncTaskRunEngine(BaseTaskRunEngine[P, R]):
    task_run: Any
    _client: Any

    @property
    def client(self) -> Any: ...
    def can_retry(self, exc: Any) -> bool: ...
    def call_hooks(self, state: Any | None = ...) -> None: ...
    def begin_run(self) -> None: ...
    def set_state(self, state: Any, force: bool = ...) -> Any: ...
    def result(self, raise_on_failure: bool = ...) -> Any: ...
    def handle_success(self, result: Any, transaction: Any) -> Any: ...
    def handle_retry(self, exc: Any) -> bool: ...
    def handle_exception(self, exc: Any) -> None: ...
    def handle_timeout(self, exc: Any) -> None: ...
    def handle_crash(self, exc: Any) -> None: ...
    def setup_run_context(self, client: Any | None = ...) -> ContextManager[None]: ...
    def initialize_run(self, task_run_id: Any | None = ..., dependencies: Any | None = ...) -> ContextManager[Self]: ...
    async def wait_until_ready(self) -> None: ...
    def start(self, task_run_id: Any | None = ..., dependencies: Any | None = ...) -> ContextManager[None]: ...
    def transaction_context(self) -> ContextManager[Any]: ...
    def run_context(self) -> ContextManager[Any]: ...
    def call_task_fn(self, transaction: Any) -> Any: ...

class AsyncTaskRunEngine(BaseTaskRunEngine[P, R]):
    task_run: Any
    _client: Any

    @property
    def client(self) -> Any: ...
    async def can_retry(self, exc: Any) -> bool: ...
    async def call_hooks(self, state: Any | None = ...) -> None: ...
    async def begin_run(self) -> None: ...
    async def set_state(self, state: Any, force: bool = ...) -> Any: ...
    async def result(self, raise_on_failure: bool = ...) -> Any: ...
    async def handle_success(self, result: Any, transaction: Any) -> Any: ...
    async def handle_retry(self, exc: Any) -> bool: ...
    async def handle_exception(self, exc: Any) -> None: ...
    async def handle_timeout(self, exc: Any) -> None: ...
    async def handle_crash(self, exc: Any) -> None: ...
    def setup_run_context(self, client: Any | None = ...) -> AsyncContextManager[None]: ...
    def initialize_run(self, task_run_id: Any | None = ..., dependencies: Any | None = ...) -> AsyncContextManager[Self]: ...
    async def wait_until_ready(self) -> None: ...
    def start(self, task_run_id: Any | None = ..., dependencies: Any | None = ...) -> AsyncContextManager[None]: ...
    def transaction_context(self) -> AsyncContextManager[Any]: ...
    def run_context(self) -> AsyncContextManager[Any]: ...
    async def call_task_fn(self, transaction: Any) -> Any: ...

