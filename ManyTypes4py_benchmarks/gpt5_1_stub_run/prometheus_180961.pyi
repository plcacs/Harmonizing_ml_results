    COMPLETED: str
    KEYS_RETRIEVED: str
    KEYS_UPDATED: str
    KEYS_DELETED: str
    def __init__(self, app: Any, pattern: str = ..., **kwargs: Any) -> None: ...
    def _initialize_metrics(self) -> None: ...
    def on_message_in(self, tp: Any, offset: Any, message: Any) -> None: ...
