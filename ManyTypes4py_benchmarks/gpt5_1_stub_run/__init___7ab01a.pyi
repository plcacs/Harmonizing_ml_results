def fullmatch(pattern: str, string: str, flags: int = ...) -> Optional[Match]: ...
def split(pattern: str, string: str, maxsplit: int = ..., flags: int = ...) -> List[Any]: ...
def findall(pattern: str, string: str, flags: int = ...) -> List[Any]: ...
def finditer(pattern: str, string: str, flags: int = ...) -> Iterator[Match]: ...
def sub(pattern: str, repl: Any, string: str, count: int = ..., flags: int = ...) -> str: ...
def subn(pattern: str, repl: Any, string: str, count: int = ..., flags: int = ...) -> Tuple[str, int]: ...
def escape(string: str) -> str: ...
def purge() -> None: ...