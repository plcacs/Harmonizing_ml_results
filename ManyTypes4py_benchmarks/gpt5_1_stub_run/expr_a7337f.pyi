class BaseExprVisitor(ast.NodeVisitor):
    const_type: ClassVar[Any]
    term_type: ClassVar[Any]
    binary_ops: ClassVar[Any]
    binary_op_nodes: ClassVar[Any]
    binary_op_nodes_map: ClassVar[Any]
    unary_ops: ClassVar[Any]
    unary_op_nodes: ClassVar[Any]
    unary_op_nodes_map: ClassVar[Any]
    rewrite_map: ClassVar[Any]
    env: Any
    engine: str
    parser: str
    preparser: Callable[..., str]
    assigner: Any
    def __init__(self, env: Any, engine: str, parser: str, preparser: Callable[..., str] = ...) -> None: ...
    def visit(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Module(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Expr(self, node: Any, **kwargs: Any) -> Any: ...
    def _rewrite_membership_op(self, node: Any, left: Any, right: Any) -> tuple[Any, Any, Any, Any]: ...
    def _maybe_transform_eq_ne(self, node: Any, left: Any = ..., right: Any = ...) -> tuple[Any, Any, Any, Any]: ...
    def _maybe_downcast_constants(self, left: Any, right: Any) -> tuple[Any, Any]: ...
    def _maybe_eval(self, binop: Any, eval_in_python: Any) -> Any: ...
    def _maybe_evaluate_binop(self, op: Any, op_class: Any, lhs: Any, rhs: Any, eval_in_python: Any = ..., maybe_eval_in_python: Any = ...) -> Any: ...
    def visit_BinOp(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_UnaryOp(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Name(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_NameConstant(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Num(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Constant(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Str(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_List(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Tuple(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Index(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Subscript(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Slice(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Assign(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Attribute(self, node: Any, **kwargs: Any) -> Any: ...
    def visit_Call(self, node: Any, side: Optional[str] = None, **kwargs: Any) -> Any: ...
    def translate_In(self, op: Any) -> Any: ...
    def visit_Compare(self, node: Any, **kwargs: Any) -> Any: ...
    def _try_visit_binop(self, bop: Any) -> Any: ...
    def visit_BoolOp(self, node: Any, **kwargs: Any) -> Any: ...

class PandasExprVisitor(BaseExprVisitor):
    def __init__(self, env: Any, engine: str, parser: str, preparser: Callable[..., str] = ...) -> None: ...

class PythonExprVisitor(BaseExprVisitor):
    def __init__(self, env: Any, engine: str, parser: str, preparser: Callable[..., str] = ...) -> None: ...

class Expr:
    expr: str
    env: Any
    engine: str
    parser: str
    _visitor: BaseExprVisitor
    terms: Any
    def __init__(self, expr: str, engine: str = 'numexpr', parser: str = 'pandas', env: Optional[Any] = None, level: int = 0) -> None: ...
    @property
    def assigner(self) -> Any: ...
    def __call__(self) -> Any: ...
    def __repr__(self) -> str: ...
    def __len__(self) -> int: ...
    def parse(self) -> Any: ...
    @property
    def names(self) -> FrozenSet[str]: ...

PARSERS: Dict[str, type[BaseExprVisitor]] = ...