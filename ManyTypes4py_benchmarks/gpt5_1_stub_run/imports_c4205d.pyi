def load_namespace_from_path(inference_state: Any, folder_io: Any) -> Any: ...
def follow_error_node_imports_if_possible(context: Any, name: Any) -> Optional[Any]: ...
def iter_module_names(inference_state: Any, module_context: Any, search_path: Any, module_cls: Any = ..., add_builtin_modules: bool = ...) -> Iterator[Any]: ...