from typing import Any, Dict, List, Optional, Set, Type
from pathlib import Path
from types import TracebackType

def read_profiles(profiles_dir: Any = ...) -> Dict[str, Any]: ...
def get_nearest_project_dir(project_dir: Any) -> Path: ...
def move_to_nearest_project_dir(project_dir: Any) -> Path: ...

class BaseTask:
    args: Any
    def __init__(self, args: Any) -> None: ...
    def __enter__(self) -> "BaseTask": ...
    def __exit__(self, exc_type: Optional[Type[BaseException]], exc_value: Optional[BaseException], traceback: Optional[TracebackType]) -> None: ...
    def run(self) -> Any: ...
    def interpret_results(self, results: Any) -> bool: ...

class ConfiguredTask(BaseTask):
    config: Any
    graph: Any
    manifest: Any
    compiler: Any
    def __init__(self, args: Any, config: Any, manifest: Any = ...) -> None: ...
    def compile_manifest(self) -> None: ...
    @classmethod
    def from_args(cls: Type["ConfiguredTask"], args: Any, *pargs: Any, **kwargs: Any) -> "ConfiguredTask": ...

class ExecutionContext:
    timing: List[Any]
    node: Any
    def __init__(self, node: Any) -> None: ...

class BaseRunner:
    config: Any
    compiler: Any
    adapter: Any
    node: Any
    node_index: int
    num_nodes: int
    skip: bool
    skip_cause: Any
    run_ephemeral_models: bool
    def __init__(self, config: Any, adapter: Any, node: Any, node_index: int, num_nodes: int) -> None: ...
    def compile(self, manifest: Any) -> Any: ...
    def _node_build_path(self) -> Optional[Any]: ...
    def get_result_status(self, result: Any) -> Dict[str, str]: ...
    def run_with_hooks(self, manifest: Any) -> Any: ...
    def _build_run_result(
        self,
        node: Any,
        start_time: float,
        status: Any,
        timing_info: Any,
        message: Optional[str],
        agate_table: Any = ...,
        adapter_response: Optional[Dict[str, Any]] = ...,
        failures: Any = ...,
        batch_results: Any = ...,
    ) -> Any: ...
    def error_result(self, node: Any, message: str, start_time: float, timing_info: Any) -> Any: ...
    def ephemeral_result(self, node: Any, start_time: float, timing_info: Any) -> Any: ...
    def from_run_result(self, result: Any, start_time: float, timing_info: Any) -> Any: ...
    def compile_and_execute(self, manifest: Any, ctx: Any) -> Any: ...
    def _handle_catchable_exception(self, e: Any, ctx: Any) -> str: ...
    def _handle_internal_exception(self, e: Any, ctx: Any) -> str: ...
    def _handle_generic_exception(self, e: Any, ctx: Any) -> str: ...
    def handle_exception(self, e: Any, ctx: Any) -> str: ...
    def safe_run(self, manifest: Any) -> Any: ...
    def _safe_release_connection(self) -> Optional[str]: ...
    def before_execute(self) -> Any: ...
    def execute(self, compiled_node: Any, manifest: Any) -> Any: ...
    def run(self, compiled_node: Any, manifest: Any) -> Any: ...
    def after_execute(self, result: Any) -> Any: ...
    def _skip_caused_by_ephemeral_failure(self) -> bool: ...
    def on_skip(self) -> Any: ...
    def do_skip(self, cause: Any = ...) -> None: ...

def resource_types_from_args(args: Any, all_resource_values: Set[Any], default_resource_values: Set[Any]) -> Set[Any]: ...