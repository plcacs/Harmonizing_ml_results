from __future__ import annotations
import logging
from datetime import datetime
from re import Pattern
from typing import Any, Dict, Iterable, List, Mapping, Optional, Set, Tuple
from superset.db_engine_specs.base import BaseEngineSpec, BasicParametersMixin

logger: logging.Logger = ...
CONNECTION_INVALID_USERNAME_REGEX: Pattern[str] = ...
CONNECTION_INVALID_PASSWORD_REGEX: Pattern[str] = ...
CONNECTION_INVALID_PASSWORD_NEEDED_REGEX: Pattern[str] = ...
CONNECTION_INVALID_HOSTNAME_REGEX: Pattern[str] = ...
CONNECTION_PORT_CLOSED_REGEX: Pattern[str] = ...
CONNECTION_HOST_DOWN_REGEX: Pattern[str] = ...
CONNECTION_UNKNOWN_DATABASE_REGEX: Pattern[str] = ...
COLUMN_DOES_NOT_EXIST_REGEX: Pattern[str] = ...
SYNTAX_ERROR_REGEX: Pattern[str] = ...
__: Any = ...

def parse_options(connect_args: Mapping[str, Any]) -> Dict[str, str]: ...

class PostgresBaseEngineSpec(BaseEngineSpec):
    engine: str
    engine_name: str
    _time_grain_expressions: Dict[Any, str]
    custom_errors: Dict[Pattern[str], Tuple[str, Any, Dict[str, Any]]]

    @classmethod
    def fetch_data(cls, cursor: Any, limit: Optional[int] = ...) -> Any: ...
    @classmethod
    def epoch_to_dttm(cls) -> str: ...
    @classmethod
    def convert_dttm(cls, target_type: Any, dttm: datetime, db_extra: Any = ...) -> Optional[str]: ...

class PostgresEngineSpec(BasicParametersMixin, PostgresBaseEngineSpec):
    engine: str
    engine_aliases: Set[str]
    supports_dynamic_schema: bool
    supports_catalog: bool
    supports_dynamic_catalog: bool
    default_driver: str
    sqlalchemy_uri_placeholder: str
    encryption_parameters: Dict[str, str]
    max_column_name_length: int
    try_remove_schema_from_table_name: bool
    column_type_mappings: Tuple[Tuple[Pattern[str], Any, Any], ...]

    @classmethod
    def get_schema_from_engine_params(cls, sqlalchemy_uri: Any, connect_args: Mapping[str, Any]) -> Optional[str]: ...
    @classmethod
    def get_default_schema_for_query(cls, database: Any, query: Any) -> Optional[str]: ...
    @classmethod
    def adjust_engine_params(cls, uri: Any, connect_args: Mapping[str, Any], catalog: Optional[str] = ..., schema: Optional[str] = ...) -> Tuple[Any, Any]: ...
    @classmethod
    def get_default_catalog(cls, database: Any) -> Optional[str]: ...
    @classmethod
    def get_prequeries(cls, database: Any, catalog: Optional[str] = ..., schema: Optional[str] = ...) -> List[str]: ...
    @classmethod
    def get_allow_cost_estimate(cls, extra: Any) -> bool: ...
    @classmethod
    def estimate_statement_cost(cls, database: Any, statement: str, cursor: Any) -> Dict[str, float]: ...
    @classmethod
    def query_cost_formatter(cls, raw_cost: Iterable[Mapping[str, Any]]) -> List[Dict[str, str]]: ...
    @classmethod
    def get_catalog_names(cls, database: Any, inspector: Any) -> Set[str]: ...
    @classmethod
    def get_table_names(cls, database: Any, inspector: Any, schema: Optional[str]) -> Set[str]: ...
    @staticmethod
    def get_extra_params(database: Any) -> Dict[str, Any]: ...
    @classmethod
    def get_datatype(cls, type_code: Any) -> Optional[str]: ...
    @classmethod
    def get_cancel_query_id(cls, cursor: Any, query: Any) -> int: ...
    @classmethod
    def cancel_query(cls, cursor: Any, query: Any, cancel_query_id: Any) -> bool: ...