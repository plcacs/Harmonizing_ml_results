from typing import Any, Dict, Iterable, Optional, Awaitable
from tornado.httpclient import AsyncHTTPClient

class AuthError(Exception): ...

class OpenIdMixin:
    def authenticate_redirect(self, callback_uri: Optional[str] = ..., ax_attrs: Iterable[str] = ...) -> None: ...
    def get_authenticated_user(self, http_client: Optional[AsyncHTTPClient] = ...) -> Awaitable[Dict[str, Any]]: ...
    def _openid_args(self, callback_uri: str, ax_attrs: Iterable[str] = ..., oauth_scope: Optional[str] = ...) -> Dict[str, str]: ...
    def _on_authentication_verified(self, response: Any) -> Dict[str, Any]: ...
    def get_auth_http_client(self) -> AsyncHTTPClient: ...

class OAuthMixin:
    def authorize_redirect(self, callback_uri: Optional[str] = ..., extra_params: Optional[Dict[str, Any]] = ..., http_client: Optional[AsyncHTTPClient] = ...) -> Awaitable[None]: ...
    def get_authenticated_user(self, http_client: Optional[AsyncHTTPClient] = ...) -> Awaitable[Dict[str, Any]]: ...
    def _oauth_request_token_url(self, callback_uri: Optional[str] = ..., extra_params: Optional[Dict[str, Any]] = ...) -> str: ...
    def _on_request_token(self, authorize_url: str, callback_uri: Optional[str], response: Any) -> None: ...
    def _oauth_access_token_url(self, request_token: Dict[str, Any]) -> str: ...
    def _oauth_consumer_token(self) -> Dict[str, Any]: ...
    def _oauth_get_user_future(self, access_token: Dict[str, Any]) -> Awaitable[Optional[Dict[str, Any]]]: ...
    def _oauth_request_parameters(self, url: str, access_token: Dict[str, Any], parameters: Dict[str, Any] = ..., method: str = ...) -> Dict[str, Any]: ...
    def get_auth_http_client(self) -> AsyncHTTPClient: ...

class OAuth2Mixin:
    def authorize_redirect(self, redirect_uri: Optional[str] = ..., client_id: Optional[str] = ..., client_secret: Optional[str] = ..., extra_params: Optional[Dict[str, Any]] = ..., scope: Optional[Iterable[str]] = ..., response_type: str = ...) -> None: ...
    def _oauth_request_token_url(self, redirect_uri: Optional[str] = ..., client_id: Optional[str] = ..., client_secret: Optional[str] = ..., code: Optional[str] = ..., extra_params: Optional[Dict[str, Any]] = ...) -> str: ...
    def oauth2_request(self, url: str, access_token: Optional[str] = ..., post_args: Optional[Dict[str, Any]] = ..., **args: Any) -> Awaitable[Any]: ...
    def get_auth_http_client(self) -> AsyncHTTPClient: ...

class TwitterMixin(OAuthMixin):
    def authenticate_redirect(self, callback_uri: Optional[str] = ...) -> Awaitable[None]: ...
    def twitter_request(self, path: str, access_token: Dict[str, Any], post_args: Optional[Dict[str, Any]] = ..., **args: Any) -> Awaitable[Any]: ...
    def _oauth_consumer_token(self) -> Dict[str, Any]: ...
    def _oauth_get_user_future(self, access_token: Dict[str, Any]) -> Awaitable[Optional[Dict[str, Any]]]: ...

class GoogleOAuth2Mixin(OAuth2Mixin):
    _OAUTH_AUTHORIZE_URL: str = ...
    _OAUTH_ACCESS_TOKEN_URL: str = ...
    _OAUTH_USERINFO_URL: str = ...
    _OAUTH_NO_CALLBACKS: bool = ...
    _OAUTH_SETTINGS_KEY: str = ...
    def get_google_oauth_settings(self) -> Dict[str, str]: ...
    def get_authenticated_user(self, redirect_uri: str, code: str, client_id: Optional[str] = ..., client_secret: Optional[str] = ...) -> Awaitable[Dict[str, Any]]: ...

class FacebookGraphMixin(OAuth2Mixin):
    _OAUTH_ACCESS_TOKEN_URL: str = ...
    _OAUTH_AUTHORIZE_URL: str = ...
    _OAUTH_NO_CALLBACKS: bool = ...
    _FACEBOOK_BASE_URL: str = ...
    def get_authenticated_user(self, redirect_uri: str, client_id: str, client_secret: str, code: str, extra_fields: Optional[Iterable[str]] = ...) -> Awaitable[Optional[Dict[str, Any]]]: ...
    def facebook_request(self, path: str, access_token: Optional[str] = ..., post_args: Optional[Dict[str, Any]] = ..., **args: Any) -> Awaitable[Any]: ...

def _oauth_signature(consumer_token: Dict[str, Any], method: str, url: str, parameters: Dict[str, Any] = ..., token: Optional[Dict[str, Any]] = ...) -> bytes: ...
def _oauth10a_signature(consumer_token: Dict[str, Any], method: str, url: str, parameters: Dict[str, Any] = ..., token: Optional[Dict[str, Any]] = ...) -> bytes: ...
def _oauth_escape(val: Any) -> str: ...
def _oauth_parse_response(body: Any) -> Dict[str, str]: ...