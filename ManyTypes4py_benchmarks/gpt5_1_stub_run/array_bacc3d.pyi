    def to_numpy(self, dtype: Optional[Any] = ..., copy: bool = ..., na_value: Any = ..., decimals: Optional[int] = ...) -> np.ndarray: ...
    def __array_ufunc__(self, ufunc: Any, method: str, *inputs: Any, **kwargs: Any) -> Any: ...
    @overload
    def __getitem__(self, item: int) -> decimal.Decimal: ...
    @overload
    def __getitem__(self, item: Any) -> 'DecimalArray': ...
    def take(self, indexer: Any, allow_fill: bool = ..., fill_value: Optional[Any] = ...) -> 'DecimalArray': ...
    def copy(self) -> 'DecimalArray': ...
    def astype(self, dtype: Any, copy: bool = ...) -> Any: ...
    def __setitem__(self, key: Any, value: Any) -> None: ...
    def __len__(self) -> int: ...
    def __contains__(self, item: Any) -> bool: ...
