from typing import Any, Callable, List, Optional, Sequence, Tuple
from allennlp.confidence_checks.task_checklists.task_suite import TaskSuite

def _add_phrase_function(phrases: Sequence[str], num_samples: int = ...) -> Callable[[str], List[str]]: ...

class SentimentAnalysisSuite(TaskSuite):
    _positive: int
    _negative: int
    monotonic_label: Any
    monotonic_label_down: Any

    def __init__(self, suite: Optional[Any] = ..., positive: int = ..., negative: int = ..., **kwargs: Any) -> None: ...
    def _prediction_and_confidence_scores(self, predictor: Any) -> Callable[[Sequence[Any]], Tuple[Any, Any]]: ...
    def _format_failing_examples(self, inputs: Any, pred: int, conf: Any, label: Optional[int] = ..., *args: Any, **kwargs: Any) -> str: ...
    def _default_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _setup_editor(self) -> None: ...
    def _default_vocabulary_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _default_robustness_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _default_ner_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _default_temporal_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _default_fairness_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _default_negation_tests(self, data: Optional[Sequence[str]], num_test_cases: int = ...) -> None: ...
    def _positive_change(self, orig_conf: Any, conf: Any) -> float: ...
    def _diff_up(self, orig_pred: Any, pred: Any, orig_conf: Any, conf: Any, labels: Any = ..., meta: Any = ...) -> Tuple[()]: ...
    def _diff_down(self, orig_pred: Any, pred: Any, orig_conf: Any, conf: Any, labels: Any = ..., meta: Any = ...) -> Tuple[()]: ...