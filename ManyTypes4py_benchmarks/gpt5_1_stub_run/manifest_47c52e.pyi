class Locality(enum.IntEnum):
    Core = 1
    Imported = 2
    Root = 3

class MacroCandidate:
    locality: "Locality"
    macro: Any

    def __eq__(self, other: Any) -> Any: ...
    def __lt__(self, other: Any) -> Any: ...

class MaterializationCandidate(MacroCandidate):
    specificity: int

    @classmethod
    def from_macro(cls, candidate: Any, specificity: int) -> "MaterializationCandidate": ...
    def __eq__(self, other: Any) -> Any: ...
    def __lt__(self, other: Any) -> Any: ...

M = TypeVar('M', bound=MacroCandidate)

class CandidateList(List[M]):
    def last_candidate(self, valid_localities: Optional[Iterable[Any]] = ...) -> Optional[M]: ...
    def last(self) -> Optional[Any]: ...

class Searchable(Protocol):
    @property
    def search_name(self) -> Any: ...

D = TypeVar('D')

class Disabled(Generic[D]): ...

