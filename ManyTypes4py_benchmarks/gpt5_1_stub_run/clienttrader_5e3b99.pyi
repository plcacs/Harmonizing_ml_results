from typing import Any, Optional

import abc


class IClientTrader(abc.ABC):
    @property
    @abc.abstractmethod
    def app(self) -> Any: ...
    @property
    @abc.abstractmethod
    def main(self) -> Any: ...
    @property
    @abc.abstractmethod
    def config(self) -> Any: ...
    @abc.abstractmethod
    def wait(self, seconds: Any) -> None: ...
    @abc.abstractmethod
    def refresh(self) -> None: ...
    @abc.abstractmethod
    def is_exist_pop_dialog(self) -> Any: ...


class ClientTrader(IClientTrader):
    _editor_need_type_keys: bool = ...
    grid_strategy: Any = ...
    _grid_strategy_instance: Any = ...
    refresh_strategy: Any = ...
    def enable_type_keys_for_editor(self) -> None: ...
    @property
    def grid_strategy_instance(self) -> Any: ...
    def __init__(self) -> None: ...
    @property
    def app(self) -> Any: ...
    @property
    def main(self) -> Any: ...
    @property
    def config(self) -> Any: ...
    def connect(self, exe_path: Optional[Any] = ..., **kwargs: Any) -> None: ...
    @property
    def broker_type(self) -> str: ...
    @property
    def balance(self) -> Any: ...
    def _init_toolbar(self) -> None: ...
    def _get_balance_from_statics(self) -> Any: ...
    @property
    def position(self) -> Any: ...
    @property
    def today_entrusts(self) -> Any: ...
    @property
    def today_trades(self) -> Any: ...
    @property
    def cancel_entrusts(self) -> Any: ...
    def cancel_entrust(self, entrust_no: Any) -> Any: ...
    def cancel_all_entrusts(self) -> None: ...
    def repo(self, security: Any, price: Any, amount: Any, **kwargs: Any) -> Any: ...
    def reverse_repo(self, security: Any, price: Any, amount: Any, **kwargs: Any) -> Any: ...
    def buy(self, security: Any, price: Any, amount: Any, **kwargs: Any) -> Any: ...
    def sell(self, security: Any, price: Any, amount: Any, **kwargs: Any) -> Any: ...
    def market_buy(self, security: Any, amount: Any, ttype: Any = ..., limit_price: Any = ..., **kwargs: Any) -> Any: ...
    def market_sell(self, security: Any, amount: Any, ttype: Any = ..., limit_price: Any = ..., **kwargs: Any) -> Any: ...
    def market_trade(self, security: Any, amount: Any, ttype: Any = ..., limit_price: Any = ..., **kwargs: Any) -> Any: ...
    def _set_market_trade_type(self, ttype: Any) -> None: ...
    def _set_stock_exchange_type(self, ttype: Any) -> None: ...
    def auto_ipo(self) -> Any: ...
    def _click_grid_by_row(self, row: Any) -> None: ...
    def is_exist_pop_dialog(self) -> bool: ...
    def close_pop_dialog(self) -> None: ...
    def _run_exe_path(self, exe_path: Any) -> str: ...
    def wait(self, seconds: Any) -> None: ...
    def exit(self) -> None: ...
    def _close_prompt_windows(self) -> None: ...
    def close_pormpt_window_no_wait(self) -> None: ...
    def trade(self, security: Any, price: Any, amount: Any) -> Any: ...
    def _click(self, control_id: Any) -> None: ...
    def _submit_trade(self) -> None: ...
    def __get_top_window_pop_dialog(self) -> Any: ...
    def _get_pop_dialog_title(self) -> Any: ...
    def _set_trade_params(self, security: Any, price: Any, amount: Any) -> None: ...
    def _set_market_trade_params(self, security: Any, amount: Any, limit_price: Any = ...) -> None: ...
    def _get_grid_data(self, control_id: Any) -> Any: ...
    def _type_keys(self, control_id: Any, text: Any) -> None: ...
    def _type_edit_control_keys(self, control_id: Any, text: Any) -> None: ...
    def type_edit_control_keys(self, editor: Any, text: Any) -> None: ...
    def _collapse_left_menus(self) -> None: ...
    def _switch_left_menus(self, path: Any, sleep: Any = ...) -> None: ...
    def _switch_left_menus_by_shortcut(self, shortcut: Any, sleep: Any = ...) -> None: ...
    def _get_left_menus_handle(self) -> Any: ...
    def _cancel_entrust_by_double_click(self, row: Any) -> None: ...
    def refresh(self) -> None: ...
    def _handle_pop_dialogs(self, handler_class: Any = ...) -> Any: ...


class BaseLoginClientTrader(ClientTrader):
    @abc.abstractmethod
    def login(self, user: Any, password: Any, exe_path: Any, comm_password: Any = ..., **kwargs: Any) -> None: ...
    def prepare(self, config_path: Any = ..., user: Any = ..., password: Any = ..., exe_path: Any = ..., comm_password: Any = ..., **kwargs: Any) -> None: ...