from abc import ABCMeta, abstractmethod
from typing import Any, List, Optional, TYPE_CHECKING, Union
from pyspark import StorageLevel
from pyspark.sql import Column, DataFrame as SparkDataFrame
from pyspark.sql.types import DataType, StructType

if TYPE_CHECKING:
    import databricks.koalas as ks
    from databricks.koalas.frame import CachedDataFrame


class SparkIndexOpsMethods(object, metaclass=ABCMeta):
    def __init__(self, data: Any) -> None: ...
    @property
    def data_type(self) -> DataType: ...
    @property
    def nullable(self) -> bool: ...
    @property
    def column(self) -> Column: ...
    def transform(self, func: Any) -> Any: ...
    @property
    @abstractmethod
    def analyzed(self) -> Any: ...


class SparkSeriesMethods(SparkIndexOpsMethods):
    def transform(self, func: Any) -> "ks.Series": ...
    def apply(self, func: Any) -> "ks.Series": ...
    @property
    def analyzed(self) -> "ks.Series": ...


class SparkIndexMethods(SparkIndexOpsMethods):
    def transform(self, func: Any) -> "ks.Index": ...
    @property
    def analyzed(self) -> "ks.Index": ...


class SparkFrameMethods(object):
    def __init__(self, frame: Any) -> None: ...
    def schema(self, index_col: Optional[Union[str, List[str]]] = ...) -> StructType: ...
    def print_schema(self, index_col: Optional[Union[str, List[str]]] = ...) -> None: ...
    def frame(self, index_col: Optional[Union[str, List[str]]] = ...) -> SparkDataFrame: ...
    def cache(self) -> "CachedDataFrame": ...
    def persist(self, storage_level: StorageLevel = ...) -> "CachedDataFrame": ...
    def hint(self, name: str, *parameters: Any) -> "ks.DataFrame": ...
    def to_table(
        self,
        name: str,
        format: Optional[str] = ...,
        mode: str = ...,
        partition_cols: Optional[Union[str, List[str]]] = ...,
        index_col: Optional[Union[str, List[str]]] = ...,
        **options: Any
    ) -> None: ...
    def to_spark_io(
        self,
        path: Optional[str] = ...,
        format: Optional[str] = ...,
        mode: str = ...,
        partition_cols: Optional[Union[str, List[str]]] = ...,
        index_col: Optional[Union[str, List[str]]] = ...,
        **options: Any
    ) -> None: ...
    def explain(self, extended: Optional[Union[bool, str]] = ..., mode: Optional[str] = ...) -> None: ...
    def apply(self, func: Any, index_col: Optional[Union[str, List[str]]] = ...) -> "ks.DataFrame": ...
    def repartition(self, num_partitions: int) -> "ks.DataFrame": ...
    def coalesce(self, num_partitions: int) -> "ks.DataFrame": ...
    def checkpoint(self, eager: bool = ...) -> "ks.DataFrame": ...
    def local_checkpoint(self, eager: bool = ...) -> "ks.DataFrame": ...
    @property
    def analyzed(self) -> "ks.DataFrame": ...


class CachedSparkFrameMethods(SparkFrameMethods):
    def __init__(self, frame: Any) -> None: ...
    @property
    def storage_level(self) -> StorageLevel: ...
    def unpersist(self) -> None: ...