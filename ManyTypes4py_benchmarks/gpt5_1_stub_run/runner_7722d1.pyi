from abc import ABC, abstractmethod
import logging
from typing import Any, Dict, List, Optional, Set

_MAX_WINDOWS_WORKERS: int = ...

class AbstractRunner(ABC):
    def __init__(self, is_async: bool = False, extra_dataset_patterns: Optional[Any] = None) -> None: ...
    _is_async: bool
    _extra_dataset_patterns: Optional[Any]

    @property
    def _logger(self) -> logging.Logger: ...
    def run(self, pipeline: Any, catalog: Any, hook_manager: Optional[Any] = ..., session_id: Optional[Any] = ...) -> Dict[str, Any]: ...
    def run_only_missing(self, pipeline: Any, catalog: Any, hook_manager: Any) -> Dict[str, Any]: ...
    @abstractmethod
    def _get_executor(self, max_workers: Any) -> Any: ...
    @abstractmethod
    def _run(self, pipeline: Any, catalog: Any, hook_manager: Optional[Any] = ..., session_id: Optional[Any] = ...) -> None: ...
    @staticmethod
    def _raise_runtime_error(todo_nodes: Any, done_nodes: Any, ready: Any, done: Any) -> None: ...
    def _suggest_resume_scenario(self, pipeline: Any, done_nodes: Any, catalog: Any) -> None: ...
    @staticmethod
    def _release_datasets(node: Any, catalog: Any, load_counts: Any, pipeline: Any) -> None: ...
    def _validate_catalog(self, catalog: Any, pipeline: Any) -> None: ...
    def _validate_nodes(self, node: Any) -> None: ...
    def _set_manager_datasets(self, catalog: Any, pipeline: Any) -> None: ...
    def _get_required_workers_count(self, pipeline: Any) -> int: ...
    @classmethod
    def _validate_max_workers(cls, max_workers: Optional[int]) -> int: ...

def _find_nodes_to_resume_from(pipeline: Any, unfinished_nodes: Any, catalog: Any) -> Set[str]: ...
def _find_all_nodes_for_resumed_pipeline(pipeline: Any, unfinished_nodes: Any, catalog: Any) -> Set[Any]: ...
def _nodes_with_external_inputs(nodes_of_interest: Any) -> Set[Any]: ...
def _enumerate_non_persistent_inputs(node: Any, catalog: Any) -> Set[str]: ...
def _enumerate_nodes_with_outputs(pipeline: Any, outputs: Any) -> List[Any]: ...
def _find_initial_node_group(pipeline: Any, nodes: Any) -> List[Any]: ...
def run_node(node: Any, catalog: Any, hook_manager: Any, is_async: bool = False, session_id: Optional[Any] = None) -> Any: ...