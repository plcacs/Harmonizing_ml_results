from typing import Any, Dict, List, Optional, ClassVar

import logging

OptStr = Optional[str]
LOGGER: logging.Logger

class ChaliceDeploymentError(Exception):
    def __init__(self, error: Any) -> None: ...
    def _get_error_location(self, error: Any) -> str: ...
    def _get_error_message(self, error: Any) -> str: ...
    def _get_error_message_for_connection_error(self, connection_error: Any) -> str: ...
    def _get_error_suggestion(self, error: Any) -> Optional[str]: ...
    def _wrap_text(self, text: str, indent: str = ...) -> str: ...
    def _get_verb_from_client_method(self, client_method_name: str) -> str: ...
    def _get_mb(self, value: Any) -> str: ...

def create_plan_only_deployer(session: Any, config: Any, ui: Any) -> "Deployer": ...
def create_default_deployer(session: Any, config: Any, ui: Any) -> "Deployer": ...
def create_build_stage(osutils: Any, ui: Any, swagger_gen: Any, config: Any) -> "BuildStage": ...
def create_deletion_deployer(client: Any, ui: Any) -> "Deployer": ...

class Deployer:
    BACKEND_NAME: ClassVar[str]
    def __init__(self, application_builder: Any, deps_builder: Any, build_stage: Any, plan_stage: Any, sweeper: Any, executor: Any, recorder: Any) -> None: ...
    def deploy(self, config: Any, chalice_stage_name: str) -> Dict[str, Any]: ...
    def _deploy(self, config: Any, chalice_stage_name: str) -> Dict[str, Any]: ...
    def _validate_config(self, config: Any) -> None: ...

class BaseDeployStep:
    def handle(self, config: Any, resource: Any) -> None: ...

class InjectDefaults(BaseDeployStep):
    def __init__(self, lambda_timeout: Any = ..., lambda_memory_size: Any = ..., tls_version: Any = ...) -> None: ...
    def handle_lambdafunction(self, config: Any, resource: Any) -> None: ...
    def handle_domainname(self, config: Any, resource: Any) -> None: ...

class DeploymentPackager(BaseDeployStep):
    def __init__(self, packager: Any) -> None: ...
    def handle_deploymentpackage(self, config: Any, resource: Any) -> None: ...

class ManagedLayerDeploymentPackager(BaseDeployStep):
    def __init__(self, lambda_packager: Any, layer_packager: Any) -> None: ...
    def handle_lambdafunction(self, config: Any, resource: Any) -> None: ...
    def handle_lambdalayer(self, config: Any, resource: Any) -> None: ...

class SwaggerBuilder(BaseDeployStep):
    def __init__(self, swagger_generator: Any) -> None: ...
    def handle_restapi(self, config: Any, resource: Any) -> None: ...

class LambdaEventSourcePolicyInjector(BaseDeployStep):
    def __init__(self) -> None: ...
    def handle_sqseventsource(self, config: Any, resource: Any) -> None: ...
    def handle_kinesiseventsource(self, config: Any, resource: Any) -> None: ...
    def handle_dynamodbeventsource(self, config: Any, resource: Any) -> None: ...
    def _needs_policy_injected(self, role: Any) -> bool: ...
    def _inject_trigger_policy(self, document: Any, policy: Any) -> None: ...

class WebsocketPolicyInjector(BaseDeployStep):
    def __init__(self) -> None: ...
    def handle_websocketapi(self, config: Any, resource: Any) -> None: ...
    def _inject_into_function(self, config: Any, lambda_function: Any) -> None: ...
    def _inject_policy(self, document: Any, policy: Any) -> None: ...

class PolicyGenerator(BaseDeployStep):
    def __init__(self, policy_gen: Any, osutils: Any) -> None: ...
    def _read_document_from_file(self, filename: str) -> Any: ...
    def handle_filebasediampolicy(self, config: Any, resource: Any) -> None: ...
    def handle_restapi(self, config: Any, resource: Any) -> None: ...
    def handle_autogeniampolicy(self, config: Any, resource: Any) -> None: ...

class BuildStage:
    def __init__(self, steps: Any) -> None: ...
    def execute(self, config: Any, resources: Any) -> None: ...

class ResultsRecorder:
    def __init__(self, osutils: Any) -> None: ...
    def record_results(self, results: Dict[str, Any], chalice_stage_name: str, project_dir: str) -> None: ...

class NoopResultsRecorder(ResultsRecorder):
    def record_results(self, results: Dict[str, Any], chalice_stage_name: str, project_dir: str) -> None: ...

class DeploymentReporter:
    _SORT_ORDER: ClassVar[Dict[str, int]]
