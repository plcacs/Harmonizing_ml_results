from __future__ import annotations
import abc
from typing import Any, Callable, Dict, Generic, List, Optional, Type, TypeVar
from uuid import UUID
from pydantic import BaseModel
from typing_extensions import Self
from prefect.events import Event, RelatedResource
from prefect.logging.loggers import PrefectLogAdapter
from prefect.client.schemas.objects import WorkerMetadata

class BaseJobConfiguration(BaseModel):
    command: Optional[str]
    env: Dict[str, Optional[str]]
    labels: Dict[str, Any]
    name: Optional[str]
    _related_objects: Dict[str, Any]

    @property
    def is_using_a_runner(self) -> bool: ...
    @classmethod
    def _coerce_command(cls, v: Any) -> Any: ...
    @classmethod
    def _coerce_env(cls, v: Dict[str, Any]) -> Dict[str, Optional[str]]: ...
    @staticmethod
    def _get_base_config_defaults(variables: Dict[str, Any]) -> Dict[str, Any]: ...
    @classmethod
    async def from_template_and_values(cls, base_job_template: Dict[str, Any], values: Dict[str, Any], client: Any = ...) -> Self: ...
    @classmethod
    def json_template(cls) -> Dict[str, Any]: ...
    def prepare_for_flow_run(self, flow_run: Any, deployment: Any = ..., flow: Any = ...) -> None: ...
    @staticmethod
    def _base_flow_run_command() -> str: ...
    @staticmethod
    def _base_flow_run_labels(flow_run: Any) -> Dict[str, str]: ...
    @classmethod
    def _base_environment(cls) -> Dict[str, Any]: ...
    @staticmethod
    def _base_flow_run_environment(flow_run: Any) -> Dict[str, str]: ...
    @staticmethod
    def _base_deployment_labels(deployment: Any) -> Dict[str, str]: ...
    @staticmethod
    def _base_flow_labels(flow: Any) -> Dict[str, str]: ...
    def _related_resources(self) -> List[Any]: ...

class BaseVariables(BaseModel):
    name: Optional[str]
    env: Dict[str, Optional[str]]
    labels: Dict[str, Any]
    command: Optional[str]

    @classmethod
    def model_json_schema(cls, by_alias: bool = ..., ref_template: str = ..., schema_generator: Any = ..., mode: str = ...) -> Dict[str, Any]: ...

class BaseWorkerResult(BaseModel, abc.ABC):
    def __bool__(self) -> bool: ...

C = TypeVar("C", bound=BaseJobConfiguration)
V = TypeVar("V", bound=BaseVariables)
R = TypeVar("R", bound=BaseWorkerResult)

class BaseWorker(abc.ABC, Generic[C, V, R]):
    job_configuration: Type[BaseJobConfiguration] = ...
    job_configuration_variables: Optional[Type[BaseVariables]] = ...
    _documentation_url: str = ...
    _logo_url: str = ...
    _description: str = ...

    def __init__(
        self,
        work_pool_name: str,
        work_queues: Optional[List[str]] = ...,
        name: Optional[str] = ...,
        prefetch_seconds: Optional[int] = ...,
        create_pool_if_not_found: bool = ...,
        limit: Optional[int] = ...,
        heartbeat_interval_seconds: Optional[int] = ...,
        *,
        base_job_template: Optional[Dict[str, Any]] = ...,
    ) -> None: ...
    @classmethod
    def get_documentation_url(cls) -> str: ...
    @classmethod
    def get_logo_url(cls) -> str: ...
    @classmethod
    def get_description(cls) -> str: ...
    @classmethod
    def get_default_base_job_template(cls) -> Dict[str, Any]: ...
    @staticmethod
    def get_worker_class_from_type(type: str) -> Optional[Type["BaseWorker[Any, Any, Any]"]]: ...
    @staticmethod
    def get_all_available_worker_types() -> List[str]: ...
    def get_name_slug(self) -> str: ...
    def get_flow_run_logger(self, flow_run: Any) -> PrefectLogAdapter: ...
    async def start(self, run_once: bool = ..., with_healthcheck: bool = ..., printer: Callable[..., Any] = ...) -> None: ...
    @abc.abstractmethod
    async def run(self, flow_run: Any, configuration: C, task_status: Any = ...) -> R: ...
    @classmethod
    def __dispatch_key__(cls) -> Optional[str]: ...
    async def setup(self) -> None: ...
    async def teardown(self, *exc_info: Any) -> None: ...
    def is_worker_still_polling(self, query_interval_seconds: int) -> bool: ...
    async def get_and_submit_flow_runs(self) -> List[Any]: ...
    async def _update_local_work_pool_info(self) -> None: ...
    async def _worker_metadata(self) -> Optional[WorkerMetadata]: ...
    async def _send_worker_heartbeat(self) -> Optional[UUID]: ...
    async def sync_with_backend(self) -> None: ...
    def _should_get_worker_id(self) -> bool: ...
    async def _get_scheduled_flow_runs(self) -> List[Any]: ...
    async def _submit_scheduled_flow_runs(self, flow_run_response: List[Any]) -> List[Any]: ...
    async def _check_flow_run(self, flow_run: Any) -> None: ...
    async def _submit_run(self, flow_run: Any) -> None: ...
    async def _submit_run_and_capture_errors(self, flow_run: Any, task_status: Any = ...) -> Any: ...
    def _release_limit_slot(self, flow_run_id: Any) -> None: ...
    def get_status(self) -> Dict[str, Any]: ...
    async def _get_configuration(self, flow_run: Any, deployment: Any = ...) -> C: ...
    async def _propose_pending_state(self, flow_run: Any) -> bool: ...
    async def _propose_failed_state(self, flow_run: Any, exc: BaseException) -> None: ...
    async def _propose_crashed_state(self, flow_run: Any, message: str) -> None: ...
    async def _mark_flow_run_as_cancelled(self, flow_run: Any, state_updates: Optional[Dict[str, Any]] = ...) -> None: ...
    async def _set_work_pool_template(self, work_pool: Any, job_template: Dict[str, Any]) -> None: ...
    async def _schedule_task(self, __in_seconds: float, fn: Callable[..., Any], *args: Any, **kwargs: Any) -> None: ...
    async def _give_worker_labels_to_flow_run(self, flow_run_id: Any) -> None: ...
    async def __aenter__(self) -> Self: ...
    async def __aexit__(self, *exc_info: Any) -> None: ...
    def __repr__(self) -> str: ...
    def _event_resource(self) -> Dict[str, str]: ...
    def _event_related_resources(self, configuration: Optional[Any] = ..., include_self: bool = ...) -> List[RelatedResource]: ...
    def _emit_flow_run_submitted_event(self, configuration: Any) -> Event: ...
    def _emit_flow_run_executed_event(self, result: Any, configuration: Any, submitted_event: Event) -> None: ...
    async def _emit_worker_started_event(self) -> Event: ...
    async def _emit_worker_stopped_event(self, started_event: Event) -> None: ...