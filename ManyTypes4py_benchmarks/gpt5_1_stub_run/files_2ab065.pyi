from typing import Any, Dict, List, Optional, Tuple, Union
from mashumaro.types import SerializableType
from dbt_common.dataclass_schema import StrEnum, dbtClassMixin

class ParseFileType(StrEnum):
    Macro: "ParseFileType"
    Model: "ParseFileType"
    Snapshot: "ParseFileType"
    Analysis: "ParseFileType"
    SingularTest: "ParseFileType"
    GenericTest: "ParseFileType"
    Seed: "ParseFileType"
    Documentation: "ParseFileType"
    Schema: "ParseFileType"
    Hook: "ParseFileType"
    Fixture: "ParseFileType"

parse_file_type_to_parser: Dict[ParseFileType, str]

class FilePath(dbtClassMixin):
    project_root: Any
    searched_path: Any
    relative_path: Any

    @property
    def search_key(self) -> str: ...
    @property
    def full_path(self) -> str: ...
    @property
    def absolute_path(self) -> str: ...
    @property
    def original_file_path(self) -> str: ...
    def seed_too_large(self) -> bool: ...

class RemoteFile(dbtClassMixin):
    path_end: str
    path: str

    def __init__(self, language: str) -> None: ...
    @property
    def searched_path(self) -> str: ...
    @property
    def relative_path(self) -> str: ...
    @property
    def absolute_path(self) -> str: ...
    @property
    def original_file_path(self) -> str: ...
    @property
    def modification_time(self) -> str: ...

class BaseSourceFile(dbtClassMixin, SerializableType):
    project_name: Any
    parse_file_type: Any
    contents: Any
    path: Any
    checksum: Any

    @property
    def file_id(self) -> Optional[str]: ...
    @property
    def original_file_path(self) -> str: ...
    def _serialize(self) -> Any: ...
    @classmethod
    def _deserialize(cls, dct: Dict[str, Any]) -> Any: ...
    def __post_serialize__(self, dct: Dict[str, Any], context: Optional[Any] = ...) -> Any: ...

class SourceFile(BaseSourceFile):
    nodes: List[Any]
    docs: List[Any]
    macros: List[Any]
    env_vars: List[Any]

    @classmethod
    def big_seed(cls, path: Any) -> "SourceFile": ...
    def add_node(self, value: Any) -> None: ...
    @classmethod
    def remote(cls, contents: Any, project_name: Any, language: Any) -> "SourceFile": ...

class SchemaSourceFile(BaseSourceFile):
    dfy: Dict[str, Any]
    data_tests: Dict[str, Any]
    sources: List[Any]
    exposures: List[Any]
    metrics: List[Any]
    snapshots: List[Any]
    generated_metrics: List[Any]
    metrics_from_measures: Dict[str, Any]
    groups: List[Any]
    ndp: List[Any]
    semantic_models: List[Any]
    unit_tests: List[Any]
    saved_queries: List[Any]
    mcp: Dict[str, Any]
    sop: List[Any]
    env_vars: Dict[str, Any]
    unrendered_configs: Dict[str, Any]
    unrendered_databases: Dict[str, Any]
    unrendered_schemas: Dict[str, Any]
    pp_dict: Any
    pp_test_index: Any

    @property
    def dict_from_yaml(self) -> Any: ...
    @property
    def node_patches(self) -> Any: ...
    @property
    def macro_patches(self) -> Any: ...
    @property
    def source_patches(self) -> Any: ...
    def __post_serialize__(self, dct: Dict[str, Any], context: Optional[Any] = ...) -> Any: ...
    def append_patch(self, yaml_key: Any, unique_id: Any) -> None: ...
    def add_test(self, node_unique_id: Any, test_from: Any) -> None: ...
    def remove_tests(self, yaml_key: Any, name: Any) -> None: ...
    def get_tests(self, yaml_key: Any, name: Any) -> List[Any]: ...
    def add_metrics_from_measures(self, semantic_model_name: Any, metric_unique_id: Any) -> None: ...
    def fix_metrics_from_measures(self) -> None: ...
    def get_key_and_name_for_test(self, test_unique_id: Any) -> Tuple[Any, Any]: ...
    def get_all_test_ids(self) -> List[Any]: ...
    def add_unrendered_config(self, unrendered_config: Any, yaml_key: Any, name: Any, version: Optional[Any] = ...) -> None: ...
    def get_unrendered_config(self, yaml_key: Any, name: Any, version: Optional[Any] = ...) -> Any: ...
    def delete_from_unrendered_configs(self, yaml_key: Any, name: Any) -> None: ...
    def add_env_var(self, var: Any, yaml_key: Any, name: Any) -> None: ...
    def delete_from_env_vars(self, yaml_key: Any, name: Any) -> None: ...
    def add_unrendered_database(self, yaml_key: Any, name: Any, unrendered_database: Any) -> None: ...
    def get_unrendered_database(self, yaml_key: Any, name: Any) -> Any: ...
    def add_unrendered_schema(self, yaml_key: Any, name: Any, unrendered_schema: Any) -> None: ...
    def get_unrendered_schema(self, yaml_key: Any, name: Any) -> Any: ...

class FixtureSourceFile(BaseSourceFile):
    fixture: Any
    unit_tests: List[Any]

    def add_unit_test(self, value: Any) -> None: ...

AnySourceFile = Union[SchemaSourceFile, SourceFile, FixtureSourceFile]