from typing import Any, Callable, List, Optional

class CachePolicy:
    key_storage: Any
    isolation_level: Any
    lock_manager: Any
    @classmethod
    def from_cache_key_fn(cls, cache_key_fn: Callable[..., Any]) -> "CacheKeyFnPolicy": ...
    def configure(self, key_storage: Optional[Any] = ..., lock_manager: Optional[Any] = ..., isolation_level: Optional[Any] = ...) -> "CachePolicy": ...
    def compute_key(self, task_ctx: Any, inputs: Any, flow_parameters: Any, **kwargs: Any) -> Optional[str]: ...
    def __sub__(self, other: str) -> "CachePolicy": ...
    def __add__(self, other: "CachePolicy") -> "CachePolicy": ...

class CacheKeyFnPolicy(CachePolicy):
    cache_key_fn: Any
    def compute_key(self, task_ctx: Any, inputs: Any, flow_parameters: Any, **kwargs: Any) -> Optional[str]: ...

class CompoundCachePolicy(CachePolicy):
    policies: List[CachePolicy]
    def __post_init__(self) -> None: ...
    def compute_key(self, task_ctx: Any, inputs: Any, flow_parameters: Any, **kwargs: Any) -> Optional[str]: ...
    def __add__(self, other: "CachePolicy") -> "CompoundCachePolicy": ...
    def __sub__(self, other: str) -> "CompoundCachePolicy": ...

class _None(CachePolicy):
    def compute_key(self, task_ctx: Any, inputs: Any, flow_parameters: Any, **kwargs: Any) -> Optional[str]: ...
    def __add__(self, other: "CachePolicy") -> "CachePolicy": ...

class TaskSource(CachePolicy):
    def compute_key(self, task_ctx: Any, inputs: Any, flow_parameters: Any, **kwargs: Any) -> Optional[str]: ...

class FlowParameters(CachePolicy):
    def compute_key(self, task_ctx: Any, inputs: Any, flow_parameters: Any, **kwargs: Any) -> Optional[str]: ...

class RunId(CachePolicy):
    def compute_key(self, task_ctx: Any, inputs: Any, flow_parameters: Any, **kwargs: Any) -> Optional[str]: ...

class Inputs(CachePolicy):
    exclude: List[str]
    def compute_key(self, task_ctx: Any, inputs: Any, flow_parameters: Any, **kwargs: Any) -> Optional[str]: ...
    def __sub__(self, other: str) -> "Inputs": ...

INPUTS: Inputs = ...
NONE: _None = ...
NO_CACHE: _None = ...
TASK_SOURCE: TaskSource = ...
FLOW_PARAMETERS: FlowParameters = ...
RUN_ID: RunId = ...
DEFAULT: CachePolicy = ...