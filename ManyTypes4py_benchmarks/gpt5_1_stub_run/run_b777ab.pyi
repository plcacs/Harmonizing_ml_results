from typing import Any, Optional, Iterable, List, Dict, Tuple, AbstractSet, Type
from dbt.task.compile import CompileRunner, CompileTask

class BiggestName(str):
    def __lt__(self, other: Any) -> bool: ...
    def __eq__(self, other: Any) -> bool: ...

def _hook_list() -> List[Any]: ...
def get_hooks_by_tags(nodes: Iterable[Any], match_tags: AbstractSet[Any]) -> List[Any]: ...
def get_hook(source: Any, index: int) -> Any: ...
def get_execution_status(sql: str, adapter: Any) -> Tuple[Any, str]: ...
def _get_adapter_info(adapter: Any, run_model_result: Any) -> Dict[str, Any]: ...
def track_model_run(index: int, num_nodes: int, run_model_result: Any, adapter: Optional[Any] = ...) -> None: ...
def _validate_materialization_relations_dict(inp: Dict[str, Any], model: Any) -> List[Any]: ...

class ModelRunner(CompileRunner):
    def get_node_representation(self) -> str: ...
    def describe_node(self) -> str: ...
    def print_start_line(self) -> None: ...
    def print_result_line(self, result: Any) -> None: ...
    def before_execute(self) -> None: ...
    def after_execute(self, result: Any) -> None: ...
    def _build_run_model_result(self, model: Any, context: Dict[str, Any], elapsed_time: float = ...) -> Any: ...
    def _materialization_relations(self, result: Any, model: Any) -> List[Any]: ...
    def _execute_model(self, hook_ctx: Any, context_config: Any, model: Any, context: Dict[str, Any], materialization_macro: Any) -> Any: ...
    def execute(self, model: Any, manifest: Any) -> Any: ...

class MicrobatchModelRunner(ModelRunner):
    batch_idx: Optional[int]
    batches: Dict[int, Any]
    relation_exists: bool

    def __init__(self, config: Any, adapter: Any, node: Any, node_index: int, num_nodes: int) -> None: ...
    def compile(self, manifest: Any) -> Any: ...
    def set_batch_idx(self, batch_idx: Optional[int]) -> None: ...
    def set_relation_exists(self, relation_exists: bool) -> None: ...
    def set_batches(self, batches: Dict[int, Any]) -> None: ...
    @property
    def batch_start(self) -> Optional[Any]: ...
    def describe_node(self) -> str: ...
    def describe_batch(self) -> str: ...
    def print_batch_result_line(self, result: Any) -> None: ...
    def print_batch_start_line(self) -> None: ...
    def before_execute(self) -> None: ...
    def after_execute(self, result: Any) -> None: ...
    def merge_batch_results(self, result: Any, batch_results: List[Any]) -> None: ...
    def on_skip(self) -> Any: ...
    def _build_succesful_run_batch_result(self, model: Any, context: Dict[str, Any], batch: Any, elapsed_time: float = ...) -> Any: ...
    def _build_failed_run_batch_result(self, model: Any, batch: Any, elapsed_time: float = ...) -> Any: ...
    def _build_run_microbatch_model_result(self, model: Any) -> Any: ...
    def _execute_microbatch_materialization(self, model: Any, context: Dict[str, Any], materialization_macro: Any) -> Any: ...
    def _has_relation(self, model: Any) -> bool: ...
    def should_run_in_parallel(self) -> bool: ...
    def _is_incremental(self, model: Any) -> bool: ...
    def _execute_model(self, hook_ctx: Any, context_config: Any, model: Any, context: Dict[str, Any], materialization_macro: Any) -> Any: ...

class RunTask(CompileTask):
    def __init__(self, args: Any, config: Any, manifest: Any, batch_map: Optional[Dict[str, Any]] = ...) -> None: ...
    def raise_on_first_error(self) -> bool: ...
    def get_hook_sql(self, adapter: Any, hook: Any, idx: int, num_hooks: int, extra_context: Dict[str, Any]) -> str: ...
    def handle_job_queue(self, pool: Any, callback: Any) -> None: ...
    def handle_microbatch_model(self, runner: Any, pool: Any) -> Any: ...
    def _submit_batch(self, node: Any, adapter: Any, relation_exists: bool, batches: Dict[int, Any], batch_idx: int, batch_results: List[Any], pool: Any, force_sequential_run: bool = ..., skip: bool = ...) -> bool: ...
    def _hook_keyfunc(self, hook: Any) -> Tuple[Any, Any]: ...
    def get_hooks_by_type(self, hook_type: Any) -> List[Any]: ...
    def safe_run_hooks(self, adapter: Any, hook_type: Any, extra_context: Dict[str, Any]) -> Any: ...
    def print_results_line(self, results: List[Any], execution_time: Optional[float]) -> None: ...
    def populate_microbatch_batches(self, selected_uids: Iterable[str]) -> None: ...
    def before_run(self, adapter: Any, selected_uids: Iterable[str]) -> Any: ...
    def after_run(self, adapter: Any, results: List[Any]) -> None: ...
    def get_node_selector(self) -> Any: ...
    def get_runner_type(self, node: Any) -> Type[Any]: ...
    def task_end_messages(self, results: List[Any]) -> None: ...