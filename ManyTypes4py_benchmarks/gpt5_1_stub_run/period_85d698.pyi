from typing import Any, Optional, Tuple

class PeriodIndex:
    _typ: str
    _data_cls: Any
    _supports_partial_string_indexing: bool

    @property
    def _engine_type(self) -> Any: ...
    @property
    def _resolution_obj(self) -> Any: ...

    def asfreq(self, freq: Any = ..., how: str = ...) -> "PeriodIndex": ...
    def to_timestamp(self, freq: Any = ..., how: str = ...) -> Any: ...

    @property
    def hour(self) -> Any: ...
    @property
    def minute(self) -> Any: ...
    @property
    def second(self) -> Any: ...

    def __new__(cls, data: Any = ..., freq: Any = ..., dtype: Any = ..., copy: bool = ..., name: Optional[str] = ...) -> "PeriodIndex": ...
    @classmethod
    def from_fields(
        cls,
        *,
        year: Any = ...,
        quarter: Any = ...,
        month: Any = ...,
        day: Any = ...,
        hour: Any = ...,
        minute: Any = ...,
        second: Any = ...,
        freq: Any = ...
    ) -> "PeriodIndex": ...
    @classmethod
    def from_ordinals(cls, ordinals: Any, *, freq: Any, name: Optional[str] = ...) -> "PeriodIndex": ...

    @property
    def values(self) -> Any: ...

    def _maybe_convert_timedelta(self, other: Any) -> Any: ...
    def _is_comparable_dtype(self, dtype: Any) -> bool: ...
    def asof_locs(self, where: Any, mask: Any) -> Any: ...

    @property
    def is_full(self) -> bool: ...
    @property
    def inferred_type(self) -> str: ...

    def _convert_tolerance(self, tolerance: Any, target: Any) -> Any: ...
    def get_loc(self, key: Any) -> Any: ...
    def _disallow_mismatched_indexing(self, key: Any) -> None: ...
    def _cast_partial_indexing_scalar(self, label: Any) -> Any: ...
    def _maybe_cast_slice_bound(self, label: Any, side: Any) -> Any: ...
    def _parsed_string_to_bounds(self, reso: Any, parsed: Any) -> Tuple[Any, Any]: ...

    def shift(self, periods: int = ..., freq: Any = ...) -> "PeriodIndex": ...

def period_range(
    start: Any = ...,
    end: Any = ...,
    periods: Optional[int] = ...,
    freq: Any = ...,
    name: Optional[str] = ...
) -> PeriodIndex: ...