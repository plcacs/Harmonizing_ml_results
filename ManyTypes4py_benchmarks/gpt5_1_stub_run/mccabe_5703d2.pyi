from typing import Any, DefaultDict, Dict, Iterator, List, Optional, Sequence, Tuple, Type
import ast

__version__: str = ...

class ASTVisitor(object):
    node: Any
    _cache: Dict[type, Any]
    visitor: Any
    def __init__(self) -> None: ...
    def default(self, node: Any, *args: Any) -> None: ...
    def dispatch(self, node: Any, *args: Any) -> Any: ...
