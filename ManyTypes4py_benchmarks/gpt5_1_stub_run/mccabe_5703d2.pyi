    def __init__(self, name: str, entity: str, lineno: int, column: int = ...) -> None: ...
    def connect(self, n1: PathNode, n2: PathNode) -> None: ...
    def to_dot(self) -> None: ...
    def complexity(self) -> int: ...

class PathGraphingAstVisitor(ASTVisitor):
    classname: str
    graphs: Dict[str, PathGraph]
    graph: Optional[PathGraph]
    tail: Optional[PathNode]
    def __init__(self) -> None: ...
    def reset(self) -> None: ...
    def dispatch_list(self, node_list: List[Any]) -> None: ...
    def visitFunctionDef(self, node: ast.AST) -> None: ...
    def visitAsyncFunctionDef(self, node: ast.AST) -> None: ...
    def visitClassDef(self, node: ast.AST) -> None: ...
    def appendPathNode(self, name: str) -> Optional[PathNode]: ...
    def visitSimpleStatement(self, node: Any) -> None: ...
    def default(self, node: Any, *args: Any) -> None: ...
    def visitLoop(self, node: Any) -> None: ...
    def visitAsyncFor(self, node: Any) -> None: ...
    def visitFor(self, node: Any) -> None: ...
    def visitWhile(self, node: Any) -> None: ...
    def visitIf(self, node: Any) -> None: ...
    def _subgraph(self, node: Any, name: str, extra_blocks: Any = ...) -> None: ...
    def _subgraph_parse(self, node: Any, pathnode: PathNode, extra_blocks: Any) -> None: ...
    def visitTryExcept(self, node: Any) -> None: ...
    def visitTry(self, node: Any) -> None: ...
    def visitWith(self, node: Any) -> None: ...
    def visitAsyncWith(self, node: Any) -> None: ...

