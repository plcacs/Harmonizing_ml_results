class PrngProvider(PrimitiveProvider):
    def __init__(self, conjecturedata: Any, /) -> None: ...
    def draw_boolean(self, p: float = ...) -> bool: ...
    def draw_integer(
        self,
        min_value: Optional[int] = ...,
        max_value: Optional[int] = ...,
        *,
        weights: Optional[Any] = ...,
        shrink_towards: int = ...,
    ) -> int: ...
    def draw_float(
        self,
        *,
        min_value: float = ...,
        max_value: float = ...,
        allow_nan: bool = ...,
        smallest_nonzero_magnitude: float,
    ) -> float: ...
    def draw_string(self, intervals: Any, *, min_size: int = ..., max_size: Optional[int] = ...) -> str: ...
    def draw_bytes(self, min_size: int = ..., max_size: Optional[int] = ...) -> bytes: ...

class TrivialProvider(PrimitiveProvider):
    def draw_integer(self, *args: Any, **kwargs: Any) -> int: ...
    def draw_boolean(self, *args: Any, **kwargs: Any) -> bool: ...
    def draw_float(self, *args: Any, **kwargs: Any) -> float: ...
    def draw_bytes(self, *args: Any, **kwargs: Any) -> bytes: ...
    def draw_string(self, *args: Any, **kwargs: Any) -> str: ...

