from __future__ import annotations

from datetime import timedelta
from typing import Any, Callable, Iterable, Optional, Union

from homeassistant.config_entries import ConfigEntry
from homeassistant.core import HomeAssistant
from .models import Event, PullPointManagerState, WebHookManagerState

UNHANDLED_TOPICS: set[str] = ...
SUBSCRIPTION_ERRORS: tuple[type[BaseException], ...] = ...
CREATE_ERRORS: tuple[type[BaseException], ...] = ...
SET_SYNCHRONIZATION_POINT_ERRORS: tuple[type[BaseException], ...] = ...
UNSUBSCRIBE_ERRORS: tuple[type[BaseException], ...] = ...
RENEW_ERRORS: tuple[type[BaseException], ...] = ...
SUBSCRIPTION_TIME: timedelta = ...
SUBSCRIPTION_RENEW_INTERVAL: int = ...
SUBSCRIPTION_ATTEMPTS: int = ...
SUBSCRIPTION_RESTART_INTERVAL_ON_ERROR: int = ...
PULLPOINT_POLL_TIME: timedelta = ...
PULLPOINT_MESSAGE_LIMIT: int = ...
PULLPOINT_COOLDOWN_TIME: float = ...


class EventManager:
    def __init__(self, hass: HomeAssistant, device: Any, config_entry: ConfigEntry, name: str) -> None: ...
    hass: HomeAssistant
    device: Any
    config_entry: ConfigEntry
    unique_id: Optional[str]
    name: str
    webhook_manager: WebHookManager
    pullpoint_manager: PullPointManager

    @property
    def started(self) -> bool: ...

    def async_add_listener(self, update_callback: Callable[[], None]) -> Callable[[], None]: ...
    def async_remove_listener(self, update_callback: Callable[[], None]) -> None: ...
    async def async_start(self, try_pullpoint: bool, try_webhook: bool) -> bool: ...
    async def async_stop(self) -> None: ...
    def async_callback_listeners(self) -> None: ...
    async def async_parse_messages(self, messages: Iterable[Any]) -> None: ...
    def get_uid(self, uid: Any) -> Optional[Event]: ...
    def get_platform(self, platform: Any) -> list[Event]: ...
    def get_uids_by_platform(self, platform: str) -> set[str]: ...
    def async_webhook_failed(self) -> None: ...
    def async_webhook_working(self) -> None: ...
    def async_mark_events_stale(self) -> None: ...


class PullPointManager:
    state: PullPointManagerState

    def __init__(self, event_manager: EventManager) -> None: ...
    async def async_start(self) -> bool: ...
    def async_pause(self) -> None: ...
    def async_resume(self) -> None: ...
    async def async_stop(self) -> None: ...
    def async_cancel_pull_messages(self) -> None: ...
    def async_schedule_pull_messages(self, delay: Optional[Union[float, timedelta]] = ...) -> None: ...


class WebHookManager:
    state: WebHookManagerState

    def __init__(self, event_manager: EventManager) -> None: ...
    async def async_start(self) -> bool: ...
    async def async_stop(self) -> None: ...