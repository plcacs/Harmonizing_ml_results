from typing import Any, List, Optional, Type
from pypinyin.contrib.uv import V2UMixin
from pypinyin.contrib.neutral_tone import NeutralToneWith5Mixin
from pypinyin.contrib.tone_sandhi import ToneSandhiMixin

class Converter(object):
    def convert(self, words: Any, style: Any, heteronym: bool, errors: Any, strict: bool, **kwargs: Any) -> List[Any]: ...

class DefaultConverter(Converter):
    def __init__(self, **kwargs: Any) -> None: ...
    def convert(self, words: Any, style: Any, heteronym: bool, errors: Any, strict: bool, **kwargs: Any) -> List[Any]: ...
    def pre_convert_style(self, han: Any, orig_pinyin: Any, style: Any, strict: bool, **kwargs: Any) -> Optional[Any]: ...
    def convert_style(self, han: Any, orig_pinyin: Any, style: Any, strict: bool, **kwargs: Any) -> Any: ...
    def post_convert_style(self, han: Any, orig_pinyin: Any, converted_pinyin: Any, style: Any, strict: bool, **kwargs: Any) -> Optional[Any]: ...
    def pre_handle_nopinyin(self, chars: Any, style: Any, heteronym: bool, errors: Any, strict: bool, **kwargs: Any) -> Optional[Any]: ...
    def handle_nopinyin(self, chars: Any, style: Any, heteronym: bool, errors: Any, strict: bool, **kwargs: Any) -> List[Any]: ...
    def post_handle_nopinyin(self, chars: Any, style: Any, heteronym: bool, errors: Any, strict: bool, pinyin: Any, **kwargs: Any) -> Optional[Any]: ...
    def post_pinyin(self, han: Any, heteronym: bool, pinyin: Any, **kwargs: Any) -> Optional[Any]: ...
    def _phrase_pinyin(self, phrase: Any, style: Any, heteronym: bool, errors: Any, strict: bool) -> List[Any]: ...
    def convert_styles(self, pinyin_list: List[Any], phrase: Any, style: Any, heteronym: bool, errors: Any, strict: bool, **kwargs: Any) -> List[Any]: ...
    def _single_pinyin(self, han: Any, style: Any, heteronym: bool, errors: Any, strict: bool) -> List[Any]: ...
    def _convert_style(self, han: Any, pinyin: Any, style: Any, strict: bool, default: Any, **kwargs: Any) -> Any: ...
    def _convert_nopinyin_chars(self, chars: Any, style: Any, heteronym: bool, errors: Any, strict: bool) -> Any: ...

class _v2UConverter(V2UMixin, DefaultConverter): ...

class _neutralToneWith5Converter(NeutralToneWith5Mixin, DefaultConverter): ...

class _toneSandhiConverter(ToneSandhiMixin, DefaultConverter): ...

class UltimateConverter(DefaultConverter):
    def __init__(self, v_to_u: bool = ..., neutral_tone_with_five: bool = ..., tone_sandhi: bool = ..., **kwargs: Any) -> None: ...
    def post_convert_style(self, han: Any, orig_pinyin: Any, converted_pinyin: Any, style: Any, strict: bool, **kwargs: Any) -> Optional[Any]: ...
    def post_pinyin(self, han: Any, heteronym: bool, pinyin: Any, **kwargs: Any) -> Optional[Any]: ...

_mixConverter: Type[UltimateConverter] = ...