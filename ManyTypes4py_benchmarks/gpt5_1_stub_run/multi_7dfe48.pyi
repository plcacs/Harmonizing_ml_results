        codes: Any = ...,
        sortorder: Any = ...,
        names: Any = ...,
        dtype: Any = ...,
        copy: bool = ...,
        name: Any = ...,
        verify_integrity: bool = ...,
    ) -> "MultiIndex": ...
    @property
    def _internal(self) -> Any: ...
    @property
    def _column_label(self) -> Any: ...
    def __abs__(self) -> Any: ...
    def _with_new_scol(self, scol: Any, *, dtype: Any = ...) -> Any: ...
    def _align_and_column_op(self, f: Any, *args: Any) -> Any: ...
    def any(self, *args: Any, **kwargs: Any) -> Any: ...
    def all(self, *args: Any, **kwargs: Any) -> Any: ...
    @staticmethod
    def from_tuples(tuples: Any, sortorder: Any = ..., names: Any = ...) -> "MultiIndex": ...
    @staticmethod
    def from_arrays(arrays: Any, sortorder: Any = ..., names: Any = ...) -> "MultiIndex": ...
    @staticmethod
    def from_product(iterables: Any, sortorder: Any = ..., names: Any = ...) -> "MultiIndex": ...
    @staticmethod
    def from_frame(df: DataFrame, names: Any = ...) -> "MultiIndex": ...
