    def argmax(self) -> Any: ...
    def argmin(self) -> Any: ...
    def asof(self, label: Any) -> Any: ...
    @property
    def is_all_dates(self) -> bool: ...
    def __getattr__(self, item: str) -> Any: ...
    def _get_level_number(self, level: Any) -> int: ...
    def get_level_values(self, level: Any) -> Index: ...
    def insert(self, loc: int, item: Any) -> "MultiIndex": ...
    def item(self) -> Tuple[Any, ...]: ...
    def intersection(self, other: Any) -> "MultiIndex": ...
