from typing import Any, Awaitable, Callable, Dict, Iterable, List, Mapping, Optional, Pattern, Sequence, Set, Tuple, TypeVar
from enum import Enum
from starlette.convertors import Convertor
from starlette.datastructures import URLPath
from starlette.middleware import Middleware
from starlette.requests import Request
from starlette.types import ASGIApp, Lifespan, Receive, Scope, Send

class NoMatchFound(Exception):
    def __init__(self, name: str, path_params: Mapping[str, Any]) -> None: ...

class Match(Enum):
    NONE: Any
    PARTIAL: Any
    FULL: Any

def iscoroutinefunction_or_partial(obj: Any) -> bool: ...
def request_response(func: Callable[..., Any]) -> ASGIApp: ...
def websocket_session(func: Callable[..., Any]) -> ASGIApp: ...
def get_name(endpoint: Any) -> str: ...
def replace_params(path: str, param_convertors: Mapping[str, Convertor], path_params: Dict[str, Any]) -> Tuple[str, Dict[str, Any]]: ...
PARAM_REGEX: Pattern[str]
def compile_path(path: str) -> Tuple[Pattern[str], str, Dict[str, Convertor]]: ...

class BaseRoute:
    def matches(self, scope: Scope) -> Tuple[Match, Dict[str, Any]]: ...
    def url_path_for(self, name, /, **path_params: Any) -> URLPath: ...
    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None: ...

class Route(BaseRoute):
    path: str
    endpoint: Any
    name: str
    include_in_schema: bool
    app: ASGIApp
    methods: Optional[Set[str]]
    path_regex: Pattern[str]
    path_format: str
    param_convertors: Dict[str, Convertor]
    def __init__(self, path: str, endpoint: Any, *, methods: Optional[Iterable[str]] = ..., name: Optional[str] = ..., include_in_schema: bool = ..., middleware: Optional[Sequence[Middleware]] = ...) -> None: ...
    def matches(self, scope: Scope) -> Tuple[Match, Dict[str, Any]]: ...
    def url_path_for(self, name, /, **path_params: Any) -> URLPath: ...
    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def __eq__(self, other: Any) -> bool: ...
    def __repr__(self) -> str: ...

class WebSocketRoute(BaseRoute):
    path: str
    endpoint: Any
    name: str
    app: ASGIApp
    path_regex: Pattern[str]
    path_format: str
    param_convertors: Dict[str, Convertor]
    def __init__(self, path: str, endpoint: Any, *, name: Optional[str] = ..., middleware: Optional[Sequence[Middleware]] = ...) -> None: ...
    def matches(self, scope: Scope) -> Tuple[Match, Dict[str, Any]]: ...
    def url_path_for(self, name, /, **path_params: Any) -> URLPath: ...
    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def __eq__(self, other: Any) -> bool: ...
    def __repr__(self) -> str: ...

class Mount(BaseRoute):
    path: str
    name: Optional[str]
    app: ASGIApp
    path_regex: Pattern[str]
    path_format: str
    param_convertors: Dict[str, Convertor]
    def __init__(self, path: str, app: Optional[ASGIApp] = ..., routes: Optional[Sequence[BaseRoute]] = ..., name: Optional[str] = ..., *, middleware: Optional[Sequence[Middleware]] = ...) -> None: ...
    @property
    def routes(self) -> List[BaseRoute]: ...
    def matches(self, scope: Scope) -> Tuple[Match, Dict[str, Any]]: ...
    def url_path_for(self, name, /, **path_params: Any) -> URLPath: ...
    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def __eq__(self, other: Any) -> bool: ...
    def __repr__(self) -> str: ...

class Host(BaseRoute):
    host: str
    app: ASGIApp
    name: Optional[str]
    host_regex: Pattern[str]
    host_format: str
    param_convertors: Dict[str, Convertor]
    def __init__(self, host: str, app: ASGIApp, name: Optional[str] = ...) -> None: ...
    @property
    def routes(self) -> List[BaseRoute]: ...
    def matches(self, scope: Scope) -> Tuple[Match, Dict[str, Any]]: ...
    def url_path_for(self, name, /, **path_params: Any) -> URLPath: ...
    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def __eq__(self, other: Any) -> bool: ...
    def __repr__(self) -> str: ...

_F = TypeVar("_F", bound=Callable[..., Any])

class Router:
    routes: List[BaseRoute]
    redirect_slashes: bool
    default: ASGIApp
    on_startup: List[Callable[[], Any]]
    on_shutdown: List[Callable[[], Any]]
    middleware_stack: ASGIApp
    def __init__(self, routes: Optional[Sequence[BaseRoute]] = ..., redirect_slashes: bool = ..., default: Optional[ASGIApp] = ..., on_startup: Optional[Sequence[Callable[[], Any]]] = ..., on_shutdown: Optional[Sequence[Callable[[], Any]]] = ..., lifespan: Optional[Lifespan[Any]] = ..., *, middleware: Optional[Sequence[Middleware]] = ...) -> None: ...
    async def not_found(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def url_path_for(self, name, /, **path_params: Any) -> URLPath: ...
    async def startup(self) -> None: ...
    async def shutdown(self) -> None: ...
    async def lifespan(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    async def app(self, scope: Scope, receive: Receive, send: Send) -> None: ...
    def __eq__(self, other: Any) -> bool: ...
    def mount(self, path: str, app: ASGIApp, name: Optional[str] = ...) -> None: ...
    def host(self, host: str, app: ASGIApp, name: Optional[str] = ...) -> None: ...
    def add_route(self, path: str, endpoint: Any, methods: Optional[Iterable[str]] = ..., name: Optional[str] = ..., include_in_schema: bool = ...) -> None: ...
    def add_websocket_route(self, path: str, endpoint: Any, name: Optional[str] = ...) -> None: ...
    def route(self, path: str, methods: Optional[Iterable[str]] = ..., name: Optional[str] = ..., include_in_schema: bool = ...) -> Callable[[_F], _F]: ...
    def websocket_route(self, path: str, name: Optional[str] = ...) -> Callable[[_F], _F]: ...
    def add_event_handler(self, event_type: str, func: Callable[[], Any]) -> None: ...
    def on_event(self, event_type: str) -> Callable[[_F], _F]: ...