from typing import Any, Callable, Literal, Optional, Self
from pandas._libs import lib

class ArrowStringArrayMixin:
    def __init__(self, *args: Any, **kwargs: Any) -> None: ...
    def _convert_bool_result(self, result: Any, na: Any = lib.no_default, method_name: Optional[str] = None) -> Any: ...
    def _convert_int_result(self, result: Any) -> Any: ...
    def _apply_elementwise(self, func: Callable[..., Any]) -> Any: ...
    def _str_len(self) -> Any: ...
    def _str_lower(self) -> Self: ...
    def _str_upper(self) -> Self: ...
    def _str_strip(self, to_strip: Optional[Any] = None) -> Self: ...
    def _str_lstrip(self, to_strip: Optional[Any] = None) -> Self: ...
    def _str_rstrip(self, to_strip: Optional[Any] = None) -> Self: ...
    def _str_pad(self, width: int, side: Literal["left", "right", "both"] = "left", fillchar: str = " ") -> Self: ...
    def _str_get(self, i: int) -> Self: ...
    def _str_slice(self, start: Optional[int] = None, stop: Optional[int] = None, step: Optional[int] = None) -> Self: ...
    def _str_slice_replace(self, start: Optional[int] = None, stop: Optional[int] = None, repl: Any = None) -> Self: ...
    def _str_replace(self, pat: Any, repl: Any, n: int = -1, case: bool = True, flags: int = 0, regex: bool = True) -> Self: ...
    def _str_capitalize(self) -> Self: ...
    def _str_title(self) -> Self: ...
    def _str_swapcase(self) -> Self: ...
    def _str_removeprefix(self, prefix: str) -> Self: ...
    def _str_removesuffix(self, suffix: str) -> Self: ...
    def _str_startswith(self, pat: Any, na: Any = lib.no_default) -> Any: ...
    def _str_endswith(self, pat: Any, na: Any = lib.no_default) -> Any: ...
    def _str_isalnum(self) -> Any: ...
    def _str_isalpha(self) -> Any: ...
    def _str_isascii(self) -> Any: ...
    def _str_isdecimal(self) -> Any: ...
    def _str_isdigit(self) -> Any: ...
    def _str_islower(self) -> Any: ...
    def _str_isnumeric(self) -> Any: ...
    def _str_isspace(self) -> Any: ...
    def _str_istitle(self) -> Any: ...
    def _str_isupper(self) -> Any: ...
    def _str_contains(self, pat: Any, case: bool = True, flags: int = 0, na: Any = lib.no_default, regex: bool = True) -> Any: ...
    def _str_match(self, pat: str, case: bool = True, flags: int = 0, na: Any = lib.no_default) -> Any: ...
    def _str_fullmatch(self, pat: str, case: bool = True, flags: int = 0, na: Any = lib.no_default) -> Any: ...
    def _str_find(self, sub: Any, start: int = 0, end: Optional[int] = None) -> Any: ...