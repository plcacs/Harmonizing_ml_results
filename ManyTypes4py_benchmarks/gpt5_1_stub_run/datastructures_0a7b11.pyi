from typing import Any, Awaitable, Dict, Iterable, Iterator, ItemsView, KeysView, List, Mapping, Optional, Sequence, Tuple, TypeVar, Union
from urllib.parse import SplitResult
from starlette.types import Scope

class Address(tuple):
    __slots__ = ()
    _field_types: Mapping[str, type]
    _fields: Tuple[str, ...]
    def __new__(cls, *args: Any, **kwargs: Any) -> "Address": ...
    def __getnewargs__(self) -> Tuple[Any, ...]: ...
    def __getstate__(self) -> Tuple[str, Tuple[Any, ...]]: ...

_KeyType = TypeVar("_KeyType")
_CovariantValueType = TypeVar("_CovariantValueType", covariant=True)

class URL:
    def __init__(self, url: str = "", scope: Optional[Scope] = None, **components: Any) -> None: ...
    @property
    def components(self) -> SplitResult: ...
    @property
    def scheme(self) -> str: ...
    @property
    def netloc(self) -> str: ...
    @property
    def path(self) -> str: ...
    @property
    def query(self) -> str: ...
    @property
    def fragment(self) -> str: ...
    @property
    def username(self) -> Optional[str]: ...
    @property
    def password(self) -> Optional[str]: ...
    @property
    def hostname(self) -> Optional[str]: ...
    @property
    def port(self) -> Optional[int]: ...
    @property
    def is_secure(self) -> bool: ...
    def replace(self, **kwargs: Any) -> "URL": ...
    def include_query_params(self, **kwargs: Any) -> "URL": ...
    def replace_query_params(self, **kwargs: Any) -> "URL": ...
    def remove_query_params(self, keys: Union[str, Iterable[str]]) -> "URL": ...
    def __eq__(self, other: object) -> bool: ...
    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...

class URLPath(str):
    protocol: str
    host: str
    def __new__(cls, path: str, protocol: str = "", host: str = "") -> "URLPath": ...
    def __init__(self, path: str, protocol: str = "", host: str = "") -> None: ...
    def make_absolute_url(self, base_url: Union[str, URL]) -> URL: ...

class Secret:
    def __init__(self, value: str) -> None: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...
    def __bool__(self) -> bool: ...

class CommaSeparatedStrings(Sequence[str]):
    def __init__(self, value: Union[str, Iterable[str]]) -> None: ...
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> str: ...
    def __iter__(self) -> Iterator[str]: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...

class ImmutableMultiDict(Mapping[_KeyType, _CovariantValueType]):
    def __init__(self, *args: Any, **kwargs: Any) -> None: ...
    def getlist(self, key: _KeyType) -> List[_CovariantValueType]: ...
    def keys(self) -> KeysView[_KeyType]: ...
    def values(self) -> ValuesView[_CovariantValueType]: ...
    def items(self) -> ItemsView[_KeyType, _CovariantValueType]: ...
    def multi_items(self) -> List[Tuple[_KeyType, _CovariantValueType]]: ...
    def __getitem__(self, key: _KeyType) -> _CovariantValueType: ...
    def __contains__(self, key: object) -> bool: ...
    def __iter__(self) -> Iterator[_KeyType]: ...
    def __len__(self) -> int: ...
    def __eq__(self, other: object) -> bool: ...
    def __repr__(self) -> str: ...

class MultiDict(ImmutableMultiDict[Any, Any]):
    def __setitem__(self, key: Any, value: Any) -> None: ...
    def __delitem__(self, key: Any) -> None: ...
    def pop(self, key: Any, default: Any = ...) -> Any: ...
    def popitem(self) -> Tuple[Any, Any]: ...
    def poplist(self, key: Any) -> List[Any]: ...
    def clear(self) -> None: ...
    def setdefault(self, key: Any, default: Any = ...) -> Any: ...
    def setlist(self, key: Any, values: Iterable[Any]) -> None: ...
    def append(self, key: Any, value: Any) -> None: ...
    def update(self, *args: Any, **kwargs: Any) -> None: ...

class QueryParams(ImmutableMultiDict[str, str]):
    def __init__(self, *args: Any, **kwargs: Any) -> None: ...
    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...

class UploadFile:
    filename: Optional[str]
    file: Any
    size: Optional[int]
    headers: "Headers"
    def __init__(self, file: Any, *, size: Optional[int] = ..., filename: Optional[str] = ..., headers: Optional["Headers"] = ...) -> None: ...
    @property
    def content_type(self) -> Optional[str]: ...
    @property
    def _in_memory(self) -> bool: ...
    def write(self, data: bytes) -> Awaitable[None]: ...
    def read(self, size: int = ...) -> Awaitable[bytes]: ...
    def seek(self, offset: int) -> Awaitable[None]: ...
    def close(self) -> Awaitable[None]: ...
    def __repr__(self) -> str: ...

class FormData(ImmutableMultiDict[str, Union[UploadFile, str]]):
    def __init__(self, *args: Any, **kwargs: Any) -> None: ...
    def close(self) -> Awaitable[None]: ...

class Headers(Mapping[str, str]):
    def __init__(self, headers: Optional[Mapping[str, str]] = ..., raw: Optional[Iterable[Tuple[bytes, bytes]]] = ..., scope: Optional[Scope] = ...) -> None: ...
    @property
    def raw(self) -> List[Tuple[bytes, bytes]]: ...
    def keys(self) -> List[str]: ...
    def values(self) -> List[str]: ...
    def items(self) -> List[Tuple[str, str]]: ...
    def getlist(self, key: str) -> List[str]: ...
    def mutablecopy(self) -> "MutableHeaders": ...
    def __getitem__(self, key: str) -> str: ...
    def __contains__(self, key: object) -> bool: ...
    def __iter__(self) -> Iterator[str]: ...
    def __len__(self) -> int: ...
    def __eq__(self, other: object) -> bool: ...
    def __repr__(self) -> str: ...

class MutableHeaders(Headers):
    def __setitem__(self, key: str, value: str) -> None: ...
    def __delitem__(self, key: str) -> None: ...
    def __ior__(self, other: Mapping[str, str]) -> "MutableHeaders": ...
    def __or__(self, other: Mapping[str, str]) -> "MutableHeaders": ...
    @property
    def raw(self) -> List[Tuple[bytes, bytes]]: ...
    def setdefault(self, key: str, value: str) -> str: ...
    def update(self, other: Mapping[str, str]) -> None: ...
    def append(self, key: str, value: str) -> None: ...
    def add_vary_header(self, vary: str) -> None: ...

class State:
    def __init__(self, state: Optional[Dict[str, Any]] = ...) -> None: ...
    def __setattr__(self, key: str, value: Any) -> None: ...
    def __getattr__(self, key: str) -> Any: ...
    def __delattr__(self, key: str) -> None: ...