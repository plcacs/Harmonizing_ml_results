from typing import Any, Dict, Optional, Set, Tuple, Union
from pydantic.v1.utils import Representation

ColorTuple = Union[Tuple[int, int, int], Tuple[int, int, int, float]]
ColorType = Union[ColorTuple, str]
HslColorTuple = Union[Tuple[float, float, float], Tuple[float, float, float, float]]

class RGBA:
    r: float
    g: float
    b: float
    alpha: Optional[float]
    _tuple: Tuple[float, float, float, Optional[float]]

    def __init__(self, r: float, g: float, b: float, alpha: Optional[float]) -> None: ...
    def __getitem__(self, item: int) -> Any: ...

r_hex_short: str = ...
r_hex_long: str = ...
_r_255: str = ...
_r_comma: str = ...
r_rgb: str = ...
_r_alpha: str = ...
r_rgba: str = ...
_r_h: str = ...
_r_sl: str = ...
r_hsl: str = ...
r_hsla: str = ...
repeat_colors: Set[int] = ...
rads: float = ...

class Color(Representation):
    _original: Any
    _rgba: RGBA

    def __init__(self, value: Any) -> None: ...
    @classmethod
    def __modify_schema__(cls, field_schema: Dict[str, Any]) -> None: ...
    def original(self) -> Any: ...
    def as_named(self, *, fallback: bool = False) -> str: ...
    def as_hex(self) -> str: ...
    def as_rgb(self) -> str: ...
    def as_rgb_tuple(self, *, alpha: Optional[bool] = None) -> ColorTuple: ...
    def as_hsl(self) -> str: ...
    def as_hsl_tuple(self, *, alpha: Optional[bool] = None) -> HslColorTuple: ...
    def _alpha_float(self) -> float: ...
    @classmethod
    def __get_validators__(cls) -> Any: ...
    def __str__(self) -> str: ...
    def __repr_args__(self) -> Any: ...
    def __eq__(self, other: Any) -> bool: ...
    def __hash__(self) -> int: ...

def parse_tuple(value: Any) -> RGBA: ...
def parse_str(value: str) -> RGBA: ...
def ints_to_rgba(r: Any, g: Any, b: Any, alpha: Any) -> RGBA: ...
def parse_color_value(value: Any, max_val: int = ...) -> float: ...
def parse_float_alpha(value: Any) -> Optional[float]: ...
def parse_hsl(h: Any, h_units: Optional[str], sat: Any, light: Any, alpha: Optional[float] = ...) -> RGBA: ...
def float_to_255(c: float) -> int: ...

COLORS_BY_NAME: Dict[str, Tuple[int, int, int]] = ...
COLORS_BY_VALUE: Dict[Tuple[int, int, int], str] = ...