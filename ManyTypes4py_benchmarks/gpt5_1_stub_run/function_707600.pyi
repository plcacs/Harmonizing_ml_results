from typing import Any, Iterable, Iterator, List, Optional, Tuple, ClassVar


class LambdaName:
    string_name: ClassVar[str]
    api_type: ClassVar[str]

    def __init__(self, lambda_value: Any) -> None: ...
    @property
    def start_pos(self) -> Any: ...
    def infer(self) -> Any: ...


class FunctionAndClassBase:
    def get_qualified_names(self) -> Optional[Tuple[str, ...]]: ...


class FunctionMixin:
    api_type: ClassVar[str]

    def get_filters(self, origin_scope: Any = ...) -> Iterable[Any]: ...
    def py__get__(self, instance: Any, class_value: Any) -> Any: ...
    def get_param_names(self) -> List[Any]: ...
    @property
    def name(self) -> Any: ...
    def is_function(self) -> bool: ...
    def py__name__(self) -> str: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...
    def py__call__(self, arguments: Any) -> Any: ...
    def _as_context(self, arguments: Optional[Any] = ...) -> Any: ...
    def get_signatures(self) -> List[Any]: ...


class FunctionValue(FunctionMixin, FunctionAndClassBase):
    @classmethod
    def from_context(cls, context: Any, tree_node: Any) -> Any: ...
    def py__class__(self) -> Any: ...
    def get_default_param_context(self) -> Any: ...
    def get_signature_functions(self) -> List[Any]: ...


class FunctionNameInClass:
    def __init__(self, class_context: Any, name: Any) -> None: ...
    def get_defining_qualified_value(self) -> Any: ...


class MethodValue(FunctionValue):
    def __init__(self, inference_state: Any, class_context: Any, *args: Any, **kwargs: Any) -> None: ...
    def get_default_param_context(self) -> Any: ...
    def get_qualified_names(self) -> Optional[Tuple[str, ...]]: ...
    @property
    def name(self) -> Any: ...


class BaseFunctionExecutionContext:
    def infer_annotations(self) -> Any: ...
    def get_return_values(self, check_yields: bool = ...) -> Any: ...
    def _get_yield_lazy_value(self, yield_expr: Any) -> Iterator[Any]: ...
    def get_yield_lazy_values(self, is_async: bool = ...) -> Iterable[Any]: ...
    def merge_yield_values(self, is_async: bool = ...) -> Any: ...
    def is_generator(self) -> bool: ...
    def infer(self) -> Any: ...


class FunctionExecutionContext(BaseFunctionExecutionContext):
    def __init__(self, function_value: Any, arguments: Any) -> None: ...
    def get_filters(self, until_position: Any = ..., origin_scope: Any = ...) -> Iterable[Any]: ...
    def infer_annotations(self) -> Any: ...
    def get_param_names(self) -> List[Any]: ...


class AnonymousFunctionExecution(BaseFunctionExecutionContext):
    def infer_annotations(self) -> Any: ...
    def get_filters(self, until_position: Any = ..., origin_scope: Any = ...) -> Iterable[Any]: ...
    def get_param_names(self) -> List[Any]: ...


class OverloadedFunctionValue(FunctionMixin):
    def __init__(self, function: Any, overloaded_functions: List[Any]) -> None: ...
    def py__call__(self, arguments: Any) -> Any: ...
    def get_signature_functions(self) -> List[Any]: ...
    def get_type_hint(self, add_class_info: bool = ...) -> str: ...


def _find_overload_functions(context: Any, tree_node: Any) -> Iterator[Any]: ...