from typing import Any, Optional

class TaskError(Exception):
    ...

class Task:
    def __init__(self, node: Any, catalog: Any, is_async: bool, hook_manager: Optional[Any] = ..., session_id: Optional[Any] = ..., parallel: bool = ...) -> None: ...
    def execute(self) -> Any: ...
    def __call__(self) -> Any: ...
    @staticmethod
    def _bootstrap_subprocess(package_name: Optional[Any], logging_config: Optional[Any] = ...) -> None: ...
    @staticmethod
    def _run_node_synchronization(package_name: Optional[Any] = ..., logging_config: Optional[Any] = ...) -> Any: ...
    def _run_node_sequential(self, node: Any, catalog: Any, hook_manager: Any, session_id: Optional[Any] = ...) -> Any: ...
    def _run_node_async(self, node: Any, catalog: Any, hook_manager: Any, session_id: Optional[Any] = ...) -> Any: ...
    @staticmethod
    def _synchronous_dataset_load(dataset_name: Any, node: Any, catalog: Any, hook_manager: Any) -> Any: ...
    @staticmethod
    def _collect_inputs_from_hook(node: Any, catalog: Any, inputs: dict[Any, Any], is_async: bool, hook_manager: Any, session_id: Optional[Any] = ...) -> dict[Any, Any]: ...
    @staticmethod
    def _call_node_run(node: Any, catalog: Any, inputs: dict[Any, Any], is_async: bool, hook_manager: Any, session_id: Optional[Any] = ...) -> Any: ...