import logging
from abc import ABC, abstractmethod
from typing import Any, Callable, Iterator

logger: logging.Logger = ...

def collect_request_payload() -> dict[str, Any]: ...
def get_logger_from_status(status: Any) -> tuple[Callable[..., Any], Any]: ...

class AbstractEventLogger(ABC):
    curated_payload_params: set[str]
    curated_form_data_params: set[str]
    def __call__(self, action: Any, object_ref: Any | None = ..., log_to_statsd: bool = ..., duration: Any = ..., **payload_override: Any) -> "AbstractEventLogger": ...
    def __enter__(self) -> None: ...
    def __exit__(self, exc_type: Any, exc_val: Any, exc_tb: Any) -> None: ...
    @classmethod
    def curate_payload(cls, payload: dict[str, Any]) -> dict[str, Any]: ...
    @classmethod
    def curate_form_data(cls, payload: dict[str, Any]) -> dict[str, Any]: ...
    @abstractmethod
    def log(self, user_id: Any, action: Any, dashboard_id: Any, duration_ms: Any, slice_id: Any, referrer: Any, curated_payload: Any, curated_form_data: Any, *args: Any, **kwargs: Any) -> None: ...
    def log_with_context(self, action: Any, duration: Any | None = ..., object_ref: Any | None = ..., log_to_statsd: bool = ..., database: Any | None = ..., **payload_override: Any) -> None: ...
    def log_context(self, action: Any, object_ref: Any | None = ..., log_to_statsd: bool = ..., **kwargs: Any) -> Iterator[Callable[..., None]]: ...
    def _wrapper(self, f: Callable[..., Any], action: Any | None = ..., object_ref: Any | None = ..., allow_extra_payload: bool = ..., **wrapper_kwargs: Any) -> Callable[..., Any]: ...
    def log_this(self, f: Callable[..., Any]) -> Callable[..., Any]: ...
    def log_this_with_context(self, **kwargs: Any) -> Callable[[Callable[..., Any]], Callable[..., Any]]: ...
    def log_this_with_extra_payload(self, f: Callable[..., Any]) -> Callable[..., Any]: ...

def get_event_logger_from_cfg_value(cfg_value: Any) -> AbstractEventLogger: ...

class DBEventLogger(AbstractEventLogger):
    def log(self, user_id: Any, action: Any, dashboard_id: Any, duration_ms: Any, slice_id: Any, referrer: Any, *args: Any, **kwargs: Any) -> None: ...

class StdOutEventLogger(AbstractEventLogger):
    def log(self, user_id: Any, action: Any, dashboard_id: Any, duration_ms: Any, slice_id: Any, referrer: Any, curated_payload: Any, curated_form_data: Any, *args: Any, **kwargs: Any) -> None: ...