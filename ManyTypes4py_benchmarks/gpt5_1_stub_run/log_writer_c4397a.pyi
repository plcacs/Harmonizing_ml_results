from typing import Any, Optional, Dict
import logging
from allennlp.training.callbacks.callback import TrainerCallback

logger: logging.Logger = ...

class LogWriterCallback(TrainerCallback):
    def __init__(
        self,
        serialization_dir: Any,
        summary_interval: int = ...,
        distribution_interval: Optional[int] = ...,
        batch_size_interval: Optional[int] = ...,
        should_log_parameter_statistics: bool = ...,
        should_log_learning_rate: bool = ...,
        batch_loss_moving_average_count: int = ...,
    ) -> None: ...
    trainer: Any
    def log_scalars(self, scalars: Dict[str, Any], log_prefix: str = ..., epoch: Optional[int] = ...) -> None: ...
    def log_tensors(self, tensors: Dict[str, Any], log_prefix: str = ..., epoch: Optional[int] = ...) -> None: ...
    def log_inputs(self, inputs: Any, log_prefix: str = ...) -> None: ...
    def close(self) -> None: ...
    def on_start(self, trainer: Any, is_primary: bool = ..., **kwargs: Any) -> None: ...
    def on_batch(
        self,
        trainer: Any,
        batch_inputs: Any,
        batch_outputs: Any,
        batch_metrics: Dict[str, Any],
        epoch: int,
        batch_number: int,
        is_training: bool,
        is_primary: bool = ...,
        batch_grad_norm: Optional[float] = ...,
        **kwargs: Any
    ) -> None: ...
    def on_epoch(self, trainer: Any, metrics: Dict[str, Any], epoch: int, is_primary: bool = ..., **kwargs: Any) -> None: ...
    def on_end(
        self,
        trainer: Any,
        metrics: Optional[Dict[str, Any]] = ...,
        epoch: Optional[int] = ...,
        is_primary: bool = ...,
        **kwargs: Any
    ) -> None: ...
    def log_batch(
        self,
        batch_grad_norm: Optional[float],
        metrics: Dict[str, Any],
        batch_group: Any,
        param_updates: Optional[Dict[str, Any]],
        batch_number: int
    ) -> None: ...
    def log_epoch(self, train_metrics: Dict[str, Any], val_metrics: Dict[str, Any], epoch: int) -> None: ...
    def _should_log_distributions_next_batch(self) -> bool: ...
    def _should_log_distributions_this_batch(self) -> bool: ...
    def _enable_activation_logging(self) -> None: ...
    def _should_log_this_batch(self) -> bool: ...
    def _log_activation_distribution(self, outputs: Any, module_name: str) -> None: ...
    def _log_parameter_and_gradient_statistics(self, batch_grad_norm: Optional[float] = ...) -> None: ...
    def _log_learning_rates(self) -> None: ...
    def _log_distributions(self) -> None: ...
    def _log_gradient_updates(self, param_updates: Dict[str, Any]) -> None: ...