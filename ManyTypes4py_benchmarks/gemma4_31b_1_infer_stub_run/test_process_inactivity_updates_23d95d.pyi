from typing import Any, Callable, Generator, Optional, Protocol, TypeVar, Union
from random import Random

# Define Protocols for the spec and state objects based on usage in the module
class SpecProtocol(Protocol):
    def is_in_inactivity_leak(self, state: 'StateProtocol') -> bool: ...
    def get_beacon_proposer_index(self, state: 'StateProtocol') -> int: ...
    def slash_validator(self, state: 'StateProtocol', validator_index: int) -> None: ...
    def get_previous_epoch(self, state: 'StateProtocol') -> int: ...

class ValidatorProtocol(Protocol):
    slashed: bool
    exit_epoch: int

class StateProtocol(Protocol):
    inactivity_scores: list[int]
    validators: list[ValidatorProtocol]
    def copy(self) -> 'StateProtocol': ...

# Type aliases for clarity
Spec = SpecProtocol
State = StateProtocol
ParticipationFn = Callable[[Spec, State, Random], None]
InactivityScoresFn = Callable[[Spec, State, Random], None]

