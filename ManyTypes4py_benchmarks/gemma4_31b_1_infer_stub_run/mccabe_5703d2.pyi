import ast
import optparse
from collections import defaultdict
from typing import Any, Callable, Dict, Generator, Iterable, List, Optional, Tuple, Union, Type

__version__: str = '0.7.0'

class ASTVisitor:
    """Performs a depth-first walk of the AST."""
    node: Any
    _cache: Dict[Type[Any], Callable[..., Any]]

    def __init__(self) -> None: ...
    def default(self, node: Any, *args: Any) -> None: ...
    def dispatch(self, node: Any, *args: Any) -> Any: ...
    def preorder(self, tree: Any, visitor: Any, *args: Any) -> None: ...

class PathNode:
    name: str
    look: str

    def __init__(self, name: str, look: str = 'circle') -> None: ...
    def to_dot(self) -> None: ...
    def dot_id(self) -> int: ...

class PathGraph:
    name: str
    entity: str
    lineno: int
    column: int
    nodes: Dict[PathNode, List[PathNode]]

    def __init__(self, name: str, entity: str, lineno: int, column: int = 0) -> None: ...
    def connect(self, n1: PathNode, n2: PathNode) -> None: ...
    def to_dot(self) -> None: ...
    def complexity(self) -> int: ...

class PathGraphingAstVisitor(ASTVisitor):
    """ A visitor for a parsed Abstract Syntax Tree which finds executable
        statements.
    """
    classname: str
    graphs: Dict[str, PathGraph]

    def __init__(self) -> None: ...
    def reset(self) -> None: ...
    def dispatch_list(self, node_list: Iterable[Any]) -> None: ...
    def visitFunctionDef(self, node: ast.FunctionDef) -> None: ...
    visitAsyncFunctionDef: Any # Alias to visitFunctionDef
    def visitClassDef(self, node: ast.ClassDef) -> None: ...
    def appendPathNode(self, name: str) -> Optional[PathNode]: ...
    def visitSimpleStatement(self, node: Any) -> None: ...
    def default(self, node: Any, *args: Any) -> None: ...
    def visitLoop(self, node: Any) -> None: ...
    visitAsyncFor: Any # Alias to visitLoop
    visitFor: Any # Alias to visitLoop
    visitWhile: Any # Alias to visitLoop
    def visitIf(self, node: ast.If) -> None: ...
    def _subgraph(self, node: Any, name: str, extra_blocks: Tuple[Any, ...] = ()) -> None: ...
    def _subgraph_parse(self, node: Any, pathnode: PathNode, extra_blocks: Iterable[Any]) -> None: ...
    def visitTryExcept(self, node: ast.Try) -> None: ...
    visitTry: Any # Alias to visitTryExcept
    def visitWith(self, node: ast.With) -> None: ...
    visitAsyncWith: Any # Alias to visitWith

class McCabeChecker:
    """McCabe cyclomatic complexity checker."""
    name: str
    version: str
    _code: str
    _error_tmpl: str
    max_complexity: int
    tree: Any

    def __init__(self, tree: Any, filename: str) -> None: ...
    @classmethod
    def add_options(cls, parser: Any) -> None: ...
    @classmethod
    def parse_options(cls, options: Any) -> None: ...
    def run(self) -> Generator[Tuple[int, int, str, Type['McCabeChecker']], None, None]: ...

def get_code_complexity(code: str, threshold: int = 7, filename: str = 'stdin') -> int: ...
def get_module_complexity(module_path: str, threshold: int = 7) -> int: ...
def _read(filename: str) -> str: ...
def main(argv: Optional[List[str]] = None) -> None: ...