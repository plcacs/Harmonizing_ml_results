class TagIDExistsError(HomeAssistantError):
    """Raised when an item is not found."""
    def __init__(self, item_id: str) -> None: ...
    item_id: str

class TagIDManager(collection.IDManager):
    """ID manager for tags."""
    def generate_id(self, suggestion: str) -> str: ...

def _create_entry(entity_registry: er.EntityRegistry, tag_id: str, name: Optional[str]) -> Any: ...

class TagStore(Store[collection.SerializedStorageCollection]):
    """Store tag data."""
    async def _async_migrate_func(self, old_major_version: int, old_minor_version: int, old_data: Any) -> Any: ...

class TagStorageCollection(collection.DictStorageCollection):
    """Tag collection stored in storage."""
    CREATE_SCHEMA: vol.Schema
    UPDATE_SCHEMA: vol.Schema
    entity_registry: er.EntityRegistry

    def __init__(self, store: Store[Any], id_manager: Optional[TagIDManager] = None) -> None: ...
    async def _process_create_data(self, data: dict[str, Any]) -> dict[str, Any]: ...
    def _get_suggested_id(self, info: dict[str, Any]) -> str: ...
    async def _update_data(self, item: dict[str, Any], update_data: dict[str, Any]) -> dict[str, Any]: ...
    def _serialize_item(self, item_id: str, item: dict[str, Any]) -> dict[str, Any]: ...

class TagDictStorageCollectionWebsocket(collection.StorageCollectionWebsocket[TagStorageCollection]):
    """Class to expose tag storage collection management over websocket."""
    entity_registry: er.EntityRegistry

    def __init__(self, storage_collection: TagStorageCollection, api_prefix: str, model_name: str, create_schema: Any, update_schema: Any) -> None: ...
    def ws_list_item(self, hass: HomeAssistant, connection: Any, msg: dict[str, Any]) -> None: ...

async def async_setup(hass: HomeAssistant, config: ConfigType) -> bool: ...

async def async_scan_tag(hass: HomeAssistant, tag_id: str, device_id: Optional[str], context: Optional[Context] = None) -> None: ...

