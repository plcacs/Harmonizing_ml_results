import copy
from collections.abc import Iterable, Callable
from typing import Any, overload, TypeVar, Generic, Optional, Union, Sequence, Mapping

from hypothesis.strategies._internal.strategies import SearchStrategy, MappedStrategy

T = TypeVar("T")
K = TypeVar("K")
V = TypeVar("V")

class TupleStrategy(SearchStrategy, Generic[T]):
    """A strategy responsible for fixed length tuples based on heterogeneous
    strategies for each of their elements."""
    element_strategies: tuple[SearchStrategy[Any], ...]

    def __init__(self, strategies: Iterable[SearchStrategy[Any]]) -> None: ...
    def do_validate(self) -> None: ...
    def calc_label(self) -> str: ...
    def __repr__(self) -> str: ...
    def calc_has_reusable_values(self, recur: Callable[[SearchStrategy[Any]], bool]) -> bool: ...
    def do_draw(self, data: Any) -> tuple[Any, ...]: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy[Any]], bool]) -> bool: ...

@overload
def tuples() -> TupleStrategy[Any]: ...
@overload
def tuples(__a1: SearchStrategy[T]) -> TupleStrategy[T]: ...
@overload
def tuples(__a1: SearchStrategy[Any], __a2: SearchStrategy[Any]) -> TupleStrategy[Any]: ...
@overload
def tuples(__a1: SearchStrategy[Any], __a2: SearchStrategy[Any], __a3: SearchStrategy[Any]) -> TupleStrategy[Any]: ...
@overload
def tuples(__a1: SearchStrategy[Any], __a2: SearchStrategy[Any], __a3: SearchStrategy[Any], __a4: SearchStrategy[Any]) -> TupleStrategy[Any]: ...
@overload
def tuples(__a1: SearchStrategy[Any], __a2: SearchStrategy[Any], __a3: SearchStrategy[Any], __a4: SearchStrategy[Any], __a5: SearchStrategy[Any]) -> TupleStrategy[Any]: ...
@overload
def tuples(*args: SearchStrategy[Any]) -> TupleStrategy[Any]: ...

def tuples(*args: SearchStrategy[Any]) -> TupleStrategy[Any]: ...

class ListStrategy(SearchStrategy, Generic[T]):
    """A strategy for lists which takes a strategy for its elements and the
    allowed lengths, and generates lists with the correct size and contents."""
    _nonempty_filters: tuple[type[Any], ...]
    min_size: float
    max_size: float
    average_size: float
    element_strategy: SearchStrategy[T]

    def __init__(self, elements: SearchStrategy[T], min_size: float = 0, max_size: float = float('inf')) -> None: ...
    def calc_label(self) -> str: ...
    def do_validate(self) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy[Any]], bool]) -> bool: ...
    def do_draw(self, data: Any) -> list[T]: ...
    def __repr__(self) -> str: ...
    def filter(self, condition: Callable[[list[T]], Any]) -> SearchStrategy[list[T]]: ...

class UniqueListStrategy(ListStrategy[T]):
    keys: Sequence[Callable[[T], Any]]
    tuple_suffixes: Optional[SearchStrategy[tuple[Any, ...]]]

    def __init__(self, elements: SearchStrategy[T], min_size: float, max_size: float, keys: Sequence[Callable[[T], Any]], tuple_suffixes: Optional[SearchStrategy[tuple[Any, ...]]]) -> None: ...
    def do_draw(self, data: Any) -> list[Union[T, tuple[T, Any]]] : ...

class UniqueSampledListStrategy(UniqueListStrategy[T]):
    def do_draw(self, data: Any) -> list[Union[T, tuple[T, Any]]]: ...

class FixedKeysDictStrategy(MappedStrategy[Mapping[K, V], Mapping[K, V]]):
    """A strategy which produces dicts with a fixed set of keys, given a
    strategy for each of their equivalent values."""
    keys: tuple[K, ...]

    def __init__(self, strategy_dict: Mapping[K, SearchStrategy[V]]) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy[Any]], bool]) -> bool: ...
    def __repr__(self) -> str: ...

class FixedAndOptionalKeysDictStrategy(SearchStrategy[Mapping[K, V]]):
    """A strategy which produces dicts with a fixed set of keys, given a
    strategy for each of their equivalent values."""
    required: Mapping[K, SearchStrategy[V]]
    fixed: FixedKeysDictStrategy
    optional: Mapping[K, SearchStrategy[V]]

    def __init__(self, strategy_dict: Mapping[K, SearchStrategy[V]], optional: Mapping[K, SearchStrategy[V]]) -> None: ...
    def calc_is_empty(self, recur: Callable[[SearchStrategy[Any]], bool]) -> bool: ...
    def __repr__(self) -> str: ...
    def do_draw(self, data: Any) -> Mapping[K, V]: ...