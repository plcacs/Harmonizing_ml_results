from typing import Any, Generator, Tuple, Union, TypeVar, Protocol
from random import Random

# Define TypeVars for the spec and state to maintain consistency across the module
T_spec = TypeVar("T_spec")
T_state = TypeVar("T_state")

class ExecutionPayload(Protocol):
    parent_hash: bytes
    block_hash: bytes
    prev_randao: bytes
    timestamp: int
    extra_data: bytes
    transactions: Any

class BeaconBlockBody(Protocol):
    execution_payload: ExecutionPayload

class State(Protocol):
    latest_execution_payload_header: Any

class Spec(Protocol):
    BeaconBlockBody: Any
    NoopExecutionEngine: Any
    process_execution_payload: Any
    Hash32: Any
    Bytes32: Any
    Transaction: Any

def run_execution_payload_processing(
    spec: T_spec,
    state: T_state,
    execution_payload: ExecutionPayload,
    valid: bool = True,
    execution_valid: bool = True,
) -> Generator[
    Tuple[str, Union[T_state, dict[str, bool], BeaconBlockBody, None]], 
    None, 
    None
]: ...

